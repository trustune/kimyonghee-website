---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import publicationsData from '../../data/publications.json';

const allPublications = await getCollection('publications');

const scholarStats = (publicationsData as any).scholarStats || { citations: 0, hIndex: 0, i10Index: 0 };
const citationGraph = (publicationsData as any).citationGraph || [];
const domesticPublications = (publicationsData as any).domestic_publications || [];

const publications = allPublications.map((pub) => ({ id: pub.slug, ...pub.data })) as any[];

const workInProgress = publications.filter((p) => p.status === 'work-in-progress').sort((a, b) => b.year - a.year);
const workingPapers = publications.filter((p) => p.status === 'working-paper').sort((a, b) => b.year - a.year);
const publishedPapers = publications.filter((p) => p.status === 'published').sort((a, b) => b.year - a.year);
const domesticPapers = [...domesticPublications].sort((a, b) => b.year - a.year || (b.citations || 0) - (a.citations || 0));

const updatedKo = new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: 'long' });
const updatedEn = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
---

<BaseLayout title="연구 · Research" description="미디어 정책, 디지털 플랫폼 규제, 미디어 경제학 분야의 학술 연구 — 김용희">
  <div class="pubs container">
    <!-- Header -->
    <header class="page-head reveal">
      <h1 class="page-title">
        <span data-lang="ko">연구</span><span data-lang="en">Research</span>
      </h1>
      <p class="page-lede">
        <span data-lang="ko">미디어 정책, 디지털 플랫폼 규제, 미디어 경제학을 계량적으로 분석한 학술 연구입니다.</span>
        <span data-lang="en">Peer-reviewed work in media policy, digital platform regulation, and media economics.</span>
      </p>

      <div class="scholar-line">
        <a href="https://scholar.google.com/citations?user=semkeskAAAAJ" target="_blank" rel="noopener noreferrer">Google Scholar</a>
        <span class="dot">·</span>
        <span class="stat"><b>{scholarStats.citations.toLocaleString()}</b> <span data-lang="ko">인용</span><span data-lang="en">citations</span></span>
        <span class="dot">·</span>
        <span class="stat"><b>{scholarStats.hIndex}</b> <span data-lang="ko">h-지수</span><span data-lang="en">h-index</span></span>
        <span class="dot">·</span>
        <span class="stat"><b>{scholarStats.i10Index}</b> <span data-lang="ko">i10-지수</span><span data-lang="en">i10-index</span></span>
        <span class="sep">|</span>
        <a href="https://orcid.org/0000-0002-5643-2748" target="_blank" rel="noopener noreferrer">ORCID</a>
      </div>
    </header>

    {citationGraph.length > 0 && (
      <div class="citation-graph reveal">
        <h2 class="graph-title">
          <span data-lang="ko">연도별 인용</span><span data-lang="en">Citations by Year</span>
        </h2>
        <canvas id="citationChart"></canvas>
        <p class="stat-updated">
          <span data-lang="ko">최종 업데이트: {updatedKo}</span><span data-lang="en">Last updated: {updatedEn}</span>
        </p>
      </div>
    )}

    <!-- Published -->
    <section class="research-section">
      <div class="block-head reveal">
        <h2 class="section-title"><span data-lang="ko">게재 논문</span><span data-lang="en">Published Papers</span></h2>
      </div>
      <p class="section-desc reveal"><span data-lang="ko">국제 학술지에 게재된 동료심사 논문</span><span data-lang="en">Peer-reviewed papers in academic journals</span></p>

      <div class="sort-controls reveal">
        <span class="sort-label"><span data-lang="ko">정렬</span><span data-lang="en">Sort by</span></span>
        <button class="sort-button active" data-sort="year"><span data-lang="ko">최신순</span><span data-lang="en">Year</span></button>
        <button class="sort-button" data-sort="citations"><span data-lang="ko">인용순</span><span data-lang="en">Citations</span></button>
      </div>

      <div class="publication-list" id="publication-list">
        {publishedPapers.map((pub, i) => (
          <div class="publication-item reveal" style={`--i:${Math.min(i, 6)}`} data-year={pub.year} data-citations={pub.citations || 0}>
            <PublicationCard publication={pub} variant="full" showAbstract={true} showBadges={true} showLinks={true} />
          </div>
        ))}
      </div>
    </section>

    {workInProgress.length > 0 && (
      <section class="research-section">
        <div class="block-head reveal">
          <h2 class="section-title"><span data-lang="ko">진행 중인 연구</span><span data-lang="en">Work in Progress</span></h2>
        </div>
        <p class="section-desc reveal"><span data-lang="ko">현재 진행 중인 연구 과제</span><span data-lang="en">Research projects under development</span></p>
        <div class="publication-list">
          {workInProgress.map((pub, i) => (
            <div class="reveal" style={`--i:${Math.min(i, 6)}`}>
              <PublicationCard publication={pub} variant="full" showAbstract={true} showBadges={true} showLinks={false} />
            </div>
          ))}
        </div>
      </section>
    )}

    {workingPapers.length > 0 && (
      <section class="research-section">
        <div class="block-head reveal">
          <h2 class="section-title"><span data-lang="ko">워킹 페이퍼</span><span data-lang="en">Working Papers</span></h2>
        </div>
        <p class="section-desc reveal"><span data-lang="ko">심사 또는 수정 중인 논문</span><span data-lang="en">Papers under review or revision</span></p>
        <div class="publication-list">
          {workingPapers.map((pub, i) => (
            <div class="reveal" style={`--i:${Math.min(i, 6)}`}>
              <PublicationCard publication={pub} variant="full" showAbstract={true} showBadges={true} showLinks={false} />
            </div>
          ))}
        </div>
      </section>
    )}

    {domesticPapers.length > 0 && (
      <section class="research-section">
        <div class="block-head reveal">
          <h2 class="section-title"><span data-lang="ko">국내 학술지 논문</span><span data-lang="en">Domestic Publications</span></h2>
        </div>
        <p class="section-desc reveal"><span data-lang="ko">한국연구재단 등재지(KCI) 게재 논문</span><span data-lang="en">Publications in Korean academic journals (KCI)</span></p>
        <div class="publication-list">
          {domesticPapers.map((pub, i) => (
            <article class="domestic-pub-item reveal" style={`--i:${Math.min(i, 6)}`}>
              <div class="pub-header">
                <h3 class="pub-title-ko">
                  <span data-lang="ko">{pub.title}</span><span data-lang="en">{pub.title_en || pub.title}</span>
                </h3>
                {pub.title_en && pub.title !== pub.title_en && (
                  <p class="pub-title-en" data-lang="ko">{pub.title_en}</p>
                )}
              </div>
              <div class="pub-meta">
                <span class="pub-authors">{pub.authors.join(', ')}</span>
                <span class="pub-separator">·</span>
                <span class="pub-journal">
                  <span data-lang="ko">{pub.journal}</span><span data-lang="en">{pub.journal_en || pub.journal}</span>
                </span>
                <span class="pub-separator">·</span>
                <span class="pub-year">{pub.year}</span>
                {pub.volume && <span class="pub-volume"> {pub.volume}({pub.issue})</span>}
                {pub.pages && <span class="pub-pages">, {pub.pages}</span>}
              </div>
              {(pub.abstract || pub.abstract_en) && (
                <div class="pub-abstract">
                  <span data-lang="ko">{pub.abstract || pub.abstract_en}</span><span data-lang="en">{pub.abstract_en || pub.abstract}</span>
                </div>
              )}
              <div class="pub-footer">
                <span class="pub-badge pub-badge-kci">KCI</span>
                {pub.citations > 0 && (
                  <span class="pub-citations">
                    <span data-lang="ko">인용 {pub.citations}</span><span data-lang="en">{pub.citations} citations</span>
                  </span>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>

  <script is:inline define:vars={{ citationGraph }}>
    var _citationGraph = citationGraph;
    var _citationChartInstance = null;

    function initPublicationsPage() {
      if (_citationGraph && _citationGraph.length > 0) {
        var ctx = document.getElementById('citationChart');
        if (ctx) {
          if (_citationChartInstance) _citationChartInstance.destroy();
          var rootStyles = getComputedStyle(document.documentElement);
          var accentColor = rootStyles.getPropertyValue('--color-accent').trim() || '#b05432';
          var borderColor = rootStyles.getPropertyValue('--color-border').trim() || '#ddd9d3';
          var textMuted = rootStyles.getPropertyValue('--color-text-muted').trim() || '#888888';

          _citationChartInstance = new Chart(ctx, {
            type: 'bar',
            data: {
              labels: _citationGraph.map(function (d) { return d.year; }),
              datasets: [{
                label: 'Citations',
                data: _citationGraph.map(function (d) { return d.citations; }),
                backgroundColor: accentColor,
                borderColor: accentColor,
                borderWidth: 0,
                borderRadius: 3,
                maxBarThickness: 36
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: true,
              plugins: { legend: { display: false } },
              scales: {
                y: { beginAtZero: true, ticks: { precision: 0, color: textMuted }, grid: { color: borderColor } },
                x: { ticks: { color: textMuted }, grid: { display: false } }
              }
            }
          });
        }
      }

      var sortButtons = document.querySelectorAll('.sort-button');
      var publicationList = document.getElementById('publication-list');
      if (publicationList) {
        sortButtons.forEach(function (button) {
          button.addEventListener('click', function () {
            sortButtons.forEach(function (btn) { btn.classList.remove('active'); });
            button.classList.add('active');
            var sortType = button.dataset.sort;
            var items = Array.from(publicationList.querySelectorAll('.publication-item'));
            items.sort(function (a, b) {
              if (sortType === 'year') return parseInt(b.dataset.year) - parseInt(a.dataset.year);
              if (sortType === 'citations') return parseInt(b.dataset.citations) - parseInt(a.dataset.citations);
              return 0;
            });
            items.forEach(function (item) { publicationList.appendChild(item); });
          });
        });
      }
    }

    initPublicationsPage();
    document.addEventListener('astro:page-load', initPublicationsPage);
  </script>

  <style>
    .pubs { padding-block: var(--section-gap); }

    .page-head { margin-bottom: var(--space-12); }
    .page-title {
      font-size: var(--step-5);
      font-weight: var(--weight-black);
      letter-spacing: -0.03em;
      line-height: 1;
    }
    .page-lede {
      margin-top: var(--space-4);
      max-width: 52ch;
      font-size: clamp(1.05rem, 1rem + 0.4vw, 1.25rem);
      color: var(--color-text-secondary);
      line-height: 1.7;
    }

    .scholar-line {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-2);
      margin-top: var(--space-8);
      padding-top: var(--space-6);
      border-top: 1px solid var(--color-border);
      font-size: 0.9rem;
      color: var(--color-text-secondary);
    }
    .scholar-line a { color: var(--color-accent); font-weight: var(--weight-semibold); }
    .scholar-line a:hover { color: var(--color-accent-hover); text-decoration: underline; }
    .scholar-line .stat b { font-weight: var(--weight-bold); color: var(--color-text); }
    .scholar-line .dot { color: var(--color-border-strong); }
    .scholar-line .sep { color: var(--color-border-strong); margin: 0 var(--space-1); }

    .citation-graph { margin-bottom: var(--space-16); }
    .graph-title {
      font-size: 0.8rem;
      font-weight: var(--weight-bold);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-text-muted);
      margin-bottom: var(--space-4);
    }
    #citationChart { max-height: 220px; }
    .stat-updated { font-size: 0.8rem; color: var(--color-text-muted); margin-top: var(--space-3); }

    .research-section { margin-bottom: var(--space-16); }
    .block-head {
      margin-bottom: var(--space-3);
      padding-bottom: var(--space-4);
      border-bottom: 2px solid var(--color-text);
    }
    .section-title {
      font-size: var(--step-3);
      font-weight: var(--weight-heavy);
      letter-spacing: -0.025em;
    }
    .section-desc { font-size: 0.95rem; color: var(--color-text-muted); margin-bottom: var(--space-8); }

    .publication-list { display: flex; flex-direction: column; gap: var(--space-8); }

    /* Domestic */
    .domestic-pub-item {
      padding-bottom: var(--space-6);
      border-bottom: 1px solid var(--color-border-light);
    }
    .domestic-pub-item:last-child { border-bottom: none; }
    .pub-header { margin-bottom: var(--space-3); }
    .pub-title-ko {
      font-size: 1.15rem;
      font-weight: var(--weight-bold);
      color: var(--color-text);
      line-height: 1.5;
    }
    .pub-title-en { font-size: 0.9rem; color: var(--color-text-muted); margin-top: var(--space-1); }
    .pub-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-2);
      font-size: 0.9rem;
      color: var(--color-text-secondary);
      margin-bottom: var(--space-3);
    }
    .pub-authors { font-weight: var(--weight-medium); }
    .pub-separator { color: var(--color-text-muted); }
    .pub-journal { font-weight: var(--weight-semibold); color: var(--color-accent); }
    .pub-abstract {
      background: var(--color-bg-sunken);
      padding: var(--space-4) var(--space-5);
      border: 1px solid var(--color-border-light);
      border-radius: var(--radius-soft);
      font-size: 0.9rem;
      color: var(--color-text-secondary);
      line-height: 1.7;
      margin-bottom: var(--space-3);
    }
    .pub-footer { display: flex; align-items: center; gap: var(--space-4); }
    .pub-badge {
      display: inline-block;
      padding: 0.15rem 0.6rem;
      font-size: 0.72rem;
      font-weight: var(--weight-bold);
      border-radius: var(--radius-pill);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border: 1px solid var(--color-accent);
      color: var(--color-accent);
    }
    .pub-citations { font-size: 0.85rem; color: var(--color-text-muted); }

    .sort-controls {
      display: flex;
      gap: var(--space-2);
      margin-bottom: var(--space-8);
      align-items: center;
      flex-wrap: wrap;
    }
    .sort-label { font-size: 0.85rem; color: var(--color-text-muted); font-weight: var(--weight-medium); margin-right: var(--space-1); }
    .sort-button {
      padding: var(--space-2) var(--space-4);
      border: 1px solid var(--color-border);
      background: var(--color-bg);
      border-radius: var(--radius-pill);
      font-family: var(--font-sans);
      font-size: 0.85rem;
      font-weight: var(--weight-medium);
      cursor: pointer;
      transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
      color: var(--color-text-secondary);
    }
    .sort-button:hover { border-color: var(--color-accent); color: var(--color-accent); }
    .sort-button.active { background: var(--color-text); color: var(--color-bg); border-color: var(--color-text); }

    @media (max-width: 640px) {
      .pub-title-ko { font-size: 1.05rem; }
      .pub-meta { font-size: 0.82rem; }
    }
  </style>
</BaseLayout>
