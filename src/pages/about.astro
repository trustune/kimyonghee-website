<style>
  .about-page {
    padding-block: var(--space-16) var(--space-8);
  }

  /* ═══════════════ HERO ═══════════════ */
  .about-hero {
    display: flex;
    align-items: center;
    gap: var(--space-10);
    padding-bottom: var(--section-gap);
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border-light);
  }
  .profile-frame {
    flex-shrink: 0;
    position: relative;
  }
  .profile-image {
    width: 200px;
    height: 200px;
    border-radius: var(--radius-soft);
    object-fit: cover;
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 44px -28px rgba(var(--shadow-color) / 0.45);
  }
  .about-hero-text { min-width: 0; }
  .about-eyebrow {
    font-size: 0.92rem;
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
    letter-spacing: 0.01em;
    margin-bottom: var(--space-3);
  }
  .about-name {
    font-size: var(--step-5);
    font-weight: var(--weight-black);
    line-height: 1;
    letter-spacing: -0.035em;
    margin-bottom: var(--space-4);
  }
  .about-role {
    font-size: clamp(1.05rem, 1rem + 0.4vw, 1.25rem);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }
  .about-lede {
    max-width: 56ch;
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 0.97rem + 0.25vw, 1.1rem);
    line-height: 1.75;
  }

  /* ═══════════════ BLOCKS (홈페이지 어휘 재사용) ═══════════════ */
  .block { padding-block: var(--space-12); }
  .block-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-4);
    border-bottom: 2px solid var(--color-text);
  }
  .block-title {
    font-size: var(--step-3);
    font-weight: var(--weight-heavy);
    letter-spacing: -0.025em;
  }

  /* ── Editorial rows (정적, 링크 아님) ── */
  .rows { list-style: none; padding: 0; margin: 0; }
  .row { border-bottom: 1px solid var(--color-border-light); }
  .row:last-child { border-bottom: none; }
  .row-static {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    align-items: baseline;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-2);
  }
  .row-index {
    font-size: 0.85rem;
    font-weight: var(--weight-bold);
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }
  .row-index--dot { position: relative; }
  .row-index--dot::before {
    content: "";
    display: inline-block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--color-accent);
    transform: translateY(-1px);
  }
  .row-main { display: flex; flex-direction: column; gap: 5px; min-width: 0; }
  .row-title {
    font-size: clamp(1.02rem, 0.98rem + 0.3vw, 1.18rem);
    font-weight: var(--weight-semibold);
    line-height: 1.45;
    color: var(--color-text);
  }
  .row-meta { font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.55; }
  .award-subtitle {
    font-weight: var(--weight-regular);
    color: var(--color-text-secondary);
  }

  /* ── Interest cards ── */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    gap: var(--space-5);
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-soft);
    background: var(--color-bg);
    transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 18px 40px -24px rgba(var(--shadow-color) / 0.5);
  }
  .card-cat {
    font-size: 0.72rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }
  .interest-list { list-style: none; padding: 0; margin: 0; }
  .interest-list li {
    padding: var(--space-2) 0;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border-light);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .interest-list li:last-child { border-bottom: none; }

  /* ═══════════════ CONTACT ═══════════════ */
  .contact-block { padding-bottom: var(--space-8); }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .contact-row {
    display: grid;
    grid-template-columns: 7rem 1fr;
    align-items: baseline;
    gap: var(--space-5);
  }
  .contact-row dt {
    font-size: 0.78rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }
  .contact-row dd {
    color: var(--color-text);
