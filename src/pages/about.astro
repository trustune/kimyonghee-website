---
import BaseLayout from '../layouts/BaseLayout.astro';
import awards from '../data/awards.json';

const sortedAwards = [...awards.awards]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 10);
---

<BaseLayout
  title="소개 · About"
  description="선문대학교 경영학과 교수 김용희의 소개 — 현직, 연구 관심분야, 학력, 경력, 수상, 자격증, 연락처.">
  <div class="about-page container">
    <!-- ═══════════════ HEADER ═══════════════ -->
    <header class="about-hero reveal">
      <div class="profile-frame">
        <img src="/images/profile.jpg" alt="김용희 / Yonghee Kim" class="profile-image" width="200" height="200" />
      </div>
      <div class="about-hero-text">
        <p class="about-eyebrow">
          <span data-lang="ko">소개</span><span data-lang="en">About</span>
        </p>
        <h1 class="about-name">
          <span data-lang="ko">김용희</span><span data-lang="en">Yonghee&nbsp;Kim</span>
        </h1>
        <p class="about-role">
          <span data-lang="ko">선문대학교 경영학과 교수 · Ph.D.</span>
          <span data-lang="en">Assistant Professor, Department of Business Administration, Sunmoon University · Ph.D.</span>
        </p>
        <p class="about-lede">
          <span data-lang="ko">미디어·정보통신 정책과 디지털 플랫폼이 시장을 바꾸는 방식을 계량경제와 데이터 분석으로 연구합니다. 연구의 결과가 정책과 산업 현장으로 이어지도록 일합니다.</span>
          <span data-lang="en">I study how media and ICT policy and digital platforms reshape markets, using econometric methods and data analysis. My aim is to carry research through to policy and industry practice.</span>
        </p>
      </div>
    </header>

    <!-- ═══════════════ CURRENT POSITION ═══════════════ -->
    <section class="block">
      <div class="block-head reveal">
        <h2 class="block-title"><span data-lang="ko">현직</span><span data-lang="en">Current Position</span></h2>
      </div>
      <ul class="rows">
        <li class="row reveal" style="--i:0">
          <div class="row-static">
            <span class="row-index row-index--dot" aria-hidden="true"></span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">선문대학교 경영학과 교수</span>
                <span data-lang="en">Professor, Department of Business Administration, Sunmoon University</span>
              </span>
              <span class="row-meta">2025.3 &ndash; <span data-lang="ko">현재</span><span data-lang="en">Present</span></span>
            </span>
          </div>
        </li>
        <li class="row reveal" style="--i:1">
          <div class="row-static">
            <span class="row-index row-index--dot" aria-hidden="true"></span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">대연산업정책연구원 원장</span>
                <span data-lang="en">Director, Daeyeon Industrial Policy Institute</span>
              </span>
            </span>
          </div>
        </li>
        <li class="row reveal" style="--i:2">
          <div class="row-static">
            <span class="row-index row-index--dot" aria-hidden="true"></span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">오픈루트 연구위원</span>
                <span data-lang="en">Research Fellow, OpenRoute Inc.</span>
              </span>
            </span>
          </div>
        </li>
      </ul>
    </section>

    <!-- ═══════════════ RESEARCH INTERESTS ═══════════════ -->
    <section class="block">
      <div class="block-head reveal">
        <h2 class="block-title"><span data-lang="ko">연구 관심분야</span><span data-lang="en">Research Interests</span></h2>
      </div>
      <div class="cards">
        <div class="card interest-card reveal" style="--i:0">
          <span class="card-cat"><span data-lang="ko">주제</span><span data-lang="en">Primary</span></span>
          <ul class="interest-list">
            <li><span data-lang="ko">미디어·정보통신 정책과 경영</span><span data-lang="en">Media &amp; ICT Policy and Management</span></li>
            <li><span data-lang="ko">정부 정책 컨설팅</span><span data-lang="en">Government Policy Consulting</span></li>
            <li><span data-lang="ko">미디어 ESG</span><span data-lang="en">Media ESG</span></li>
          </ul>
        </div>
        <div class="card interest-card reveal" style="--i:1">
          <span class="card-cat"><span data-lang="ko">방법론</span><span data-lang="en">Methods</span></span>
          <ul class="interest-list">
            <li><span data-lang="ko">계량경제 분석</span><span data-lang="en">Econometrics</span></li>
            <li><span data-lang="ko">빅데이터 분석</span><span data-lang="en">Big Data Analysis</span></li>
            <li><span data-lang="ko">자료포락분석</span><span data-lang="en">Data Envelopment Analysis</span></li>
            <li><span data-lang="ko">구조방정식 모형</span><span data-lang="en">Structural Equation Modeling</span></li>
          </ul>
        </div>
        <div class="card interest-card reveal" style="--i:2">
          <span class="card-cat"><span data-lang="ko">분야</span><span data-lang="en">Topics</span></span>
          <ul class="interest-list">
            <li><span data-lang="ko">미디어 산업 정책</span><span data-lang="en">Media Industry Policy</span></li>
            <li><span data-lang="ko">미디어 ESG</span><span data-lang="en">Media ESG</span></li>
            <li><span data-lang="ko">정보통신·미디어 산업 효율성</span><span data-lang="en">ICT &amp; Media Industry Efficiency</span></li>
            <li><span data-lang="ko">온라인 동영상 서비스·방송 정책</span><span data-lang="en">OTT &amp; Broadcasting Policy</span></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ═══════════════ EDUCATION ═══════════════ -->
    <section class="block">
      <div class="block-head reveal">
        <h2 class="block-title"><span data-lang="ko">학력</span><span data-lang="en">Education</span></h2>
      </div>
      <ul class="rows">
        <li class="row reveal" style="--i:0">
          <div class="row-static">
            <span class="row-index" aria-hidden="true">2016</span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">경영학 박사 (생산운영·경영정보)</span>
                <span data-lang="en">Ph.D. in Business Administration (OMIS)</span>
              </span>
              <span class="row-meta">
                <span data-lang="ko">숭실대학교 · 2013&ndash;2016</span>
                <span data-lang="en">Soongsil University · 2013&ndash;2016</span>
              </span>
            </span>
          </div>
        </li>
        <li class="row reveal" style="--i:1">
          <div class="row-static">
            <span class="row-index" aria-hidden="true">2012</span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">경영학 석사 (생산운영·경영정보)</span>
                <span data-lang="en">M.S. in Business Administration (OMIS)</span>
              </span>
              <span class="row-meta">
                <span data-lang="ko">숭실대학교 · 2010&ndash;2012</span>
                <span data-lang="en">Soongsil University · 2010&ndash;2012</span>
              </span>
            </span>
