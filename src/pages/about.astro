            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">겸임교수</span>
                <span data-lang="en">Adjunct Professor</span>
              </span>
              <span class="row-meta">
                <span data-lang="ko">경희대학교 미디어대학원 · 2023.9&ndash;2025.2</span>
                <span data-lang="en">Graduate School of Media &amp; Communication, Kyung Hee University · 2023.9&ndash;2025.2</span>
              </span>
            </span>
          </div>
        </li>
        <li class="row reveal" style="--i:1">
          <div class="row-static">
            <span class="row-index" aria-hidden="true">2022</span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">OTT 교수</span>
                <span data-lang="en">OTT Professor</span>
              </span>
              <span class="row-meta">
                <span data-lang="ko">동국대학교 · 2022.7&ndash;2023.6</span>
                <span data-lang="en">Dongguk University · 2022.7&ndash;2023.6</span>
              </span>
            </span>
          </div>
        </li>
        <li class="row reveal" style="--i:2">
          <div class="row-static">
            <span class="row-index" aria-hidden="true">2022</span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">겸임교수</span>
                <span data-lang="en">Adjunct Professor</span>
              </span>
              <span class="row-meta">KAIST · 2022.7&ndash;2023.6</span>
            </span>
