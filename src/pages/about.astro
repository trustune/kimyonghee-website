              </span>
              <span class="row-meta">
                <span data-lang="ko">숭실대학교 · 2000&ndash;2010</span>
                <span data-lang="en">Soongsil University · 2000&ndash;2010</span>
              </span>
            </span>
          </div>
        </li>
      </ul>
    </section>

    <!-- ═══════════════ PROFESSIONAL EXPERIENCE ═══════════════ -->
    <section class="block">
      <div class="block-head reveal">
        <h2 class="block-title"><span data-lang="ko">경력</span><span data-lang="en">Experience</span></h2>
