---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const dataPath = path.join(process.cwd(), 'public/data/mediaint/latest.json');
let data: any = { clusters: [], tmdb: {}, cat_counts: {}, timestamp: '', stats: {} };
try { data = JSON.parse(fs.readFileSync(dataPath, 'utf-8')); } catch (e) {}

const clusters = data.clusters || [];
const tmdb = data.tmdb || {};
const catCounts = data.cat_counts || {};
const ts = (data.timestamp || '').slice(0, 10);
const totalArts = clusters.reduce((s: number, c: any) => s + (c.article_count || c.articles?.length || 0), 0);

const featured = clusters.filter((c: any) => (c.article_count || c.articles?.length || 0) >= 2).slice(0, 15);
const topStory = featured[0];
const editorPick = featured[1];
const focusOn = featured[2];
const cards = featured.slice(3, 10);
const singles = clusters
  .filter((c: any) => (c.article_count || c.articles?.length || 0) === 1)
  .slice(0, 20)
  .map((c: any) => ({ ...c.articles?.[0], category: c.primary_cat || '' }));

// Archive list from filesystem
const archiveDir = path.join(process.cwd(), 'public/data/mediaint/archive');
let archive: any[] = [];
try {
  const files = fs.readdirSync(archiveDir).filter((f: string) => f.endsWith('.json')).sort().reverse();
  for (const f of files) {
    try {
      const d = JSON.parse(fs.readFileSync(path.join(archiveDir, f), 'utf-8'));
      const cls = d.clusters || [];
      const topCl = cls[0];
      archive.push({
        date: d.issue_date || f.replace('.json', ''),
        top_story: topCl?.synthesis_title || topCl?.headline || '',
        total: cls.reduce((s: number, c: any) => s + (c.article_count || c.articles?.length || 0), 0),
        stories: cls.filter((c: any) => (c.article_count || c.articles?.length || 0) >= 2).length,
      });
    } catch {}
  }
} catch {}

const CAT_COLORS: Record<string, string> = {
  "OTT/Streaming": "#e53935", "Film/Cinema": "#8e24aa", "Music/Audio": "#2e7d32",
  "Gaming/Esports": "#ef6c00", "K-Content": "#d81b60", "Media Business": "#1565c0",
  "Regulation": "#455a64", "Other": "#607d8b"
};

function esc(s: string) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
---

<BaseLayout title="미디어 동향 · MediaINT" description="미디어·엔터테인먼트 산업을 매주 추적해 정리하는 미디어 동향 브리핑." image={featured[0]?.image || ''}>

  <div class="mi container-wide">
    <!-- ═══════════════ HEADER ═══════════════ -->
    <header class="mi-header reveal">
      <p class="mi-eyebrow">
        <span data-lang="ko">주간 미디어 동향</span><span data-lang="en">Weekly Media Intelligence</span>
      </p>
      <h1 class="mi-title">Media<b>INT</b></h1>
      <p class="mi-sub">
        <span data-lang="ko">전 세계 미디어·엔터테인먼트 산업을 매주 추적해 정리하는 브리핑입니다.</span>
        <span data-lang="en">A weekly briefing that tracks the global media and entertainment industry.</span>
      </p>
      <p class="mi-meta">
        <span class="mi-meta-date">{ts}</span>
        <span class="mi-meta-sep" aria-hidden="true">·</span>
        <span>{totalArts}<span data-lang="ko"> 건의 기사</span><span data-lang="en"> articles</span></span>
        <span class="mi-meta-sep" aria-hidden="true">·</span>
        <span>{featured.length}<span data-lang="ko"> 개 스토리</span><span data-lang="en"> stories</span></span>
      </p>
      <nav class="mi-intelnav" aria-label="동향 / Intelligence">
        <a href="/mediaint" class="active" aria-current="page">MediaINT</a>
        <a href="/journalint">JournalINT</a>
      </nav>
    </header>

    <!-- ═══════════════ STATS ═══════════════ -->
    <dl class="mi-stats reveal">
      <div class="mi-st">
        <dt class="mi-st-num">{totalArts}</dt>
        <dd class="mi-st-lbl"><span data-lang="ko">기사</span><span data-lang="en">Articles</span></dd>
      </div>
      <div class="mi-st">
        <dt class="mi-st-num">{featured.length}</dt>
        <dd class="mi-st-lbl"><span data-lang="ko">스토리</span><span data-lang="en">Stories</span></dd>
      </div>
      <div class="mi-st">
        <dt class="mi-st-num">{tmdb.movies?.length || 0}</dt>
        <dd class="mi-st-lbl"><span data-lang="ko">영화</span><span data-lang="en">Movies</span></dd>
      </div>
      <div class="mi-st">
        <dt class="mi-st-num">{tmdb.tv?.length || 0}</dt>
        <dd class="mi-st-lbl"><span data-lang="ko">방송</span><span data-lang="en">TV</span></dd>
      </div>
      {Object.entries(catCounts).sort((a: any, b: any) => b[1] - a[1]).slice(0, 5).map(([cat, cnt]: [string, any]) => (
        <div class="mi-st">
          <dt class="mi-st-num" style={`color:${CAT_COLORS[cat] || 'var(--color-accent)'}`}>{cnt}</dt>
          <dd class="mi-st-lbl">{cat}</dd>
        </div>
      ))}
    </dl>

    {/* Top Story */}
    {topStory && (
      <Fragment>
        <h2 class="mi-sec reveal"><span data-lang="ko">톱 스토리</span><span data-lang="en">Top Story</span></h2>
        <article class="mi-top reveal">
          {topStory.image && <div class="mi-top-img" style={`background-image:url("${topStory.image}")`}></div>}
          <div class="mi-top-body">
            <div class="tags">
              <span class="mi-tag" style={`background:color-mix(in srgb, ${CAT_COLORS[topStory.primary_cat] || 'var(--color-accent)'} 14%, transparent);color:${CAT_COLORS[topStory.primary_cat] || 'var(--color-accent)'}`}>{topStory.primary_cat}</span>
              <span class="mi-tag mi-tag--src">{topStory.article_count}<span data-lang="ko"> 출처</span><span data-lang="en"> sources</span></span>
            </div>
            <h3>{esc(topStory.synthesis_title || topStory.headline)}</h3>
            <p class="lede">{esc(topStory.synthesis || '')}</p>
            {topStory.key_points?.length > 0 && (
              <ul class="kps">
                {topStory.key_points.map((kp: string) => <li>{esc(kp)}</li>)}
              </ul>
            )}
            <div class="mi-srcbar">
              {topStory.articles?.slice(0, 8).reduce((acc: any[], a: any) => {
                if (a.domain && !acc.find((x: any) => x.domain === a.domain)) acc.push({domain: a.domain, url: a.url});
                return acc;
              }, []).map((s: any) => <a href={s.url} target="_blank" rel="noopener" class="mi-src">{s.domain}</a>)}
            </div>
          </div>
        </article>
      </Fragment>
    )}

    {/* Editor's Pick - dynamically from 2nd cluster */}
    {editorPick && (
      <Fragment>
        <h2 class="mi-sec reveal"><span data-lang="ko">에디터 픽</span><span data-lang="en">Editor's Pick</span></h2>
        <article class="mi-editor reveal">
          {editorPick.image && <div class="mi-editor-img" style={`background-image:url("${editorPick.image}")`}></div>}
          <div class="mi-editor-body">
            <div class="tags">
              <span class="mi-editor-badge"><span data-lang="ko">에디터 픽</span><span data-lang="en">Editor's Pick</span></span>
              <span class="mi-tag" style={`color:${CAT_COLORS[editorPick.primary_cat] || 'var(--color-accent)'}`}>{editorPick.primary_cat}</span>
            </div>
            <h3><a href={editorPick.headline_url || '#'} target="_blank" rel="noopener">{esc(editorPick.synthesis_title || editorPick.headline)}</a></h3>
            <p class="lede">{esc(editorPick.synthesis || '')}</p>
            {editorPick.key_points?.length > 0 && (
              <ul class="kps">
                {editorPick.key_points.slice(0, 3).map((kp: string) => <li>{esc(kp)}</li>)}
              </ul>
            )}
            <div class="mi-srcbar">
              {(editorPick.articles || []).reduce((acc: any[], a: any) => {
                if (a.domain && !acc.find((x: any) => x.domain === a.domain) && acc.length < 4) acc.push({domain: a.domain, url: a.url});
                return acc;
              }, []).map((s: any) => <a href={s.url} target="_blank" rel="noopener" class="mi-src">{s.domain}</a>)}
            </div>
          </div>
        </article>
      </Fragment>
    )}

    {/* Focus On - same layout as Editor's Pick */}
    {focusOn && (
      <Fragment>
        <h2 class="mi-sec reveal"><span data-lang="ko">집중 조명</span><span data-lang="en">Focus On</span></h2>
        <article class="mi-editor reveal" style={`border-left-color:${CAT_COLORS[focusOn.primary_cat] || 'var(--color-accent)'}`}>
          {focusOn.image && <div class="mi-editor-img" style={`background-image:url("${focusOn.image}")`}></div>}
          <div class="mi-editor-body">
            <div class="tags">
              <span class="mi-editor-badge" style={`background:${CAT_COLORS[focusOn.primary_cat] || 'var(--color-accent)'}`}><span data-lang="ko">집중 조명</span><span data-lang="en">Focus On</span></span>
              <span class="mi-tag" style={`color:${CAT_COLORS[focusOn.primary_cat] || 'var(--color-accent)'}`}>{focusOn.primary_cat}</span>
            </div>
            <h3><a href={focusOn.headline_url || '#'} target="_blank" rel="noopener">{esc(focusOn.synthesis_title || focusOn.headline)}</a></h3>
            <p class="lede">{esc(focusOn.synthesis || '')}</p>
            {focusOn.key_points?.length > 0 && (
              <ul class="kps">
                {focusOn.key_points.slice(0, 3).map((kp: string) => <li>{esc(kp)}</li>)}
              </ul>
            )}
            <div class="mi-srcbar">
              {(focusOn.articles || []).reduce((acc: any[], a: any) => {
                if (a.domain && !acc.find((x: any) => x.domain === a.domain) && acc.length < 4) acc.push({domain: a.domain, url: a.url});
                return acc;
              }, []).map((s: any) => <a href={s.url} target="_blank" rel="noopener" class="mi-src">{s.domain}</a>)}
            </div>
          </div>
        </article>
      </Fragment>
    )}

    {/* Featured Stories */}
    {cards.length > 0 && (
      <Fragment>
        <h2 class="mi-sec reveal"><span data-lang="ko">주요 스토리</span><span data-lang="en">Featured Stories</span></h2>
        <div class="mi-cards">
          {cards.map((cl, i) => (
            <article class="mi-card reveal" style={`--i:${i}`}>
              {cl.image && <img src={cl.image} alt="" class="mi-card-img" loading="lazy" onerror="this.remove()" />}
              <div class="mi-card-body">
                <div class="tags">
                  <span class="mi-tag" style={`background:color-mix(in srgb, ${CAT_COLORS[cl.primary_cat] || 'var(--color-accent)'} 14%, transparent);color:${CAT_COLORS[cl.primary_cat] || 'var(--color-accent)'}`}>{cl.primary_cat}</span>
                  <span class="mi-tag mi-tag--src">{cl.article_count || cl.articles?.length || 0}<span data-lang="ko"> 출처</span><span data-lang="en"> sources</span></span>
                </div>
                <h3>{esc(cl.synthesis_title || cl.headline)}</h3>
                <p class="syn">{esc(cl.synthesis || '')}</p>
                {cl.key_points?.length > 0 && (
                  <ul class="kps">
                    {cl.key_points.slice(0, 2).map((kp: string) => <li>{esc(kp)}</li>)}
                  </ul>
                )}
                <div class="mi-srcbar" style="margin-top:auto;">
                  {(cl.articles || []).reduce((acc: any[], a: any) => {
                    if (a.domain && !acc.find((x: any) => x.domain === a.domain) && acc.length < 4) acc.push({domain: a.domain, url: a.url});
                    return acc;
                  }, []).map((s: any) => <a href={s.url} target="_blank" rel="noopener" class="mi-src">{s.domain}</a>)}
                </div>
              </div>
            </article>
          ))}
        </div>
      </Fragment>
    )}

    {/* Headlines */}
    {singles.length > 0 && (
      <Fragment>
        <h2 class="mi-sec reveal"><span data-lang="ko">헤드라인</span><span data-lang="en">Headlines</span></h2>
        <div class="mi-briefs">
          {singles.map(a => (
            <div class="mi-brief">
              <span class="mi-dot" style={`background:${CAT_COLORS[a.category] || 'var(--color-border-strong)'}`}></span>
              <div>
                <a href={a.url} target="_blank" rel="noopener">{esc(a.title || '')}</a>
                <div class="mi-brief-m">{a.domain || ''}</div>
              </div>
            </div>
          ))}
        </div>
      </Fragment>
    )}

    {/* Trending Entertainment */}
    <h2 class="mi-sec reveal"><span data-lang="ko">엔터테인먼트 동향</span><span data-lang="en">Trending Entertainment</span></h2>
    <div class="mi-ent">
      <div class="mi-ent-box reveal">
        <h3><span data-lang="ko">인기 영화</span><span data-lang="en">Trending Movies</span></h3>
        <div class="mi-posters">
          {(tmdb.movies || []).slice(0, 6).map((m: any) => (
            <div class="mi-poster">
              {m.poster_path && <img src={`https://image.tmdb.org/t/p/w185${m.poster_path}`} alt={m.title} loading="lazy" />}
              <div class="mi-poster-t">{m.title}</div>
              <div class="mi-poster-v">&#9733; {(m.vote_average || 0).toFixed(1)}</div>
            </div>
          ))}
        </div>
      </div>
      <div class="mi-ent-box reveal">
        <h3><span data-lang="ko">인기 방송</span><span data-lang="en">Trending TV</span></h3>
        <div class="mi-posters">
          {(tmdb.tv || []).slice(0, 6).map((s: any) => (
            <div class="mi-poster">
              {s.poster_path && <img src={`https://image.tmdb.org/t/p/w185${s.poster_path}`} alt={s.name} loading="lazy" />}
              <div class="mi-poster-t">{s.name}</div>
              <div class="mi-poster-v">&#9733; {(s.vote_average || 0).toFixed(1)}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    {/* Archive */}
    {archive.length > 0 && (
      <Fragment>
        <h2 class="mi-sec reveal"><span data-lang="ko">지난 호 보기</span><span data-lang="en">Archive</span></h2>
        <div class="mi-archive">
          {archive.map((a, i) => (
            <a href={`/mediaint/${a.date}`} class="mi-archive-item reveal" style={`--i:${i}`}>
              <span class="mi-archive-date">{a.date}</span>
              <span class="mi-archive-title">{a.top_story}</span>
              <span class="mi-archive-cnt">{a.total}<span data-lang="ko">건</span><span data-lang="en"> items</span></span>
            </a>
          ))}
        </div>
      </Fragment>
    )}

    <footer class="mi-footer">
      <span>MediaINT v3</span>
      <span class="mi-meta-sep" aria-hidden="true">·</span>
      <span data-lang="ko">미디어 산업 동향</span><span data-lang="en">Media industry intelligence</span>
      <span class="mi-meta-sep" aria-hidden="true">·</span>
      <span>Google News RSS + TMDb</span>
      <span class="mi-meta-sep" aria-hidden="true">·</span>
      <span>{ts}</span>
    </footer>
  </div>

</BaseLayout>

<style>
  .mi {
    padding-block: var(--space-16) var(--space-24);
  }

  /* ═══════════════ HEADER ═══════════════ */
  .mi-header {
    padding-bottom: var(--space-8);
    margin-bottom: var(--space-8);
    border-bottom: 2px solid var(--color-text);
  }
  .mi-eyebrow {
    font-size: 0.85rem;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }
  .mi-title {
    font-size: var(--step-5);
    font-weight: var(--weight-black);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-text);
  }
  .mi-title b { color: var(--color-accent); font-weight: var(--weight-black); }
  .mi-sub {
    max-width: 56ch;
    margin-top: var(--space-4);
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.15rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
  }
  .mi-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
    margin-top: var(--space-5);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .mi-meta-date { font-weight: var(--weight-semibold); color: var(--color-accent); }
  .mi-meta-sep { color: var(--color-border-strong); }

  .mi-intelnav { display: inline-flex; margin-top: var(--space-6); }
  .mi-intelnav a {
    font-size: 0.85rem;
    font-weight: var(--weight-semibold);
    color: var(--color-text-secondary);
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    transition: color var(--transition-fast), background var(--transition-base), border-color var(--transition-base);
  }
  .mi-intelnav a:first-child { border-radius: var(--border-radius) 0 0 var(--border-radius); }
  .mi-intelnav a:last-child { border-radius: 0 var(--border-radius) var(--border-radius) 0; border-left: none; }
  .mi-intelnav a:hover { color: var(--color-accent); background: var(--color-accent-light); }
  .mi-intelnav a.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
    font-weight: var(--weight-bold);
  }
  .mi-intelnav a.active:hover { background: var(--color-accent-hover); border-color: var(--color-accent-hover); color: #fff; }

  /* ═══════════════ STATS ═══════════════ */
  .mi-stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.25rem, 0.8rem + 2.4vw, 2.75rem);
    padding-block: var(--space-5);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-16);
  }
  .mi-st { display: flex; flex-direction: column; gap: 2px; }
  .mi-st-num {
    font-size: clamp(1.4rem, 1.2rem + 0.8vw, 1.8rem);
    font-weight: var(--weight-heavy);
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }
  .mi-st-lbl {
    font-size: 0.72rem;
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
  }

  /* ═══════════════ SECTION LABEL ═══════════════ */
  .mi-sec {
    font-size: 0.78rem;
    font-weight: var(--weight-heavy);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: var(--space-16) 0 var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 2px solid var(--color-text);
  }

  .mi-tag {
    font-size: 0.68rem;
    font-weight: var(--weight-semibold);
    padding: 3px 9px;
    border-radius: var(--radius-pill);
    background: var(--color-accent-light);
    color: var(--color-accent);
    letter-spacing: 0.01em;
  }
  .mi-tag--src { background: var(--color-surface); color: var(--color-text-muted); }

  /* ═══════════════ TOP STORY ═══════════════ */
  .mi-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-soft);
    background: var(--color-bg-sunken);
    margin-bottom: var(--space-8);
  }
  .mi-top-img { background-size: cover; background-position: center; min-height: 320px; }
  .mi-top-body { padding: var(--space-8); display: flex; flex-direction: column; justify-content: center; }
  .mi-top h3 {
    font-size: var(--step-2);
    font-weight: var(--weight-bold);
    line-height: 1.4;
    margin: var(--space-2) 0 var(--space-4);
    color: var(--color-text);
  }
  .mi-top .lede {
    font-size: 0.98rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  /* ═══════════════ EDITOR / FOCUS ═══════════════ */
  .mi-editor {
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-soft);
    background: var(--color-bg-sunken);
    margin-bottom: var(--space-8);
  }
  .mi-editor-img { background-size: cover; background-position: center; min-height: 280px; }
  .mi-editor-body { padding: var(--space-8); display: flex; flex-direction: column; justify-content: center; }
  .mi-editor h3 {
    font-size: var(--step-1);
    font-weight: var(--weight-bold);
    line-height: 1.4;
    margin: var(--space-2) 0 var(--space-3);
    color: var(--color-text);
  }
  .mi-editor h3 a { color: inherit; }
  .mi-editor h3 a:hover { color: var(--color-accent); }
  .mi-editor .lede {
    font-size: 0.92rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-3);
  }
  .mi-editor-badge {
    font-size: 0.68rem;
    font-weight: var(--weight-bold);
    padding: 3px 11px;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
    color: #fff;
    letter-spacing: 0.01em;
  }

  /* shared inside-card pieces */
  .tags { display: flex; gap: var(--space-2); flex-wrap: wrap; margin-bottom: var(--space-3); }
  .kps {
    margin: 0 0 var(--space-4) 1.1rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
  .kps li { margin-bottom: var(--space-1); }
  .mi-srcbar {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    padding-top: var(--space-3);
