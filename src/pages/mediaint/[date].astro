---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Static paths from archive index
export function getStaticPaths() {
  const indexPath = path.join(process.cwd(), 'public/data/mediaint/index.json');
  let issues: any[] = [];
  try {
    issues = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));
  } catch (e) {}
  return issues.map(issue => ({
    params: { date: issue.date },
  }));
}

const { date } = Astro.params;
const dataPath = path.join(process.cwd(), `public/data/mediaint/archive/${date}.json`);
let data: any = { clusters: [], tmdb: {}, cat_counts: {}, timestamp: '', stats: {} };
try {
  data = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
} catch (e) {
  console.warn(`MediaINT archive not found for ${date}`);
}

const clusters = data.clusters || [];
const tmdb = data.tmdb || {};
const catCounts = data.cat_counts || {};
const ts = (data.timestamp || '').slice(0, 16);

const featured = clusters.filter((c: any) => (c.article_count || c.articles?.length || 0) >= 2).slice(0, 15);
const hero = featured[0];
const cards = featured.slice(1);
const singles = clusters
  .filter((c: any) => (c.article_count || c.articles?.length || 0) === 1)
  .slice(0, 20)
  .map((c: any) => c.articles?.[0] || {});

const totalArts = clusters.reduce((s: number, c: any) => s + (c.article_count || c.articles?.length || 0), 0);

const CAT_COLORS: Record<string, string> = {
  "OTT/Streaming": "#e53935", "Film/Cinema": "#8e24aa", "Music/Audio": "#2e7d32",
  "Gaming/Esports": "#ef6c00", "K-Content": "#d81b60", "Media Business": "#1565c0",
  "Regulation": "#455a64", "Other": "#607d8b"
};

function esc(s: string) {
  return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
---

<BaseLayout title={`MediaINT - ${date}`} description={`Media Intelligence for ${date}`} image={hero?.image || ''}>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/fonts-archive/Paperlogy/subsets/Paperlogy-dynamic-subset.css">

<style>
  .mi { font-family: 'Paperlogy', var(--font-sans); max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
  .mi-header { margin-bottom: 1rem; }
  .mi-title { font-family: 'Paperlogy'; font-size: 2rem; font-weight: 900; letter-spacing: -1px; }
  .mi-title b { color: var(--color-accent, #1a6bff); }
  .mi-sub { font-size: 0.85rem; color: var(--color-text-light, #888); margin-top: 0.25rem; }
  .mi-nav { display: flex; gap: 1rem; margin-bottom: 1.5rem; font-size: 0.9rem; }
  .mi-nav a { color: var(--color-text-light, #666); text-decoration: none; padding: 0.25rem 0; border-bottom: 2px solid transparent; }
  .mi-nav a:hover { color: var(--color-accent, #1a6bff); border-bottom-color: var(--color-accent, #1a6bff); }
  .mi-stats { display: flex; gap: 1.5rem; margin-bottom: 1.5rem; padding: 0.75rem 0; border-top: 2px solid var(--color-text, #111); border-bottom: 1px solid var(--color-border, #e5e5e5); }
  .mi-st b { font-size: 1.1rem; color: var(--color-accent, #1a6bff); margin-right: 0.25rem; }
  .mi-st span { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-text-light, #888); }
  .mi-sec { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; color: var(--color-text-light, #888); margin: 2.5rem 0 1rem; padding-bottom: 0.4rem; border-bottom: 2px solid var(--color-text, #111); }
  .mi-hero { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-radius: 12px; overflow: hidden; background: var(--color-surface, #fff); box-shadow: 0 2px 16px rgba(0,0,0,0.06); margin-bottom: 2rem; }
  .mi-hero-img { background-size: cover; background-position: center; min-height: 350px; }
  .mi-hero-body { padding: 2rem; display: flex; flex-direction: column; justify-content: center; }
  .mi-hero h1 { font-family: 'Paperlogy'; font-size: 1.5rem; font-weight: 800; line-height: 1.35; margin: 0.5rem 0 0.75rem; }
  .mi-hero h1 a { color: var(--color-text, #111); text-decoration: none; }
  .mi-hero h1 a:hover { color: var(--color-accent, #1a6bff); }
  .mi-hero .lede { font-size: 0.95rem; color: var(--color-text-light, #555); line-height: 1.75; margin-bottom: 0.75rem; }
  .mi-hero .kps { margin: 0 0 0.75rem 1.25rem; font-size: 0.85rem; color: var(--color-text-light, #555); line-height: 1.6; }
  .mi-hero .kps li { margin-bottom: 0.25rem; }
  .mi-tag { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; }
  .mi-tag-row { display: flex; align-items: center; gap: 0.5rem; }
  .mi-nsrc { font-size: 0.7rem; color: var(--color-text-light, #888); background: var(--color-bg, #f5f5f7); padding: 1px 8px; border-radius: 8px; }
  .mi-srcbar { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: auto; padding-top: 0.6rem; border-top: 1px solid var(--color-border, #e5e5e5); }
  .mi-src { font-size: 0.7rem; color: var(--color-text-light, #888); background: var(--color-bg, #f5f5f7); padding: 2px 8px; border-radius: 4px; text-decoration: none; }
  .mi-src:hover { color: var(--color-accent, #1a6bff); }
  .mi-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .mi-card { background: var(--color-surface, #fff); border-radius: 10px; overflow: hidden; box-shadow: 0 1px 6px rgba(0,0,0,0.05); display: flex; flex-direction: column; transition: box-shadow 0.2s, transform 0.2s; }
  .mi-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .mi-card img { width: 100%; height: 170px; object-fit: cover; }
  .mi-card-body { padding: 1rem; flex: 1; display: flex; flex-direction: column; }
  .mi-card h3 { font-family: 'Paperlogy'; font-size: 0.95rem; font-weight: 700; line-height: 1.4; margin: 0.4rem 0; }
  .mi-card h3 a { color: var(--color-text, #111); text-decoration: none; }
  .mi-card h3 a:hover { color: var(--color-accent, #1a6bff); }
  .mi-card p { font-size: 0.8rem; color: var(--color-text-light, #555); line-height: 1.6; flex: 1; margin-bottom: 0.5rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .mi-briefs { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .mi-brief { display: flex; gap: 0.6rem; align-items: flex-start; padding: 0.6rem 0.8rem; background: var(--color-surface, #fff); border-radius: 8px; }
  .mi-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 6px; flex-shrink: 0; }
  .mi-brief a { font-size: 0.8rem; font-weight: 600; color: var(--color-text, #111); text-decoration: none; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .mi-brief a:hover { color: var(--color-accent, #1a6bff); }
  .mi-brief-s { font-size: 0.7rem; color: var(--color-text-light, #888); }
  .mi-ent { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .mi-ent-box { background: var(--color-surface, #fff); border-radius: 10px; padding: 1.25rem; box-shadow: 0 1px 6px rgba(0,0,0,0.05); }
  .mi-ent-box h3 { font-family: 'Paperlogy'; font-size: 1rem; font-weight: 700; margin-bottom: 0.75rem; }
  .mi-posters { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
  .mi-poster { text-align: center; }
  .mi-poster img { width: 100%; aspect-ratio: 2/3; object-fit: cover; border-radius: 6px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
  .mi-poster-t { font-size: 0.75rem; font-weight: 600; margin-top: 0.4rem; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .mi-poster-v { font-size: 0.7rem; color: var(--color-text-light, #888); }
  .mi-footer { text-align: center; padding: 2rem; color: var(--color-text-light, #ccc); font-size: 0.7rem; margin-top: 2rem; }
  @media (max-width: 768px) { .mi-hero, .mi-cards, .mi-ent, .mi-briefs { grid-template-columns: 1fr; } }
</style>

<div class="mi">
  <div class="mi-header">
    <div class="mi-title">Media<b>INT</b></div>
    <div class="mi-sub">Issue: {date}</div>
  </div>

  <div class="mi-nav">
    <a href="/mediaint">Latest</a>
    <a href="/mediaint/archive">Archive</a>
    <span style="color:var(--color-text-light);font-size:0.85rem;">| Viewing: {date}</span>
  </div>

  <div class="mi-stats">
    <div class="mi-st"><b>{totalArts}</b><span>Articles</span></div>
    <div class="mi-st"><b>{featured.length}</b><span>Stories</span></div>
    <div class="mi-st"><b>{tmdb.movies?.length || 0}</b><span>Movies</span></div>
    <div class="mi-st"><b>{tmdb.tv?.length || 0}</b><span>TV</span></div>
  </div>

  {hero && (
    <>
      <div class="mi-sec">Top Story</div>
      <article class="mi-hero">
        {hero.image && <div class="mi-hero-img" style={`background-image:url("${hero.image}")`}></div>}
        <div class="mi-hero-body">
          <div class="mi-tag-row">
            <span class="mi-tag" style={`color:${CAT_COLORS[hero.primary_cat] || '#666'}`}>{hero.primary_cat}</span>
            <span class="mi-nsrc">{hero.article_count} sources</span>
          </div>
          <h1><a href={hero.headline_url} target="_blank">{esc(hero.synthesis_title || hero.headline)}</a></h1>
          <p class="lede">{esc(hero.synthesis || '')}</p>
          {hero.key_points?.length > 0 && (
            <ul class="kps">{hero.key_points.map((kp: string) => <li>{esc(kp)}</li>)}</ul>
          )}
          <div class="mi-srcbar">
            {hero.articles?.slice(0, 6).reduce((acc: string[], a: any) => {
              if (a.domain && !acc.includes(a.domain)) acc.push(a.domain);
              return acc;
            }, []).map((d: string) => <a href="#" class="mi-src">{d}</a>)}
          </div>
        </div>
      </article>
    </>
  )}

  {cards.length > 0 && (
    <>
      <div class="mi-sec">Featured Stories</div>
      <div class="mi-cards">
        {cards.map(cl => (
          <article class="mi-card">
            {cl.image && <img src={cl.image} alt="" loading="lazy" onerror="this.remove()" />}
            <div class="mi-card-body">
              <div class="mi-tag-row">
                <span class="mi-tag" style={`color:${CAT_COLORS[cl.primary_cat] || '#666'}`}>{cl.primary_cat}</span>
                <span class="mi-nsrc">{cl.article_count || cl.articles?.length || 0}</span>
              </div>
              <h3><a href={cl.headline_url} target="_blank">{esc(cl.synthesis_title || cl.headline)}</a></h3>
              <p>{esc((cl.synthesis || '').slice(0, 180))}</p>
              <div class="mi-srcbar">
                {(cl.articles || []).reduce((acc: string[], a: any) => {
                  if (a.domain && !acc.includes(a.domain) && acc.length < 3) acc.push(a.domain);
                  return acc;
                }, []).map((d: string) => <a href="#" class="mi-src">{d}</a>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </>
  )}

  {singles.length > 0 && (
    <>
      <div class="mi-sec">More Headlines</div>
      <div class="mi-briefs">
        {singles.map(a => (
          <div class="mi-brief">
            <span class="mi-dot" style={`background:${CAT_COLORS[a.category] || '#ccc'}`}></span>
            <div>
              <a href={a.url} target="_blank">{esc(a.title || '')}</a>
              <div class="mi-brief-s">{a.domain || ''}</div>
            </div>
          </div>
        ))}
      </div>
    </>
  )}

  <div class="mi-sec">Trending Entertainment</div>
  <div class="mi-ent">
    <div class="mi-ent-box">
      <h3>Trending Movies</h3>
      <div class="mi-posters">
        {(tmdb.movies || []).slice(0, 6).map((m: any) => (
          <div class="mi-poster">
            {m.poster_path && <img src={`https://image.tmdb.org/t/p/w185${m.poster_path}`} alt={m.title} loading="lazy" />}
            <div class="mi-poster-t">{m.title}</div>
            <div class="mi-poster-v">★ {(m.vote_average || 0).toFixed(1)}</div>
          </div>
        ))}
      </div>
    </div>
    <div class="mi-ent-box">
      <h3>Trending TV</h3>
      <div class="mi-posters">
        {(tmdb.tv || []).slice(0, 6).map((s: any) => (
          <div class="mi-poster">
            {s.poster_path && <img src={`https://image.tmdb.org/t/p/w185${s.poster_path}`} alt={s.name} loading="lazy" />}
            <div class="mi-poster-t">{s.name}</div>
            <div class="mi-poster-v">★ {(s.vote_average || 0).toFixed(1)}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="mi-footer">MediaINT · Issue {date}</div>
</div>

</BaseLayout>
