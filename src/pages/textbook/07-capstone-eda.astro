// ==================== MATH UTILITIES ====================
function pearsonR(xs, ys) {
  const n = xs.length;
  if (n < 2) return 0;
  const mx = xs.reduce((a, b) => a + b, 0) / n;
  const my = ys.reduce((a, b) => a + b, 0) / n;
  let num = 0, dx = 0, dy = 0;
  for (let i = 0; i < n; i++) {
    num += (xs[i] - mx) * (ys[i] - my);
    dx += (xs[i] - mx) ** 2;
    dy += (ys[i] - my) ** 2;
  }
  return dx && dy ? num / Math.sqrt(dx * dy) : 0;
}

function linReg(xs, ys) {
  const n = xs.length;
  const mx = xs.reduce((a, b) => a + b, 0) / n;
  const my = ys.reduce((a, b) => a + b, 0) / n;
  let ssxy = 0, ssxx = 0;
  for (let i = 0; i < n; i++) { ssxy += (xs[i] - mx) * (ys[i] - my); ssxx += (xs[i] - mx) ** 2; }
  const b = ssxx ? ssxy / ssxx : 0;
  const a = my - b * mx;
  return { a, b };
}

function computeStats(arr) {
  const n = arr.length;
  const sorted = [...arr].sort((a, b) => a - b);
  const mean = arr.reduce((a, b) => a + b, 0) / n;
  const median = n % 2 ? sorted[Math.floor(n / 2)] : (sorted[n / 2 - 1] + sorted[n / 2]) / 2;
  const variance = arr.reduce((a, v) => a + (v - mean) ** 2, 0) / n;
  const sd = Math.sqrt(variance);
  const skewness = n > 2 ? arr.reduce((a, v) => a + ((v - mean) / sd) ** 3, 0) / n : 0;
  return { mean, median, sd, min: sorted[0], max: sorted[n - 1], skewness };
}

function fmt(v, precision = 2) {
  if (typeof v !== 'number' || isNaN(v)) return '-';
  return v.toFixed(precision);
}

function makeHistogram(data, bins = 15) {
  const min = Math.min(...data), max = Math.max(...data);
  const bw = (max - min) / bins || 1;
  const hist = new Array(bins).fill(0);
  data.forEach(v => { hist[Math.min(bins - 1, Math.floor((v - min) / bw))]++; });
  const labels = hist.map((_, i) => (min + (i + 0.5) * bw).toFixed(1));
  return { hist, labels, min, max, bw };
}

