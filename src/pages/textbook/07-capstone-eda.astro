async function generateDashboard() {
  
  const selected = Array.from(document.querySelectorAll('.dash-cb:checked')).map(cb => cb.value);
  if (selected.length < 3) {
    document.getElementById('dashboard-msg').textContent = '3개 이상 선택하세요!';
    return;
  }

  const vars = selected.map(k => ({ key: k, ...DATA[k] }));
  const n = vars.length;

  // Correlation matrix
  const matrix = [];
  for (let i = 0; i < n; i++) {
    matrix[i] = [];
    for (let j = 0; j < n; j++) {
      matrix[i][j] = pearsonR(vars[i].data, vars[j].data);
    }
  }

  // Heatmap
  const canvas = document.getElementById('dashboard-heatmap');
  if (dashboardChart) { dashboardChart.destroy(); dashboardChart = null; }

  const heatData = [];
  for (let i = 0; i < n; i++) {
    for (let j = 0; j < n; j++) {
      heatData.push({ x: j, y: n - 1 - i, r: matrix[i][j] });
    }
  }
  const labels = vars.map(v => v.label.split('(')[0].split('/')[0].trim());

  dashboardChart = new Chart(canvas, {
    type: 'scatter',
    data: {
      datasets: [{
        label: '상관계수',
        data: heatData.map(d => ({ x: d.x, y: d.y })),
        backgroundColor: heatData.map(d => {
          const rv = d.r;
          if (rv > 0) return `rgba(37, 99, 235, ${Math.abs(rv) * 0.8 + 0.1})`;
          if (rv < 0) return `rgba(239, 68, 68, ${Math.abs(rv) * 0.8 + 0.1})`;
          return 'rgba(100, 116, 139, 0.2)';
        }),
        pointRadius: heatData.map(d => 12 + Math.abs(d.r) * 16),
        pointStyle: 'rectRounded',
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: {
        legend: { display: false },
        title: { display: true, text: '상관행렬 (파랑=양의 상관, 빨강=음의 상관)', font: { size: 13, family: "'Paperlogy'" } },
        tooltip: {
          callbacks: {
            label: (ctx) => {
              const idx = ctx.dataIndex;
              const i = n - 1 - heatData[idx].y;
              const j = heatData[idx].x;
              return `${labels[i]} vs ${labels[j]}: r = ${matrix[i][j].toFixed(3)}`;
            }
          }
        }
      },
      scales: {
        x: { min: -0.5, max: n - 0.5, ticks: { callback: (v) => labels[v] || '', stepSize: 1, font: { size: 9 } } },
        y: { min: -0.5, max: n - 0.5, ticks: { callback: (v) => labels[n - 1 - v] || '', stepSize: 1, font: { size: 9 } } },
      }
    }
  });

  // Top 3 correlations
  const pairs = [];
  for (let i = 0; i < n; i++) {
    for (let j = i + 1; j < n; j++) {
      pairs.push({ i, j, r: matrix[i][j] });
    }
  }
  pairs.sort((a, b) => Math.abs(b.r) - Math.abs(a.r));

  const top3Div = document.getElementById('dashboard-top3');
  top3Div.innerHTML = '<h3 style="margin-bottom: 8px;">가장 강한 상관관계 Top 3</h3>';
  const top3 = pairs.slice(0, 3);
  top3.forEach((p, idx) => {
    const color = p.r > 0 ? 'var(--tb-primary)' : 'var(--tb-danger)';
    const direction = p.r > 0 ? '양의 상관' : '음의 상관';
    top3Div.insertAdjacentHTML('beforeend', `
      <div style="padding: 10px 16px; background: var(--tb-g100); border-radius: 8px; margin-bottom: 6px; display: flex; justify-content: space-between; align-items: center;">
        <span><strong>${idx + 1}.</strong> ${vars[p.i].label.split('(')[0].trim()} vs ${vars[p.j].label.split('(')[0].trim()}</span>
        <span style="color: ${color}; font-weight: 700;">r = ${p.r.toFixed(3)} (${direction})</span>
      </div>
    `);
  });
}

