      <li style="margin-bottom: 6px;"><strong>세 차례 위기의 다른 성격:</strong> 1997년(IMF)은 환율과 실업률 급등, 2008년(GFC)은 주가 폭락과 수출 급감, 2020년(COVID)은 전반적 경기 위축으로 각각 다른 양상을 보입니다.</li>
      <li><strong>GDP 성장률의 추세적 둔화:</strong> 1990년대 평균 약 6%대에서 2020년대 약 2%대로 성장률이 구조적으로 하락하고 있습니다.</li>
    </ol>
  </div>`;

  reportDiv.innerHTML = html;
}

// ==================== INTERACTIVE 5: CRISIS DETECTOR ====================
let crisisChart = null;

async function detectCrisis() {
  
  const threshold = parseFloat(document.getElementById('crisis-threshold').value);

  // Calculate Z-scores for each variable and year
  const zScores = {};
  VAR_KEYS.forEach(key => {
    const v = DATA[key];
    const s = computeStats(v.data);
    zScores[key] = v.data.map(val => (val - s.mean) / s.sd);
  });

  // Count deviations per year
  const yearDeviations = YEARS.map((year, yi) => {
    let count = 0;
    const details = [];
    VAR_KEYS.forEach(key => {
      const z = zScores[key][yi];
      if (Math.abs(z) > threshold) {
        count++;
        details.push({ var: DATA[key].label.split('(')[0].trim(), z: z.toFixed(2) });
      }
    });
    return { year, count, details };
  });

  // Draw time series with crisis bands
  const canvas = document.getElementById('crisis-chart');
  if (crisisChart) { crisisChart.destroy(); crisisChart = null; }

  // Use GDP growth as main indicator, highlight crisis years
  const crisisYears = yearDeviations.filter(y => y.count >= 2);
  const bgColors = YEARS.map((_, i) => yearDeviations[i].count >= 2 ? '#ef444433' : 'transparent');

  crisisChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: YEARS.map(String),
      datasets: [
        {
          label: '이탈 지표 수',
          data: yearDeviations.map(y => y.count),
          backgroundColor: yearDeviations.map(y => y.count >= 2 ? '#ef4444cc' : y.count >= 1 ? '#f59e0b88' : '#22c55e55'),
          borderRadius: 3,
          order: 2,
          yAxisID: 'y',
        },
        {
          label: 'GDP 성장률 (%)',
          type: 'line',
          data: DATA.gdp.data,
          borderColor: '#2563eb',
          backgroundColor: '#2563eb22',
          borderWidth: 2,
          pointRadius: 3,
          fill: false,
          tension: 0.2,
          order: 1,
          yAxisID: 'y1',
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: {
        legend: { position: 'top' },
        title: { display: true, text: `위기 감지 (기준: ${threshold} SD 이상 이탈)`, font: { size: 14, family: "'Paperlogy'" } },
        tooltip: {
          callbacks: {
            afterLabel: (ctx) => {
              if (ctx.datasetIndex === 0) {
                const yd = yearDeviations[ctx.dataIndex];
                if (yd.details.length > 0) {
                  return yd.details.map(d => `  ${d.var}: Z=${d.z}`).join('\n');
                }
              }
              return '';
            }
          }
        }
      },
      scales: {
        y: { beginAtZero: true, position: 'left', title: { display: true, text: '이탈 지표 수' }, max: 10 },
        y1: { position: 'right', title: { display: true, text: 'GDP 성장률 (%)' }, grid: { drawOnChartArea: false } },
        x: { ticks: { maxTicksLimit: 15 } },
      }
    }
  });

  // Results
  const resultsDiv = document.getElementById('crisis-results');
  if (crisisYears.length === 0) {
    resultsDiv.innerHTML = '<div class="tb-explain">해당 기준에서 감지된 위기 연도가 없습니다. 기준을 낮춰보세요.</div>';
  } else {
    let rHtml = '<h3 style="margin-bottom: 8px;">감지된 위기 연도</h3>';
    crisisYears.sort((a, b) => b.count - a.count);
    crisisYears.forEach(cy => {
      const eventName = cy.year === 1997 || cy.year === 1998 ? 'IMF 외환위기'
        : cy.year === 2008 || cy.year === 2009 ? '글로벌 금융위기'
        : cy.year === 2020 ? 'COVID-19 팬데믹'
        : '';
      const badge = eventName ? `<span style="background:#fee2e2;color:var(--tb-danger);padding:2px 8px;border-radius:10px;font-size:.78rem;font-weight:700;margin-left:8px;">${eventName}</span>` : '';

      rHtml += `<div style="padding: 12px 16px; background: var(--tb-g100); border-radius: 8px; margin-bottom: 8px; border-left: 4px solid var(--tb-danger);">
        <div style="font-weight: 700; margin-bottom: 4px;">${cy.year}년 -- ${cy.count}개 지표 이탈${badge}</div>
        <div style="font-size: .85rem; color: var(--tb-g600);">
          ${cy.details.map(d => `${d.var} (Z=${d.z})`).join(' | ')}
        </div>
      </div>`;
    });
    resultsDiv.innerHTML = rHtml;
  }

  // Stats
  document.getElementById('crisis-stats').style.display = '';
  document.getElementById('crisis-years').textContent = crisisYears.length + '개';
  if (crisisYears.length > 0) {
    document.getElementById('crisis-worst').textContent = crisisYears[0].year + '년';
    document.getElementById('crisis-max-dev').textContent = crisisYears[0].count + '개';
  }
}

// ==================== INIT ====================
function init() {

  // Interactive 1
  document.getElementById('btn-var-explore').addEventListener('click', exploreVariable);
  exploreVariable();

  // Interactive 2
  document.getElementById('btn-scatter-draw').addEventListener('click', drawTwoVarScatter);
  drawTwoVarScatter();

  // Interactive 3
  initDashboardVars();
  document.getElementById('btn-dashboard-gen').addEventListener('click', generateDashboard);

  // Interactive 4
  document.getElementById('btn-gen-report').addEventListener('click', generateReport);

  // Interactive 5
  document.getElementById('btn-crisis-detect').addEventListener('click', detectCrisis);
}

document.addEventListener('DOMContentLoaded', init);
