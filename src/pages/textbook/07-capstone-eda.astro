  if (outlierYears.length > 0) {
    html += `<div style="margin-bottom: 14px;">`;
    outlierYears.forEach(o => {
      html += `<div style="padding: 10px 16px; background: linear-gradient(135deg, #fef2f2, #fee2e2); border-radius: 8px; margin-bottom: 6px;">
