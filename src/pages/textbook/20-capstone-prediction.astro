function renderHeatmap() {
  const canvas = document.getElementById('canvas-heatmap');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const vars = NUM_VARS;
  const labels = vars.map(v => VAR_LABELS[v]);
  const n = vars.length;

  const corr = [];
  for (let i = 0; i < n; i++) {
    corr.push([]);
    for (let j = 0; j < n; j++) {
      corr[i].push(corrCoef(dataset.map(r => r[vars[i]]), dataset.map(r => r[vars[j]])));
    }
  }

  const size = canvas.width;
  const pad = 90;
  const cell = (size - pad) / n;
  ctx.clearRect(0, 0, size, size);

  for (let i = 0; i < n; i++) {
    for (let j = 0; j < n; j++) {
      const val = corr[i][j];
      let r, g, b;
      if (val >= 0) {
        r = 239; g = Math.round(239 - val * 171); b = Math.round(239 - val * 171);
      } else {
        const av = Math.abs(val);
        r = Math.round(239 - av * 202); g = Math.round(239 - av * 140); b = 239;
      }
      ctx.fillStyle = `rgb(${r},${g},${b})`;
      ctx.fillRect(pad + j * cell, pad + i * cell, cell - 1, cell - 1);
      ctx.fillStyle = Math.abs(val) > 0.5 ? '#fff' : '#1e293b';
      ctx.font = '11px sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(val.toFixed(2), pad + j * cell + cell/2, pad + i * cell + cell/2);
    }
  }
  ctx.fillStyle = '#1e293b';
  ctx.font = '11px sans-serif';
  for (let i = 0; i < n; i++) {
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    ctx.fillText(labels[i], pad - 6, pad + i * cell + cell/2);
    ctx.save();
    ctx.translate(pad + i * cell + cell/2, pad - 6);
    ctx.rotate(-Math.PI / 4);
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(labels[i], 0, 0);
    ctx.restore();
  }
}

// ======================== STEP 2: FEATURE SELECTION ========================

function getSelectedFeatures() {
  return Array.from(document.querySelectorAll('.feat-check:checked')).map(c => c.value);
}

async function runFeatureSelection() {
  const feats = getSelectedFeatures();
  if (feats.length === 0) { alert('하나 이상의 변수를 선택하세요.'); return; }
  

  const { X, y, colNames } = prepareFeatures(dataset, feats);
  const res = gdOLS(X, y, 0.05, 300);
  const pred = predict(X, res.w);
  const r2 = calcR2(y, pred);
  const p = colNames.length - 1;
  const adjR2 = calcAdjR2(r2, y.length, p);
  const rmseVal = calcRMSE(y, pred);

  document.getElementById('stat-r2').textContent = r2.toFixed(4);
  document.getElementById('stat-adj-r2').textContent = adjR2.toFixed(4);
  document.getElementById('stat-rmse').textContent = fmtK(rmseVal);
  document.getElementById('stat-p').textContent = p;

  // Coefficients + VIF
  const tbody = document.getElementById('reg-coef-tbody');
  tbody.innerHTML = '';
  let hasHighVIF = false;
  for (let j = 0; j < colNames.length; j++) {
    let vif = '-', status = '';
    if (j > 0 && colNames.length > 2) {
      const v = calcVIF(X, j);
      vif = v.toFixed(2);
      if (v >= 5) { status = 'HIGH'; hasHighVIF = true; }
      else status = 'OK';
    }
    const vifColor = status === 'HIGH' ? 'var(--tb-danger)' : status === 'OK' ? 'var(--tb-success)' : '';
    tbody.insertAdjacentHTML('beforeend', `<tr>
      <td>${colNames[j]}</td>
      <td>${res.w[j].toFixed(2)}</td>
      <td style="color:${vifColor};font-weight:${status==='HIGH'?'700':'400'}">${vif}</td>
      <td style="color:${vifColor};font-weight:700;">${status}</td>
    </tr>`);
  }
  document.getElementById('vif-warning').style.display = hasHighVIF ? '' : 'none';

  // R2 history bar chart
  r2History.push({ label: feats.length + '변수', r2: r2, adjR2: adjR2 });
  if (r2History.length > 8) r2History = r2History.slice(-8);
  destroyChart('chart-r2-bar');
  chartInstances['chart-r2-bar'] = new Chart(document.getElementById('chart-r2-bar'), {
    type: 'bar',
    data: {
      labels: r2History.map(h => h.label),
      datasets: [
        { label: 'R2', data: r2History.map(h => h.r2), backgroundColor: 'rgba(37,99,235,0.6)' },
        { label: 'Adj-R2', data: r2History.map(h => h.adjR2), backgroundColor: 'rgba(124,58,237,0.5)' }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false,
      scales: { y: { min: 0, max: 1, title: { display: true, text: 'R-제곱' } } },
      plugins: { legend: { position: 'top' } }
    }
  });

  document.getElementById('reg-results').style.display = '';
  document.getElementById('btn-feat-done').style.display = '';
}

// ======================== STEP 3: SPLIT ========================

function splitData() {
  const ratio = parseInt(document.getElementById('slider-train').value) / 100;
  const seed = parseInt(document.getElementById('input-seed').value) || 42;
  const rng = seededRandom(seed);
  const shuffled = shuffle(dataset, rng);
  const splitIdx = Math.round(shuffled.length * ratio);
  trainSet = shuffled.slice(0, splitIdx);
  testSet = shuffled.slice(splitIdx);

  document.getElementById('split-visual').style.display = '';
  const trainBar = document.getElementById('split-bar-train');
  const testBar = document.getElementById('split-bar-test');
  trainBar.style.width = (ratio * 100) + '%';
  trainBar.textContent = '학습 ' + Math.round(ratio * 100) + '%';
  testBar.style.width = ((1-ratio)*100) + '%';
  testBar.textContent = '검증 ' + Math.round((1-ratio)*100) + '%';
  document.getElementById('stat-train-n').textContent = trainSet.length;
  document.getElementById('stat-test-n').textContent = testSet.length;
}

// ======================== STEP 4: MODEL COMPARISON ========================

async function runComparison() {
  if (trainSet.length === 0) { alert('먼저 Step 3에서 데이터를 분할하세요.'); return; }
  
  const feats = getSelectedFeatures();
  if (feats.length === 0) { alert('Step 2에서 변수를 선택하세요.'); return; }

  const lambda = parseFloat(document.getElementById('slider-lambda').value);
  const lr = parseFloat(document.getElementById('sel-lr').value);
  const maxIter = 500;

  const trainPrep = prepareFeatures(trainSet, feats);
  const testX = testSet.map(r => standardizeTestRow(r, feats, trainPrep));
  const testY = testSet.map(r => r.price_10k);

  // Fit all three models via gradient descent
  const olsRes = gdOLS(trainPrep.X, trainPrep.y, lr, maxIter);
  const ridgeRes = gdRidge(trainPrep.X, trainPrep.y, lr, lambda, maxIter);
  const lassoRes = gdLasso(trainPrep.X, trainPrep.y, lr, lambda, maxIter);

  fittedModels.ols = { w: olsRes.w, prep: trainPrep, feats };
  fittedModels.ridge = { w: ridgeRes.w, prep: trainPrep, feats };
  fittedModels.lasso = { w: lassoRes.w, prep: trainPrep, feats };
  lossHistory = { ols: olsRes.losses, ridge: ridgeRes.losses, lasso: lassoRes.losses };

  const results = [
    { name: 'OLS', w: olsRes.w },
    { name: 'Ridge', w: ridgeRes.w },
    { name: 'Lasso', w: lassoRes.w }
  ].map(m => {
    const trP = predict(trainPrep.X, m.w);
    const teP = predict(testX, m.w);
    return { ...m,
      trainRMSE: calcRMSE(trainPrep.y, trP), testRMSE: calcRMSE(testY, teP),
      trainR2: calcR2(trainPrep.y, trP), testR2: calcR2(testY, teP) };
  });
  const bestIdx = results.reduce((bi, r, i) => r.testRMSE < results[bi].testRMSE ? i : bi, 0);

  // Performance table
  const tbody = document.getElementById('compare-perf-tbody');
  tbody.innerHTML = '';
  results.forEach((r, i) => {
    tbody.insertAdjacentHTML('beforeend', `<tr style="${i===bestIdx?'background:var(--tb-accent-light);font-weight:700':''}">
      <td>${r.name}</td><td>${fmtK(r.trainRMSE)}</td><td>${fmtK(r.testRMSE)}</td>
      <td>${r.trainR2.toFixed(4)}</td><td>${r.testR2.toFixed(4)}</td>
      <td>${i===bestIdx?'BEST':''}</td>
    </tr>`);
  });

  // RMSE bar chart
  destroyChart('chart-compare-rmse');
  chartInstances['chart-compare-rmse'] = new Chart(document.getElementById('chart-compare-rmse'), {
    type: 'bar',
    data: {
      labels: results.map(r => r.name),
      datasets: [
        { label: 'Train RMSE', data: results.map(r => Math.round(r.trainRMSE)), backgroundColor: 'rgba(37,99,235,0.6)' },
        { label: 'Test RMSE', data: results.map(r => Math.round(r.testRMSE)), backgroundColor: 'rgba(239,68,68,0.6)' }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'top' } },
      scales: { y: { title: { display: true, text: 'RMSE (만원)' }, beginAtZero: true } }
    }
  });

  // Loss curves
  destroyChart('chart-loss-curve');
  const maxLen = Math.max(olsRes.losses.length, ridgeRes.losses.length, lassoRes.losses.length);
  const epochLabels = Array.from({ length: maxLen }, (_, i) => i + 1);
  chartInstances['chart-loss-curve'] = new Chart(document.getElementById('chart-loss-curve'), {
    type: 'line',
    data: {
      labels: epochLabels,
      datasets: [
        { label: 'OLS', data: olsRes.losses, borderColor: '#2563eb', fill: false, pointRadius: 0, borderWidth: 2 },
        { label: 'Ridge', data: ridgeRes.losses, borderColor: '#22c55e', fill: false, pointRadius: 0, borderWidth: 2 },
        { label: 'Lasso', data: lassoRes.losses, borderColor: '#f59e0b', fill: false, pointRadius: 0, borderWidth: 2 }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'top' } },
      scales: {
        x: { title: { display: true, text: '반복 횟수' }, ticks: { maxTicksLimit: 10 } },
        y: { title: { display: true, text: 'Loss (MSE)' }, type: 'logarithmic' }
      }
    }
  });

  // Coefficient comparison
  const ctbody = document.getElementById('compare-coef-tbody');
  ctbody.innerHTML = '';
  for (let j = 0; j < trainPrep.colNames.length; j++) {
    const lassoZero = Math.abs(lassoRes.w[j]) < 0.01 && j > 0;
    const ls = lassoZero ? 'color:var(--tb-danger);font-weight:700;background:#fef2f2;' : '';
    ctbody.insertAdjacentHTML('beforeend', `<tr>
      <td>${trainPrep.colNames[j]}</td>
      <td>${olsRes.w[j].toFixed(2)}</td>
      <td>${ridgeRes.w[j].toFixed(2)}</td>
      <td style="${ls}">${lassoRes.w[j].toFixed(2)}${lassoZero ? ' [0]' : ''}</td>
    </tr>`);
  }

  document.getElementById('compare-results').style.display = '';
}

// ======================== STEP 5: DIAGNOSTICS ========================

async function runDiagnostics() {
  
  const modelKey = document.getElementById('sel-diag-model').value;
  const model = fittedModels[modelKey];
  if (!model) { alert('먼저 Step 4에서 모델을 학습시키세요.'); return; }

  const testX = testSet.map(r => standardizeTestRow(r, model.feats, model.prep));
  const actual = testSet.map(r => r.price_10k);
  const predicted = predict(testX, model.w);
  const residuals = actual.map((a, i) => a - predicted[i]);

  const allVals = [...actual, ...predicted];
  const lo = Math.min(...allVals), hi = Math.max(...allVals);

  // Actual vs Predicted
  destroyChart('chart-diag-actual');
  chartInstances['chart-diag-actual'] = new Chart(document.getElementById('chart-diag-actual'), {
    type: 'scatter',
    data: {
      datasets: [
        { label: '데이터', data: predicted.map((p, i) => ({ x: p, y: actual[i] })), backgroundColor: 'rgba(37,99,235,0.4)', pointRadius: 3 },
        { label: 'y=x', data: [{ x: lo, y: lo }, { x: hi, y: hi }], type: 'line', borderColor: '#ef4444', borderDash: [6,3], pointRadius: 0, borderWidth: 2 }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false,
      scales: { x: { title: { display: true, text: '예측값' } }, y: { title: { display: true, text: '실제값' } } }
    }
  });

  // Residuals vs Fitted
  destroyChart('chart-diag-resid');
  chartInstances['chart-diag-resid'] = new Chart(document.getElementById('chart-diag-resid'), {
    type: 'scatter',
    data: {
      datasets: [
        { label: '잔차', data: predicted.map((p, i) => ({ x: p, y: residuals[i] })), backgroundColor: 'rgba(124,58,237,0.4)', pointRadius: 3 },
        { label: '0선', data: [{ x: lo, y: 0 }, { x: hi, y: 0 }], type: 'line', borderColor: '#ef4444', borderDash: [6,3], pointRadius: 0, borderWidth: 2 }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false,
      scales: { x: { title: { display: true, text: '예측값' } }, y: { title: { display: true, text: '잔차' } } }
    }
  });

  // Residual Histogram
  destroyChart('chart-diag-hist');
  const rMin = Math.min(...residuals), rMax = Math.max(...residuals);
  const binCount = 20;
  const bw = (rMax - rMin) / binCount || 1;
  const bins = Array(binCount).fill(0);
  const labels = [];
  for (let i = 0; i < binCount; i++) labels.push(Math.round(rMin + i * bw));
  residuals.forEach(v => {
    let idx = Math.floor((v - rMin) / bw);
    if (idx >= binCount) idx = binCount - 1;
    if (idx < 0) idx = 0;
    bins[idx]++;
  });
  chartInstances['chart-diag-hist'] = new Chart(document.getElementById('chart-diag-hist'), {
    type: 'bar',
    data: { labels, datasets: [{ label: '잔차 빈도', data: bins, backgroundColor: 'rgba(124,58,237,0.5)', borderColor: '#7c3aed', borderWidth: 1 }] },
    options: { responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: { y: { title: { display: true, text: '빈도' } }, x: { title: { display: true, text: '잔차 (만원)' } } }
    }
  });

  // Stats
  const maxAbsErr = Math.max(...residuals.map(Math.abs));
  document.getElementById('stat-resid-mean').textContent = mean(residuals).toFixed(1);
  document.getElementById('stat-resid-std').textContent = std(residuals).toFixed(1);
  document.getElementById('stat-mae').textContent = fmtK(calcMAE(actual, predicted));
  document.getElementById('stat-max-err').textContent = fmtK(maxAbsErr);
  document.getElementById('diag-results').style.display = '';
}

// ======================== STEP 6: PREDICTOR ========================

function predictPrice() {
  const modelKey = document.getElementById('sel-pred-model').value;
  const model = fittedModels[modelKey];
  if (!model) { alert('먼저 Step 4에서 모델을 학습시키세요.'); return; }

  const district = document.getElementById('pred-district').value;
  const inputRow = {
    district,
    area_m2: parseFloat(document.getElementById('pred-area').value),
    floor: parseFloat(document.getElementById('pred-floor').value),
    built_year: parseFloat(document.getElementById('pred-year').value),
    station_dist_m: parseFloat(document.getElementById('pred-station').value),
    school_score: parseFloat(document.getElementById('pred-school').value)
  };

  const row = standardizeTestRow(inputRow, model.feats, model.prep);
  const predPrice = predict([row], model.w)[0];

  // Prediction interval
  const trainPred = predict(model.prep.X, model.w);
  const trainResid = model.prep.y.map((y, i) => y - trainPred[i]);
  const residSE = std(trainResid);
  const lower = predPrice - 1.96 * residSE;
  const upper = predPrice + 1.96 * residSE;

  document.getElementById('pred-price').textContent = fmtK(predPrice) + ' 만원';
  document.getElementById('pred-interval').textContent =
    '95% 예측 구간: ' + fmtK(Math.max(lower, 0)) + ' ~ ' + fmtK(upper) + ' 만원';
  document.getElementById('pred-result').style.display = '';

  // Similar apartments (by Euclidean distance in feature space)
  const dists = dataset.map((r, i) => {
    let d = 0;
    d += ((r.area_m2 - inputRow.area_m2) / 30) ** 2;
    d += ((r.floor - inputRow.floor) / 10) ** 2;
    d += ((r.built_year - inputRow.built_year) / 10) ** 2;
    d += ((r.station_dist_m - inputRow.station_dist_m) / 500) ** 2;
    d += ((r.school_score - inputRow.school_score) / 3) ** 2;
    d += r.district === district ? 0 : 4;
    return { idx: i, dist: d };
  });
  dists.sort((a, b) => a.dist - b.dist);
  const similar = dists.slice(0, 5).map(d => dataset[d.idx]);

  const stbody = document.getElementById('pred-similar-tbody');
  stbody.innerHTML = '';
  similar.forEach(r => {
    const diff = r.price_10k - predPrice;
    const diffStr = (diff >= 0 ? '+' : '') + fmtK(diff);
    const diffColor = diff >= 0 ? 'var(--tb-danger)' : 'var(--tb-success)';
    stbody.insertAdjacentHTML('beforeend', `<tr>
      <td>${r.district}</td><td>${r.area_m2}</td><td>${r.floor}</td>
      <td>${r.built_year}</td><td>${r.station_dist_m}</td>
      <td>${fmtK(r.price_10k)}</td>
      <td style="color:${diffColor};font-weight:600;">${diffStr}</td>
    </tr>`);
  });

  // Verdict
  const avgSim = similar.length > 0 ? mean(similar.map(r => r.price_10k)) : predPrice;
  const verdictEl = document.getElementById('pred-verdict');
  if (similar.length > 0) {
    const pct = ((predPrice - avgSim) / avgSim * 100).toFixed(1);
    if (predPrice < avgSim * 0.95) {
      verdictEl.className = 'pred-verdict verdict-low';
      verdictEl.innerHTML = '<span class="verdict-tag">시세 대비 저렴</span> ' +
        '유사 매물 평균(' + fmtK(avgSim) + '만원) 대비 ' + Math.abs(pct) + '% 낮습니다.';
    } else if (predPrice > avgSim * 1.05) {
      verdictEl.className = 'pred-verdict verdict-high';
      verdictEl.innerHTML = '<span class="verdict-tag">시세 대비 고가</span> ' +
        '유사 매물 평균(' + fmtK(avgSim) + '만원) 대비 ' + pct + '% 높습니다.';
    } else {
      verdictEl.className = 'pred-verdict verdict-ok';
      verdictEl.innerHTML = '<span class="verdict-tag">적정 가격</span> ' +
        '유사 매물 평균(' + fmtK(avgSim) + '만원)과 비슷한 수준입니다.';
    }
  } else {
    verdictEl.className = 'pred-verdict verdict-ok';
    verdictEl.textContent = '유사 매물이 부족하여 비교가 어렵습니다.';
  }

  markStepDone(6);
}

// ======================== INITIALIZATION ========================

function init() {
  const n = parseInt(document.getElementById('sel-data-size').value);
  dataset = generateData(n);
  trainSet = [];
  testSet = [];
  fittedModels = { ols, ridge, lasso };
  r2History = [];
  completedSteps = new Set();

  // Reset pipeline
  document.querySelectorAll('.pipe-step').forEach(el => {
    el.classList.remove('done', 'active');
    if (el.dataset.step === '1') el.classList.add('active');
  });
  document.querySelectorAll('.step-line').forEach(el => el.classList.remove('done'));

  renderPreview();
  renderEDAHist();
  renderScatter();
  renderHeatmap();

  // Reset downstream
  document.getElementById('reg-results').style.display = 'none';
  document.getElementById('btn-feat-done').style.display = 'none';
  document.getElementById('split-visual').style.display = 'none';
  document.getElementById('compare-results').style.display = 'none';
  document.getElementById('diag-results').style.display = 'none';
  document.getElementById('pred-result').style.display = 'none';
}

(function() {
  init();

  // Data regen
  document.getElementById('btn-regen-data').addEventListener('click', init);
  document.getElementById('sel-data-size').addEventListener('change', init);

  // Step 1: EDA
  document.getElementById('sel-eda-var').addEventListener('change', renderEDAHist);
  document.getElementById('sel-scatter-x').addEventListener('change', renderScatter);
  document.getElementById('btn-eda-done').addEventListener('click', () => markStepDone(1));

  // Step 2: Feature Selection
  document.getElementById('btn-run-reg').addEventListener('click', runFeatureSelection);
  document.getElementById('btn-feat-done').addEventListener('click', () => markStepDone(2));

  // Step 3: Split
  document.getElementById('slider-train').addEventListener('input', (e) => {
    document.getElementById('lbl-train-ratio').textContent = e.target.value + '%';
  });
  document.getElementById('btn-split').addEventListener('click', splitData);
  document.getElementById('btn-split-done').addEventListener('click', () => markStepDone(3));

  // Step 4: Model comparison
  document.getElementById('slider-lambda').addEventListener('input', (e) => {
    document.getElementById('lbl-lambda').textContent = e.target.value;
  });
  document.getElementById('btn-compare').addEventListener('click', runComparison);
  document.getElementById('btn-compare-done').addEventListener('click', () => markStepDone(4));

  // Step 5: Diagnostics
  document.getElementById('btn-diagnose').addEventListener('click', runDiagnostics);
  document.getElementById('btn-diag-done').addEventListener('click', () => markStepDone(5));

  // Step 6: Predictor
  document.getElementById('btn-predict').addEventListener('click', predictPrice);

  // Mark visited
});
</script>

