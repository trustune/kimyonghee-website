<script>
// ========================================================================
//  Chapter 20: Capstone III - Real Estate Price Predictor
//  All regression math in vanilla JS. Chart.js loaded from CDN.
// ========================================================================

// ======================== UTILITIES ========================

function seededRandom(seed) {
  let s = seed;
  return function() {
    s = (s * 16807 + 0) % 2147483647;
    return (s - 1) / 2147483646;
  };
}

function shuffle(arr, rng) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(rng() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function mean(arr) { return arr.reduce((s,v) => s+v, 0) / arr.length; }
function std(arr) {
  const m = mean(arr);
  return Math.sqrt(arr.reduce((s,v) => s + (v-m)*(v-m), 0) / (arr.length - 1));
}
function median(arr) {
  const s = [...arr].sort((a,b) => a-b);
  const mid = Math.floor(s.length / 2);
  return s.length % 2 ? s[mid] : (s[mid-1] + s[mid]) / 2;
}
function corrCoef(x, y) {
  const mx = mean(x), my = mean(y);
  let num = 0, dx = 0, dy = 0;
  for (let i = 0; i < x.length; i++) {
    num += (x[i]-mx)*(y[i]-my);
    dx += (x[i]-mx)*(x[i]-mx);
    dy += (y[i]-my)*(y[i]-my);
  }
  return dx === 0 || dy === 0 ? 0 : num / Math.sqrt(dx*dy);
}

// ======================== MATRIX OPS ========================

function matCreate(rows, cols, fill=0) {
  return Array.from({length:rows}, () => Array(cols).fill(fill));
}
function matTranspose(A) {
  const r = A.length, c = A[0].length;
  const T = matCreate(c, r);
  for (let i = 0; i < r; i++) for (let j = 0; j < c; j++) T[j][i] = A[i][j];
  return T;
}
function matMul(A, B) {
  const r = A.length, c = B[0].length, k = B.length;
  const C = matCreate(r, c);
  for (let i = 0; i < r; i++)
    for (let j = 0; j < c; j++)
      for (let p = 0; p < k; p++) C[i][j] += A[i][p] * B[p][j];
  return C;
}
function matInverse(M) {
  const n = M.length;
  const aug = M.map((row, i) => {
    const r = [...row];
    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
    return r;
  });
  for (let col = 0; col < n; col++) {
    let maxRow = col;
    for (let row = col+1; row < n; row++)
      if (Math.abs(aug[row][col]) > Math.abs(aug[maxRow][col])) maxRow = row;
    [aug[col], aug[maxRow]] = [aug[maxRow], aug[col]];
    const pivot = aug[col][col];
    if (Math.abs(pivot) < 1e-12) {
      for (let j = 0; j < 2*n; j++) aug[col][j] = 0;
      continue;
    }
    for (let j = 0; j < 2*n; j++) aug[col][j] /= pivot;
    for (let row = 0; row < n; row++) {
      if (row === col) continue;
      const f = aug[row][col];
      for (let j = 0; j < 2*n; j++) aug[row][j] -= f * aug[col][j];
    }
  }
  return aug.map(row => row.slice(n));
}

// ======================== DATASET GENERATION ========================

const DISTRICTS = ['강남', '서초', '마포', '용산', '성동'];
const DIST_BASE = { '강남': 18000, '서초': 15000, '마포': 10000, '용산': 12000, '성동': 9000 };
const VAR_NAMES = ['area_m2','floor','built_year','station_dist_m','school_score','parking','price_10k'];
const VAR_LABELS = {'area_m2':'면적(m2)','floor':'층수','built_year':'건축년도','station_dist_m':'역거리(m)',
  'school_score':'학군지수','parking':'주차비율','price_10k':'실거래가(만원)'};

let dataset = [];
let trainSet = [], testSet = [];
let fittedModels = { ols: null, ridge: null, lasso: null };
let chartInstances = {};

function generateApartmentData(n) {
  const rng = seededRandom(Date.now() % 100000);
  const data = [];
  for (let i = 0; i < n; i++) {
    const district = DISTRICTS[Math.floor(rng() * DISTRICTS.length)];
    const area = Math.round(15 + rng() * 135);
    const floor = Math.round(1 + rng() * 29);
    const builtYear = Math.round(1985 + rng() * 39);
    const stationDist = Math.round(50 + rng() * 2950);
    const schoolScore = Math.round(1 + rng() * 9);
    const parking = Math.round((0.5 + rng() * 1.5) * 10) / 10;

    const age = 2025 - builtYear;
    const base = DIST_BASE[district];
    const price = base
      + 120 * area
      + 50 * floor
      - 40 * age
      + 800000 / Math.max(stationDist, 50)
      + 200 * schoolScore
      + 500 * parking
      + (rng() - 0.5) * 3000;

    data.push({
      id: i + 1,
      district,
      area_m2: area,
      floor,
      built_year: builtYear,
      station_dist_m: stationDist,
      school_score: schoolScore,
      parking,
      price_10k: Math.round(Math.max(price, 2000))
    });
  }
  return data;
}

// ======================== REGRESSION CLASSES ========================

function prepareFeatureMatrix(data, featureNames) {
  const n = data.length;
  const cols = [];
  const colNames = [];

  for (const f of featureNames) {
    if (f === 'district_code') {
      // one-hot: use all but first district as reference
      for (let d = 1; d < DISTRICTS.length; d++) {
        cols.push(data.map(r => r.district === DISTRICTS[d] ? 1 : 0));
        colNames.push('구_' + DISTRICTS[d]);
      }
    } else {
      cols.push(data.map(r => r[f]));
      colNames.push(VAR_LABELS[f] || f);
    }
  }

  // Standardize
  const means = cols.map(c => mean(c));
  const stds = cols.map(c => { const s = std(c); return s === 0 ? 1 : s; });
  const X = data.map((_, i) => {
    const row = [1]; // intercept
    for (let j = 0; j < cols.length; j++) row.push((cols[j][i] - means[j]) / stds[j]);
    return row;
  });
  const y = data.map(r => r.price_10k);

  return { X, y, means, stds, colNames: ['절편', ...colNames] };
}

function olsFit(X, y) {
  const Xt = matTranspose(X);
  const XtX = matMul(Xt, X);
  const XtXinv = matInverse(XtX);
  const Xty = matMul(Xt, y.map(v => [v]));
  const beta = matMul(XtXinv, Xty).map(r => r[0]);
  return beta;
}

function ridgeFit(X, y, alpha) {
  const p = X[0].length;
  const Xt = matTranspose(X);
  const XtX = matMul(Xt, X);
  // Add alpha * I (skip intercept penalty)
  for (let i = 1; i < p; i++) XtX[i][i] += alpha;
  const XtXinv = matInverse(XtX);
  const Xty = matMul(Xt, y.map(v => [v]));
  const beta = matMul(XtXinv, Xty).map(r => r[0]);
  return beta;
}

function lassoFit(X, y, alpha, maxIter = 500) {
  const n = X.length, p = X[0].length;
  const beta = new Array(p).fill(0);

  // Precompute column norms
  const colNorms = [];
  for (let j = 0; j < p; j++) {
    let s = 0;
    for (let i = 0; i < n; i++) s += X[i][j] * X[i][j];
    colNorms.push(s);
  }

  for (let iter = 0; iter < maxIter; iter++) {
    let maxChange = 0;
    for (let j = 0; j < p; j++) {
      // Compute residual without j-th feature
      let rho = 0;
      for (let i = 0; i < n; i++) {
        let pred = 0;
        for (let k = 0; k < p; k++) {
          if (k !== j) pred += X[i][k] * beta[k];
        }
        rho += X[i][j] * (y[i] - pred);
      }

      let newBeta;
      if (j === 0) {
        // Don't penalize intercept
        newBeta = rho / colNorms[j];
      } else {
        // Soft threshold
        if (rho > alpha) newBeta = (rho - alpha) / colNorms[j];
        else if (rho < -alpha) newBeta = (rho + alpha) / colNorms[j];
        else newBeta = 0;
      }

      maxChange = Math.max(maxChange, Math.abs(newBeta - beta[j]));
      beta[j] = newBeta;
    }
    if (maxChange < 1e-6) break;
  }
  return beta;
}

function predict(X, beta) {
  return X.map(row => {
    let s = 0;
    for (let j = 0; j < beta.length; j++) s += row[j] * beta[j];
    return s;
  });
}

function calcRMSE(actual, predicted) {
  let s = 0;
  for (let i = 0; i < actual.length; i++) s += (actual[i]-predicted[i])**2;
  return Math.sqrt(s / actual.length);
}

function calcMAE(actual, predicted) {
  let s = 0;
  for (let i = 0; i < actual.length; i++) s += Math.abs(actual[i]-predicted[i]);
  return s / actual.length;
}

function calcR2(actual, predicted) {
  const m = mean(actual);
  let ssTot = 0, ssRes = 0;
  for (let i = 0; i < actual.length; i++) {
    ssTot += (actual[i]-m)**2;
    ssRes += (actual[i]-predicted[i])**2;
  }
  return ssTot === 0 ? 0 : 1 - ssRes/ssTot;
}

function calcAdjR2(r2, n, p) {
  if (n - p - 1 <= 0) return r2;
  return 1 - (1 - r2) * (n - 1) / (n - p - 1);
}

function calcVIF(X, colIdx) {
  // Regress X[colIdx] on all other columns (excluding intercept col 0)
  const n = X.length;
  const p = X[0].length;
  if (p <= 2) return 1;

  const yCol = X.map(r => r[colIdx]);
  const Xother = X.map(r => {
    const row = [1];
    for (let j = 1; j < p; j++) if (j !== colIdx) row.push(r[j]);
    return row;
  });

  const beta = olsFit(Xother, yCol);
  const pred = predict(Xother, beta);
  const r2 = calcR2(yCol, pred);
  return r2 >= 1 ? 100 : 1 / (1 - r2);
}

// ======================== CHART.JS LOADING ========================

let chartJSLoaded = false;
function loadChartJS() {
  return new Promise((resolve) => {
    if (chartJSLoaded) { resolve(); return; }
    if (window.Chart) { chartJSLoaded = true; resolve(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js';
    s.onload = () => { chartJSLoaded = true; resolve(); };
    document.head.appendChild(s);
  });
}

function destroyChart(id) {
  if (chartInstances[id]) { chartInstances[id].destroy(); delete chartInstances[id]; }
}

// ======================== DATA PREVIEW ========================

function renderPreview() {
  const tbody = document.getElementById('data-preview-tbody');
  if (!tbody) return;
  tbody.innerHTML = '';
  const show = dataset.length <= 12 ? dataset : [...dataset.slice(0,6), null, ...dataset.slice(-5)];
  show.forEach(row => {
    if (!row) {
      tbody.insertAdjacentHTML('beforeend',
        '<tr><td colspan="9" style="color:var(--tb-g600);font-style:italic">... (중략) ...</td></tr>');
      return;
    }
    tbody.insertAdjacentHTML('beforeend', `<tr>
      <td>${row.id}</td><td>${row.district}</td><td>${row.area_m2}</td><td>${row.floor}</td>
      <td>${row.built_year}</td><td>${row.station_dist_m}</td><td>${row.school_score}</td>
      <td>${row.parking}</td><td>${row.price_10k.toLocaleString()}</td>
    </tr>`);
  });
  const el = document.getElementById('stat-n');
  if (el) el.textContent = dataset.length;
}

// ======================== EDA ========================

async function renderEDAHist() {
  await loadChartJS();
  const varName = document.getElementById('sel-eda-var').value;
  const values = dataset.map(r => r[varName]);
  const mn = Math.min(...values), mx = Math.max(...values);
  const binCount = 20;
  const binWidth = (mx - mn) / binCount || 1;
  const bins = Array(binCount).fill(0);
  const labels = [];
  for (let i = 0; i < binCount; i++) {
    const lo = mn + i * binWidth;
    labels.push(Math.round(lo));
  }
  values.forEach(v => {
    let idx = Math.floor((v - mn) / binWidth);
    if (idx >= binCount) idx = binCount - 1;
    if (idx < 0) idx = 0;
    bins[idx]++;
  });

  destroyChart('chart-eda-hist');
  const ctx = document.getElementById('chart-eda-hist');
  chartInstances['chart-eda-hist'] = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [{ label: VAR_LABELS[varName] || varName, data: bins, backgroundColor: 'rgba(37,99,235,0.6)', borderColor: '#2563eb', borderWidth: 1 }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } },
      scales: { y: { title: { display: true, text: '빈도' } }, x: { title: { display: true, text: VAR_LABELS[varName] || varName } } }
    }
  });

  // Summary stats
  const tbody = document.getElementById('eda-summary-tbody');
  if (tbody) {
    tbody.innerHTML = `<tr>
      <td>${VAR_LABELS[varName]||varName}</td>
      <td>${values.length}</td>
      <td>${mean(values).toFixed(1)}</td>
      <td>${median(values).toFixed(1)}</td>
      <td>${std(values).toFixed(1)}</td>
      <td>${Math.min(...values).toFixed(1)}</td>
      <td>${Math.max(...values).toFixed(1)}</td>
    </tr>`;
  }
}

async function renderEDAScatter() {
  await loadChartJS();
  const xVar = document.getElementById('sel-scatter-x').value;
  const points = dataset.map(r => ({ x: r[xVar], y: r.price_10k }));
  const r = corrCoef(dataset.map(d => d[xVar]), dataset.map(d => d.price_10k));

  destroyChart('chart-eda-scatter');
  const ctx = document.getElementById('chart-eda-scatter');
  chartInstances['chart-eda-scatter'] = new Chart(ctx, {
    type: 'scatter',
    data: {
      datasets: [{ label: `r = ${r.toFixed(3)}`, data: points, backgroundColor: 'rgba(37,99,235,0.4)', pointRadius: 3 }]
    },
    options: { responsive: true, maintainAspectRatio: false,
      scales: {
        x: { title: { display: true, text: VAR_LABELS[xVar] || xVar } },
        y: { title: { display: true, text: '실거래가(만원)' } }
      }
    }
  });
}

function renderHeatmap() {
  const canvas = document.getElementById('canvas-heatmap');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const vars = VAR_NAMES;
  const labels = vars.map(v => VAR_LABELS[v] || v);
  const n = vars.length;

  const corrMatrix = [];
  for (let i = 0; i < n; i++) {
    corrMatrix.push([]);
    for (let j = 0; j < n; j++) {
      corrMatrix[i].push(corrCoef(dataset.map(r => r[vars[i]]), dataset.map(r => r[vars[j]])));
    }
  }

  const size = canvas.width;
  const pad = 90;
  const cellSize = (size - pad) / n;
  ctx.clearRect(0, 0, size, size);

  for (let i = 0; i < n; i++) {
    for (let j = 0; j < n; j++) {
      const val = corrMatrix[i][j];
      // Color: red for positive, blue for negative
      let r, g, b;
      if (val >= 0) {
        r = 239; g = Math.round(239 - val * 171); b = Math.round(239 - val * 171);
      } else {
        const av = Math.abs(val);
        r = Math.round(239 - av * 202); g = Math.round(239 - av * 140); b = 239;
      }
      ctx.fillStyle = `rgb(${r},${g},${b})`;
      ctx.fillRect(pad + j * cellSize, pad + i * cellSize, cellSize - 1, cellSize - 1);

      // Text
      ctx.fillStyle = Math.abs(val) > 0.5 ? '#fff' : '#1e293b';
      ctx.font = '11px sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(val.toFixed(2), pad + j * cellSize + cellSize/2, pad + i * cellSize + cellSize/2);
    }
  }

  // Labels
  ctx.fillStyle = '#1e293b';
  ctx.font = '12px sans-serif';
  for (let i = 0; i < n; i++) {
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    ctx.fillText(labels[i], pad - 6, pad + i * cellSize + cellSize/2);

    ctx.save();
    ctx.translate(pad + i * cellSize + cellSize/2, pad - 6);
    ctx.rotate(-Math.PI / 4);
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText(labels[i], 0, 0);
    ctx.restore();
  }
}

// ======================== FEATURE SELECTION ========================

function getSelectedFeatures() {
  const checks = document.querySelectorAll('.feat-check:checked');
  return Array.from(checks).map(c => c.value);
}

function runFeatureSelection() {
  const feats = getSelectedFeatures();
  if (feats.length === 0) { alert('하나 이상의 변수를 선택하세요.'); return; }

  const { X, y, colNames } = prepareFeatureMatrix(dataset, feats);
  const beta = olsFit(X, y);
  const pred = predict(X, beta);
  const r2 = calcR2(y, pred);
  const p = colNames.length - 1;
  const adjR2 = calcAdjR2(r2, y.length, p);
  const rmseVal = calcRMSE(y, pred);

  document.getElementById('stat-r2').textContent = r2.toFixed(4);
  document.getElementById('stat-adj-r2').textContent = adjR2.toFixed(4);
  document.getElementById('stat-rmse').textContent = Math.round(rmseVal).toLocaleString();
  document.getElementById('stat-p').textContent = p;
  document.getElementById('reg-stats').style.display = '';

  // Coefficients + VIF
  const tbody = document.getElementById('reg-coef-tbody');
  tbody.innerHTML = '';
  let hasHighVIF = false;
  for (let j = 0; j < colNames.length; j++) {
    let vif = '-';
    let status = '';
    if (j > 0 && colNames.length > 2) {
      const v = calcVIF(X, j);
      vif = v.toFixed(2);
      if (v > 5) { status = 'WARN'; hasHighVIF = true; }
      else status = 'OK';
    }
    tbody.insertAdjacentHTML('beforeend', `<tr>
      <td>${colNames[j]}</td>
      <td>${beta[j].toFixed(2)}</td>
      <td>${vif}</td>
      <td style="color:${status==='WARN'?'var(--tb-danger)':'var(--tb-success)'}; font-weight:700;">${status}</td>
    </tr>`);
  }
  document.getElementById('reg-coef-wrap').style.display = '';
  document.getElementById('vif-warning').style.display = hasHighVIF ? '' : 'none';
}

// ======================== TRAIN/TEST SPLIT ========================

function splitData() {
  const ratio = parseInt(document.getElementById('slider-train').value) / 100;
  const rng = seededRandom(42);
  const shuffled = shuffle(dataset, rng);
  const splitIdx = Math.round(shuffled.length * ratio);
  trainSet = shuffled.slice(0, splitIdx);
  testSet = shuffled.slice(splitIdx);

  document.getElementById('split-visual').style.display = '';
  const trainBar = document.getElementById('split-bar-train');
  const testBar = document.getElementById('split-bar-test');
  trainBar.style.width = (ratio * 100) + '%';
  trainBar.textContent = `학습 ${(ratio*100).toFixed(0)}%`;
  testBar.style.width = ((1-ratio)*100) + '%';
  testBar.textContent = `검증 ${((1-ratio)*100).toFixed(0)}%`;

  document.getElementById('stat-train-n').textContent = trainSet.length;
  document.getElementById('stat-test-n').textContent = testSet.length;
}

// ======================== MODEL COMPARISON ========================

async function runComparison() {
  if (trainSet.length === 0) {
    alert('먼저 Step 3에서 데이터를 분할하세요.');
    return;
  }
  await loadChartJS();

  const feats = getSelectedFeatures();
  if (feats.length === 0) { alert('Step 2에서 변수를 선택하세요.'); return; }

  const lambda = parseFloat(document.getElementById('slider-lambda').value);

  const trainPrep = prepareFeatureMatrix(trainSet, feats);
  // Use train stats to standardize test data
  const testX = testSet.map(row => {
    const r = [1];
    let ci = 0;
    for (const f of feats) {
      if (f === 'district_code') {
        for (let d = 1; d < DISTRICTS.length; d++) {
          r.push(((row.district === DISTRICTS[d] ? 1 : 0) - trainPrep.means[ci]) / trainPrep.stds[ci]);
          ci++;
        }
      } else {
        r.push((row[f] - trainPrep.means[ci]) / trainPrep.stds[ci]);
        ci++;
      }
    }
    return r;
  });
  const testY = testSet.map(r => r.price_10k);

  // Fit models
  const betaOLS = olsFit(trainPrep.X, trainPrep.y);
  const betaRidge = ridgeFit(trainPrep.X, trainPrep.y, lambda);
  const betaLasso = lassoFit(trainPrep.X, trainPrep.y, lambda);

  fittedModels.ols = { beta: betaOLS, prep: trainPrep, feats };
  fittedModels.ridge = { beta: betaRidge, prep: trainPrep, feats };
  fittedModels.lasso = { beta: betaLasso, prep: trainPrep, feats };

  const results = [
    { name: 'OLS', beta: betaOLS },
    { name: 'Ridge', beta: betaRidge },
    { name: 'Lasso', beta: betaLasso }
  ].map(m => {
    const trainPred = predict(trainPrep.X, m.beta);
    const testPred = predict(testX, m.beta);
    return {
      ...m,
      trainRMSE: calcRMSE(trainPrep.y, trainPred),
      testRMSE: calcRMSE(testY, testPred),
      trainR2: calcR2(trainPrep.y, trainPred),
      testR2: calcR2(testY, testPred)
    };
  });

  // Best model = lowest test RMSE
  const bestIdx = results.reduce((bi, r, i) => r.testRMSE < results[bi].testRMSE ? i : bi, 0);

  // Performance table
  const tbody = document.getElementById('compare-perf-tbody');
  tbody.innerHTML = '';
  results.forEach((r, i) => {
    tbody.insertAdjacentHTML('beforeend', `<tr style="${i===bestIdx?'background:var(--tb-accent-light);font-weight:700':''}">
      <td>${r.name}</td>
      <td>${Math.round(r.trainRMSE).toLocaleString()}</td>
      <td>${Math.round(r.testRMSE).toLocaleString()}</td>
      <td>${r.trainR2.toFixed(4)}</td>
      <td>${r.testR2.toFixed(4)}</td>
      <td>${i===bestIdx?'BEST':''}</td>
    </tr>`);
  });

  // RMSE bar chart
  destroyChart('chart-compare-rmse');
  const ctx = document.getElementById('chart-compare-rmse');
  chartInstances['chart-compare-rmse'] = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: results.map(r => r.name),
      datasets: [
        { label: 'Train RMSE', data: results.map(r => Math.round(r.trainRMSE)), backgroundColor: 'rgba(37,99,235,0.6)' },
        { label: 'Test RMSE', data: results.map(r => Math.round(r.testRMSE)), backgroundColor: 'rgba(239,68,68,0.6)' }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } },
      scales: { y: { title: { display: true, text: 'RMSE (만원)' }, beginAtZero: true } }
    }
  });

  // Coefficient comparison
  const ctbody = document.getElementById('compare-coef-tbody');
  ctbody.innerHTML = '';
  for (let j = 0; j < trainPrep.colNames.length; j++) {
    const lassoStyle = Math.abs(betaLasso[j]) < 0.01 && j > 0 ? 'color:var(--tb-danger); font-weight:700;' : '';
    ctbody.insertAdjacentHTML('beforeend', `<tr>
      <td>${trainPrep.colNames[j]}</td>
      <td>${betaOLS[j].toFixed(2)}</td>
      <td>${betaRidge[j].toFixed(2)}</td>
      <td style="${lassoStyle}">${betaLasso[j].toFixed(2)}</td>
    </tr>`);
  }

  document.getElementById('compare-results').style.display = '';
}

// ======================== RESIDUAL DIAGNOSTICS ========================

async function runDiagnostics() {
  await loadChartJS();
  const modelKey = document.getElementById('sel-diag-model').value;
  const model = fittedModels[modelKey];
  if (!model) { alert('먼저 Step 4에서 모델을 학습시키세요.'); return; }

  const feats = model.feats;
  const prep = model.prep;

  // Use test set for diagnostics
  const testX = testSet.map(row => {
    const r = [1];
    let ci = 0;
    for (const f of feats) {
      if (f === 'district_code') {
        for (let d = 1; d < DISTRICTS.length; d++) {
          r.push(((row.district === DISTRICTS[d] ? 1 : 0) - prep.means[ci]) / prep.stds[ci]);
          ci++;
        }
      } else {
        r.push((row[f] - prep.means[ci]) / prep.stds[ci]);
        ci++;
      }
    }
    return r;
  });
  const actual = testSet.map(r => r.price_10k);
  const predicted = predict(testX, model.beta);
  const residuals = actual.map((a, i) => a - predicted[i]);

  // 1. Actual vs Predicted
  destroyChart('chart-diag-actual');
  const allVals = [...actual, ...predicted];
  const lo = Math.min(...allVals), hi = Math.max(...allVals);
  chartInstances['chart-diag-actual'] = new Chart(document.getElementById('chart-diag-actual'), {
    type: 'scatter',
    data: {
      datasets: [
        { label: '데이터', data: predicted.map((p, i) => ({x: p, y: actual[i]})), backgroundColor: 'rgba(37,99,235,0.4)', pointRadius: 3 },
        { label: 'y=x', data: [{x:lo,y:lo},{x:hi,y:hi}], type: 'line', borderColor: '#ef4444', borderDash: [6,3], pointRadius: 0, borderWidth: 2 }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false,
      scales: { x: { title: { display: true, text: '예측값' } }, y: { title: { display: true, text: '실제값' } } }
    }
  });

  // 2. Residuals vs Fitted
  destroyChart('chart-diag-resid');
  chartInstances['chart-diag-resid'] = new Chart(document.getElementById('chart-diag-resid'), {
    type: 'scatter',
    data: {
      datasets: [
        { label: '잔차', data: predicted.map((p, i) => ({x: p, y: residuals[i]})), backgroundColor: 'rgba(124,58,237,0.4)', pointRadius: 3 },
        { label: '0선', data: [{x: lo, y: 0}, {x: hi, y: 0}], type: 'line', borderColor: '#ef4444', borderDash: [6,3], pointRadius: 0, borderWidth: 2 }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false,
      scales: { x: { title: { display: true, text: '예측값' } }, y: { title: { display: true, text: '잔차' } } }
    }
  });

  // 3. Residual Histogram
  destroyChart('chart-diag-hist');
  const rMin = Math.min(...residuals), rMax = Math.max(...residuals);
  const binCount = 20;
  const bw = (rMax - rMin) / binCount || 1;
  const bins = Array(binCount).fill(0);
  const labels = [];
  for (let i = 0; i < binCount; i++) labels.push(Math.round(rMin + i * bw));
  residuals.forEach(v => {
    let idx = Math.floor((v - rMin) / bw);
    if (idx >= binCount) idx = binCount - 1;
    if (idx < 0) idx = 0;
    bins[idx]++;
  });
  chartInstances['chart-diag-hist'] = new Chart(document.getElementById('chart-diag-hist'), {
    type: 'bar',
    data: { labels, datasets: [{ label: '잔차 빈도', data: bins, backgroundColor: 'rgba(124,58,237,0.5)', borderColor: '#7c3aed', borderWidth: 1 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } },
      scales: { y: { title: { display: true, text: '빈도' } }, x: { title: { display: true, text: '잔차 (만원)' } } }
    }
  });

  // Stats
  document.getElementById('stat-resid-mean').textContent = mean(residuals).toFixed(1);
  document.getElementById('stat-resid-std').textContent = std(residuals).toFixed(1);
  document.getElementById('stat-mae').textContent = Math.round(calcMAE(actual, predicted)).toLocaleString();
  document.getElementById('diag-results').style.display = '';
}

// ======================== PRICE PREDICTOR ========================

function predictPrice() {
  const modelKey = document.getElementById('sel-pred-model').value;
  const model = fittedModels[modelKey];
  if (!model) { alert('먼저 Step 4에서 모델을 학습시키세요.'); return; }

  const district = document.getElementById('pred-district').value;
  const area = parseFloat(document.getElementById('pred-area').value);
  const floor = parseFloat(document.getElementById('pred-floor').value);
  const year = parseFloat(document.getElementById('pred-year').value);
  const station = parseFloat(document.getElementById('pred-station').value);
  const school = parseFloat(document.getElementById('pred-school').value);
  const parking = parseFloat(document.getElementById('pred-parking').value);

  const inputRow = { district, area_m2: area, floor, built_year: year,
    station_dist_m: station, school_score: school, parking };

  const feats = model.feats;
  const prep = model.prep;
  const row = [1];
  let ci = 0;
  for (const f of feats) {
    if (f === 'district_code') {
      for (let d = 1; d < DISTRICTS.length; d++) {
        row.push(((district === DISTRICTS[d] ? 1 : 0) - prep.means[ci]) / prep.stds[ci]);
        ci++;
      }
    } else {
      row.push((inputRow[f] - prep.means[ci]) / prep.stds[ci]);
      ci++;
    }
  }

  const predPrice = predict([row], model.beta)[0];

  // Prediction interval using residual SE from training data
  const trainPred = predict(prep.X, model.beta);
  const trainResid = prep.y.map((y, i) => y - trainPred[i]);
  const residSE = std(trainResid);
  const lower = predPrice - 1.96 * residSE;
  const upper = predPrice + 1.96 * residSE;

  document.getElementById('pred-price').textContent =
    Math.round(predPrice).toLocaleString() + ' 만원';
  document.getElementById('pred-interval').textContent =
    `95% 예측 구간: ${Math.round(lower).toLocaleString()} ~ ${Math.round(upper).toLocaleString()} 만원`;
  document.getElementById('pred-result').style.display = '';

  // Similar apartments
  const similar = dataset.filter(r =>
    r.district === district &&
    Math.abs(r.area_m2 - area) < 20 &&
    Math.abs(r.floor - floor) < 5
  ).slice(0, 5);

  const stbody = document.getElementById('pred-similar-tbody');
  stbody.innerHTML = '';
  if (similar.length === 0) {
    stbody.insertAdjacentHTML('beforeend', '<tr><td colspan="5" style="color:var(--tb-g600);">유사 매물 없음</td></tr>');
  } else {
    similar.forEach(r => {
      stbody.insertAdjacentHTML('beforeend', `<tr>
        <td>${r.district}</td><td>${r.area_m2}</td><td>${r.floor}</td>
        <td>${r.built_year}</td><td>${r.price_10k.toLocaleString()}</td>
      </tr>`);
    });
  }

  // Verdict
  const avgSimilar = similar.length > 0 ? mean(similar.map(r => r.price_10k)) : predPrice;
  const verdictEl = document.getElementById('pred-verdict');
  if (similar.length > 0) {
    const diff = ((predPrice - avgSimilar) / avgSimilar * 100).toFixed(1);
    if (predPrice < avgSimilar * 0.95) {
      verdictEl.style.background = 'linear-gradient(135deg, #dcfce7, #bbf7d0)';
      verdictEl.style.color = '#166534';
      verdictEl.textContent = `유사 매물 평균(${Math.round(avgSimilar).toLocaleString()}만원) 대비 ${Math.abs(diff)}% 저렴합니다. 합리적 가격대로 판단됩니다.`;
    } else if (predPrice > avgSimilar * 1.05) {
      verdictEl.style.background = 'linear-gradient(135deg, #fef2f2, #fecaca)';
      verdictEl.style.color = '#991b1b';
      verdictEl.textContent = `유사 매물 평균(${Math.round(avgSimilar).toLocaleString()}만원) 대비 ${diff}% 높습니다. 프리미엄 요인을 확인하세요.`;
    } else {
      verdictEl.style.background = 'linear-gradient(135deg, #dbeafe, #bfdbfe)';
      verdictEl.style.color = '#1e40af';
      verdictEl.textContent = `유사 매물 평균(${Math.round(avgSimilar).toLocaleString()}만원)과 비슷한 수준입니다.`;
    }
  } else {
    verdictEl.style.background = 'var(--tb-g100)';
    verdictEl.style.color = 'var(--tb-g600)';
    verdictEl.textContent = '동일 조건의 유사 매물이 없어 비교가 어렵습니다.';
  }
}

// ======================== INITIALIZATION ========================

function init() {
  const n = parseInt(document.getElementById('sel-data-size').value);
  dataset = generateApartmentData(n);
  trainSet = [];
  testSet = [];
  fittedModels = { ols: null, ridge: null, lasso: null };
  renderPreview();
  renderEDAHist();
  renderEDAScatter();
  renderHeatmap();

  // Reset downstream displays
  document.getElementById('reg-stats').style.display = 'none';
  document.getElementById('reg-coef-wrap').style.display = 'none';
  document.getElementById('vif-warning').style.display = 'none';
  document.getElementById('split-visual').style.display = 'none';
  document.getElementById('compare-results').style.display = 'none';
  document.getElementById('diag-results').style.display = 'none';
  document.getElementById('pred-result').style.display = 'none';
}

document.addEventListener('DOMContentLoaded', () => {
  init();

  // Data regen
  document.getElementById('btn-regen-data').addEventListener('click', init);
  document.getElementById('sel-data-size').addEventListener('change', init);

  // EDA
  document.getElementById('sel-eda-var').addEventListener('change', renderEDAHist);
  document.getElementById('sel-scatter-x').addEventListener('change', renderEDAScatter);

  // Feature selection
  document.getElementById('btn-run-reg').addEventListener('click', runFeatureSelection);

  // Train/test split
  document.getElementById('slider-train').addEventListener('input', (e) => {
    document.getElementById('lbl-train-ratio').textContent = e.target.value + '%';
  });
  document.getElementById('btn-split').addEventListener('click', splitData);

  // Model comparison
  document.getElementById('slider-lambda').addEventListener('input', (e) => {
    document.getElementById('lbl-lambda').textContent = e.target.value;
  });
  document.getElementById('btn-compare').addEventListener('click', runComparison);

  // Diagnostics
  document.getElementById('btn-diagnose').addEventListener('click', runDiagnostics);

  // Predictor
  document.getElementById('btn-predict').addEventListener('click', predictPrice);
});
