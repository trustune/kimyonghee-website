<script is:inline>

function waitForChart(fn) {
  if (typeof Chart !== 'undefined') { fn(); return; }
  var s = document.querySelector('script[src*="chart.js"]');
  if (s) { s.addEventListener('load', fn); return; }
  setTimeoutwaitForChart(function() { waitForChart(fn); }, 50);
}

// ========================================================================
//  Chapter 20: Capstone III -- Real Estate Price Predictor
//  All regression via GRADIENT DESCENT. Chart.js loaded from CDN.
// ========================================================================

// ======================== UTILITIES ========================

function seededRandom(seed) {
  let s = seed | 0;
  return function() {
    s = (s * 16807 + 0) % 2147483647;
    return (s - 1) / 2147483646;
  };
}
function shuffle(arr, rng) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(rng() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
function mean(arr) { return arr.reduce((s,v) => s+v, 0) / arr.length; }
function std(arr) {
  if (arr.length < 2) return 0;
  const m = mean(arr);
  return Math.sqrt(arr.reduce((s,v) => s + (v-m)*(v-m), 0) / (arr.length - 1));
}
function median(arr) {
  const s = [...arr].sort((a,b) => a-b);
  const mid = Math.floor(s.length / 2);
  return s.length % 2 ? s[mid] : (s[mid-1] + s[mid]) / 2;
}
function corrCoef(x, y) {
  const mx = mean(x), my = mean(y);
  let num = 0, dx = 0, dy = 0;
  for (let i = 0; i < x.length; i++) {
    num += (x[i]-mx)*(y[i]-my);
    dx += (x[i]-mx)*(x[i]-mx);
    dy += (y[i]-my)*(y[i]-my);
  }
  return dx === 0 || dy === 0 ? 0 : num / Math.sqrt(dx*dy);
}
function fmt(v, d) { return typeof v === 'number' ? v.toFixed(d) : '-'; }
function fmtK(v) { return Math.round(v).toLocaleString(); }

// ======================== DATASET ========================

const DISTRICTS = ['강남', '서초', '마포', '용산', '성동'];
const DIST_BASE = { '강남': 18000, '서초': 15000, '마포': 10000, '용산': 12000, '성동': 9000 };
const DIST_COLORS = { '강남': '#ef4444', '서초': '#f59e0b', '마포': '#22c55e', '용산': '#3b82f6', '성동': '#8b5cf6' };
const NUM_VARS = ['area_m2','floor','built_year','station_dist_m','school_score','price_10k'];
const VAR_LABELS = {
  'area_m2':'면적(m2)','floor':'층수','built_year':'건축년도',
  'station_dist_m':'역거리(m)','school_score':'학군지수',
  'price_10k':'실거래가(만원)','district':'구'
};

let dataset = [];
let trainSet = [], testSet = [];
let fittedModels = { ols, ridge, lasso };
let lossHistory = { ols: [], ridge: [], lasso: [] };
let chartInstances = {};
let r2History = [];
let completedSteps = new Set();

function generateData(n) {
  const rng = seededRandom(Date.now() % 100000);
  const data = [];
  for (let i = 0; i < n; i++) {
    const district = DISTRICTS[Math.floor(rng() * DISTRICTS.length)];
    const area = Math.round(20 + rng() * 130);
    const floor = Math.round(1 + rng() * 29);
    const builtYear = Math.round(1985 + rng() * 39);
    const stationDist = Math.round(50 + rng() * 2950);
    const schoolScore = Math.round(1 + rng() * 9);

    const base = DIST_BASE[district];
    const price = base
      + 120 * area
      + 50 * floor
      - 80 * (2024 - builtYear)
      - 2 * stationDist
      + 500 * schoolScore
      + (rng() - 0.5) * 4000;

    data.push({
      id: i + 1, district,
      area_m2: area, floor, built_year: builtYear,
      station_dist_m: stationDist, school_score: schoolScore,
      price_10k: Math.round(Math.max(price, 1500))
    });
  }
  return data;
}

// ======================== GRADIENT DESCENT REGRESSION ========================

function prepareFeatures(data, featureNames) {
  const cols = [];
  const colNames = [];
  for (const f of featureNames) {
    if (f === 'district_code') {
      for (let d = 1; d < DISTRICTS.length; d++) {
        cols.push(data.map(r => r.district === DISTRICTS[d] ? 1 : 0));
        colNames.push('구_' + DISTRICTS[d]);
      }
    } else {
      cols.push(data.map(r => r[f]));
      colNames.push(VAR_LABELS[f] || f);
    }
  }
  const means = cols.map(c => mean(c));
  const stds = cols.map(c => { const s = std(c); return s === 0 ? 1 : s; });
  const X = data.map((_, i) => {
    const row = [1];
    for (let j = 0; j < cols.length; j++) row.push((cols[j][i] - means[j]) / stds[j]);
    return row;
  });
  const y = data.map(r => r.price_10k);
  return { X, y, means, stds, colNames: ['절편', ...colNames] };
}

function standardizeTestRow(row, feats, prep) {
  const r = [1];
  let ci = 0;
  for (const f of feats) {
    if (f === 'district_code') {
      for (let d = 1; d < DISTRICTS.length; d++) {
        r.push(((row.district === DISTRICTS[d] ? 1 : 0) - prep.means[ci]) / prep.stds[ci]);
        ci++;
      }
    } else {
      r.push((row[f] - prep.means[ci]) / prep.stds[ci]);
      ci++;
    }
  }
  return r;
}

// --- Gradient Descent for OLS ---
function gdOLS(X, y, lr, maxIter) {
  const n = X.length, p = X[0].length;
  const w = new Array(p).fill(0);
  const losses = [];
  for (let it = 0; it < maxIter; it++) {
    const grad = new Array(p).fill(0);
    let loss = 0;
    for (let i = 0; i < n; i++) {
      let pred = 0;
      for (let j = 0; j < p; j++) pred += X[i][j] * w[j];
      const err = pred - y[i];
      loss += err * err;
      for (let j = 0; j < p; j++) grad[j] += (2 / n) * err * X[i][j];
    }
    for (let j = 0; j < p; j++) w[j] -= lr * grad[j];
    losses.push(loss / n);
    if (it > 10 && Math.abs(losses[it] - losses[it - 1]) < 1e-4) break;
  }
  return { w: [...w], losses };
}

// --- Gradient Descent for Ridge ---
function gdRidge(X, y, lr, lambda, maxIter) {
  const n = X.length, p = X[0].length;
  const w = new Array(p).fill(0);
  const losses = [];
  for (let it = 0; it < maxIter; it++) {
    const grad = new Array(p).fill(0);
    let loss = 0;
    for (let i = 0; i < n; i++) {
      let pred = 0;
      for (let j = 0; j < p; j++) pred += X[i][j] * w[j];
      const err = pred - y[i];
      loss += err * err;
      for (let j = 0; j < p; j++) grad[j] += (2 / n) * err * X[i][j];
    }
    // L2 penalty gradient (skip intercept j=0)
    let penLoss = 0;
    for (let j = 1; j < p; j++) {
      grad[j] += (2 * lambda / n) * w[j];
      penLoss += w[j] * w[j];
    }
    for (let j = 0; j < p; j++) w[j] -= lr * grad[j];
    losses.push(loss / n + (lambda / n) * penLoss);
    if (it > 10 && Math.abs(losses[it] - losses[it - 1]) < 1e-4) break;
  }
  return { w: [...w], losses };
}

// --- Proximal Gradient Descent for Lasso ---
function gdLasso(X, y, lr, lambda, maxIter) {
  const n = X.length, p = X[0].length;
  const w = new Array(p).fill(0);
  const losses = [];
  function softThresh(val, th) {
    if (val > th) return val - th;
    if (val < -th) return val + th;
    return 0;
  }
  for (let it = 0; it < maxIter; it++) {
    const grad = new Array(p).fill(0);
    let loss = 0;
    for (let i = 0; i < n; i++) {
      let pred = 0;
      for (let j = 0; j < p; j++) pred += X[i][j] * w[j];
      const err = pred - y[i];
      loss += err * err;
      for (let j = 0; j < p; j++) grad[j] += (2 / n) * err * X[i][j];
    }
    // Gradient step
    for (let j = 0; j < p; j++) w[j] -= lr * grad[j];
    // Proximal step (soft thresholding, skip intercept)
    let penLoss = 0;
    for (let j = 1; j < p; j++) {
      w[j] = softThresh(w[j], lr * lambda / n);
      penLoss += Math.abs(w[j]);
    }
    losses.push(loss / n + (lambda / n) * penLoss);
    if (it > 10 && Math.abs(losses[it] - losses[it - 1]) < 1e-4) break;
  }
  return { w: [...w], losses };
}

function predict(X, w) {
  return X.map(row => {
    let s = 0;
    for (let j = 0; j < w.length; j++) s += row[j] * w[j];
    return s;
  });
}
function calcRMSE(a, p) { let s = 0; for (let i = 0; i < a.length; i++) s += (a[i]-p[i])**2; return Math.sqrt(s/a.length); }
function calcMAE(a, p) { let s = 0; for (let i = 0; i < a.length; i++) s += Math.abs(a[i]-p[i]); return s/a.length; }
function calcR2(a, p) {
  const m = mean(a);
  let t = 0, r = 0;
  for (let i = 0; i < a.length; i++) { t += (a[i]-m)**2; r += (a[i]-p[i])**2; }
  return t === 0 ? 0 : 1 - r/t;
}
function calcAdjR2(r2, n, p) { return n-p-1 <= 0 ? r2 : 1 - (1-r2)*(n-1)/(n-p-1); }

// VIF: regress X_j on others via simple OLS GD
function calcVIF(X, colIdx) {
  const n = X.length, p = X[0].length;
  if (p <= 2) return 1;
  const yCol = X.map(r => r[colIdx]);
  const Xo = X.map(r => {
    const row = [1];
    for (let j = 1; j < p; j++) if (j !== colIdx) row.push(r[j]);
    return row;
  });
  const res = gdOLS(Xo, yCol, 0.05, 200);
  const pred = predict(Xo, res.w);
  const r2 = calcR2(yCol, pred);
  return r2 >= 0.999 ? 100 : 1 / (1 - r2);
}

// ======================== CHART.JS ========================

