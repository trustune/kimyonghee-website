async function renderEDAHist() {
  
  const varName = document.getElementById('sel-eda-var').value;
  destroyChart('chart-eda-hist');
  const ctx = document.getElementById('chart-eda-hist');
  const tbody = document.getElementById('eda-summary-tbody');

  if (varName === 'district') {
    // categorical bar chart
    const counts = {};
    DISTRICTS.forEach(d => counts[d] = 0);
    dataset.forEach(r => counts[r.district]++);
    const labels = DISTRICTS.map(d => d + '구');
    const values = DISTRICTS.map(d => counts[d]);
    const colors = DISTRICTS.map(d => DIST_COLORS[d]);
    chartInstances['chart-eda-hist'] = new Chart(ctx, {
      type: 'bar',
      data: { labels, datasets: [{ label: '건수', data: values, backgroundColor: colors }] },
      options: { responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: { y: { title: { display: true, text: '건수' }, beginAtZero: true } }
      }
    });
    if (tbody) {
      tbody.innerHTML = DISTRICTS.map(d =>
        `<tr><td>${d}구</td><td>${counts[d]}건 (${(counts[d]/dataset.length*100).toFixed(1)}%)</td></tr>`
      ).join('');
    }
  } else {
    // numeric histogram
    const values = dataset.map(r => r[varName]);
    const mn = Math.min(...values), mx = Math.max(...values);
    const binCount = 20;
    const bw = (mx - mn) / binCount || 1;
    const bins = Array(binCount).fill(0);
    const labels = [];
    for (let i = 0; i < binCount; i++) labels.push(Math.round(mn + i * bw));
    values.forEach(v => {
      let idx = Math.floor((v - mn) / bw);
      if (idx >= binCount) idx = binCount - 1;
      if (idx < 0) idx = 0;
      bins[idx]++;
    });
    chartInstances['chart-eda-hist'] = new Chart(ctx, {
      type: 'bar',
      data: { labels, datasets: [{ label: VAR_LABELS[varName], data: bins,
        backgroundColor: 'rgba(37,99,235,0.6)', borderColor: '#2563eb', borderWidth: 1 }] },
      options: { responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: { y: { title: { display: true, text: '빈도' } },
                  x: { title: { display: true, text: VAR_LABELS[varName] } } }
      }
    });
    if (tbody) {
      const m = mean(values), s = std(values), med = median(values);
      tbody.innerHTML = `
        <tr><td>N</td><td>${values.length}</td></tr>
        <tr><td>평균</td><td>${m.toFixed(1)}</td></tr>
        <tr><td>중앙값</td><td>${med.toFixed(1)}</td></tr>
        <tr><td>표준편차</td><td>${s.toFixed(1)}</td></tr>
        <tr><td>최솟값</td><td>${Math.min(...values).toFixed(1)}</td></tr>
        <tr><td>최댓값</td><td>${Math.max(...values).toFixed(1)}</td></tr>`;
    }
  }
}

