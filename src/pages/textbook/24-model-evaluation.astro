      <div class="checklist-step" id="step-2" style="margin-bottom: 14px; display: none;">
        <div style="font-weight: 700; font-size: 0.95rem; margin-bottom: 8px; color: var(--tb-primary);">Q2. 오류의 비용이 비대칭인가요?</div>
        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
          <button class="tb-btn tb-btn-primary checklist-btn" data-step="2" data-answer="fn-costly">놓치는 것이 더 위험 (FN 비용 높음)</button>
          <button class="tb-btn tb-btn-warning checklist-btn" data-step="2" data-answer="fp-costly">오탐이 더 위험 (FP 비용 높음)</button>
          <button class="tb-btn tb-btn-success checklist-btn" data-step="2" data-answer="symmetric">비슷함</button>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="checklist-step" id="step-3" style="margin-bottom: 14px; display: none;">
        <div style="font-weight: 700; font-size: 0.95rem; margin-bottom: 8px; color: var(--tb-primary);">Q3. 모델의 해석 가능성이 중요한가요?</div>
        <div style="display: flex; gap: 10px;">
          <button class="tb-btn tb-btn-primary checklist-btn" data-step="3" data-answer="interpretable">매우 중요 (규제, 의료 등)</button>
          <button class="tb-btn tb-btn-warning checklist-btn" data-step="3" data-answer="not-important">성능이 더 중요</button>
        </div>
      </div>

      <!-- Step 4 -->
      <div class="checklist-step" id="step-4" style="margin-bottom: 14px; display: none;">
        <div style="font-weight: 700; font-size: 0.95rem; margin-bottom: 8px; color: var(--tb-primary);">Q4. 데이터 크기는?</div>
        <div style="display: flex; gap: 10px;">
          <button class="tb-btn tb-btn-primary checklist-btn" data-step="4" data-answer="small">소규모 (&lt; 1000건)</button>
          <button class="tb-btn tb-btn-warning checklist-btn" data-step="4" data-answer="medium">중규모 (1000-10만건)</button>
          <button class="tb-btn tb-btn-success checklist-btn" data-step="4" data-answer="large">대규모 (&gt; 10만건)</button>
        </div>
      </div>

      <!-- Recommendation -->
      <div id="checklist-result" style="display: none; margin-top: 16px;">
        <div style="background: linear-gradient(135deg, #dcfce7, #bbf7d0); padding: 20px; border-radius: var(--tb-radius); border-left: 4px solid var(--tb-success);">
          <div style="font-weight: 800; font-size: 1.05rem; color: #166534; margin-bottom: 10px;">추천 결과</div>
          <div id="recommend-model" style="font-size: 0.93rem; margin-bottom: 8px;"></div>
          <div id="recommend-metric" style="font-size: 0.93rem; margin-bottom: 8px;"></div>
          <div id="recommend-cv" style="font-size: 0.93rem;"></div>
        </div>
        <button class="tb-btn tb-btn-danger" id="btn-reset-checklist" style="margin-top: 10px;">다시 선택하기</button>
      </div>
    </div>
  </div>

  <!-- ===== SECTION: 지표 요약 테이블 ===== -->
  <div class="tb-card">
    <h2>평가 지표 요약</h2>

    <div class="tb-data-table-wrap" style="max-height: none;">
      <table class="tb-data-table">
        <thead>
          <tr>
            <th>지표</th>
            <th>언제 사용?</th>
            <th>주의점</th>
          </tr>
        </thead>
        <tbody>
          <tr><td style="font-weight: 700;">Accuracy</td><td>클래스 균형, 오류 비용 대칭</td><td>불균형 데이터에서는 무의미</td></tr>
          <tr><td style="font-weight: 700;">Precision</td><td>FP 비용이 높을 때 (스팸 필터)</td><td>FN을 무시할 수 있음</td></tr>
          <tr><td style="font-weight: 700;">Recall</td><td>FN 비용이 높을 때 (암 검진)</td><td>FP를 무시할 수 있음</td></tr>
          <tr><td style="font-weight: 700;">F1</td><td>정밀도와 재현율 균형</td><td>TN을 반영하지 않음</td></tr>
          <tr><td style="font-weight: 700;">AUC-ROC</td><td>전체 임계값 범위의 성능</td><td>불균형 시 PR-AUC가 더 나음</td></tr>
          <tr><td style="font-weight: 700;">Log Loss</td><td>확률 예측의 품질</td><td>확률 보정이 중요</td></tr>
        </tbody>
      </table>
    </div>

    <BusinessBox>
      <strong>비즈니스 함의:</strong> 모델 선택은 기술적 결정이 아니라 <strong>비즈니스 결정</strong>입니다.
      "사기를 놓치는 비용이 얼마인가?" "고객을 잘못 차단하면 얼마를 잃는가?"
      이 비용을 먼저 정의하고, 그에 맞는 지표를 선택해야 합니다.
    </BusinessBox>
  </div>

  <!-- ===== CONCLUSION ===== -->
  <ConclusionBox>
    <ul style="line-height: 2;">
      <li>정확도만으로 모델을 평가하면 안 된다. 특히 불균형 데이터에서는 치명적이다.</li>
      <li>혼동 행렬에서 TP/FP/FN/TN을 이해하면 모든 지표를 파악할 수 있다.</li>
      <li>정밀도와 재현율은 시소 관계. 비즈니스 맥락에 따라 우선순위를 정해야 한다.</li>
      <li>ROC 곡선과 AUC로 전체적인 분류 성능을 비교할 수 있다.</li>
      <li>K-겹 교차검증은 안정적인 성능 추정을 제공하며, K=5 또는 10이 표준이다.</li>
    </ul>
    <p style="margin-top: 12px;">
      <strong>다음 장 예고:</strong> 의사결정트리, 앙상블, 모델 평가를 모두 배웠습니다.
      다음 장에서는 이 모든 기법을 종합하여 실전 프로젝트를 수행합니다.
    </p>
  </ConclusionBox>

</TextbookLayout>

<script is:inline>

  // ====================== INTERACTIVE 1: IMBALANCED DATA ======================
  let fraudData = [];

  function generateFraudData(n = 1000) {
    fraudData = [];
    const fraudRate = 0.01;
    for (let i = 0; i < n; i++) {
      const actual = Math.random() < fraudRate ? 1 : 0;
      // Score: higher for fraud, but with overlap
      const score = actual === 1
        ? 0.4 + Math.random() * 0.55 + (Math.random() - 0.5) * 0.3
        : Math.random() * 0.6 + (Math.random() - 0.5) * 0.2;
      fraudData.push({ score: Math.max(0, Math.min(1, score)), actual });
    }
  }

  let chartThresholdMetrics = null;

  function updateFraudMetrics() {
    const threshold = parseInt((document.getElementById('range-threshold')).value) / 100;
    document.getElementById('label-threshold').textContent = threshold.toFixed(2);

    let tp = 0, fp = 0, fn = 0, tn = 0;
    for (const d of fraudData) {
      const pred = d.score >= threshold ? 1 : 0;
      if (pred === 1 && d.actual === 1) tp++;
      else if (pred === 1 && d.actual === 0) fp++;
      else if (pred === 0 && d.actual === 1) fn++;
      else tn++;
    }

    const accuracy = (tp + tn) / (tp + fp + fn + tn);
    const precision = tp + fp > 0 ? tp / (tp + fp) : 0;
    const recall = tp + fn > 0 ? tp / (tp + fn) : 0;
    const f1 = precision + recall > 0 ? 2 * precision * recall / (precision + recall) : 0;

    setStat('stat-im-accuracy', (accuracy * 100).toFixed(1) + '%');
    setStat('stat-im-precision', (precision * 100).toFixed(1) + '%');
    setStat('stat-im-recall', (recall * 100).toFixed(1) + '%');
    setStat('stat-im-f1', f1.toFixed(3));

    setStat('stat-fn-count', String(fn));
    setStat('stat-fp-count', String(fp));
    setStat('stat-fn-cost', (fn * 100).toFixed(0) + '만원');
    setStat('stat-fp-cost', (fp * 1).toFixed(0) + '만원');
    document.getElementById('stat-total-cost').textContent = ((fn * 100) + (fp * 1)).toFixed(0) + '만원';

    // Update threshold metrics chart
    if (chartThresholdMetrics) {
      const thresholds = [];
      const precisions = [];
      const recalls = [];
      const f1s = [];
      for (let t = 0; t <= 100; t += 2) {
        const th = t / 100;
        thresholds.push(th);
        let ltp = 0, lfp = 0, lfn = 0;
        for (const d of fraudData) {
          const pred = d.score >= th ? 1 : 0;
          if (pred === 1 && d.actual === 1) ltp++;
          else if (pred === 1 && d.actual === 0) lfp++;
          else if (pred === 0 && d.actual === 1) lfn++;
        }
        const lp = ltp + lfp > 0 ? ltp / (ltp + lfp) : 0;
        const lr = ltp + lfn > 0 ? ltp / (ltp + lfn) : 0;
        const lf = lp + lr > 0 ? 2 * lp * lr / (lp + lr) : 0;
        precisions.push(lp);
        recalls.push(lr);
        f1s.push(lf);
      }
      chartThresholdMetrics.data.labels = thresholds.map(t => t.toFixed(2));
      chartThresholdMetrics.data.datasets[0].data = precisions;
      chartThresholdMetrics.data.datasets[1].data = recalls;
      chartThresholdMetrics.data.datasets[2].data = f1s;
      chartThresholdMetrics.update();
    }
  }

  // ====================== INTERACTIVE 2: CONFUSION MATRIX BUILDER ======================
  function updateConfusionMatrix() {
    const tp = parseInt((document.getElementById('input-tp')).value) || 0;
    const fn = parseInt((document.getElementById('input-fn')).value) || 0;
    const fp = parseInt((document.getElementById('input-fp')).value) || 0;
    const tn = parseInt((document.getElementById('input-tn')).value) || 0;

    const total = tp + fn + fp + tn;
    const accuracy = total > 0 ? (tp + tn) / total : 0;
    const errorRate = 1 - accuracy;
    const precision = tp + fp > 0 ? tp / (tp + fp) : 0;
    const recall = tp + fn > 0 ? tp / (tp + fn) : 0;
    const f1 = precision + recall > 0 ? 2 * precision * recall / (precision + recall) : 0;
    const specificity = fp + tn > 0 ? tn / (fp + tn) : 0;

    setStat('stat-cm-accuracy', (accuracy * 100).toFixed(1) + '%');
    setStat('stat-cm-error', (errorRate * 100).toFixed(1) + '%');
    setStat('stat-cm-precision', (precision * 100).toFixed(1) + '%');
    setStat('stat-cm-recall', (recall * 100).toFixed(1) + '%');
    setStat('stat-cm-f1', f1.toFixed(3));
    setStat('stat-cm-specificity', (specificity * 100).toFixed(1) + '%');
  }

  // ====================== INTERACTIVE 3: ROC CURVE ======================
  let chartRocCurves = null;

  function generateROCData(quality) {
    // Generate scores that approximate a model of given AUC quality
    const points = [];
    for (let i = 0; i < 500; i++) {
      const actual = Math.random() > 0.5 ? 1 : 0;
      const noise = (1 - quality) * 2;
      const score = actual === 1
        ? quality + (Math.random() - 0.5) * noise
        : (1 - quality) + (Math.random() - 0.5) * noise;
      points.push({ score: Math.max(0, Math.min(1, score)), actual });
    }
    return points;
  }

  function computeROC(data) {
    const sorted = [...data].sort((a, b) => b.score - a.score);
    const totalP = data.filter(d => d.actual === 1).length;
    const totalN = data.length - totalP;
    const fprList = [0];
    const tprList = [0];
    let tp = 0, fp = 0;

    for (const d of sorted) {
      if (d.actual === 1) tp++;
      else fp++;
      tprList.push(totalP > 0 ? tp / totalP : 0);
      fprList.push(totalN > 0 ? fp / totalN : 0);
    }

    // Compute AUC using trapezoidal rule
    let auc = 0;
    for (let i = 1; i < fprList.length; i++) {
      auc += (fprList[i] - fprList[i - 1]) * (tprList[i] + tprList[i - 1]) / 2;
    }

    // Subsample for chart
    const step = Math.max(1, Math.floor(fprList.length / 100));
    const sampledFpr = [];
    const sampledTpr = [];
    for (let i = 0; i < fprList.length; i += step) {
      sampledFpr.push(fprList[i]);
      sampledTpr.push(tprList[i]);
    }
    if (sampledFpr[sampledFpr.length - 1] !== 1) {
      sampledFpr.push(1);
      sampledTpr.push(1);
    }

    return { fpr: sampledFpr, tpr: sampledTpr, auc };
  }

  function updateROC() {
    const qualA = parseFloat((document.getElementById('select-model-a')).value);
    const qualB = parseFloat((document.getElementById('select-model-b')).value);

    const dataA = generateROCData(qualA);
    const dataB = generateROCData(qualB);
    const rocA = computeROC(dataA);
    const rocB = computeROC(dataB);

    setStat('stat-auc-a', rocA.auc.toFixed(3));
    setStat('stat-auc-b', rocB.auc.toFixed(3));

    if (chartRocCurves) {
      // Model A
      chartRocCurves.data.datasets[0].data = rocA.fpr.map((fpr, i) => ({ x: fpr, y: rocA.tpr[i] }));
      // Model B
      chartRocCurves.data.datasets[1].data = rocB.fpr.map((fpr, i) => ({ x: fpr, y: rocB.tpr[i] }));
      // Random
      chartRocCurves.data.datasets[2].data = [{ x: 0, y: 0 }, { x: 1, y: 1 }];
      chartRocCurves.update();
    }
  }

  // ====================== INTERACTIVE 4: K-FOLD CV ======================
  let chartCvComparison = null;

  function simulateCV(k) {
    // Generate a dataset
    const n = 200;
    const data = [];
    for (let i = 0; i < n; i++) {
      const x = Math.random() * 10;
      const y = Math.random() * 10;
      const cls = (y > 3 * Math.sin(x * 0.8) + 5 + (Math.random() - 0.5) * 2) ? 1 : 0;
      data.push({ x, y, cls });
    }

    // K-fold
    const foldSize = Math.floor(n / k);
    const accuracies = [];

    for (let fold = 0; fold < k; fold++) {
      const testStart = fold * foldSize;
      const testEnd = fold === k - 1 ? n : (fold + 1) * foldSize;
      const testSet = data.slice(testStart, testEnd);
      const trainSet = [...data.slice(0, testStart), ...data.slice(testEnd)];

      // Simple KNN-like classifier (k=5 nearest neighbors)
      let correct = 0;
      for (const t of testSet) {
        const dists = trainSet.map(tr => ({
          dist: Math.sqrt((tr.x - t.x) ** 2 + (tr.y - t.y) ** 2),
          cls: tr.cls,
        })).sort((a, b) => a.dist - b.dist);
        const neighbors = dists.slice(0, 5);
        const vote = neighbors.filter(n => n.cls === 1).length > 2 ? 1 : 0;
        if (vote === t.cls) correct++;
      }
      accuracies.push(correct / testSet.length);
    }

    const mean = accuracies.reduce((a, b) => a + b, 0) / accuracies.length;
    const std = Math.sqrt(accuracies.reduce((a, b) => a + (b - mean) ** 2, 0) / accuracies.length);

    return { accuracies, mean, std };
  }

  function drawKFoldVisual(k) {
    const canvas = document.getElementById('canvas-kfold');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);

    const blockW = (W - 40) / k;
    const rowH = 28;
    const startY = 20;

    ctx.font = '11px Paperlogy, sans-serif';
    ctx.textAlign = 'center';

    for (let fold = 0; fold < k; fold++) {
      const y = startY + fold * (rowH + 8);
      ctx.fillStyle = '#475569';
      ctx.textAlign = 'right';
      ctx.fillText(`Fold ${fold + 1}`, 35, y + rowH / 2 + 4);
      ctx.textAlign = 'center';

      for (let block = 0; block < k; block++) {
        const x = 40 + block * blockW;
        const isTest = block === fold;
        ctx.fillStyle = isTest ? '#ef4444' : '#3b82f6';
        ctx.globalAlpha = isTest ? 0.9 : 0.3;
        ctx.beginPath();
        ctx.roundRect(x + 1, y, blockW - 2, rowH, 4);
        ctx.fill();
        ctx.globalAlpha = 1;

        if (isTest) {
          ctx.fillStyle = '#fff';
          ctx.font = '10px Paperlogy, sans-serif';
          ctx.fillText('Test', x + blockW / 2, y + rowH / 2 + 3);
          ctx.font = '11px Paperlogy, sans-serif';
        }
      }
    }

    // Legend
    ctx.textAlign = 'left';
    ctx.fillStyle = '#3b82f6';
    ctx.globalAlpha = 0.3;
    ctx.fillRect(40, H - 25, 20, 12);
    ctx.globalAlpha = 1;
    ctx.fillStyle = '#475569';
    ctx.fillText('훈련', 65, H - 15);

    ctx.fillStyle = '#ef4444';
    ctx.globalAlpha = 0.9;
    ctx.fillRect(120, H - 25, 20, 12);
    ctx.globalAlpha = 1;
    ctx.fillStyle = '#475569';
    ctx.fillText('테스트', 145, H - 15);
  }

  function runCV() {
    const k = parseInt((document.getElementById('select-kfold')).value);
    drawKFoldVisual(k);

    const result = simulateCV(k);
    setStat('stat-cv-mean', (result.mean * 100).toFixed(1) + '%');
    setStat('stat-cv-std', (result.std * 100).toFixed(2) + '%');

    // Single holdout for comparison
    const holdout = simulateCV(2);
    setStat('stat-cv-holdout', (holdout.accuracies[0] * 100).toFixed(1) + '%');

    // Display fold results
    const container = document.getElementById('cv-results');
    container.innerHTML = `<div style="display:flex; gap:8px; flex-wrap:wrap;">` +
      result.accuracies.map((acc, i) =>
        `<span style="padding:6px 14px; background:var(--tb-g100); border-radius:20px; font-size:0.85rem; font-weight:600;">Fold ${i + 1}: ${(acc * 100).toFixed(1)}%</span>`
      ).join('') +
      `</div><div style="margin-top:8px; font-weight:700; font-size:0.9rem;">평균: ${(result.mean * 100).toFixed(1)}% +/- ${(result.std * 100).toFixed(2)}%</div>`;
  }

  function compareCV() {
    const results = [];
    for (const k of [3, 5, 10]) {
      const r = simulateCV(k);
      results.push({ k, mean: r.mean, std: r.std, accs: r.accuracies });
    }

    if (chartCvComparison) {
      chartCvComparison.data.labels = results.map(r => `K=${r.k}`);
      chartCvComparison.data.datasets[0].data = results.map(r => r.mean * 100);
      chartCvComparison.data.datasets[1].data = results.map(r => r.std * 100);
      chartCvComparison.update();
    }
  }

  // ====================== INTERACTIVE 5: MODEL SELECTION CHECKLIST ======================
  let checklistAnswers = {};

  function handleChecklistClick(step, answer) {
    checklistAnswers[step] = answer;

    // Highlight selected button
    const stepEl = document.getElementById(`step-${step}`);
    if (stepEl) {
      stepEl.querySelectorAll('.checklist-btn').forEach((btn) => {
        btn.style.opacity = btn.dataset.answer === answer ? '1' : '0.4';
      });
    }

    // Show next step
    const nextStep = parseInt(step) + 1;
    if (nextStep <= 4) {
      const nextEl = document.getElementById(`step-${nextStep}`);
      if (nextEl) nextEl.style.display = 'block';
    }

    // Show result after step 4
    if (parseInt(step) >= 4 || (parseInt(step) === 3 && Object.keys(checklistAnswers).length >= 3)) {
      showChecklistResult();
    }
  }

  function showChecklistResult() {
    const result = document.getElementById('checklist-result');
    result.style.display = 'block';

    const isBalanced = checklistAnswers['1'] === 'balanced';
    const costType = checklistAnswers['2'] || 'symmetric';
    const needInterpret = checklistAnswers['3'] === 'interpretable';
    const dataSize = checklistAnswers['4'] || 'medium';

    // Determine recommendation
    let model = '';
    let metric = '';
    let cv = '';

    if (needInterpret) {
      model = dataSize === 'small'
        ? '<strong>로지스틱 회귀</strong> 또는 <strong>의사결정트리</strong> (해석 가능 + 소규모 데이터에 적합)'
        : '<strong>의사결정트리</strong> 또는 <strong>규칙 기반 모델</strong> (해석 가능 + 비선형 포착)';
    } else {
      if (dataSize === 'large') {
        model = '<strong>그레이디언트 부스팅 (XGBoost/LightGBM)</strong> (대규모 데이터에서 최강 성능)';
      } else {
        model = '<strong>랜덤 포레스트</strong> (안정적 성능, 과적합 방지)';
      }
    }

    if (!isBalanced) {
      if (costType === 'fn-costly') {
        metric = '<strong>재현율(Recall)</strong> 또는 <strong>F2 Score</strong> (FN 최소화 우선)';
      } else if (costType === 'fp-costly') {
        metric = '<strong>정밀도(Precision)</strong> 또는 <strong>F0.5 Score</strong> (FP 최소화 우선)';
      } else {
        metric = '<strong>F1 Score</strong> + <strong>AUC-PR</strong> (불균형 데이터의 균형 지표)';
      }
    } else {
      if (costType === 'fn-costly') {
        metric = '<strong>재현율(Recall)</strong> 우선, Accuracy도 참고';
      } else if (costType === 'fp-costly') {
        metric = '<strong>정밀도(Precision)</strong> 우선, Accuracy도 참고';
      } else {
        metric = '<strong>Accuracy</strong> + <strong>AUC-ROC</strong> (균형 데이터의 표준 지표)';
      }
    }

    if (dataSize === 'small') {
      cv = '<strong>K=10 교차검증</strong> 또는 <strong>Leave-One-Out</strong> (소규모에서 안정적 추정)';
    } else if (dataSize === 'medium') {
      cv = '<strong>K=5 교차검증</strong> (표준적 선택)';
    } else {
      cv = '<strong>단일 홀드아웃 (80/20)</strong>으로 충분 (데이터가 많으면 분산이 자연히 낮음)';
    }

    document.getElementById('recommend-model').innerHTML = '추천 모델: ' + model;
    document.getElementById('recommend-metric').innerHTML = '추천 평가 지표: ' + metric;
    document.getElementById('recommend-cv').innerHTML = '검증 방법: ' + cv;
  }

  function resetChecklist() {
    checklistAnswers = {};
    for (let i = 2; i <= 4; i++) {
      const el = document.getElementById(`step-${i}`);
      if (el) el.style.display = 'none';
    }
    document.getElementById('checklist-result').style.display = 'none';
    document.querySelectorAll('.checklist-btn').forEach((btn) => { btn.style.opacity = '1'; });
  }

  // ====================== UTILITY ======================
  function setStat(id, val) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  // ====================== CHART INITIALIZATION ======================
  async function initCharts() {

    // Threshold metrics chart
    const ctxThreshold = (document.getElementById('chart-threshold-metrics'))?.getContext('2d');
    if (ctxThreshold) {
      chartThresholdMetrics = new Chart(ctxThreshold, {
        type: 'line',
        data: {
          labels: [],
          datasets: [
            { label: '정밀도', data: [], borderColor: '#2563eb', tension: 0.3, pointRadius: 0, borderWidth: 2 },
            { label: '재현율', data: [], borderColor: '#ef4444', tension: 0.3, pointRadius: 0, borderWidth: 2 },
            { label: 'F1', data: [], borderColor: '#22c55e', tension: 0.3, pointRadius: 0, borderWidth: 2.5 },
          ],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          scales: {
            x: { title: { display: true, text: '임계값 (Threshold)', font: { family: 'Paperlogy' } },
                 ticks: { maxTicksLimit: 10 } },
            y: { title: { display: true, text: '점수', font: { family: 'Paperlogy' } }, min: 0, max: 1 },
          },
          plugins: { legend: { labels: { font: { family: 'Paperlogy' } } } },
        },
      });
    }

    // ROC curves chart
    const ctxRoc = (document.getElementById('chart-roc-curves'))?.getContext('2d');
    if (ctxRoc) {
      chartRocCurves = new Chart(ctxRoc, {
        type: 'scatter',
        data: {
          datasets: [
            { label: '모델 A', data: [], borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.1)', showLine: true, pointRadius: 0, borderWidth: 2.5, fill: false },
            { label: '모델 B', data: [], borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.1)', showLine: true, pointRadius: 0, borderWidth: 2.5, fill: false },
            { label: '무작위', data: [{ x: 0, y: 0 }, { x: 1, y: 1 }], borderColor: '#94a3b8', showLine: true, pointRadius: 0, borderWidth: 1.5, borderDash: [5, 5], fill: false },
          ],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          scales: {
            x: { title: { display: true, text: 'FPR (거짓 양성률)', font: { family: 'Paperlogy' } }, min: 0, max: 1 },
            y: { title: { display: true, text: 'TPR (참 양성률)', font: { family: 'Paperlogy' } }, min: 0, max: 1 },
          },
          plugins: { legend: { labels: { font: { family: 'Paperlogy' } } } },
        },
      });
    }

    // CV comparison chart
    const ctxCv = (document.getElementById('chart-cv-comparison'))?.getContext('2d');
    if (ctxCv) {
      chartCvComparison = new Chart(ctxCv, {
        type: 'bar',
        data: {
          labels: ['K=3', 'K=5', 'K=10'],
          datasets: [
            { label: '평균 정확도 (%)', data: [0, 0, 0], backgroundColor: ['#3b82f6', '#22c55e', '#f59e0b'] },
            { label: '표준편차 (%)', data: [0, 0, 0], backgroundColor: ['rgba(59,130,246,0.3)', 'rgba(34,197,94,0.3)', 'rgba(245,158,11,0.3)'] },
          ],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          scales: {
            y: { title: { display: true, text: '%', font: { family: 'Paperlogy' } }, min: 0 },
          },
          plugins: { legend: { labels: { font: { family: 'Paperlogy' } } } },
        },
      });
    }
  }

  // ====================== INITIALIZATION ======================
  function init() {
    // Interactive 1: Fraud data
    generateFraudData(2000);
    const thresholdSlider = document.getElementById('range-threshold');
    thresholdSlider?.addEventListener('input', updateFraudMetrics);
    document.getElementById('btn-new-fraud-data')?.addEventListener('click', () => {
      generateFraudData(2000);
      updateFraudMetrics();
    });

    // Interactive 2: Confusion matrix
    const cmInputs = ['input-tp', 'input-fn', 'input-fp', 'input-tn'];
    for (const id of cmInputs) {
      document.getElementById(id)?.addEventListener('input', updateConfusionMatrix);
    }
    updateConfusionMatrix();

    // Interactive 3: ROC
    document.getElementById('btn-gen-roc')?.addEventListener('click', updateROC);

    // Interactive 4: K-fold CV
    document.getElementById('btn-run-cv')?.addEventListener('click', runCV);
    document.getElementById('btn-compare-cv')?.addEventListener('click', compareCV);

    // Interactive 5: Checklist
    document.querySelectorAll('.checklist-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        handleChecklistClick(btn.dataset.step, btn.dataset.answer);
      });
    });
    document.getElementById('btn-reset-checklist')?.addEventListener('click', resetChecklist);

    // Init charts then update
    initCharts().then(() => {
      updateFraudMetrics();
      updateROC();
      drawKFoldVisual(5);
    });
  }

  if (document.readyState === 'loading') {
init();
  } else {
    init();
  }
</script>

