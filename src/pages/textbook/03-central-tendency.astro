function initHonestQuiz() {
  const container = document.getElementById('honest-quiz');
  container.innerHTML = '';
  document.getElementById('honest-results').style.display = 'none';

  HONEST_SCENARIOS.forEach((s, i) => {
    const div = document.createElement('div');
    div.style.cssText = 'padding: 14px 0; border-bottom: 1px solid var(--tb-g200);';
    div.innerHTML = `
      <p style="font-weight: 700; margin-bottom: 4px;">${i + 1}. ${s.title}</p>
      <p style="font-size: .88rem; color: var(--tb-g600); margin-bottom: 8px;">${s.desc}</p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 8px;">
        <canvas id="honest-mini-${i}" width="240" height="80" style="border: 1px solid var(--tb-g200); border-radius: 6px;"></canvas>
      </div>
      <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <label class="honest-option"><input type="radio" name="honest${i}" value="mean"> 평균</label>
        <label class="honest-option"><input type="radio" name="honest${i}" value="median"> 중앙값</label>
        <label class="honest-option"><input type="radio" name="honest${i}" value="mode"> 최빈값</label>
      </div>
      <div class="honest-feedback" data-idx="${i}" style="display: none; margin-top: 6px; font-size: .88rem;"></div>
    `;
    container.appendChild(div);
  });

  // Draw mini distribution charts
  setTimeout(() => {
    HONEST_SCENARIOS.forEach((s, i) => {
      const miniCanvas = document.getElementById(`honest-mini-${i}`);
      if (!miniCanvas) return;
      const ctx = miniCanvas.getContext('2d');
      const w = miniCanvas.width, h = miniCanvas.height;
      const maxVal = Math.max(...s.dist);

      s.dist.forEach((val, j) => {
        const barW = w / s.dist.length - 2;
        const barH = (val / maxVal) * (h - 10);
        ctx.fillStyle = '#2563eb88';
        ctx.fillRect(j * (barW + 2) + 1, h - barH - 5, barW, barH);
      });
    });
  }, 100);
}

function checkHonestQuiz() {
  let correct = 0;

  HONEST_SCENARIOS.forEach((s, i) => {
    const selected = document.querySelector(`input[name="honest${i}"]:checked`);
    const fb = document.querySelector(`.honest-feedback[data-idx="${i}"]`);
    fb.style.display = '';

    if (!selected) {
      fb.textContent = '선택하지 않았습니다.';
      fb.style.color = 'var(--tb-g600)';
      return;
    }

    if (selected.value === s.answer) {
      correct++;
      fb.textContent = '정답! ' + s.hint;
      fb.style.color = 'var(--tb-success)';
      selected.parentElement.style.background = '#dcfce7';
    } else {
      fb.textContent = '오답. ' + s.hint;
      fb.style.color = 'var(--tb-danger)';
      selected.parentElement.style.background = '#fee2e2';
    }
  });

  document.getElementById('honest-results').style.display = '';
  document.getElementById('honest-correct').textContent = correct;
  document.getElementById('honest-rate').textContent = Math.round(correct / 5 * 100) + '%';
}

// ==================== INTERACTIVE 4: TRIMMED MEAN ====================
let trimData = [];
let trimChart = null;

function generateTrimData() {
  trimData = [];
  for (let i = 0; i < 80; i++) {
    // Right-skewed distribution
    const val = Math.pow(Math.random(), 0.4) * 8000 + 2000;
    trimData.push(Math.round(val));
  }
  document.getElementById('trim-slider').value = 0;
  document.getElementById('trim-label').textContent = '0%';
  updateTrimDisplay();
}

function addTrimOutliers() {
  trimData.push(95000, 120000, 200000);
  updateTrimDisplay();
}

async function updateTrimDisplay() {
  
  const canvas = document.getElementById('trim-chart');
  if (trimChart) { trimChart.destroy(); trimChart = null; }

  const pct = parseInt(document.getElementById('trim-slider').value);
  document.getElementById('trim-label').textContent = pct + '%';

  const sorted = [...trimData].sort((a, b) => a - b);
  const trim = Math.floor(sorted.length * pct / 100);
  const removed = trim * 2;

  // Histogram
  const min = sorted[0], max = sorted[sorted.length - 1];
  const bins = 20;
  const bw = (max - min) / bins || 1;
  const hist = new Array(bins).fill(0);
  sorted.forEach(v => {
    const idx = Math.min(bins - 1, Math.floor((v - min) / bw));
    hist[idx]++;
  });
  const labels = hist.map((_, i) => Math.round((min + i * bw + bw / 2) / 100) * 100);

  // Coloring: highlight trimmed regions
  const bgColors = hist.map((_, i) => {
    const binCenter = min + i * bw + bw / 2;
    if (trim > 0) {
      const lowBound = sorted[trim];
      const highBound = sorted[sorted.length - 1 - trim];
      if (binCenter < lowBound || binCenter > highBound) return '#ef444466';
    }
    return '#2563eb44';
  });

  trimChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: '빈도',
        data: hist,
        backgroundColor: bgColors,
        borderColor: bgColors.map(c => c.replace('44', 'cc').replace('66', 'cc')),
        borderWidth: 1,
        borderRadius: 2,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: {
        legend: { display: false },
        title: { display: true, text: '빨간 영역 = 절사된 데이터', font: { size: 11, family: "'Paperlogy'" } }
      },
      scales: {
        y: { beginAtZero: true, title: { display: true, text: '빈도' } },
        x: { title: { display: true, text: '값' } }
      }
    }
  });

  const mean = calcMean(trimData);
  const trimmedMean = calcTrimmedMean(trimData, pct);
  const median = calcMedian(trimData);

  document.getElementById('trim-mean').textContent = fmt(mean);
  document.getElementById('trim-trimmed').textContent = fmt(trimmedMean);
  document.getElementById('trim-median').textContent = fmt(median);
  document.getElementById('trim-removed').textContent = removed + '개';
}

