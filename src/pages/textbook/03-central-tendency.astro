// ==================== INTERACTIVE 2: ROBUSTNESS TESTER ====================
let robustData = [];
let robustBaseData = [];
let robustBaseMean = 0;
let robustChart = null;

function generateRobustData() {
  const dist = document.getElementById('robust-dist').value;
  const n = parseInt(document.getElementById('robust-n').value);
  const data = [];

  for (let i = 0; i < n; i++) {
    let val;
    if (dist === 'normal') {
      // Box-Muller
      const u1 = Math.random(), u2 = Math.random();
      val = Math.sqrt(-2 * Math.log(u1)) * Math.cos(2 * Math.PI * u2);
      val = val * 15 + 50;
    } else if (dist === 'skewed') {
      val = Math.pow(Math.random(), 0.3) * 80 + 10;
    } else if (dist === 'bimodal') {
      if (Math.random() < 0.5) val = (Math.random() * 20 + 20);
      else val = (Math.random() * 20 + 60);
    } else { // uniform
      val = Math.random() * 80 + 10;
    }
    data.push(Math.round(val * 10) / 10);
  }

  robustBaseData = [...data];
  robustBaseMean = calcMean(data);
  robustData = [...data];
  document.getElementById('outlier-slider').value = 0;
  document.getElementById('outlier-label').textContent = '0개';
  updateRobustDisplay();
}

function updateRobustWithOutliers() {
  const count = parseInt(document.getElementById('outlier-slider').value);
  document.getElementById('outlier-label').textContent = count + '개';

  robustData = [...robustBaseData];
  const max = Math.max(...robustBaseData);
  for (let i = 0; i < count; i++) {
    robustData.push(max * 3 + i * max);
  }
  updateRobustDisplay();
}

async function updateRobustDisplay() {
  
  const canvas = document.getElementById('robust-chart');
  if (robustChart) { robustChart.destroy(); robustChart = null; }

  const sorted = [...robustData].sort((a, b) => a - b);
  const min = sorted[0], max = sorted[sorted.length - 1];
  const bins = 20;
  const bw = (max - min) / bins || 1;
  const hist = new Array(bins).fill(0);
  sorted.forEach(v => {
    const idx = Math.min(bins - 1, Math.floor((v - min) / bw));
    hist[idx]++;
  });
  const labels = hist.map((_, i) => Math.round(min + i * bw + bw / 2));

  const mean = calcMean(robustData);
  const median = calcMedian(robustData);
  const mode = calcMode(robustData);

  robustChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: '빈도',
        data: hist,
        backgroundColor: '#2563eb44',
        borderColor: '#2563eb',
        borderWidth: 1,
        borderRadius: 2,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: {
        legend: { display: false },
        annotation: undefined,
      },
      scales: {
        y: { beginAtZero: true, title: { display: true, text: '빈도' } },
        x: { title: { display: true, text: '값' } }
      }
    }
  });

  document.getElementById('robust-mean').textContent = fmt(mean);
  document.getElementById('robust-median').textContent = fmt(median);
  document.getElementById('robust-mode').textContent = fmt(mode);

  const change = robustBaseMean > 0 ? Math.round((mean - robustBaseMean) / robustBaseMean * 100) : 0;
  document.getElementById('robust-mean-change').textContent = (change >= 0 ? '+' : '') + change + '%';
}

