<script is:inline>

function waitForChart(fn) {
  if (typeof Chart !== 'undefined') { fn(); return; }
  var s = document.querySelector('script[src*="chart.js"]');
  if (s) { s.addEventListener('load', fn); return; }
  setTimeout(function() { waitForChart(fn); }, 50);
}

// ==================== UTILITY ====================

function destroyChart(ref) {
  if (ref && ref.destroy) ref.destroy();
  return null;
}

// ==================== POLYNOMIAL DATA ====================
let polyTrainX = [], polyTrainY = [], polyTestX = [], polyTestY = [];
let polyFitChart = null, polyErrorChart = null;

function generatePolyData() {
  const n = 20;
  polyTrainX = []; polyTrainY = []; polyTestX = []; polyTestY = [];
  for (let i = 0; i < n; i++) {
    const x = (i / (n - 1)) * 4 - 2;
    const trueY = 0.5 * x * x * x - x * x + 0.3 * x + 2;
    polyTrainX.push(x);
    polyTrainY.push(trueY + (Math.random() - 0.5) * 3);
  }
  for (let i = 0; i < n; i++) {
    const x = (Math.random()) * 4 - 2;
    const trueY = 0.5 * x * x * x - x * x + 0.3 * x + 2;
    polyTestX.push(x);
    polyTestY.push(trueY + (Math.random() - 0.5) * 3);
  }
}

function polyFit(xs, ys, degree) {
  // Simple polynomial fit using normal equations
  const n = xs.length;
  const X = xs.map(x => {
    const row = [];
    for (let d = 0; d <= degree; d++) row.push(Math.pow(x, d));
    return row;
  });
  // X^T X
  const p = degree + 1;
  const XtX = Array.from({length: p}, () => new Array(p).fill(0));
  const XtY = new Array(p).fill(0);
  for (let i = 0; i < n; i++) {
    for (let j = 0; j < p; j++) {
      XtY[j] += X[i][j] * ys[i];
      for (let k = 0; k < p; k++) {
        XtX[j][k] += X[i][j] * X[i][k];
      }
    }
  }
  // Add small ridge to avoid singular matrix
  for (let i = 0; i < p; i++) XtX[i][i] += 1e-8;
  // Solve via Gauss elimination
  const aug = XtX.map((row, i) => [...row, XtY[i]]);
  for (let i = 0; i < p; i++) {
    let maxRow = i;
    for (let k = i + 1; k < p; k++) if (Math.abs(aug[k][i]) > Math.abs(aug[maxRow][i])) maxRow = k;
    [aug[i], aug[maxRow]] = [aug[maxRow], aug[i]];
    if (Math.abs(aug[i][i]) < 1e-12) continue;
    for (let k = i + 1; k < p; k++) {
      const factor = aug[k][i] / aug[i][i];
      for (let j = i; j <= p; j++) aug[k][j] -= factor * aug[i][j];
    }
  }
  const coef = new Array(p).fill(0);
  for (let i = p - 1; i >= 0; i--) {
    coef[i] = aug[i][p];
    for (let j = i + 1; j < p; j++) coef[i] -= aug[i][j] * coef[j];
    coef[i] /= aug[i][i];
  }
  return coef;
}

function polyPredict(coef, x) {
  let y = 0;
  for (let d = 0; d < coef.length; d++) y += coef[d] * Math.pow(x, d);
  return y;
}

function mse(actual, predicted) {
  let s = 0;
  for (let i = 0; i < actual.length; i++) s += (actual[i] - predicted[i]) ** 2;
  return s / actual.length;
}

async function drawPolyFit() {
  
  const degree = parseInt(document.getElementById('poly-degree').value);
  document.getElementById('poly-degree-label').textContent = '차수: ' + degree;

  const coef = polyFit(polyTrainX, polyTrainY, degree);
  const trainPred = polyTrainX.map(x => polyPredict(coef, x));
  const testPred = polyTestX.map(x => polyPredict(coef, x));

  const trainMSE = mse(polyTrainY, trainPred);
  const testMSE = mse(polyTestY, testPred);

  document.getElementById('poly-train-mse').textContent = trainMSE.toFixed(2);
  document.getElementById('poly-test-mse').textContent = testMSE.toFixed(2);
  document.getElementById('poly-current-deg').textContent = degree;

  // Fit curve points
  const curveX = [];
  for (let x = -2.2; x <= 2.2; x += 0.05) curveX.push(x);
  const curveY = curveX.map(x => {
    const y = polyPredict(coef, x);
    return Math.max(-20, Math.min(20, y));
  });

  polyFitChart = destroyChart(polyFitChart);
  polyFitChart = new Chart(document.getElementById('poly-fit-chart'), {
    type: 'scatter',
    data: {
      datasets: [
        {
          label: '훈련 데이터',
          data: polyTrainX.map((x, i) => ({x, y: polyTrainY[i]})),
          backgroundColor: '#2563eb88',
          pointRadius: 5,
        },
        {
          label: '테스트 데이터',
          data: polyTestX.map((x, i) => ({x, y: polyTestY[i]})),
          backgroundColor: '#ef444488',
          pointRadius: 5,
          pointStyle: 'triangle',
        },
        {
          label: '적합 곡선 (차수=' + degree + ')',
          data: curveX.map((x, i) => ({x, y: curveY[i]})),
          type: 'line',
          borderColor: '#22c55e',
          borderWidth: 2,
          pointRadius: 0,
          fill: false,
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      scales: {
        x: {min: -2.5, max: 2.5, title: {display: true, text: 'X'}},
        y: {min: -15, max: 15, title: {display: true, text: 'Y'}}
      },
      plugins: {legend: {position: 'bottom', labels: {font: {size: 11}}}}
    }
  });

  // Error curve for all degrees
  const degrees = [];
  const trainErrors = [];
  const testErrors = [];
  let bestDeg = 1, bestTestMSE = Infinity;
  for (let d = 1; d <= 15; d++) {
    degrees.push(d);
    const c = polyFit(polyTrainX, polyTrainY, d);
    const trnMSE = mse(polyTrainY, polyTrainX.map(x => polyPredict(c, x)));
    const tstMSE = mse(polyTestY, polyTestX.map(x => polyPredict(c, x)));
    trainErrors.push(Math.min(trnMSE, 50));
    testErrors.push(Math.min(tstMSE, 50));
    if (tstMSE < bestTestMSE) { bestTestMSE = tstMSE; bestDeg = d; }
  }
  document.getElementById('poly-best-deg').textContent = bestDeg;

  polyErrorChart = destroyChart(polyErrorChart);
  polyErrorChart = new Chart(document.getElementById('poly-error-chart'), {
    type: 'line',
    data: {
      labels: degrees,
      datasets: [
        {label: '훈련 MSE', data: trainErrors, borderColor: '#2563eb', backgroundColor: '#2563eb22', fill: true, tension: 0.3},
        {label: '테스트 MSE', data: testErrors, borderColor: '#ef4444', backgroundColor: '#ef444422', fill: true, tension: 0.3},
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      scales: {
        x: {title: {display: true, text: '다항식 차수'}},
        y: {beginAtZero: true, title: {display: true, text: 'MSE'}, max: 50}
      },
      plugins: {
        legend: {position: 'bottom', labels: {font: {size: 11}}},
        annotation: degree ? undefined : undefined,
      }
    }
  });
}

// ==================== BIAS-VARIANCE ====================
let bvData = {xs: [], ys: []};
let bvChart = null;

function generateBVData() {
  bvData = {xs: [], ys: []};
  for (let i = 0; i < 30; i++) {
    const x = (i / 29) * 6 - 3;
    const trueY = Math.sin(x) * 2 + 0.3 * x;
    bvData.xs.push(x);
    bvData.ys.push(trueY + (Math.random() - 0.5) * 1.5);
  }
}

async function drawBV() {
  
  const complexity = parseInt(document.getElementById('bv-complexity').value);
  document.getElementById('bv-complexity-label').textContent = '복잡도: ' + complexity;

  const coef = polyFit(bvData.xs, bvData.ys, complexity);
  const curveX = [];
  for (let x = -3.3; x <= 3.3; x += 0.05) curveX.push(x);
  const curveY = curveX.map(x => {
    const y = polyPredict(coef, x);
    return Math.max(-10, Math.min(10, y));
  });

  // True function
  const trueY = curveX.map(x => Math.sin(x) * 2 + 0.3 * x);

  // Bias and variance estimates
  const predicted = bvData.xs.map(x => polyPredict(coef, x));
  const trueVals = bvData.xs.map(x => Math.sin(x) * 2 + 0.3 * x);
  const biasEst = Math.sqrt(predicted.reduce((s, p, i) => s + (p - trueVals[i]) ** 2, 0) / predicted.length);
  // Variance estimate: variation of predictions with different data samples
  let varEst = 0;
  for (let trial = 0; trial < 10; trial++) {
    const noiseY = bvData.xs.map((x, i) => bvData.ys[i] + (Math.random() - 0.5) * 1.0);
    const c2 = polyFit(bvData.xs, noiseY, complexity);
    const p2 = bvData.xs.map(x => polyPredict(c2, x));
    varEst += p2.reduce((s, p, i) => s + (p - predicted[i]) ** 2, 0) / predicted.length;
  }
  varEst /= 10;

  document.getElementById('bv-bias').textContent = biasEst.toFixed(3);
  document.getElementById('bv-variance').textContent = varEst.toFixed(3);
  document.getElementById('bv-total').textContent = (biasEst * biasEst + varEst).toFixed(3);

  bvChart = destroyChart(bvChart);
  bvChart = new Chart(document.getElementById('bv-chart'), {
    type: 'scatter',
    data: {
      datasets: [
        {
          label: '데이터',
          data: bvData.xs.map((x, i) => ({x, y: bvData.ys[i]})),
          backgroundColor: '#64748b88',
          pointRadius: 5,
        },
        {
          label: '참 함수',
          data: curveX.map((x, i) => ({x, y: trueY[i]})),
          type: 'line',
          borderColor: '#22c55e',
          borderWidth: 2,
          borderDash: [6, 4],
          pointRadius: 0,
          fill: false,
        },
        {
          label: '모델 (차수=' + complexity + ')',
          data: curveX.map((x, i) => ({x, y: curveY[i]})),
          type: 'line',
          borderColor: '#2563eb',
          borderWidth: 2.5,
          pointRadius: 0,
          fill: false,
        },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      scales: {
        x: {min: -3.5, max: 3.5, title: {display: true, text: 'X'}},
        y: {min: -8, max: 8, title: {display: true, text: 'Y'}}
      },
      plugins: {legend: {position: 'bottom', labels: {font: {size: 11}}}}
    }
  });
}

// ==================== RIDGE vs LASSO ====================
let regFeatureNames = ['소득', '나이', '교육연수', '근속연수', '가족수', '노이즈1', '노이즈2', '노이즈3'];
let regTrueCoefs = [3.0, -1.5, 2.0, 1.2, -0.8, 0, 0, 0]; // last 3 are noise
let regX = [], regY = [];
let ridgeChart = null, lassoChart = null;

function generateRegData() {
  const n = 50;
  const p = regTrueCoefs.length;
  regX = [];
  regY = [];
  for (let i = 0; i < n; i++) {
    const row = [];
    for (let j = 0; j < p; j++) row.push((Math.random() - 0.5) * 2);
    regX.push(row);
    let y = 0;
    for (let j = 0; j < p; j++) y += regTrueCoefs[j] * row[j];
    y += (Math.random() - 0.5) * 2;
    regY.push(y);
  }
}

function ridgeCoefs(X, y, lambda) {
  const n = X.length, p = X[0].length;
  const XtX = Array.from({length: p}, () => new Array(p).fill(0));
  const XtY = new Array(p).fill(0);
  for (let i = 0; i < n; i++) {
    for (let j = 0; j < p; j++) {
      XtY[j] += X[i][j] * y[i];
      for (let k = 0; k < p; k++) XtX[j][k] += X[i][j] * X[i][k];
    }
  }
  for (let i = 0; i < p; i++) XtX[i][i] += lambda * n;
  const aug = XtX.map((row, i) => [...row, XtY[i]]);
  for (let i = 0; i < p; i++) {
    let maxRow = i;
    for (let k = i + 1; k < p; k++) if (Math.abs(aug[k][i]) > Math.abs(aug[maxRow][i])) maxRow = k;
    [aug[i], aug[maxRow]] = [aug[maxRow], aug[i]];
    if (Math.abs(aug[i][i]) < 1e-12) continue;
    for (let k = i + 1; k < p; k++) {
      const f = aug[k][i] / aug[i][i];
      for (let j = i; j <= p; j++) aug[k][j] -= f * aug[i][j];
    }
  }
  const coef = new Array(p).fill(0);
  for (let i = p - 1; i >= 0; i--) {
    coef[i] = aug[i][p];
    for (let j = i + 1; j < p; j++) coef[i] -= aug[i][j] * coef[j];
    coef[i] /= aug[i][i];
  }
  return coef;
}

function lassoCoefs(X, y, lambda, maxIter = 200) {
  const n = X.length, p = X[0].length;
  const coef = new Array(p).fill(0);
  const lr = 0.01;
  for (let iter = 0; iter < maxIter; iter++) {
    const grad = new Array(p).fill(0);
    for (let i = 0; i < n; i++) {
      let pred = 0;
      for (let j = 0; j < p; j++) pred += coef[j] * X[i][j];
      const err = pred - y[i];
      for (let j = 0; j < p; j++) grad[j] += (2 / n) * err * X[i][j];
    }
    for (let j = 0; j < p; j++) {
      coef[j] -= lr * grad[j];
      // Soft thresholding (proximal step for L1)
      const threshold = lr * lambda;
      if (coef[j] > threshold) coef[j] -= threshold;
      else if (coef[j] < -threshold) coef[j] += threshold;
      else coef[j] = 0;
    }
  }
  return coef;
}

function regMSE(X, y, coef) {
  let s = 0;
  for (let i = 0; i < X.length; i++) {
    let pred = 0;
    for (let j = 0; j < coef.length; j++) pred += coef[j] * X[i][j];
    s += (pred - y[i]) ** 2;
  }
  return s / X.length;
}

async function drawRegularization() {
  
  const logLambda = parseFloat(document.getElementById('reg-lambda').value);
  const lambda = Math.pow(10, logLambda);
  document.getElementById('reg-lambda-label').textContent = 'lambda: ' + lambda.toFixed(4);

  const rCoefs = ridgeCoefs(regX, regY, lambda);
  const lCoefs = lassoCoefs(regX, regY, lambda, 500);

  const colors = ['#2563eb', '#ef4444', '#22c55e', '#f59e0b', '#7c3aed', '#94a3b8', '#94a3b8', '#94a3b8'];

  ridgeChart = destroyChart(ridgeChart);
  ridgeChart = new Chart(document.getElementById('ridge-chart'), {
    type: 'bar',
    data: {
      labels: regFeatureNames,
      datasets: [{
        label: 'Ridge 계수',
        data: rCoefs,
        backgroundColor: colors.map(c => c + '88'),
        borderColor: colors,
        borderWidth: 2,
        borderRadius: 4,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      indexAxis: 'y',
      scales: {x: {min: -4, max: 4, title: {display: true, text: '계수 값'}}},
      plugins: {legend: {display: false}}
    }
  });

  lassoChart = destroyChart(lassoChart);
  lassoChart = new Chart(document.getElementById('lasso-chart'), {
    type: 'bar',
    data: {
      labels: regFeatureNames,
      datasets: [{
        label: 'Lasso 계수',
        data: lCoefs,
        backgroundColor: colors.map(c => c + '88'),
        borderColor: colors,
        borderWidth: 2,
        borderRadius: 4,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      indexAxis: 'y',
      scales: {x: {min: -4, max: 4, title: {display: true, text: '계수 값'}}},
      plugins: {legend: {display: false}}
    }
  });

  document.getElementById('ridge-nonzero').textContent = rCoefs.filter(c => Math.abs(c) > 0.01).length;
  document.getElementById('lasso-nonzero').textContent = lCoefs.filter(c => Math.abs(c) > 0.01).length;
  document.getElementById('ridge-mse').textContent = regMSE(regX, regY, rCoefs).toFixed(3);
  document.getElementById('lasso-mse').textContent = regMSE(regX, regY, lCoefs).toFixed(3);
}

// ==================== CROSS-VALIDATION ====================
let cvData = {xs: [], ys: []};
let cvChart = null;

function generateCVData() {
  cvData = {xs: [], ys: []};
  for (let i = 0; i < 50; i++) {
    const x = (i / 49) * 6 - 3;
    const trueY = Math.sin(x) * 2 + 0.3 * x;
    cvData.xs.push(x);
    cvData.ys.push(trueY + (Math.random() - 0.5) * 2);
  }
}

async function runCV(animate = false) {
  
  const K = parseInt(document.getElementById('cv-k').value);
  const degree = parseInt(document.getElementById('cv-degree').value);
  const n = cvData.xs.length;
  const foldSize = Math.floor(n / K);

  // Shuffle indices
  const indices = Array.from({length: n}, (_, i) => i);
  for (let i = n - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [indices[i], indices[j]] = [indices[j], indices[i]];
  }

  // Display fold blocks
  const blocksDiv = document.getElementById('cv-blocks');
  const foldColors = ['#2563eb', '#ef4444', '#22c55e', '#f59e0b', '#7c3aed', '#06b6d4', '#ec4899', '#64748b', '#ea580c', '#14b8a6'];

  const foldErrors = [];

  async function runFold(k) {
    const testIdx = indices.slice(k * foldSize, Math.min((k + 1) * foldSize, n));
    const trainIdx = indices.filter((_, i) => i < k * foldSize || i >= Math.min((k + 1) * foldSize, n));

    const trainX = trainIdx.map(i => cvData.xs[i]);
    const trainY = trainIdx.map(i => cvData.ys[i]);
    const testX = testIdx.map(i => cvData.xs[i]);
    const testY = testIdx.map(i => cvData.ys[i]);

    const coef = polyFit(trainX, trainY, degree);
    const testPred = testX.map(x => polyPredict(coef, x));
    const foldMSE = mse(testY, testPred);
    foldErrors.push(foldMSE);

    if (animate) {
      // Highlight current fold
      const blocks = blocksDiv.querySelectorAll('.cv-block');
      blocks.forEach((b, i) => {
        b.style.opacity = i === k ? '1' : '0.4';
        b.style.transform = i === k ? 'scale(1.05)' : 'scale(1)';
      });
      await new Promise(r => setTimeout(r, 600));
    }
  }

  // Render blocks
  let blocksHTML = '<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;">';
  for (let k = 0; k < K; k++) {
    blocksHTML += `<div class="cv-block" style="flex:1;min-width:60px;padding:10px;background:${foldColors[k % foldColors.length]}22;border:2px solid ${foldColors[k % foldColors.length]};border-radius:8px;text-align:center;font-size:.82rem;font-weight:700;transition:0.3s;">Fold ${k + 1}</div>`;
  }
  blocksHTML += '</div>';
  blocksDiv.innerHTML = blocksHTML;

  for (let k = 0; k < K; k++) {
    await runFold(k);
  }

  // Reset block styles
  blocksDiv.querySelectorAll('.cv-block').forEach((b, i) => {
    b.style.opacity = '1';
    b.style.transform = 'scale(1)';
    b.innerHTML = `Fold ${i + 1}<br><span style="font-size:.78rem;font-weight:400;">MSE: ${foldErrors[i] ? foldErrors[i].toFixed(2) : '-'}</span>`;
  });

  const meanError = foldErrors.reduce((a, b) => a + b, 0) / foldErrors.length;
  const stdError = Math.sqrt(foldErrors.reduce((a, e) => a + (e - meanError) ** 2, 0) / foldErrors.length);

  document.getElementById('cv-mean').textContent = meanError.toFixed(3);
  document.getElementById('cv-std').textContent = stdError.toFixed(3);
  document.getElementById('cv-k-display').textContent = K;
  document.getElementById('cv-fold-size').textContent = foldSize;

  // Bar chart of fold errors
  cvChart = destroyChart(cvChart);
  cvChart = new Chart(document.getElementById('cv-chart'), {
    type: 'bar',
    data: {
      labels: foldErrors.map((_, i) => 'Fold ' + (i + 1)),
      datasets: [
        {
          label: 'Fold별 테스트 MSE',
          data: foldErrors,
          backgroundColor: foldErrors.map((_, i) => foldColors[i % foldColors.length] + '88'),
          borderColor: foldErrors.map((_, i) => foldColors[i % foldColors.length]),
          borderWidth: 2,
          borderRadius: 6,
        },
        {
          label: '평균 CV MSE',
          data: foldErrors.map(() => meanError),
          type: 'line',
          borderColor: '#0f172a',
          borderWidth: 2,
          borderDash: [8, 4],
          pointRadius: 0,
          fill: false,
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      scales: {
        y: {beginAtZero: true, title: {display: true, text: 'MSE'}},
        x: {title: {display: true, text: 'Fold'}}
      },
      plugins: {legend: {position: 'bottom', labels: {font: {size: 11}}}}
    }
  });
}

// ==================== INIT ====================
(function() {
  generatePolyData();
  generateBVData();
  generateRegData();
  generateCVData();

  drawPolyFit();
  drawBV();
  drawRegularization();

  // Polynomial controls
  document.getElementById('poly-degree').addEventListener('input', drawPolyFit);
  document.getElementById('btn-poly-newdata').addEventListener('click', () => {
    generatePolyData();
    drawPolyFit();
  });

  // Bias-variance controls
  document.getElementById('bv-complexity').addEventListener('input', drawBV);
  document.getElementById('btn-bv-regen').addEventListener('click', () => {
    generateBVData();
    drawBV();
  });
  document.getElementById('btn-bv-under').addEventListener('click', () => {
    document.getElementById('bv-complexity').value = 1;
    drawBV();
  });
  document.getElementById('btn-bv-good').addEventListener('click', () => {
    document.getElementById('bv-complexity').value = 3;
    drawBV();
  });
  document.getElementById('btn-bv-over').addEventListener('click', () => {
    document.getElementById('bv-complexity').value = 15;
    drawBV();
  });

  // Regularization controls
  document.getElementById('reg-lambda').addEventListener('input', drawRegularization);
  document.getElementById('btn-reg-newdata').addEventListener('click', () => {
    generateRegData();
    drawRegularization();
  });

  // CV controls
  document.getElementById('btn-cv-run').addEventListener('click', () => runCV(false));
  document.getElementById('btn-cv-animate').addEventListener('click', () => runCV(true));
});
