<script is:inline>
// ==================== UTILITY FUNCTIONS ====================
function sigmoid(x) { return 1 / (1 + Math.exp(-Math.max(-500, Math.min(500, x)))); }
function relu(x) { return Math.max(0, x); }
function tanhAct(x) { return Math.tanh(x); }
function sigmoidDeriv(x) { const s = sigmoid(x); return s * (1 - s); }
function reluDeriv(x) { return x > 0 ? 1 : 0; }
function tanhDeriv(x) { const t = Math.tanh(x); return 1 - t * t; }

function randn() { let u = 0, v = 0; while (u === 0) u = Math.random(); while (v === 0) v = Math.random(); return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v); }
function randRange(a, b) { return a + Math.random() * (b - a); }

const el = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };

// ==================== DATASETS ====================
function generateCircle(n) {
  const data = [];
  for (let i = 0; i < n; i++) {
    const angle = Math.random() * Math.PI * 2;
    const inner = Math.random() < 0.5;
    const r = inner ? randRange(0, 0.5) : randRange(0.7, 1.2);
    data.push({ x: [Math.cos(angle) * r, Math.sin(angle) * r], y: inner ? 1 : 0 });
  }
  return data;
}

function generateXOR(n) {
  const data = [];
  for (let i = 0; i < n; i++) {
    const px = randRange(-1.5, 1.5), py = randRange(-1.5, 1.5);
    data.push({ x: [px, py], y: (px * py > 0) ? 1 : 0 });
  }
  return data;
}

function generateSpiral(n) {
  const data = [];
  const half = Math.floor(n / 2);
  for (let c = 0; c < 2; c++) {
    for (let i = 0; i < half; i++) {
      const t = i / half * 2 * Math.PI + c * Math.PI;
      const r = 0.4 + t * 0.12;
      data.push({ x: [r * Math.cos(t) + randn() * 0.08, r * Math.sin(t) + randn() * 0.08], y: c });
    }
  }
  return data;
}

function generateMoons(n) {
  const data = [];
  const half = Math.floor(n / 2);
  for (let i = 0; i < half; i++) {
    const angle = Math.PI * i / half;
    data.push({ x: [Math.cos(angle) + randn() * 0.1, Math.sin(angle) + randn() * 0.1], y: 0 });
    data.push({ x: [1 - Math.cos(angle) + randn() * 0.1, 0.5 - Math.sin(angle) + randn() * 0.1], y: 1 });
  }
  return data;
}

function getDataset(type, n = 200) {
  switch (type) {
    case 'circle': return generateCircle(n);
    case 'xor': return generateXOR(n);
    case 'spiral': return generateSpiral(n);
    case 'moons': return generateMoons(n);
    default: return generateXOR(n);
  }
}

// ==================== MULTI-LAYER NETWORK ====================
class MLPNetwork {
  constructor(layerSizes, activationType = 'relu', dropoutRate = 0) {
    this.layers = [];
    this.activationType = activationType;
    this.dropoutRate = dropoutRate;
    this.training = true;
    for (let i = 0; i < layerSizes.length - 1; i++) {
      const inp = layerSizes[i], out = layerSizes[i + 1];
      const scale = Math.sqrt(2.0 / inp);
      const w = Array.from({ length: out }, () => Array.from({ length: inp }, () => randn() * scale));
      const b = new Array(out).fill(0);
      this.layers.push({ w, b });
    }
  }

  activate(x, isOutput) {
    if (isOutput) return sigmoid(x);
    switch (this.activationType) {
      case 'relu': return relu(x);
      case 'sigmoid': return sigmoid(x);
      case 'tanh': return tanhAct(x);
      default: return relu(x);
    }
  }

  activateDerivFromOutput(a, isOutput) {
    if (isOutput) return a * (1 - a);
    switch (this.activationType) {
      case 'relu': return a > 0 ? 1 : 0;
      case 'sigmoid': return a * (1 - a);
      case 'tanh': return 1 - a * a;
      default: return a > 0 ? 1 : 0;
    }
  }

  forward(input) {
    let a = [...input];
    this.activations = [a];
    this.dropMasks = [];
    for (let l = 0; l < this.layers.length; l++) {
      const layer = this.layers[l];
      const isOutput = l === this.layers.length - 1;
      const next = [];
      for (let j = 0; j < layer.b.length; j++) {
        let z = layer.b[j];
        for (let k = 0; k < a.length; k++) z += layer.w[j][k] * a[k];
        next.push(this.activate(z, isOutput));
      }
      // Dropout (not on output layer)
      if (!isOutput && this.training && this.dropoutRate > 0) {
        const mask = next.map(() => Math.random() > this.dropoutRate ? 1 : 0);
        this.dropMasks.push(mask);
        for (let j = 0; j < next.length; j++) next[j] *= mask[j];
      } else {
        this.dropMasks.push(next.map(() => 1));
      }
      a = next;
      this.activations.push(a);
    }
    return a[0];
  }

  backward(input, target, lr) {
    const L = this.layers.length;
    const deltas = new Array(L);
    // Output layer delta
    const outA = this.activations[L];
    deltas[L - 1] = [outA[0] - target];
    // Hidden layers
    for (let l = L - 2; l >= 0; l--) {
      const nextLayer = this.layers[l + 1];
      const a = this.activations[l + 1];
      const d = [];
      for (let j = 0; j < this.layers[l].b.length; j++) {
        let err = 0;
        for (let k = 0; k < nextLayer.b.length; k++) err += nextLayer.w[k][j] * deltas[l + 1][k];
        const deriv = this.activateDerivFromOutput(a[j], false);
        d.push(err * deriv * this.dropMasks[l][j]);
      }
      deltas[l] = d;
    }
    // Update weights
    for (let l = 0; l < L; l++) {
      const a = this.activations[l];
      for (let j = 0; j < this.layers[l].b.length; j++) {
        for (let k = 0; k < a.length; k++) {
          this.layers[l].w[j][k] -= lr * deltas[l][j] * a[k];
        }
        this.layers[l].b[j] -= lr * deltas[l][j];
      }
    }
  }

  predict(input) {
    const prev = this.training;
    this.training = false;
    const out = this.forward(input);
    this.training = prev;
    return out >= 0.5 ? 1 : 0;
  }

  predictRaw(input) {
    const prev = this.training;
    this.training = false;
    const out = this.forward(input);
    this.training = prev;
    return out;
  }

  paramCount() {
    let c = 0;
    for (const l of this.layers) {
      c += l.b.length;
      for (const row of l.w) c += row.length;
    }
    return c;
  }
}

// ==================== DRAW BOUNDARY ====================
function drawBoundary(canvasId, net, data) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  // Find data bounds
  let minX = -2, maxX = 2, minY = -2, maxY = 2;
  if (data.length > 0) {
    const xs = data.map(d => d.x[0]), ys = data.map(d => d.x[1]);
    minX = Math.min(...xs) - 0.5; maxX = Math.max(...xs) + 0.5;
    minY = Math.min(...ys) - 0.5; maxY = Math.max(...ys) + 0.5;
  }

  // Decision boundary heatmap
  const step = 4;
  for (let py = 0; py < H; py += step) {
    for (let px = 0; px < W; px += step) {
      const x1 = minX + (px / W) * (maxX - minX);
      const x2 = maxY - (py / H) * (maxY - minY);
      const pred = net.predictRaw([x1, x2]);
      const r = Math.round(255 * (1 - pred));
      const b = Math.round(255 * pred);
      ctx.fillStyle = `rgba(${r}, 100, ${b}, 0.3)`;
      ctx.fillRect(px, py, step, step);
    }
  }

  // Data points
  data.forEach(d => {
    const px = ((d.x[0] - minX) / (maxX - minX)) * W;
    const py = (1 - (d.x[1] - minY) / (maxY - minY)) * H;
    ctx.beginPath();
    ctx.arc(px, py, 4, 0, Math.PI * 2);
    ctx.fillStyle = d.y === 1 ? '#2563eb' : '#ef4444';
    ctx.fill();
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 1;
    ctx.stroke();
  });
}

// ==================== CHART.JS LOADER ====================
let ChartJS = null;
async function loadChart() {
  if (ChartJS) return;
  const mod = await import('https://cdn.jsdelivr.net/npm/chart.js@4/+esm');
  ChartJS = mod.Chart;
}

// ==================== INTERACTIVE 1: MINI PLAYGROUND ====================
let pgNet = null;
let pgData = [];
let pgTraining = false;
let pgAnimFrame = null;
let pgLossChart = null;

function buildLayers(numLayers, neuronsPerLayer) {
  const sizes = [2];
  for (let i = 0; i < numLayers; i++) sizes.push(neuronsPerLayer);
  sizes.push(1);
  return sizes;
}

async function setupPlayground() {
  await loadChart();

  function createNet() {
    const layers = parseInt(document.getElementById('pg-layers').value);
    const neurons = parseInt(document.getElementById('pg-neurons').value);
    const act = document.getElementById('pg-activation').value;
    pgNet = new MLPNetwork(buildLayers(layers, neurons), act, 0);
    el('pg-params', pgNet.paramCount().toString());
  }

  function createData() {
    pgData = getDataset(document.getElementById('pg-dataset').value, 200);
  }

  createData();
  createNet();
  drawBoundary('pg-canvas', pgNet, pgData);

  document.getElementById('pg-lr').addEventListener('input', function () {
    el('pg-lr-val', parseFloat(this.value).toFixed(3));
  });

  document.getElementById('btn-pg-train').addEventListener('click', () => {
    if (pgTraining) return;
    pgTraining = true;
    const lr = parseFloat(document.getElementById('pg-lr').value);
    let epoch = 0;
    const maxEpochs = 600;
    const lossHistory = [];

    function step() {
      if (!pgTraining || epoch >= maxEpochs) { pgTraining = false; return; }
      for (let i = 0; i < 5 && epoch < maxEpochs; i++) {
        let totalLoss = 0;
        const shuffled = [...pgData].sort(() => Math.random() - 0.5);
        shuffled.forEach(d => {
          const out = pgNet.forward(d.x);
          const eps = 1e-7;
          totalLoss += -(d.y * Math.log(out + eps) + (1 - d.y) * Math.log(1 - out + eps));
          pgNet.backward(d.x, d.y, lr);
        });
        lossHistory.push(totalLoss / pgData.length);
        epoch++;
      }
      let correct = 0;
      pgData.forEach(d => { if (pgNet.predict(d.x) === d.y) correct++; });
      el('pg-epoch', epoch.toString());
      el('pg-loss', lossHistory[lossHistory.length - 1].toFixed(4));
      el('pg-acc', Math.round(correct / pgData.length * 100) + '%');
      drawBoundary('pg-canvas', pgNet, pgData);
      updatePgLossChart(lossHistory);
      pgAnimFrame = requestAnimationFrame(step);
    }
    step();
  });

  document.getElementById('btn-pg-reset').addEventListener('click', () => {
    pgTraining = false;
    if (pgAnimFrame) cancelAnimationFrame(pgAnimFrame);
    createData(); createNet();
    el('pg-epoch', '0'); el('pg-loss', '-'); el('pg-acc', '-');
    if (pgLossChart) { pgLossChart.destroy(); pgLossChart = null; }
    drawBoundary('pg-canvas', pgNet, pgData);
  });

  ['pg-dataset', 'pg-layers', 'pg-neurons', 'pg-activation'].forEach(id => {
    document.getElementById(id).addEventListener('change', () => {
      if (!pgTraining) {
        if (id === 'pg-dataset') createData();
        createNet();
        el('pg-epoch', '0'); el('pg-loss', '-'); el('pg-acc', '-');
        if (pgLossChart) { pgLossChart.destroy(); pgLossChart = null; }
        drawBoundary('pg-canvas', pgNet, pgData);
      }
    });
  });
}

function updatePgLossChart(hist) {
  const canvas = document.getElementById('pg-loss-chart');
  if (!canvas || !ChartJS) return;
  const labels = hist.map((_, i) => i + 1);
  if (pgLossChart) {
    pgLossChart.data.labels = labels;
    pgLossChart.data.datasets[0].data = hist;
    pgLossChart.update('none');
  } else {
    pgLossChart = new ChartJS(canvas, {
      type: 'line',
      data: { labels, datasets: [{ label: '손실', data: hist, borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.1)', fill: true, pointRadius: 0, borderWidth: 2 }] },
      options: {
        responsive: true, maintainAspectRatio: false, animation: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { title: { display: true, text: '에포크', font: { family: "'Paperlogy'" } }, ticks: { maxTicksLimit: 6, font: { size: 10 } } },
          y: { title: { display: true, text: '손실', font: { family: "'Paperlogy'" } }, beginAtZero: true, ticks: { font: { size: 10 } } }
        }
      }
    });
  }
}

// ==================== INTERACTIVE 2: DEPTH EXPERIMENT ====================
let depthChart = null;
let depthTraining = false;
let depthAnimFrame = null;

async function setupDepthExperiment() {
  await loadChart();

  document.getElementById('btn-depth-run').addEventListener('click', () => {
    if (depthTraining) return;
    depthTraining = true;

    const total = parseInt(document.getElementById('depth-total').value);
    const dsType = document.getElementById('depth-dataset').value;
    const data = getDataset(dsType, 200);

    // Three configs with same total neurons
    const configs = [
      { layers: buildLayers(1, total), label: '1층 (' + total + ')' },
      { layers: buildLayers(2, Math.round(total / 2)), label: '2층 (' + Math.round(total / 2) + 'x2)' },
      { layers: buildLayers(3, Math.round(total / 3)), label: '3층 (' + Math.round(total / 3) + 'x3)' }
    ];
    const nets = configs.map(c => new MLPNetwork(c.layers, 'relu', 0));
    const histories = [[], [], []];
    let epoch = 0;
    const maxEpochs = 400;
    const lr = 0.03;

    function step() {
      if (!depthTraining || epoch >= maxEpochs) {
        depthTraining = false;
        // Final accuracies
        nets.forEach((net, i) => {
          let correct = 0;
          data.forEach(d => { if (net.predict(d.x) === d.y) correct++; });
          el('depth-acc' + (i + 1), Math.round(correct / data.length * 100) + '%');
        });
        return;
      }

      for (let rep = 0; rep < 5 && epoch < maxEpochs; rep++) {
        const shuffled = [...data].sort(() => Math.random() - 0.5);
        nets.forEach((net, idx) => {
          let totalLoss = 0;
          shuffled.forEach(d => {
            const out = net.forward(d.x);
            const eps = 1e-7;
            totalLoss += -(d.y * Math.log(out + eps) + (1 - d.y) * Math.log(1 - out + eps));
            net.backward(d.x, d.y, lr);
          });
          histories[idx].push(totalLoss / data.length);
        });
        epoch++;
      }

      // Draw boundaries
      drawBoundary('depth-canvas1', nets[0], data);
      drawBoundary('depth-canvas2', nets[1], data);
      drawBoundary('depth-canvas3', nets[2], data);

      // Update accuracies
      nets.forEach((net, i) => {
        let correct = 0;
        data.forEach(d => { if (net.predict(d.x) === d.y) correct++; });
        el('depth-acc' + (i + 1), Math.round(correct / data.length * 100) + '%');
      });

      updateDepthChart(histories, configs);
      depthAnimFrame = requestAnimationFrame(step);
    }
    step();
  });

  document.getElementById('btn-depth-reset').addEventListener('click', () => {
    depthTraining = false;
    if (depthAnimFrame) cancelAnimationFrame(depthAnimFrame);
    if (depthChart) { depthChart.destroy(); depthChart = null; }
    ['depth-acc1', 'depth-acc2', 'depth-acc3'].forEach(id => el(id, '-'));
    ['depth-canvas1', 'depth-canvas2', 'depth-canvas3'].forEach(cid => {
      const c = document.getElementById(cid);
      if (c) c.getContext('2d').clearRect(0, 0, c.width, c.height);
    });
  });
}

function updateDepthChart(histories, configs) {
  const canvas = document.getElementById('depth-chart');
  if (!canvas || !ChartJS) return;
  const colors = ['#2563eb', '#22c55e', '#f59e0b'];
  const labels = histories[0].map((_, i) => i + 1);
  const datasets = histories.map((h, i) => ({
    label: configs[i].label,
    data: h,
    borderColor: colors[i],
    backgroundColor: 'transparent',
    pointRadius: 0,
    borderWidth: 2
  }));

  if (depthChart) {
    depthChart.data.labels = labels;
    depthChart.data.datasets = datasets;
    depthChart.update('none');
  } else {
    depthChart = new ChartJS(canvas, {
      type: 'line',
      data: { labels, datasets },
      options: {
        responsive: true, maintainAspectRatio: false, animation: false,
        plugins: { legend: { labels: { font: { family: "'Paperlogy'", size: 12 } } } },
        scales: {
          x: { title: { display: true, text: '에포크', font: { family: "'Paperlogy'" } }, ticks: { maxTicksLimit: 6, font: { size: 10 } } },
          y: { title: { display: true, text: '손실', font: { family: "'Paperlogy'" } }, beginAtZero: true, ticks: { font: { size: 10 } } }
        }
      }
    });
  }
}

// ==================== INTERACTIVE 3: DROPOUT DEMO ====================
let doChart = null;
let doRunning = false;
let doAnimFrame = null;

async function setupDropoutDemo() {
  await loadChart();

  document.getElementById('do-rate').addEventListener('input', function () {
    el('do-rate-val', parseFloat(this.value).toFixed(2));
  });

  document.getElementById('btn-do-run').addEventListener('click', () => {
    if (doRunning) return;
    doRunning = true;

    const dsType = document.getElementById('do-dataset').value;
    const neurons = parseInt(document.getElementById('do-neurons').value);
    const dropRate = parseFloat(document.getElementById('do-rate').value);

    // Generate data: 70% train, 30% test
    const allData = getDataset(dsType, 300);
    const shuffled = [...allData].sort(() => Math.random() - 0.5);
    const split = Math.floor(shuffled.length * 0.7);
    const trainData = shuffled.slice(0, split);
    const testData = shuffled.slice(split);

    const netOff = new MLPNetwork(buildLayers(2, neurons), 'relu', 0);
    const netOn = new MLPNetwork(buildLayers(2, neurons), 'relu', dropRate);

    const trainAccOff = [], testAccOff = [];
    const trainAccOn = [], testAccOn = [];
    let epoch = 0;
    const maxEpochs = 300;
    const lr = 0.03;

    function calcAcc(net, data) {
      let correct = 0;
      data.forEach(d => { if (net.predict(d.x) === d.y) correct++; });
      return correct / data.length * 100;
    }

    function step() {
      if (!doRunning || epoch >= maxEpochs) {
        doRunning = false;
        return;
      }

      for (let rep = 0; rep < 5 && epoch < maxEpochs; rep++) {
        const sh = [...trainData].sort(() => Math.random() - 0.5);
        [netOff, netOn].forEach(net => {
          sh.forEach(d => {
            net.forward(d.x);
            net.backward(d.x, d.y, lr);
          });
        });
        trainAccOff.push(calcAcc(netOff, trainData));
        testAccOff.push(calcAcc(netOff, testData));
        trainAccOn.push(calcAcc(netOn, trainData));
        testAccOn.push(calcAcc(netOn, testData));
        epoch++;
      }

      el('do-train-off', Math.round(trainAccOff[trainAccOff.length - 1]) + '%');
      el('do-test-off', Math.round(testAccOff[testAccOff.length - 1]) + '%');
      el('do-train-on', Math.round(trainAccOn[trainAccOn.length - 1]) + '%');
      el('do-test-on', Math.round(testAccOn[testAccOn.length - 1]) + '%');

      updateDoChart(trainAccOff, testAccOff, trainAccOn, testAccOn);
      doAnimFrame = requestAnimationFrame(step);
    }
    step();
  });
}

function updateDoChart(trOff, tsOff, trOn, tsOn) {
  const canvas = document.getElementById('do-chart');
  if (!canvas || !ChartJS) return;
  const labels = trOff.map((_, i) => i + 1);
  const datasets = [
    { label: 'OFF: 훈련', data: trOff, borderColor: '#ef4444', borderDash: [], pointRadius: 0, borderWidth: 2, backgroundColor: 'transparent' },
    { label: 'OFF: 테스트', data: tsOff, borderColor: '#ef4444', borderDash: [5, 5], pointRadius: 0, borderWidth: 2, backgroundColor: 'transparent' },
    { label: 'ON: 훈련', data: trOn, borderColor: '#2563eb', borderDash: [], pointRadius: 0, borderWidth: 2, backgroundColor: 'transparent' },
    { label: 'ON: 테스트', data: tsOn, borderColor: '#2563eb', borderDash: [5, 5], pointRadius: 0, borderWidth: 2, backgroundColor: 'transparent' }
  ];

  if (doChart) {
    doChart.data.labels = labels;
    doChart.data.datasets = datasets;
    doChart.update('none');
  } else {
    doChart = new ChartJS(canvas, {
      type: 'line',
      data: { labels, datasets },
      options: {
        responsive: true, maintainAspectRatio: false, animation: false,
        plugins: { legend: { labels: { font: { family: "'Paperlogy'", size: 11 } } } },
        scales: {
          x: { title: { display: true, text: '에포크', font: { family: "'Paperlogy'" } }, ticks: { maxTicksLimit: 6, font: { size: 10 } } },
          y: { title: { display: true, text: '정확도 (%)', font: { family: "'Paperlogy'" } }, min: 40, max: 105, ticks: { font: { size: 10 } } }
        }
      }
    });
  }
}

// ==================== INTERACTIVE 4: LEARNING RATE FINDER ====================
let lrfChart = null;
let lrfRunning = false;
let lrfAnimFrame = null;

async function setupLRFinder() {
  await loadChart();

  const midSlider = document.getElementById('lrf-mid');
  midSlider.addEventListener('input', function () {
    el('lrf-mid-val', Math.pow(10, parseFloat(this.value)).toFixed(3));
  });

  document.getElementById('btn-lrf-run').addEventListener('click', () => {
    if (lrfRunning) return;
    lrfRunning = true;
    if (lrfChart) { lrfChart.destroy(); lrfChart = null; }

    const data = getDataset('moons', 200);
    const midLR = Math.pow(10, parseFloat(midSlider.value));
    const smallLR = 0.0005;
    const largeLR = 0.8;

    el('lrf-small-val', smallLR.toFixed(4));
    el('lrf-large-val', largeLR.toFixed(3));

    const nets = [
      new MLPNetwork(buildLayers(2, 6), 'relu', 0),
      new MLPNetwork(buildLayers(2, 6), 'relu', 0),
      new MLPNetwork(buildLayers(2, 6), 'relu', 0)
    ];
    const lrs = [smallLR, midLR, largeLR];
    const histories = [[], [], []];
    let epoch = 0;
    const maxEpochs = 300;

    function step() {
      if (!lrfRunning || epoch >= maxEpochs) {
        lrfRunning = false;
        histories.forEach((h, i) => {
          const ids = ['lrf-loss-small', 'lrf-loss-mid', 'lrf-loss-large'];
          el(ids[i], h.length > 0 ? h[h.length - 1].toFixed(4) : '-');
        });
        return;
      }

      for (let rep = 0; rep < 5 && epoch < maxEpochs; rep++) {
        const sh = [...data].sort(() => Math.random() - 0.5);
        nets.forEach((net, idx) => {
          let totalLoss = 0;
          sh.forEach(d => {
            const out = net.forward(d.x);
            const eps = 1e-7;
            totalLoss += -(d.y * Math.log(Math.max(out, eps)) + (1 - d.y) * Math.log(Math.max(1 - out, eps)));
            net.backward(d.x, d.y, lrs[idx]);
          });
          const avgLoss = Math.min(totalLoss / data.length, 5);
          histories[idx].push(avgLoss);
        });
        epoch++;
      }

      histories.forEach((h, i) => {
        const ids = ['lrf-loss-small', 'lrf-loss-mid', 'lrf-loss-large'];
        el(ids[i], h.length > 0 ? h[h.length - 1].toFixed(4) : '-');
      });

      updateLRFChart(histories, lrs);
      lrfAnimFrame = requestAnimationFrame(step);
    }
    step();
  });

  document.getElementById('btn-lrf-reset').addEventListener('click', () => {
    lrfRunning = false;
    if (lrfAnimFrame) cancelAnimationFrame(lrfAnimFrame);
    if (lrfChart) { lrfChart.destroy(); lrfChart = null; }
    ['lrf-loss-small', 'lrf-loss-mid', 'lrf-loss-large'].forEach(id => el(id, '-'));
  });
}

function updateLRFChart(histories, lrs) {
  const canvas = document.getElementById('lrf-chart');
  if (!canvas || !ChartJS) return;
  const labels = histories[0].map((_, i) => i + 1);
  const colors = ['#94a3b8', '#2563eb', '#ef4444'];
  const names = ['lr=' + lrs[0].toFixed(4) + ' (작음)', 'lr=' + lrs[1].toFixed(3) + ' (적절)', 'lr=' + lrs[2].toFixed(3) + ' (큼)'];
  const datasets = histories.map((h, i) => ({
    label: names[i], data: h, borderColor: colors[i], backgroundColor: 'transparent',
    pointRadius: 0, borderWidth: 2, borderDash: i === 0 ? [5, 5] : []
  }));

  if (lrfChart) {
    lrfChart.data.labels = labels;
    lrfChart.data.datasets = datasets;
    lrfChart.update('none');
  } else {
    lrfChart = new ChartJS(canvas, {
      type: 'line',
      data: { labels, datasets },
      options: {
        responsive: true, maintainAspectRatio: false, animation: false,
        plugins: { legend: { labels: { font: { family: "'Paperlogy'", size: 11 } } } },
        scales: {
          x: { title: { display: true, text: '에포크', font: { family: "'Paperlogy'" } }, ticks: { maxTicksLimit: 6, font: { size: 10 } } },
          y: { title: { display: true, text: '손실', font: { family: "'Paperlogy'" } }, min: 0, max: 2.5, ticks: { font: { size: 10 } } }
        }
      }
    });
  }
}

