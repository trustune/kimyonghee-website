function init() {
  import('../../textbook/lib/progress').then(m => m.markVisited('29-pca')).catch(() => {});

  generatePcaData();
  setupPca2DDrag();

  document.getElementById('btn-pca2d-reset').addEventListener('click', generatePcaData);
  document.getElementById('sel-pca2d-corr').addEventListener('change', generatePcaData);
  document.getElementById('btn-pca2d-snap').addEventListener('click', animateToOptimal);

  document.getElementById('btn-scree-run').addEventListener('click', runScreePlot);
  document.getElementById('btn-biplot').addEventListener('click', generateBiplot);

  generateImage();
  document.getElementById('btn-img-gen').addEventListener('click', generateImage);
  document.getElementById('slider-img-pc').addEventListener('input', drawImagePair);
}

document.addEventListener('DOMContentLoaded', init);
document.addEventListener('astro:page-load', init);
