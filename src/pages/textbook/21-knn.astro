<script is:inline>

function waitForChart(fn) {
  if (typeof Chart !== 'undefined') { fn(); return; }
  var s = document.querySelector('script[src*="chart.js"]');
  if (s) { s.addEventListener('load', fn); return; }
  setTimeoutwaitForChart(function() { waitForChart(fn); }, 50);
}

// ==================== UTILITY ====================

function destroyChart(ref) {
  if (ref && ref.destroy) ref.destroy();
  return null;
}

function euclideanDist(a, b) {
  let s = 0;
  for (let i = 0; i < a.length; i++) s += (a[i] - b[i]) ** 2;
  return Math.sqrt(s);
}

function manhattanDist(a, b) {
  let s = 0;
  for (let i = 0; i < a.length; i++) s += Math.abs(a[i] - b[i]);
  return s;
}

function knnClassify(trainX, trainY, point, k, distFn) {
  const dists = trainX.map((x, i) => ({dist: distFn(x, point), label: trainY[i]}));
  dists.sort((a, b) => a.dist - b.dist);
  const neighbors = dists.slice(0, k);
  const counts = {};
  neighbors.forEach(n => { counts[n.label] = (counts[n.label] || 0) + 1; });
  let maxLabel = neighbors[0].label, maxCount = 0;
  for (const [label, count] of Object.entries(counts)) {
    if (count > maxCount) { maxCount = count; maxLabel = parseInt(label); }
  }
  return {label: maxLabel, neighbors};
}

// ==================== INTERACTIVE 1: 2D KNN Canvas ===== ====================
let knnPoints = {red: [], blue: [], classified: []};

function getCanvasCoords(canvas, e) {
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.width / rect.width;
  const scaleY = canvas.height / rect.height;
  return {
    x: (e.clientX - rect.left) * scaleX,
    y: (e.clientY - rect.top) * scaleY
  };
}

function drawKNNCanvas() {
  const canvas = document.getElementById('knn-canvas');
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  // Draw grid
  ctx.strokeStyle = '#e2e8f0';
  ctx.lineWidth = 0.5;
  for (let x = 0; x < canvas.width; x += 50) {
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
  }
  for (let y = 0; y < canvas.height; y += 50) {
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
  }

  // Draw points
  knnPoints.red.forEach(p => {
    ctx.beginPath();
    ctx.arc(p.x, p.y, 6, 0, Math.PI * 2);
    ctx.fillStyle = '#ef4444';
    ctx.fill();
    ctx.strokeStyle = '#991b1b';
    ctx.lineWidth = 1.5;
    ctx.stroke();
  });

  knnPoints.blue.forEach(p => {
    ctx.beginPath();
    ctx.arc(p.x, p.y, 6, 0, Math.PI * 2);
    ctx.fillStyle = '#2563eb';
    ctx.fill();
    ctx.strokeStyle = '#1e3a8a';
    ctx.lineWidth = 1.5;
    ctx.stroke();
  });

  // Draw classified points
  knnPoints.classified.forEach(p => {
    // Draw neighbor lines
    if (p.neighbors) {
      p.neighbors.forEach(n => {
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
        ctx.lineTo(n.x, n.y);
        ctx.strokeStyle = '#94a3b888';
        ctx.lineWidth = 1;
        ctx.stroke();
      });
    }

    ctx.beginPath();
    ctx.arc(p.x, p.y, 8, 0, Math.PI * 2);
    ctx.fillStyle = p.label === 0 ? '#ef444488' : '#2563eb88';
    ctx.fill();
    ctx.strokeStyle = p.label === 0 ? '#ef4444' : '#2563eb';
    ctx.lineWidth = 2;
    ctx.setLineDash([4, 3]);
    ctx.stroke();
    ctx.setLineDash([]);

    // ? marker
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 10px sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('?', p.x, p.y);
  });

  // Update stats
  document.getElementById('knn-red-count').textContent = knnPoints.red.length;
  document.getElementById('knn-blue-count').textContent = knnPoints.blue.length;
  document.getElementById('knn-classified').textContent = knnPoints.classified.length;
  document.getElementById('knn-k-display').textContent = document.getElementById('knn-k').value;
}

function classifyPoint(px, py) {
  const k = parseInt(document.getElementById('knn-k').value);
  const allPoints = [
    ...knnPoints.red.map(p => ({...p, label: 0})),
    ...knnPoints.blue.map(p => ({...p, label: 1}))
  ];
  if (allPoints.length < k) return;

  const trainX = allPoints.map(p => [p.x, p.y]);
  const trainY = allPoints.map(p => p.label);
  const result = knnClassify(trainX, trainY, [px, py], k, euclideanDist);

  const neighborPoints = [];
  const dists = allPoints.map((p, i) => ({dist: euclideanDist([p.x, p.y], [px, py]), idx: i}));
  dists.sort((a, b) => a.dist - b.dist);
  for (let i = 0; i < k; i++) {
    neighborPoints.push(allPoints[dists[i].idx]);
  }

  knnPoints.classified.push({x: px, y: py, label: result.label, neighbors: neighborPoints});
  drawKNNCanvas();
}

function drawDecisionBoundary() {
  const canvas = document.getElementById('knn-canvas');
  const ctx = canvas.getContext('2d');
  const k = parseInt(document.getElementById('knn-k').value);
  const allPoints = [
    ...knnPoints.red.map(p => ({...p, label: 0})),
    ...knnPoints.blue.map(p => ({...p, label: 1}))
  ];
  if (allPoints.length < k) return;

  const trainX = allPoints.map(p => [p.x, p.y]);
  const trainY = allPoints.map(p => p.label);
  const step = 8;

  for (let x = 0; x < canvas.width; x += step) {
    for (let y = 0; y < canvas.height; y += step) {
      const result = knnClassify(trainX, trainY, [x, y], k, euclideanDist);
      ctx.fillStyle = result.label === 0 ? 'rgba(239,68,68,0.08)' : 'rgba(37,99,235,0.08)';
      ctx.fillRect(x, y, step, step);
    }
  }

  drawKNNCanvas();
}

// ==================== INTERACTIVE 2: K Effect ====================
let keffectData = {points: [], labels: []};

function generateKEffectData() {
  keffectData = {points: [], labels: []};
  // Two-moon shaped clusters
  for (let i = 0; i < 80; i++) {
    const angle = Math.PI * Math.random();
    const r = 100 + (Math.random() - 0.5) * 40;
    keffectData.points.push([140 + r * Math.cos(angle), 140 - r * Math.sin(angle)]);
    keffectData.labels.push(0);
  }
  for (let i = 0; i < 80; i++) {
    const angle = Math.PI + Math.PI * Math.random();
    const r = 100 + (Math.random() - 0.5) * 40;
    keffectData.points.push([140 + r * Math.cos(angle), 100 - r * Math.sin(angle)]);
    keffectData.labels.push(1);
  }
}

function drawKEffectBoundary(canvasId, k) {
  const canvas = document.getElementById(canvasId);
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  const step = 6;
  let correct = 0, total = 0;

  // Draw boundary
  for (let x = 0; x < canvas.width; x += step) {
    for (let y = 0; y < canvas.height; y += step) {
      const result = knnClassify(keffectData.points, keffectData.labels, [x, y], k, euclideanDist);
      ctx.fillStyle = result.label === 0 ? 'rgba(239,68,68,0.12)' : 'rgba(37,99,235,0.12)';
      ctx.fillRect(x, y, step, step);
    }
  }

  // Leave-one-out accuracy
  for (let i = 0; i < keffectData.points.length; i++) {
    const trainX = keffectData.points.filter((_, j) => j !== i);
    const trainY = keffectData.labels.filter((_, j) => j !== i);
    const result = knnClassify(trainX, trainY, keffectData.points[i], k, euclideanDist);
    if (result.label === keffectData.labels[i]) correct++;
    total++;
  }

  // Draw points
  keffectData.points.forEach((p, i) => {
    ctx.beginPath();
    ctx.arc(p[0], p[1], 3, 0, Math.PI * 2);
    ctx.fillStyle = keffectData.labels[i] === 0 ? '#ef4444' : '#2563eb';
    ctx.fill();
  });

  return (correct / total * 100).toFixed(1);
}

let keffectAccChart = null;

async function runKEffectComparison() {
  
  const acc1 = drawKEffectBoundary('keffect-k1', 1);
  const acc5 = drawKEffectBoundary('keffect-k5', 5);
  const acc50 = drawKEffectBoundary('keffect-k50', Math.min(50, keffectData.points.length - 1));

  document.getElementById('keffect-acc1').textContent = acc1 + '%';
  document.getElementById('keffect-acc5').textContent = acc5 + '%';
  document.getElementById('keffect-acc50').textContent = acc50 + '%';

  // Accuracy vs K chart
  const ks = [1, 3, 5, 7, 9, 11, 15, 21, 31, 51];
  const accs = ks.map(k => {
    let correct = 0;
    const kk = Math.min(k, keffectData.points.length - 1);
    for (let i = 0; i < keffectData.points.length; i++) {
      const trainX = keffectData.points.filter((_, j) => j !== i);
      const trainY = keffectData.labels.filter((_, j) => j !== i);
      const result = knnClassify(trainX, trainY, keffectData.points[i], kk, euclideanDist);
      if (result.label === keffectData.labels[i]) correct++;
    }
    return (correct / keffectData.points.length * 100);
  });

  keffectAccChart = destroyChart(keffectAccChart);
  keffectAccChart = new Chart(document.getElementById('keffect-accuracy-chart'), {
    type: 'line',
    data: {
      labels: ks,
      datasets: [{
        label: '정확도 (%)',
        data: accs,
        borderColor: '#2563eb',
        backgroundColor: '#2563eb22',
        fill: true,
        tension: 0.3,
        pointRadius: 5,
        pointBackgroundColor: '#2563eb',
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      scales: {
        x: {title: {display: true, text: 'K'}},
        y: {min: 50, max: 100, title: {display: true, text: '정확도 (%)'}}
      },
      plugins: {legend: {display: false}}
    }
  });
}

// ==================== INTERACTIVE 3: Distance Metric ====================
let distData = {points: [], labels: []};

function generateDistData() {
  distData = {points: [], labels: []};
  // Cluster 1: top-left
  for (let i = 0; i < 40; i++) {
    distData.points.push([80 + (Math.random() - 0.5) * 80, 80 + (Math.random() - 0.5) * 80]);
    distData.labels.push(0);
  }
  // Cluster 2: bottom-right
  for (let i = 0; i < 40; i++) {
    distData.points.push([250 + (Math.random() - 0.5) * 80, 250 + (Math.random() - 0.5) * 80]);
    distData.labels.push(1);
  }
  // Some overlap in the middle
  for (let i = 0; i < 20; i++) {
    distData.points.push([170 + (Math.random() - 0.5) * 60, 170 + (Math.random() - 0.5) * 60]);
    distData.labels.push(Math.random() < 0.5 ? 0 : 1);
  }
}

function drawDistMetric(canvasId, distFn) {
  const canvas = document.getElementById(canvasId);
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  const k = parseInt(document.getElementById('dist-k').value);
  const step = 6;
  let correct = 0;

  // Boundary
  for (let x = 0; x < canvas.width; x += step) {
    for (let y = 0; y < canvas.height; y += step) {
      const result = knnClassify(distData.points, distData.labels, [x, y], k, distFn);
      ctx.fillStyle = result.label === 0 ? 'rgba(239,68,68,0.1)' : 'rgba(37,99,235,0.1)';
      ctx.fillRect(x, y, step, step);
    }
  }

  // LOO accuracy
  for (let i = 0; i < distData.points.length; i++) {
    const trainX = distData.points.filter((_, j) => j !== i);
    const trainY = distData.labels.filter((_, j) => j !== i);
    const result = knnClassify(trainX, trainY, distData.points[i], k, distFn);
    if (result.label === distData.labels[i]) correct++;
  }

  // Points
  distData.points.forEach((p, i) => {
    ctx.beginPath();
    ctx.arc(p[0], p[1], 4, 0, Math.PI * 2);
    ctx.fillStyle = distData.labels[i] === 0 ? '#ef4444' : '#2563eb';
    ctx.fill();
  });

  return (correct / distData.points.length * 100).toFixed(1);
}

function runDistComparison() {
  document.getElementById('dist-k-label').textContent = 'K=' + document.getElementById('dist-k').value;
  const eucAcc = drawDistMetric('dist-euclidean-canvas', euclideanDist);
  const manAcc = drawDistMetric('dist-manhattan-canvas', manhattanDist);
  document.getElementById('dist-euc-acc').textContent = eucAcc + '%';
  document.getElementById('dist-man-acc').textContent = manAcc + '%';
}

// ==================== INTERACTIVE 4: Curse of Dimensionality ====================
let curseDist = null, curseRatio = null;

async function runCurseSim() {
  
  const dim = parseInt(document.getElementById('curse-dim').value);
  const n = parseInt(document.getElementById('curse-n').value);
  document.getElementById('curse-dim-label').textContent = '차원: ' + dim;

  // Generate random points in [0,1]^dim
  const points = [];
  for (let i = 0; i < n; i++) {
    const p = [];
    for (let d = 0; d < dim; d++) p.push(Math.random());
    points.push(p);
  }

  // For each point, find nearest and farthest distance
  let nearestSum = 0, farthestSum = 0;
  const nearests = [], farthests = [];
  for (let i = 0; i < Math.min(n, 30); i++) {
    let minDist = Infinity, maxDist = 0;
    for (let j = 0; j < n; j++) {
      if (i === j) continue;
      const d = euclideanDist(points[i], points[j]);
      if (d < minDist) minDist = d;
      if (d > maxDist) maxDist = d;
    }
    nearestSum += minDist;
    farthestSum += maxDist;
    nearests.push(minDist);
    farthests.push(maxDist);
  }

  const count = Math.min(n, 30);
  const avgNearest = nearestSum / count;
  const avgFarthest = farthestSum / count;
  const ratio = avgNearest / avgFarthest;

  document.getElementById('curse-dim-display').textContent = dim;
  document.getElementById('curse-nearest').textContent = avgNearest.toFixed(3);
  document.getElementById('curse-farthest').textContent = avgFarthest.toFixed(3);
  document.getElementById('curse-ratio').textContent = ratio.toFixed(4);

  // Chart: distances across dimensions
  const dims = [1, 2, 5, 10, 20, 50, 100, 200].filter(d => d <= Math.max(dim, 10));
  if (!dims.includes(dim) && dim <= 200) dims.push(dim);
  dims.sort((a, b) => a - b);

  const nearestByDim = [];
  const farthestByDim = [];
  const ratioByDim = [];

  for (const d of dims) {
    const pts = [];
    for (let i = 0; i < Math.min(n, 50); i++) {
      const p = [];
      for (let dd = 0; dd < d; dd++) p.push(Math.random());
      pts.push(p);
    }
    let nSum = 0, fSum = 0;
    const sampleN = Math.min(pts.length, 20);
    for (let i = 0; i < sampleN; i++) {
      let mn = Infinity, mx = 0;
      for (let j = 0; j < pts.length; j++) {
        if (i === j) continue;
        const dist = euclideanDist(pts[i], pts[j]);
        if (dist < mn) mn = dist;
        if (dist > mx) mx = dist;
      }
      nSum += mn;
      fSum += mx;
    }
    nearestByDim.push(nSum / sampleN);
    farthestByDim.push(fSum / sampleN);
    ratioByDim.push((nSum / sampleN) / (fSum / sampleN));
  }

  curseDist = destroyChart(curseDist);
  curseDist = new Chart(document.getElementById('curse-dist-chart'), {
    type: 'line',
    data: {
      labels: dims,
      datasets: [
        {label: '최근접 거리', data: nearestByDim, borderColor: '#2563eb', tension: 0.3, pointRadius: 4},
        {label: '최원접 거리', data: farthestByDim, borderColor: '#ef4444', tension: 0.3, pointRadius: 4},
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      scales: {
        x: {title: {display: true, text: '차원 수'}},
        y: {beginAtZero: true, title: {display: true, text: '거리'}}
      },
      plugins: {legend: {position: 'bottom', labels: {font: {size: 11}}}}
    }
  });

  curseRatio = destroyChart(curseRatio);
  curseRatio = new Chart(document.getElementById('curse-ratio-chart'), {
    type: 'line',
    data: {
      labels: dims,
      datasets: [{
        label: '최근접/최원접 비율',
        data: ratioByDim,
        borderColor: '#f59e0b',
        backgroundColor: '#f59e0b22',
        fill: true,
        tension: 0.3,
        pointRadius: 4,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      scales: {
        x: {title: {display: true, text: '차원 수'}},
        y: {min: 0, max: 1, title: {display: true, text: '비율 (1에 가까울수록 위험)'}}
      },
      plugins: {legend: {display: false},
        annotation: {
          annotations: {
            danger: {type: 'line', yMin: 0.9, yMax: 0.9, borderColor: '#ef4444', borderDash: [4,4], borderWidth: 1}
          }
        }
      }
    }
  });
}

// ==================== INTERACTIVE 5: Feature Scaling ====================
let scaleData = {points: [], labels: [], income: [], age: []};

function generateScaleData() {
  scaleData = {points: [], labels: [], income: [], age: []};
  // Class 0: Lower income, younger
  for (let i = 0; i < 40; i++) {
    const income = 20000 + Math.random() * 30000;
    const age = 20 + Math.random() * 15;
    scaleData.income.push(income);
    scaleData.age.push(age);
    scaleData.labels.push(0);
  }
  // Class 1: Higher income, older
  for (let i = 0; i < 40; i++) {
    const income = 50000 + Math.random() * 50000;
    const age = 35 + Math.random() * 25;
    scaleData.income.push(income);
    scaleData.age.push(age);
    scaleData.labels.push(1);
  }
  // Some overlap
  for (let i = 0; i < 20; i++) {
    const income = 35000 + Math.random() * 30000;
    const age = 28 + Math.random() * 15;
    scaleData.income.push(income);
    scaleData.age.push(age);
    scaleData.labels.push(Math.random() < 0.5 ? 0 : 1);
  }
}

function standardize(arr) {
  const mean = arr.reduce((a, b) => a + b, 0) / arr.length;
  const std = Math.sqrt(arr.reduce((a, v) => a + (v - mean) ** 2, 0) / arr.length);
  return arr.map(v => (v - mean) / (std || 1));
}

function drawScaleCanvas(canvasId, xArr, yArr, labels, k, distFn) {
  const canvas = document.getElementById(canvasId);
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  const xMin = Math.min(...xArr), xMax = Math.max(...xArr);
  const yMin = Math.min(...yArr), yMax = Math.max(...yArr);
  const xRange = xMax - xMin || 1;
  const yRange = yMax - yMin || 1;
  const pad = 20;
  const w = canvas.width - pad * 2;
  const h = canvas.height - pad * 2;

  const toCanvasX = v => pad + ((v - xMin) / xRange) * w;
  const toCanvasY = v => pad + h - ((v - yMin) / yRange) * h;

  const points2D = xArr.map((x, i) => [x, yArr[i]]);
  const step = 8;
  let correct = 0;

  // Decision boundary
  for (let cx = 0; cx < canvas.width; cx += step) {
    for (let cy = 0; cy < canvas.height; cy += step) {
      const dataX = xMin + (cx - pad) / w * xRange;
      const dataY = yMin + (h - (cy - pad)) / h * yRange;
      const result = knnClassify(points2D, labels, [dataX, dataY], k, distFn);
      ctx.fillStyle = result.label === 0 ? 'rgba(239,68,68,0.08)' : 'rgba(37,99,235,0.08)';
      ctx.fillRect(cx, cy, step, step);
    }
  }

  // LOO accuracy
  for (let i = 0; i < points2D.length; i++) {
    const trainX = points2D.filter((_, j) => j !== i);
    const trainY = labels.filter((_, j) => j !== i);
    const result = knnClassify(trainX, trainY, points2D[i], k, distFn);
    if (result.label === labels[i]) correct++;
  }

  // Points
  xArr.forEach((x, i) => {
    const cx = toCanvasX(x);
    const cy = toCanvasY(yArr[i]);
    ctx.beginPath();
    ctx.arc(cx, cy, 4, 0, Math.PI * 2);
    ctx.fillStyle = labels[i] === 0 ? '#ef4444' : '#2563eb';
    ctx.fill();
  });

  // Axis labels
  ctx.fillStyle = '#64748b';
  ctx.font = '11px sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('X (소득/표준화)', canvas.width / 2, canvas.height - 4);
  ctx.save();
  ctx.translate(10, canvas.height / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillText('Y (나이/표준화)', 0, 0);
  ctx.restore();

  return (correct / points2D.length * 100).toFixed(1);
}

function runScaleComparison() {
  const k = parseInt(document.getElementById('scale-k').value);
  document.getElementById('scale-k-label').textContent = 'K=' + k;

  // Before scaling (raw)
  const accBefore = drawScaleCanvas('scale-before-canvas', scaleData.income, scaleData.age, scaleData.labels, k, euclideanDist);

  // After scaling (standardized)
  const stdIncome = standardize(scaleData.income);
  const stdAge = standardize(scaleData.age);
  const accAfter = drawScaleCanvas('scale-after-canvas', stdIncome, stdAge, scaleData.labels, k, euclideanDist);

  document.getElementById('scale-before-acc').textContent = accBefore + '%';
  document.getElementById('scale-after-acc').textContent = accAfter + '%';
  document.getElementById('scale-income-range').textContent =
    Math.round(Math.min(...scaleData.income)).toLocaleString() + ' ~ ' + Math.round(Math.max(...scaleData.income)).toLocaleString();
  document.getElementById('scale-age-range').textContent =
    Math.round(Math.min(...scaleData.age)) + ' ~ ' + Math.round(Math.max(...scaleData.age));
}

// ==================== INIT ====================
(function() {
  // Interactive 1: KNN Canvas
  const knnCanvas = document.getElementById('knn-canvas');
  knnCanvas.addEventListener('click', (e) => {
    const {x, y} = getCanvasCoords(knnCanvas, e);
    const mode = document.getElementById('knn-mode').value;
    if (mode === 'red') {
      knnPoints.red.push({x, y});
    } else if (mode === 'blue') {
      knnPoints.blue.push({x, y});
    } else {
      classifyPoint(x, y);
    }
    drawKNNCanvas();
  });

  document.getElementById('knn-k').addEventListener('input', () => {
    document.getElementById('knn-k-label').textContent = 'K=' + document.getElementById('knn-k').value;
    document.getElementById('knn-k-display').textContent = document.getElementById('knn-k').value;
  });

  document.getElementById('btn-knn-boundary').addEventListener('click', () => {
    drawDecisionBoundary();
  });

  document.getElementById('btn-knn-clear').addEventListener('click', () => {
    knnPoints = {red: [], blue: [], classified: []};
    drawKNNCanvas();
  });

  drawKNNCanvas();

  // Interactive 2: K Effect
  generateKEffectData();
  document.getElementById('btn-keffect-gen').addEventListener('click', () => {
    generateKEffectData();
    runKEffectComparison();
  });
  document.getElementById('btn-keffect-compare').addEventListener('click', runKEffectComparison);

  // Interactive 3: Distance Metric
  generateDistData();
  document.getElementById('btn-dist-run').addEventListener('click', runDistComparison);
  document.getElementById('dist-k').addEventListener('input', () => {
    document.getElementById('dist-k-label').textContent = 'K=' + document.getElementById('dist-k').value;
  });
  document.getElementById('btn-dist-newdata').addEventListener('click', () => {
    generateDistData();
    runDistComparison();
  });

  // Interactive 4: Curse of Dimensionality
  document.getElementById('curse-dim').addEventListener('input', () => {
    document.getElementById('curse-dim-label').textContent = '차원: ' + document.getElementById('curse-dim').value;
  });
  document.getElementById('btn-curse-run').addEventListener('click', runCurseSim);

  // Interactive 5: Feature Scaling
  generateScaleData();
  document.getElementById('btn-scale-run').addEventListener('click', runScaleComparison);
  document.getElementById('scale-k').addEventListener('input', () => {
    document.getElementById('scale-k-label').textContent = 'K=' + document.getElementById('scale-k').value;
  });
  document.getElementById('btn-scale-newdata').addEventListener('click', () => {
    generateScaleData();
    runScaleComparison();
  });

  // Auto-run initial visualizations with a short delay
  setTimeout(() => {
    runKEffectComparison();
    runDistComparison();
    runCurseSim();
    runScaleComparison();
  }, 300);
});
