let corrmatChart = null;

function initCorrmatVars() {
  const container = document.getElementById('corrmat-vars');
  container.innerHTML = '';
  ECON_VARS.forEach(v => {
    const label = document.createElement('label');
    label.style.cssText = 'display:flex;align-items:center;gap:6px;padding:8px 12px;background:var(--tb-g100);border-radius:8px;cursor:pointer;font-size:.88rem;font-weight:600;transition:0.15s;border:2px solid transparent;';
    label.innerHTML = `<input type="checkbox" class="corrmat-cb" value="${v.key}" /> ${v.label}`;
    label.addEventListener('change', () => {
      const checked = document.querySelectorAll('.corrmat-cb:checked').length;
      document.getElementById('corrmat-msg').textContent = `${checked}개 선택됨 (3~6개 필요)`;
      label.style.borderColor = label.querySelector('input').checked ? 'var(--tb-primary)' : 'transparent';
      label.style.background = label.querySelector('input').checked ? 'var(--tb-primary-light)' : 'var(--tb-g100)';
    });
    container.appendChild(label);
  });
}

async function generateCorrMatrix() {
  
  const selected = Array.from(document.querySelectorAll('.corrmat-cb:checked')).map(cb => cb.value);
  if (selected.length < 3) {
    document.getElementById('corrmat-msg').textContent = '3개 이상의 변수를 선택하세요!';
    return;
  }

  const vars = selected.map(key => ECON_VARS.find(v => v.key === key));
  const n = vars.length;
  const minLen = Math.min(...vars.map(v => v.data.length));

  // Compute correlation matrix
  const matrix = [];
  for (let i = 0; i < n; i++) {
    matrix[i] = [];
    for (let j = 0; j < n; j++) {
      matrix[i][j] = pearsonR(
        vars[i].data.slice(0, minLen),
        vars[j].data.slice(0, minLen)
      );
    }
  }

  // Draw heatmap using scatter with colored points
  const canvas = document.getElementById('corrmat-heatmap');
  if (corrmatChart) { corrmatChart.destroy(); corrmatChart = null; }

  const heatData = [];
  for (let i = 0; i < n; i++) {
    for (let j = 0; j < n; j++) {
      heatData.push({ x: j, y: n - 1 - i, r: matrix[i][j] });
    }
  }

  const labels = vars.map(v => v.label.split('(')[0].trim());

  corrmatChart = new Chart(canvas, {
    type: 'scatter',
    data: {
      datasets: [{
        label: '상관계수',
        data: heatData.map(d => ({ x: d.x, y: d.y })),
        backgroundColor: heatData.map(d => {
          const r = d.r;
          if (r > 0) return `rgba(37, 99, 235, ${Math.abs(r) * 0.8 + 0.1})`;
          if (r < 0) return `rgba(239, 68, 68, ${Math.abs(r) * 0.8 + 0.1})`;
          return 'rgba(100, 116, 139, 0.2)';
        }),
        pointRadius: heatData.map(d => 15 + Math.abs(d.r) * 15),
        pointStyle: 'rectRounded',
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: {
        legend: { display: false },
        title: { display: true, text: '상관행렬 히트맵 (파랑=양, 빨강=음, 크기=강도)', font: { size: 13, family: "'Paperlogy'" } },
        tooltip: {
          callbacks: {
            label: (ctx) => {
              const idx = ctx.dataIndex;
              const i = n - 1 - heatData[idx].y;
              const j = heatData[idx].x;
              return `${labels[i]} vs ${labels[j]}: r = ${matrix[i][j].toFixed(3)}`;
            }
          }
        }
      },
      scales: {
        x: {
          min: -0.5, max: n - 0.5,
          ticks: { callback: (v) => labels[v] || '', stepSize: 1, font: { size: 10 } },
        },
        y: {
          min: -0.5, max: n - 0.5,
          ticks: { callback: (v) => labels[n - 1 - v] || '', stepSize: 1, font: { size: 10 } },
        }
      }
    }
  });

  // Pairs display
  const pairsDiv = document.getElementById('corrmat-pairs');
  pairsDiv.innerHTML = '<h3 style="margin-bottom: 12px;">주요 상관관계</h3>';
  const pairs = [];
  for (let i = 0; i < n; i++) {
    for (let j = i + 1; j < n; j++) {
      pairs.push({ i, j, r: matrix[i][j] });
    }
  }
  pairs.sort((a, b) => Math.abs(b.r) - Math.abs(a.r));

  const table = document.createElement('div');
  table.className = 'tb-data-table-wrap';
  table.style.maxHeight = 'none';
  table.innerHTML = `<table class="tb-data-table">
    <thead><tr><th>변수 1</th><th>변수 2</th><th>Pearson r</th><th>강도</th></tr></thead>
    <tbody>${pairs.map(p => {
      const absR = Math.abs(p.r);
      let strength = '';
      if (absR >= 0.7) strength = '강한';
      else if (absR >= 0.4) strength = '보통';
      else if (absR >= 0.2) strength = '약한';
      else strength = '거의 없음';
      const color = p.r > 0 ? 'var(--tb-primary)' : 'var(--tb-danger)';
      return `<tr><td>${vars[p.i].label}</td><td>${vars[p.j].label}</td><td style="color:${color};font-weight:700">${p.r.toFixed(3)}</td><td>${strength}</td></tr>`;
    }).join('')}</tbody>
  </table>`;
  pairsDiv.appendChild(table);
}

