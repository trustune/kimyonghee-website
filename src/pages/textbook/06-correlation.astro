let anscombeCharts = [];

async function drawAnscombe() {
  
  const keys = ['I', 'II', 'III', 'IV'];
  const palette = ['#2563eb', '#ef4444', '#22c55e', '#f59e0b'];

  anscombeCharts.forEach(c => c.destroy());
  anscombeCharts = [];

