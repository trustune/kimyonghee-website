}

// ==================== INTERACTIVE 2: CORRELATION PLAYGROUND ====================
let corrPoints = [];

function drawCorrPlayground() {
  const canvas = document.getElementById('corr-playground');
  const ctx = canvas.getContext('2d');
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.width / rect.width;
  const scaleY = canvas.height / rect.height;

  ctx.clearRect(0, 0, canvas.width, canvas.height);

  // Grid
  ctx.strokeStyle = '#e2e8f0';
  ctx.lineWidth = 1;
  for (let x = 0; x <= canvas.width; x += 60) {
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
  }
  for (let y = 0; y <= canvas.height; y += 40) {
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
  }

  // Points
  corrPoints.forEach(p => {
    ctx.beginPath();
    ctx.arc(p.x, p.y, 6, 0, 2 * Math.PI);
    ctx.fillStyle = '#2563eb99';
    ctx.fill();
    ctx.strokeStyle = '#2563eb';
    ctx.lineWidth = 2;
    ctx.stroke();
  });

  // Regression line
  if (corrPoints.length >= 2) {
    const xs = corrPoints.map(p => p.x);
    const ys = corrPoints.map(p => p.y);
    const reg = linReg(xs, ys);
    ctx.beginPath();
    ctx.moveTo(0, reg.a + reg.b * 0);
    ctx.lineTo(canvas.width, reg.a + reg.b * canvas.width);
    ctx.strokeStyle = '#ef4444';
    ctx.lineWidth = 2;
    ctx.setLineDash([6, 4]);
    ctx.stroke();
    ctx.setLineDash([]);
  }

  // Stats
  const n = corrPoints.length;
  document.getElementById('corr-n').textContent = n;
  if (n >= 2) {
    const xs = corrPoints.map(p => p.x);
    const ys = corrPoints.map(p => canvas.height - p.y); // Flip Y for intuitive direction
    const r = pearsonR(xs, ys);
    document.getElementById('corr-r').textContent = r.toFixed(3);
    document.getElementById('corr-r2').textContent = (r * r * 100).toFixed(1) + '%';
  } else {
    document.getElementById('corr-r').textContent = '-';
    document.getElementById('corr-r2').textContent = '-';
  }
}

function setupCorrPlayground() {
  const canvas = document.getElementById('corr-playground');

  canvas.addEventListener('click', (e) => {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    const x = (e.clientX - rect.left) * scaleX;
    const y = (e.clientY - rect.top) * scaleY;
    corrPoints.push({ x, y });
    drawCorrPlayground();
  });

  document.getElementById('btn-corr-clear').addEventListener('click', () => {
    corrPoints = [];
    drawCorrPlayground();
  });

  document.getElementById('btn-corr-undo').addEventListener('click', () => {
    corrPoints.pop();
    drawCorrPlayground();
  });

  drawCorrPlayground();
}

