    const canvas = document.getElementById(`anscombe-${idx + 1}`);
    if (!canvas) return;

    const reg = linReg(ds.x, ds.y);
    const minX = Math.min(...ds.x) - 1, maxX = Math.max(...ds.x) + 1;

    const chart = new Chart(canvas, {
      type: 'scatter',
      data: {
        datasets: [
          {
            label: `Dataset ${key}`,
            data: ds.x.map((x, i) => ({ x, y: ds.y[i] })),
            backgroundColor: palette[idx] + '99',
            pointRadius: 6,
            order: 2,
          },
          {
            label: '회귀선',
            type: 'line',
            data: [{ x: minX, y: reg.a + reg.b * minX }, { x: maxX, y: reg.a + reg.b * maxX }],
            borderColor: '#64748b',
            borderWidth: 2,
            borderDash: [5, 5],
            pointRadius: 0,
            fill: false,
            order: 1,
          }
        ]
