<script is:inline>

function waitForChart(fn) {
  if (typeof Chart !== 'undefined') { fn(); return; }
  var s = document.querySelector('script[src*="chart.js"]');
  if (s) { s.addEventListener('load', fn); return; }
  setTimeout(function() { waitForChart(fn); }, 50);
}


  // ====================== DATA GENERATION ======================
  function generateEmployeeData(n = 30) {
    const data = [];
    for (let i = 0; i < n; i++) {
      const salary = Math.round(3000 + Math.random() * 5000);
      const tenure = Math.round(Math.random() * 15);
      const satisfaction = Math.ceil(Math.random() * 5);
      const overtime = Math.round(Math.random() * 30);
      const promoted = Math.random() > 0.6 ? 1 : 0;
      // Target: more likely to leave if low salary, low satisfaction, high overtime
      const prob = 1 / (1 + Math.exp(-(
        -2 + (salary < 4500 ? 1.5 : -0.5) + (satisfaction <= 2 ? 1.5 : -0.5) +
        (overtime > 15 ? 1.2 : -0.3) + (promoted === 0 ? 0.8 : -0.5) +
        (tenure < 3 ? 0.5 : -0.2) + (Math.random() - 0.5) * 1.5
      )));
      const left = Math.random() < prob ? 1 : 0;
      data.push({ salary, tenure, satisfaction, overtime, promoted, left });
    }
    return data;
  }

  const FEATURES = ['salary', 'tenure', 'satisfaction', 'overtime', 'promoted'];
  const FEATURE_LABELS = ['연봉', '근속연수', '만족도', '야근시간', '승진여부'];
  let employeeData = generateEmployeeData(30);
  let userTree = null;
  let optimalTree = null;

  // ====================== GINI / ENTROPY ======================
  function gini(counts) {
    const total = counts.reduce((a, b) => a + b, 0);
    if (total === 0) return 0;
    let sum = 0;
    for (const c of counts) sum += (c / total) ** 2;
    return 1 - sum;
  }

  function entropy(counts) {
    const total = counts.reduce((a, b) => a + b, 0);
    if (total === 0) return 0;
    let sum = 0;
    for (const c of counts) {
      if (c === 0) continue;
      const p = c / total;
      sum -= p * Math.log2(p);
    }
    return sum;
  }

  function countClasses(data) {
    let c0 = 0, c1 = 0;
    for (const d of data) { if (d.left === 0) c0++; else c1++; }
    return [c0, c1];
  }

  // ====================== TREE BUILDING (ID3-like) ======================

  function findBestSplit(data, features) {
    const parentCounts = countClasses(data);
    const parentGini = gini(parentCounts);
    let bestGain = -1, bestFeature = -1, bestThreshold = 0;

    for (const fi of features) {
      const key = FEATURES[fi];
      const values = [...new Set(data.map(d => d[key]))].sort((a, b) => a - b);
      for (let vi = 0; vi < values.length - 1; vi++) {
        const thresh = (values[vi] + values[vi + 1]) / 2;
        const leftData = data.filter(d => d[key] <= thresh);
        const rightData = data.filter(d => d[key] > thresh);
        if (leftData.length === 0 || rightData.length === 0) continue;
        const wGini = (leftData.length * gini(countClasses(leftData)) +
                       rightData.length * gini(countClasses(rightData))) / data.length;
        const gain = parentGini - wGini;
        if (gain > bestGain) {
          bestGain = gain;
          bestFeature = fi;
          bestThreshold = thresh;
        }
      }
    }
    return { bestFeature, bestThreshold, bestGain };
  }

  function buildTree(data, depth = 0, maxDepth = 5, minSamples = 2) {
    const counts = countClasses(data);
    const prediction = counts[0] >= counts[1] ? 0 : 1;
    const g = gini(counts);

    if (depth >= maxDepth || data.length < minSamples || g === 0) {
      return { prediction, counts, giniVal: g, depth, samples: data.length };
    }

    const { bestFeature, bestThreshold, bestGain } = findBestSplit(data, [0, 1, 2, 3, 4]);
    if (bestGain <= 0) {
      return { prediction, counts, giniVal: g, depth, samples: data.length };
    }

    const key = FEATURES[bestFeature];
    const leftData = data.filter(d => d[key] <= bestThreshold);
    const rightData = data.filter(d => d[key] > bestThreshold);

    return {
      feature: bestFeature,
      threshold: bestThreshold,
      left: buildTree(leftData, depth + 1, maxDepth, minSamples),
      right: buildTree(rightData, depth + 1, maxDepth, minSamples),
      counts,
      giniVal: g,
      depth,
      samples: data.length,
    };
  }

  function predictTree(node, sample) {
    if (node.feature === undefined) return node.prediction;
    const val = sample[FEATURES[node.feature]];
    return val <= node.threshold ? predictTree(node.left, sample) : predictTree(node.right, sample);
  }

  function treeAccuracy(node, data) {
    let correct = 0;
    for (const d of data) if (predictTree(node, d) === d.left) correct++;
    return data.length > 0 ? correct / data.length : 0;
  }

  function countLeaves(node) {
    if (node.feature === undefined) return 1;
    return countLeaves(node.left) + countLeaves(node.right);
  }

  function treeDepthFn(node) {
    if (node.feature === undefined) return 0;
    return 1 + Math.max(treeDepthFn(node.left), treeDepthFn(node.right));
  }

  // ====================== RENDER DATA TABLE ======================
  function renderDataTable() {
    const tbody = document.getElementById('tree-data-tbody');
    if (!tbody) return;
    tbody.innerHTML = '';
    for (const d of employeeData) {
      const tr = document.createElement('tr');
      tr.innerHTML = `<td>${d.salary}</td><td>${d.tenure}</td><td>${d.satisfaction}</td>` +
        `<td>${d.overtime}</td><td>${d.promoted ? '예' : '아니오'}</td>` +
        `<td style="background:${d.left ? '#fee2e2' : '#dcfce7'}; font-weight:700;">${d.left ? '이탈' : '잔류'}</td>`;
      tbody.appendChild(tr);
    }
  }

  // ====================== INTERACTIVE 1: MANUAL TREE BUILDER ======================
  let currentBuildData = [];
  let buildPath = [];

  function initTreeBuilder() {
    currentBuildData = [...employeeData];
    buildPath = [];
    renderSplitCandidates(currentBuildData);
    renderUserTreeCanvas();
    document.getElementById('current-node-info').textContent = `루트 (${currentBuildData.length}개 샘플)`;
    document.getElementById('selected-feature-label').textContent = '--';
    setStat('stat-user-acc', '--');
    setStat('stat-optimal-acc', '--');
    setStat('stat-tree-depth', '--');
  }

  let selectedSplitFeature = -1;

  function renderSplitCandidates(data) {
    const container = document.getElementById('split-candidates');
    if (!container) return;
    container.innerHTML = '';
    selectedSplitFeature = -1;

    const parentCounts = countClasses(data);
    const parentGini = gini(parentCounts);

    for (let fi = 0; fi < 5; fi++) {
      const key = FEATURES[fi];
      const values = [...new Set(data.map((d) => d[key]))].sort((a, b) => a - b);
      let bestGain = 0, bestThresh = 0;
      for (let vi = 0; vi < values.length - 1; vi++) {
        const thresh = (values[vi] + values[vi + 1]) / 2;
        const leftD = data.filter((d) => d[key] <= thresh);
        const rightD = data.filter((d) => d[key] > thresh);
        if (leftD.length === 0 || rightD.length === 0) continue;
        const wg = (leftD.length * gini(countClasses(leftD)) + rightD.length * gini(countClasses(rightD))) / data.length;
        const gain = parentGini - wg;
        if (gain > bestGain) { bestGain = gain; bestThresh = thresh; }
      }

      const card = document.createElement('div');
      card.style.cssText = 'padding:14px; border:2px solid var(--tb-g200); border-radius:var(--tb-radius); cursor:pointer; transition:0.2s;';
      card.innerHTML = `<div style="font-weight:700; font-size:0.95rem;">${FEATURE_LABELS[fi]}</div>` +
        `<div style="font-size:0.82rem; color:var(--tb-g600); margin-top:4px;">Gini 감소: <strong style="color:var(--tb-primary);">${bestGain.toFixed(4)}</strong></div>` +
        `<div style="font-size:0.78rem; color:var(--tb-g600);">최적 분할점: ${bestThresh.toFixed(1)}</div>`;

      card.addEventListener('click', () => {
        container.querySelectorAll('div').forEach((c) => { c.style.borderColor = 'var(--tb-g200)'; c.style.background = ''; });
        card.style.borderColor = 'var(--tb-primary)';
        card.style.background = 'var(--tb-primary-light)';
        selectedSplitFeature = fi;
        document.getElementById('selected-feature-label').textContent = `${FEATURE_LABELS[fi]} (Gain: ${bestGain.toFixed(4)})`;
      });

      container.appendChild(card);
    }
  }

  function renderUserTreeCanvas() {
    const canvas = document.getElementById('canvas-user-tree');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.font = '13px Paperlogy, sans-serif';
    ctx.textAlign = 'center';

    if (buildPath.length === 0) {
      ctx.fillStyle = '#94a3b8';
      ctx.fillText('분할을 선택하면 트리가 여기에 그려집니다', canvas.width / 2, canvas.height / 2);
      return;
    }

    // Simple tree rendering
    const drawNode = (x, y, text, isLeaf) => {
      ctx.fillStyle = isLeaf ? '#dcfce7' : '#dbeafe';
      ctx.strokeStyle = isLeaf ? '#22c55e' : '#2563eb';
      ctx.lineWidth = 2;
      const w = 120, h = 36, r = 8;
      ctx.beginPath();
      ctx.roundRect(x - w/2, y - h/2, w, h, r);
      ctx.fill();
      ctx.stroke();
      ctx.fillStyle = '#1e293b';
      ctx.fillText(text, x, y + 4);
    };

    // Render build path as a simple chain
    let cx = canvas.width / 2;
    let cy = 30;
    for (let i = 0; i < buildPath.length; i++) {
      const bp = buildPath[i];
      drawNode(cx, cy, `${FEATURE_LABELS[bp.feature]} <= ${bp.threshold.toFixed(1)}`, false);
      if (i > 0) {
        ctx.strokeStyle = '#94a3b8';
        ctx.beginPath();
        ctx.moveTo(cx, cy - 18);
        ctx.lineTo(cx, cy - 36);
        ctx.stroke();
      }
      cy += 60;
    }
    drawNode(cx - 80, cy, '잔류/이탈', true);
    drawNode(cx + 80, cy, '잔류/이탈', true);
    ctx.strokeStyle = '#94a3b8';
    ctx.beginPath();
    ctx.moveTo(cx, cy - 42);
    ctx.lineTo(cx - 80, cy - 18);
    ctx.moveTo(cx, cy - 42);
    ctx.lineTo(cx + 80, cy - 18);
    ctx.stroke();
  }

  // ====================== EXAMPLE TREE VISUAL ======================
  function drawExampleTree() {
    const canvas = document.getElementById('canvas-tree-example');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.font = '12px Paperlogy, sans-serif';
    ctx.textAlign = 'center';

    const drawBox = (x, y, text, color, bg) => {
      const w = 130, h = 32;
      ctx.fillStyle = bg;
      ctx.strokeStyle = color;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.roundRect(x - w/2, y - h/2, w, h, 6);
      ctx.fill();
      ctx.stroke();
      ctx.fillStyle = '#1e293b';
      ctx.fillText(text, x, y + 4);
    };

    const drawLine = (x1, y1, x2, y2, label) => {
      ctx.strokeStyle = '#94a3b8';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.moveTo(x1, y1 + 16);
      ctx.lineTo(x2, y2 - 16);
      ctx.stroke();
      ctx.fillStyle = '#64748b';
      ctx.font = '11px Paperlogy, sans-serif';
      ctx.fillText(label, (x1 + x2) / 2 + (x2 < x1 ? -20 : 20), (y1 + y2) / 2);
      ctx.font = '12px Paperlogy, sans-serif';
    };

    // Root
    drawBox(350, 40, '만족도 <= 2?', '#2563eb', '#dbeafe');
    // Level 1
    drawBox(180, 120, '야근 > 15시간?', '#2563eb', '#dbeafe');
    drawBox(520, 120, '연봉 <= 4000?', '#2563eb', '#dbeafe');
    drawLine(350, 40, 180, 120, '예');
    drawLine(350, 40, 520, 120, '아니오');
    // Level 2 leaves
    drawBox(100, 210, '이탈 (85%)', '#ef4444', '#fee2e2');
    drawBox(260, 210, '잔류 (60%)', '#22c55e', '#dcfce7');
    drawBox(440, 210, '이탈 (70%)', '#ef4444', '#fee2e2');
    drawBox(600, 210, '잔류 (90%)', '#22c55e', '#dcfce7');
    drawLine(180, 120, 100, 210, '예');
    drawLine(180, 120, 260, 210, '아니오');
    drawLine(520, 120, 440, 210, '예');
    drawLine(520, 120, 600, 210, '아니오');

    // Labels
    ctx.font = '11px Paperlogy, sans-serif';
    ctx.fillStyle = '#64748b';
    ctx.textAlign = 'left';
    ctx.fillText('루트 노드 (Root)', 10, 290);
    ctx.fillText('내부 노드 (Internal)', 170, 290);
    ctx.fillText('리프 노드 (Leaf)', 400, 290);
    ctx.fillStyle = '#2563eb';
    ctx.fillRect(10, 295, 30, 3);
    ctx.fillStyle = '#22c55e';
    ctx.fillRect(400, 295, 30, 3);
  }

  // ====================== INTERACTIVE 2: GINI vs ENTROPY COMPARISON ======================
  let chartGiniEntropy = null;

  function drawPieChart(canvasId, ratio, color1, color2) {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const cx = canvas.width / 2, cy = canvas.height / 2, r = 80;
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Class A
    ctx.fillStyle = color1;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, 0, Math.PI * 2 * ratio);
    ctx.fill();

    // Class B
    ctx.fillStyle = color2;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, Math.PI * 2 * ratio, Math.PI * 2);
    ctx.fill();

    // Labels
    ctx.fillStyle = '#1e293b';
    ctx.font = '12px Paperlogy, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(`A: ${(ratio * 100).toFixed(0)}%`, cx - 30, cy + r + 20);
    ctx.fillText(`B: ${((1 - ratio) * 100).toFixed(0)}%`, cx + 30, cy + r + 20);
  }

  function updateGiniEntropyComparison() {
    const slider = document.getElementById('range-class-ratio');
    const ratio = parseInt(slider.value) / 100;
    document.getElementById('label-class-ratio').textContent = `${Math.round(ratio * 100)}%`;

    const g = gini([ratio * 100, (1 - ratio) * 100]);
    const e = entropy([ratio * 100, (1 - ratio) * 100]);

    drawPieChart('canvas-gini-pie', ratio, '#3b82f6', '#f97316');
    drawPieChart('canvas-entropy-pie', ratio, '#3b82f6', '#f97316');

    document.getElementById('gini-values').innerHTML = `Gini = <strong>${g.toFixed(4)}</strong>`;
    document.getElementById('entropy-values').innerHTML = `Entropy = <strong>${e.toFixed(4)}</strong>`;
  }

  async function initGiniEntropyChart() {

    const labels = [];
    const giniData = [];
    const entropyData = [];
    for (let p = 0; p <= 100; p += 2) {
      const r = p / 100;
      labels.push(r);
      giniData.push(gini([p, 100 - p]));
      entropyData.push(entropy([p, 100 - p]));
    }

    const ctx = (document.getElementById('chart-gini-entropy'))?.getContext('2d');
    if (!ctx) return;

    chartGiniEntropy = new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          { label: 'Gini', data: giniData, borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.1)', fill: true, tension: 0.3, pointRadius: 0 },
          { label: 'Entropy', data: entropyData, borderColor: '#7c3aed', backgroundColor: 'rgba(124,58,237,0.1)', fill: true, tension: 0.3, pointRadius: 0 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          x: { title: { display: true, text: '클래스 A 비율 (p)', font: { family: 'Paperlogy' } } },
          y: { title: { display: true, text: '불순도', font: { family: 'Paperlogy' } } },
        },
        plugins: { legend: { labels: { font: { family: 'Paperlogy' } } } },
      },
    });
  }

  // ====================== INTERACTIVE 3: OVERFITTING DEPTH ======================
  let overfitTrainData = [];
  let overfitTestData = [];
  let chartDepthAccuracy = null;

  function generate2DData(n) {
    const data = [];
    for (let i = 0; i < n; i++) {
      const x = Math.random() * 10;
      const y = Math.random() * 10;
      const noise = (Math.random() - 0.5) * 2;
      const boundary = 3 * Math.sin(x * 0.8) + 5 + noise;
      const cls = y > boundary ? 1 : 0;
      data.push({ x, y, cls });
    }
    return data;
  }

  function buildTree2D(data, depth, maxDepth) {
    const c0 = data.filter(d => d.cls === 0).length;
    const c1 = data.length - c0;
    const pred = c0 >= c1 ? 0 : 1;
    const g = gini([c0, c1]);

    if (depth >= maxDepth || data.length < 4 || g === 0) {
      return { prediction: pred, counts: [c0, c1], giniVal: g, depth, samples: data.length };
    }

    let bestGain = -1, bestFeat = 'x', bestThresh = 0;
    for (const feat of ['x', 'y']) {
      const vals = data.map(d => d[feat]).sort((a, b) => a - b);
      for (let i = 0; i < vals.length - 1; i += Math.max(1, Math.floor(vals.length / 20))) {
        const thresh = (vals[i] + vals[i + 1]) / 2;
        const left = data.filter(d => d[feat] <= thresh);
        const right = data.filter(d => d[feat] > thresh);
        if (left.length === 0 || right.length === 0) continue;
        const lc = countClasses2D(left), rc = countClasses2D(right);
        const wg = (left.length * gini(lc) + right.length * gini(rc)) / data.length;
        const gain = g - wg;
        if (gain > bestGain) { bestGain = gain; bestFeat = feat; bestThresh = thresh; }
      }
    }

    if (bestGain <= 0) return { prediction: pred, counts: [c0, c1], giniVal: g, depth, samples: data.length };

    const leftD = data.filter(d => d[bestFeat] <= bestThresh);
    const rightD = data.filter(d => d[bestFeat] > bestThresh);

    return {
      feature: bestFeat === 'x' ? 0 : 1,
      threshold: bestThresh,
      left: buildTree2D(leftD, depth + 1, maxDepth),
      right: buildTree2D(rightD, depth + 1, maxDepth),
      counts: [c0, c1], giniVal: g, depth, samples: data.length,
    };
  }

  function countClasses2D(data) {
    const c0 = data.filter(d => d.cls === 0).length;
    return [c0, data.length - c0];
  }

  function predict2D(node, sample) {
    if (node.feature === undefined) return node.prediction;
    const feat = node.feature === 0 ? 'x' : 'y';
    return sample[feat] <= node.threshold ? predict2D(node.left, sample) : predict2D(node.right, sample);
  }

  function drawBoundary(tree) {
    const canvas = document.getElementById('canvas-boundary');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);

    // Draw decision regions
    const step = 4;
    for (let px = 0; px < W; px += step) {
      for (let py = 0; py < H; py += step) {
        const x = (px / W) * 10;
        const y = ((H - py) / H) * 10;
        const pred = predict2D(tree, { x, y });
        ctx.fillStyle = pred === 0 ? 'rgba(37,99,235,0.15)' : 'rgba(239,68,68,0.15)';
        ctx.fillRect(px, py, step, step);
      }
    }

    // Draw data points
    const allData = [...overfitTrainData.map(d => ({...d, isTrain: true})), ...overfitTestData.map(d => ({...d, isTrain: false}))];
    for (const d of allData) {
      const px = (d.x / 10) * W;
      const py = H - (d.y / 10) * H;
      ctx.beginPath();
      ctx.arc(px, py, d.isTrain ? 4 : 3, 0, Math.PI * 2);
      ctx.fillStyle = d.cls === 0 ? '#2563eb' : '#ef4444';
      ctx.globalAlpha = d.isTrain ? 1 : 0.4;
      ctx.fill();
      if (!d.isTrain) {
        ctx.strokeStyle = '#666';
        ctx.lineWidth = 1;
        ctx.stroke();
      }
      ctx.globalAlpha = 1;
    }
  }

  async function initDepthChart() {

    const ctx = (document.getElementById('chart-depth-accuracy'))?.getContext('2d');
    if (!ctx) return;

    chartDepthAccuracy = new Chart(ctx, {
      type: 'line',
      data: {
        labels: Array.from({ length: 20 }, (_, i) => i + 1),
        datasets: [
          { label: '훈련 정확도', data: [], borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.1)', fill: false, tension: 0.3 },
          { label: '테스트 정확도', data: [], borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.1)', fill: false, tension: 0.3 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          x: { title: { display: true, text: '트리 깊이', font: { family: 'Paperlogy' } } },
          y: { title: { display: true, text: '정확도', font: { family: 'Paperlogy' } }, min: 0.4, max: 1.05 },
        },
        plugins: { legend: { labels: { font: { family: 'Paperlogy' } } } },
      },
    });
  }

  function updateDepthDemo() {
    const maxDepth = parseInt((document.getElementById('range-depth')).value);
    document.getElementById('label-depth').textContent = String(maxDepth);

    const tree = buildTree2D(overfitTrainData, 0, maxDepth);
    const trainAcc = overfitTrainData.filter(d => predict2D(tree, d) === d.cls).length / overfitTrainData.length;
    const testAcc = overfitTestData.filter(d => predict2D(tree, d) === d.cls).length / overfitTestData.length;

    drawBoundary(tree);
    setStat('stat-train-acc', (trainAcc * 100).toFixed(1) + '%');
    setStat('stat-test-acc', (testAcc * 100).toFixed(1) + '%');
    setStat('stat-leaf-count', String(countLeaves(tree)));

    // Compute all depths for chart
    const trainAccs = [];
    const testAccs = [];
    let bestD = 1, bestTestAcc = 0;
    for (let d = 1; d <= 20; d++) {
      const t = buildTree2D(overfitTrainData, 0, d);
      const trA = overfitTrainData.filter(dd => predict2D(t, dd) === dd.cls).length / overfitTrainData.length;
      const teA = overfitTestData.filter(dd => predict2D(t, dd) === dd.cls).length / overfitTestData.length;
      trainAccs.push(trA);
      testAccs.push(teA);
      if (teA > bestTestAcc) { bestTestAcc = teA; bestD = d; }
    }

    if (chartDepthAccuracy) {
      chartDepthAccuracy.data.datasets[0].data = trainAccs;
      chartDepthAccuracy.data.datasets[1].data = testAccs;
      chartDepthAccuracy.update();
    }
    setStat('stat-best-depth', String(bestD));
  }

  // ====================== INTERACTIVE 4: PRUNING ======================
  let pruneFullTree = null;
  let pruneTrainData = [];
  let pruneTestData = [];
  let chartAlphaAccuracy = null;

  function pruneTree(node, alpha) {
    if (node.feature === undefined) return { ...node };
    const leftPruned = pruneTree(node.left, alpha);
    const rightPruned = pruneTree(node.right, alpha);

    // Cost of keeping subtree
    const subLeaves = countLeaves(leftPruned) + countLeaves(rightPruned);
    // Cost of collapsing to leaf
    const counts = node.counts || [0, 0];
    const total = counts[0] + counts[1];
    const leafError = total > 0 ? 1 - Math.max(counts[0], counts[1]) / total : 0;

    // Effective alpha: collapse if simplicity gain outweighs error
    const subError = computeTreeError(leftPruned, pruneTrainData.filter(d => d[FEATURES[node.feature]] <= node.threshold))
      + computeTreeError(rightPruned, pruneTrainData.filter(d => d[FEATURES[node.feature]] > node.threshold));

    if (leafError <= subError + alpha * (subLeaves - 1) || subLeaves <= 1) {
      return { prediction: counts[0] >= counts[1] ? 0 : 1, counts, giniVal: gini(counts), depth: node.depth, samples: total };
    }
    return { ...node, left: leftPruned, right: rightPruned };
  }

  function computeTreeError(node, data) {
    let errors = 0;
    for (const d of data) if (predictTree(node, d) !== d.left) errors++;
    return data.length > 0 ? errors / data.length : 0;
  }

  function drawPrunedTree(node) {
    const canvas = document.getElementById('canvas-pruned-tree');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.font = '11px Paperlogy, sans-serif';
    ctx.textAlign = 'center';

    function getWidth(n) {
      if (n.feature === undefined) return 1;
      return getWidth(n.left) + getWidth(n.right);
    }

    const totalWidth = getWidth(node);
    const xScale = canvas.width / (totalWidth + 1);
    const yStep = 55;

    function draw(n, x, y, leftBound, rightBound) {
      const isLeaf = n.feature === undefined;
      const w = isLeaf ? 60 : 100;
      const h = 28;
      ctx.fillStyle = isLeaf ? (n.prediction === 1 ? '#fee2e2' : '#dcfce7') : '#dbeafe';
      ctx.strokeStyle = isLeaf ? (n.prediction === 1 ? '#ef4444' : '#22c55e') : '#2563eb';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.roundRect(x - w/2, y - h/2, w, h, 5);
      ctx.fill();
      ctx.stroke();

      ctx.fillStyle = '#1e293b';
      if (isLeaf) {
        ctx.fillText(n.prediction === 1 ? '이탈' : '잔류', x, y + 4);
      } else {
        ctx.fillText(`${FEATURE_LABELS[n.feature]}`, x, y + 4);
      }

      if (!isLeaf) {
        const leftW = getWidth(n.left);
        const rightW = getWidth(n.right);
        const mid = leftBound + leftW;
        const leftX = leftBound + leftW / 2;
        const rightX = mid + rightW / 2;
        const lx = (leftX + 0.5) * xScale;
        const rx = (rightX + 0.5) * xScale;
        const ny = y + yStep;

        ctx.strokeStyle = '#94a3b8';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(x, y + h/2);
        ctx.lineTo(lx, ny - h/2);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(x, y + h/2);
        ctx.lineTo(rx, ny - h/2);
        ctx.stroke();

        draw(n.left, lx, ny, leftBound, mid);
        draw(n.right, rx, ny, mid, rightBound);
      }
    }

    draw(node, (0.5 + totalWidth / 2) * xScale, 25, 0, totalWidth);
  }

  async function initAlphaChart() {

    const ctx = (document.getElementById('chart-alpha-accuracy'))?.getContext('2d');
    if (!ctx) return;

    chartAlphaAccuracy = new Chart(ctx, {
      type: 'line',
      data: {
        labels: [],
        datasets: [
          { label: '훈련', data: [], borderColor: '#2563eb', tension: 0.3, pointRadius: 2 },
          { label: '테스트', data: [], borderColor: '#ef4444', tension: 0.3, pointRadius: 2 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          x: { title: { display: true, text: 'Alpha', font: { family: 'Paperlogy' } } },
          y: { title: { display: true, text: '정확도', font: { family: 'Paperlogy' } }, min: 0.4, max: 1.05 },
        },
        plugins: { legend: { labels: { font: { family: 'Paperlogy' } } } },
      },
    });
  }

  function updatePruningDemo() {
    const alphaVal = parseInt((document.getElementById('range-alpha')).value) / 2000;
    document.getElementById('label-alpha').textContent = alphaVal.toFixed(3);

    if (!pruneFullTree) return;

    const pruned = pruneTree(pruneFullTree, alphaVal);
    drawPrunedTree(pruned);

    const trainAcc = treeAccuracy(pruned, pruneTrainData);
    const testAcc = treeAccuracy(pruned, pruneTestData);
    setStat('stat-prune-leaves', String(countLeaves(pruned)));
    setStat('stat-prune-train', (trainAcc * 100).toFixed(1) + '%');
    setStat('stat-prune-test', (testAcc * 100).toFixed(1) + '%');

    // Update alpha chart
    if (chartAlphaAccuracy) {
      const alphas = [];
      const trainAccs = [];
      const testAccs = [];
      for (let a = 0; a <= 100; a += 2) {
        const av = a / 2000;
        alphas.push(av);
        const pt = pruneTree(pruneFullTree, av);
        trainAccs.push(treeAccuracy(pt, pruneTrainData));
        testAccs.push(treeAccuracy(pt, pruneTestData));
      }
      chartAlphaAccuracy.data.labels = alphas.map(a => a.toFixed(3));
      chartAlphaAccuracy.data.datasets[0].data = trainAccs;
      chartAlphaAccuracy.data.datasets[1].data = testAccs;
      chartAlphaAccuracy.update();
    }
  }

  // ====================== INTERACTIVE 5: FEATURE IMPORTANCE ======================
  let chartFeatureImportance = null;

  function computeFeatureImportance(node, totalSamples) {
    const importance = [0, 0, 0, 0, 0];
    function traverse(n) {
      if (n.feature === undefined) return;
      const parentGini = gini(n.counts);
      const leftGini = gini(n.left.counts);
      const rightGini = gini(n.right.counts);
      const leftN = n.left.samples || 0;
      const rightN = n.right.samples || 0;
      const nSamples = n.samples || 1;
      const gain = (nSamples / totalSamples) * (parentGini - (leftN / nSamples) * leftGini - (rightN / nSamples) * rightGini);
      importance[n.feature] += gain;
      traverse(n.left);
      traverse(n.right);
    }
    traverse(node);
    // Normalize
    const total = importance.reduce((a, b) => a + b, 0);
    if (total > 0) for (let i = 0; i < importance.length; i++) importance[i] /= total;
    return importance;
  }

  async function initFeatureImportanceChart() {

    const ctx = (document.getElementById('chart-feature-importance'))?.getContext('2d');
    if (!ctx) return;

    chartFeatureImportance = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: FEATURE_LABELS,
        datasets: [{ label: '특성 중요도', data: [0, 0, 0, 0, 0], backgroundColor: ['#3b82f6', '#8b5cf6', '#f59e0b', '#ef4444', '#22c55e'] }],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        indexAxis: 'y',
        scales: { x: { title: { display: true, text: '중요도 (Normalized Gini Gain)', font: { family: 'Paperlogy' } }, min: 0, max: 1 } },
        plugins: { legend: { display: false } },
      },
    });
  }

  function updateFeatureImportance(removeIdx = -1) {
    const data = [...employeeData];
    const split = Math.floor(data.length * 0.7);
    const train = data.slice(0, split);
    const test = data.slice(split);

    // Build full tree
    const fullTree = buildTree(train, 0, 5);
    const fullAcc = treeAccuracy(fullTree, test);
    const importance = computeFeatureImportance(fullTree, train.length);

    if (chartFeatureImportance) {
      chartFeatureImportance.data.datasets[0].data = importance;
      chartFeatureImportance.update();
    }

    setStat('stat-full-acc', (fullAcc * 100).toFixed(1) + '%');

    // Render ranking
    const ranking = document.getElementById('importance-ranking');
    if (ranking) {
      const sorted = importance.map((v, i) => ({ label: FEATURE_LABELS[i], value: v }))
        .sort((a, b) => b.value - a.value);
      ranking.innerHTML = '<div style="font-weight:700; font-size:0.9rem; margin-bottom:8px;">중요도 순위:</div>' +
        sorted.map((s, i) => `<span style="display:inline-block; padding:4px 12px; margin:3px; background:var(--tb-g100); border-radius:20px; font-size:0.85rem;">${i + 1}. ${s.label} (${(s.value * 100).toFixed(1)}%)</span>`).join('');
    }

    // If removing a feature
    if (removeIdx >= 0) {
      const modTrain = train.map(d => {
        const nd = { ...d };
        nd[FEATURES[removeIdx]] = Math.random() * 10; // shuffle this feature
        return nd;
      });
      const modTree = buildTree(modTrain, 0, 5);
      const modAcc = treeAccuracy(modTree, test);
      setStat('stat-removed-acc', (modAcc * 100).toFixed(1) + '%');
      setStat('stat-acc-change', ((modAcc - fullAcc) * 100).toFixed(1) + '%');
    } else {
      setStat('stat-removed-acc', '--');
      setStat('stat-acc-change', '--');
    }
  }

  // ====================== UTILITY ======================
  function setStat(id, val) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  // ====================== INITIALIZATION ======================
  function init() {
    renderDataTable();
    drawExampleTree();
    initTreeBuilder();

    // Interactive 2: Gini vs Entropy
    updateGiniEntropyComparison();
    const ratioSlider = document.getElementById('range-class-ratio');
    ratioSlider?.addEventListener('input', updateGiniEntropyComparison);
    document.getElementById('btn-compare-metrics')?.addEventListener('click', updateGiniEntropyComparison);

    // Interactive 3: Overfitting
    overfitTrainData = generate2DData(80);
    overfitTestData = generate2DData(40);
    const depthSlider = document.getElementById('range-depth');
    depthSlider?.addEventListener('input', updateDepthDemo);
    document.getElementById('btn-gen-overfit-data')?.addEventListener('click', () => {
      overfitTrainData = generate2DData(80);
      overfitTestData = generate2DData(40);
      updateDepthDemo();
    });

    // Interactive 4: Pruning
    pruneTrainData = employeeData.slice(0, 20);
    pruneTestData = employeeData.slice(20);
    pruneFullTree = buildTree(pruneTrainData, 0, 10);
    const alphaSlider = document.getElementById('range-alpha');
    alphaSlider?.addEventListener('input', updatePruningDemo);
    document.getElementById('btn-full-tree')?.addEventListener('click', () => {
      (document.getElementById('range-alpha')).value = '0';
      updatePruningDemo();
    });
    document.getElementById('btn-best-alpha')?.addEventListener('click', () => {
      // Find best alpha
      let bestAlpha = 0, bestAcc = 0;
      for (let a = 0; a <= 100; a += 1) {
        const av = a / 2000;
        const pt = pruneTree(pruneFullTree, av);
        const acc = treeAccuracy(pt, pruneTestData);
        if (acc > bestAcc) { bestAcc = acc; bestAlpha = a; }
      }
      (document.getElementById('range-alpha')).value = String(bestAlpha);
      updatePruningDemo();
    });

    // Interactive 1: Tree builder
    document.getElementById('btn-confirm-split')?.addEventListener('click', () => {
      if (selectedSplitFeature < 0) return;
      const key = FEATURES[selectedSplitFeature];
      const vals = [...new Set(currentBuildData.map(d => d[key]))].sort((a, b) => a - b);
      let bestThresh = 0, bestGain = -1;
      const pc = countClasses(currentBuildData);
      const pg = gini(pc);
      for (let i = 0; i < vals.length - 1; i++) {
        const thresh = (vals[i] + vals[i + 1]) / 2;
        const ld = currentBuildData.filter(d => d[key] <= thresh);
        const rd = currentBuildData.filter(d => d[key] > thresh);
        if (ld.length === 0 || rd.length === 0) continue;
        const wg = (ld.length * gini(countClasses(ld)) + rd.length * gini(countClasses(rd))) / currentBuildData.length;
        if (pg - wg > bestGain) { bestGain = pg - wg; bestThresh = thresh; }
      }
      buildPath.push({ feature: selectedSplitFeature, threshold: bestThresh });
      currentBuildData = currentBuildData.filter(d => d[key] <= bestThresh);
      renderSplitCandidates(currentBuildData);
      renderUserTreeCanvas();
      document.getElementById('current-node-info').textContent = `깊이 ${buildPath.length} (${currentBuildData.length}개 샘플)`;
    });

    document.getElementById('btn-auto-build')?.addEventListener('click', () => {
      optimalTree = buildTree(employeeData, 0, 4);
      const optAcc = treeAccuracy(optimalTree, employeeData);
      setStat('stat-optimal-acc', (optAcc * 100).toFixed(1) + '%');
      setStat('stat-tree-depth', String(treeDepthFn(optimalTree)));
      drawPrunedTree(optimalTree); // reuse pruned tree canvas style
    });

    document.getElementById('btn-reset-tree')?.addEventListener('click', () => {
      employeeData = generateEmployeeData(30);
      renderDataTable();
      initTreeBuilder();
    });

    // Interactive 5: Feature importance
    document.getElementById('btn-fit-importance')?.addEventListener('click', () => updateFeatureImportance());
    document.getElementById('btn-shuffle-importance')?.addEventListener('click', () => {
      const idx = parseInt((document.getElementById('select-remove-feature')).value);
      updateFeatureImportance(idx);
    });

    // Initialize charts
    initGiniEntropyChart();
    initDepthChart().then(() => updateDepthDemo());
    initAlphaChart().then(() => updatePruningDemo());
    initFeatureImportanceChart();
  }

  if (document.readyState === 'loading') {
init();
  } else {
    init();
  }
</script>

