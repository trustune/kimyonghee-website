---
import EconTextbookLayout from '../../../layouts/EconTextbookLayout.astro';
import ExplainBox from '../../../components/textbook/ExplainBox.astro';
import InsightBox from '../../../components/textbook/InsightBox.astro';
import FormulaBox from '../../../components/textbook/FormulaBox.astro';
import WarningBox from '../../../components/textbook/WarningBox.astro';
import ExerciseBox from '../../../components/textbook/ExerciseBox.astro';
import BusinessBox from '../../../components/textbook/BusinessBox.astro';
import ConclusionBox from '../../../components/textbook/ConclusionBox.astro';
import StatBox from '../../../components/textbook/StatBox.astro';
import ChartContainer from '../../../components/textbook/ChartContainer.astro';
import SimControls from '../../../components/textbook/SimControls.astro';
---

<EconTextbookLayout
  title="캡스톤: 거시경제 대시보드"
  subtitle="한국 거시경제 데이터를 종합 분석하다"
  chapterNum={18}
  part={2}
>

  <!-- ===== HOOK ===== -->
  <div class="tb-warning-box" style="margin-bottom: 18px; font-size: .85rem;">
    <strong>데이터 안내:</strong>
    이 장의 시뮬레이션에 사용된 데이터 중 일부는 교육 목적으로 생성된 가상 데이터입니다.
    실제 한국 경제 데이터는 한국은행 ECOS(ecos.bok.or.kr), 통계청 KOSIS(kosis.kr), World Bank에서 확인할 수 있습니다.
  </div>

  <div class="tb-card">
    <h2>거시경제학의 모든 것을 합쳐 보자</h2>
    <p>
      11장(GDP)부터 17장(국제무역)까지, 우리는 거시경제학의 핵심 개념들을 배웠습니다.
      이제 이 모든 지표를 하나의 대시보드에서 종합적으로 살펴봅시다.
    </p>
    <p style="margin-top: 12px;">
      실제 경제 분석가, 정책 결정자, 중앙은행 총재가 보는 것처럼
      여러 지표를 동시에 보면서 경제 상황을 진단하고, 정책을 제안해 봅시다.
    </p>

    <InsightBox title="이 장의 목표">
      <ul style="margin: 8px 0 0 16px; line-height: 1.8;">
        <li>GDP, 물가, 실업률, 금리, 환율 5대 지표를 동시에 모니터링</li>
        <li>경기 사이클(호황/불황)을 식별</li>
        <li>경기 침체 시나리오에서 정책 대응을 시뮬레이션</li>
        <li>IS-LM 모형으로 정책 효과를 분석</li>
        <li>종합 경제 보고서를 자동 생성</li>
      </ul>
    </InsightBox>
  </div>

  <!-- ===== INTERACTIVE 1: 종합 대시보드 ===== -->
  <div class="tb-card">
    <h2>1. 거시경제 종합 대시보드</h2>
    <p>
      한국 경제의 5대 핵심 지표를 한눈에 봅니다 (합성 데이터 기반).
      차트를 클릭하면 해당 시점의 상세 정보를 확인할 수 있습니다.
    </p>

    <div style="display: flex; gap: 12px; flex-wrap: wrap; margin: 16px 0;">
      <StatBox label="GDP 성장률" value="-" id="dash-gdp" borderColor="#059669" />
      <StatBox label="인플레이션" value="-" id="dash-cpi" borderColor="#ef4444" />
      <StatBox label="실업률" value="-" id="dash-unemp" borderColor="#f59e0b" />
      <StatBox label="기준금리" value="-" id="dash-rate" borderColor="#3b82f6" />
      <StatBox label="환율" value="-" id="dash-fx" borderColor="#7c3aed" />
    </div>

    <SimControls>
      <label>연도 선택: <span id="dash-year-val">2024</span></label>
      <input type="range" id="dash-year" min="2000" max="2025" value="2024" step="1" />
    </SimControls>

    <ChartContainer id="dashChart" height="420px" />
  </div>

  <!-- ===== INTERACTIVE 2: 경기 사이클 식별 ===== -->
  <div class="tb-card">
    <h2>2. 경기 사이클 식별</h2>
    <p>
      경제는 <strong>호황 → 정점 → 불황 → 저점</strong>의 사이클을 반복합니다.
      아래 30년 GDP 성장률 데이터에서 불황 구간(성장률이 낮거나 마이너스)을 찾아보세요.
    </p>

    <ExplainBox title="경기 사이클의 4단계">
      <p><strong>확장(호황):</strong> GDP 증가, 실업률 하락, 기업 이윤 증가</p>
      <p><strong>정점(peak):</strong> 경기가 최고점에 도달. 과열 조짐</p>
      <p><strong>수축(불황):</strong> GDP 감소, 실업률 상승, 기업 이윤 감소</p>
      <p><strong>저점(trough):</strong> 경기가 최저점에 도달. 회복 시작</p>
    </ExplainBox>

    <ChartContainer id="cycleChart" height="380px" />

    <ExerciseBox title="경기 사이클 퀴즈">
      <p>위 차트에서 불황 구간을 모두 찾으세요. 몇 번의 경기 침체가 있었나요?</p>
      <div style="margin: 12px 0;">
        <button class="tb-btn" id="cycle-reveal">정답 확인</button>
      </div>
      <div id="cycle-answer" style="display: none; padding: 12px; background: #f0fdf4; border-radius: 8px; margin-top: 8px;">
        <p style="font-weight: bold; color: #059669;">주요 침체기 3번:</p>
        <ul style="margin: 8px 0 0 16px; line-height: 1.8;">
          <li><strong>1997-1998:</strong> IMF 외환위기 (성장률 -5.1%)</li>
          <li><strong>2008-2009:</strong> 글로벌 금융위기 (성장률 0.8%)</li>
          <li><strong>2020:</strong> 코로나19 팬데믹 (성장률 -0.7%)</li>
        </ul>
      </div>
    </ExerciseBox>
  </div>

  <!-- ===== INTERACTIVE 3: 정책 시뮬레이터 ===== -->
  <div class="tb-card">
    <h2>3. 경기 침체 정책 시뮬레이터</h2>
    <p>
      경기 침체가 발생했습니다! 당신은 경제 정책 결정자입니다.
      재정정책과 통화정책 중 어떤 도구를 사용할 것인가요?
      두 정책의 효과를 비교해 봅시다.
    </p>

    <WarningBox title="시나리오: 경기 침체">
      <p>현재 경제 상황: GDP 성장률 -2%, 실업률 6%, 물가상승률 1%, 기준금리 2%</p>
      <p>정부와 중앙은행이 각각 대응합니다.</p>
    </WarningBox>

    <div style="display: flex; gap: 16px; flex-wrap: wrap; margin: 16px 0;">
      <StatBox label="GDP 변화" value="-" id="pol-gdp" borderColor="#059669" />
      <StatBox label="실업률 변화" value="-" id="pol-unemp" borderColor="#f59e0b" />
      <StatBox label="물가 변화" value="-" id="pol-cpi" borderColor="#ef4444" />
    </div>

    <SimControls>
      <label><strong>재정정책:</strong> 정부 지출 변화: <span id="pol-fiscal-val">0</span>조원</label>
      <input type="range" id="pol-fiscal" min="0" max="50" value="0" step="5" />
      <label><strong>통화정책:</strong> 금리 변화: <span id="pol-monetary-val">0</span>%p</label>
      <input type="range" id="pol-monetary" min="-2" max="0" value="0" step="0.25" />
    </SimControls>

    <ChartContainer id="polChart" height="350px" />

    <ExerciseBox title="정책 판단">
      <p>재정정책과 통화정책을 동시에 사용하면 효과가 더 클까요?
        아니면 부작용이 있을까요?</p>
      <button class="tb-btn" id="pol-answer-btn">생각 힌트</button>
      <p id="pol-answer" style="margin-top: 8px; display: none; color: #059669;">
        동시에 사용하면 (정책 조합 = policy mix) 효과가 더 클 수 있습니다.
        하지만 재정정책은 국가부채 증가, 통화정책은 자산 버블 위험이 있으므로
        적절한 균형이 필요합니다. 2020년 코로나19 대응 시 전 세계가 양쪽 모두 사용했습니다.
      </p>
    </ExerciseBox>
  </div>

  <!-- ===== INTERACTIVE 4: IS-LM 모형 ===== -->
  <div class="tb-card">
    <h2>4. IS-LM 간이 모형</h2>
    <p>
      <strong>IS-LM 모형</strong>은 재정정책과 통화정책의 효과를
      이자율과 GDP 평면 위에서 보여주는 유명한 거시경제 모형입니다.
    </p>

    <ExplainBox title="IS 곡선과 LM 곡선">
      <p><strong>IS 곡선 (Investment-Saving):</strong>
        재화 시장의 균형. 이자율이 낮으면 투자가 많아져 GDP가 커짐. 우하향.</p>
      <p style="margin-top: 8px;"><strong>LM 곡선 (Liquidity-Money):</strong>
        화폐 시장의 균형. GDP가 커지면 화폐 수요 증가 → 이자율 상승. 우상향.</p>
      <p style="margin-top: 8px;"><strong>균형:</strong> 두 곡선의 교차점이 균형 이자율과 균형 GDP.</p>
    </ExplainBox>

    <div style="display: flex; gap: 16px; flex-wrap: wrap; margin: 16px 0;">
      <StatBox label="균형 GDP" value="-" id="islm-gdp" borderColor="#059669" />
      <StatBox label="균형 이자율" value="-" id="islm-rate" borderColor="#3b82f6" />
    </div>

    <SimControls>
      <label>재정정책 (IS 이동): <span id="islm-is-val">0</span></label>
      <input type="range" id="islm-is" min="-20" max="20" value="0" step="5" />
      <label>통화정책 (LM 이동): <span id="islm-lm-val">0</span></label>
      <input type="range" id="islm-lm" min="-20" max="20" value="0" step="5" />
    </SimControls>

    <ChartContainer id="islmChart" height="400px" />

    <InsightBox title="정책별 IS-LM 효과">
      <ul style="margin: 8px 0 0 16px; line-height: 1.8;">
        <li><strong>확장적 재정정책</strong> (정부 지출 증가): IS 오른쪽 이동 → GDP 증가 + 이자율 상승</li>
        <li><strong>확장적 통화정책</strong> (통화량 증가): LM 오른쪽 이동 → GDP 증가 + 이자율 하락</li>
        <li><strong>두 정책 동시</strong>: GDP는 확실히 증가, 이자율은 정책 조합에 따라 다름</li>
      </ul>
    </InsightBox>

    <WarningBox title="IS-LM 모형의 한계">
      <p>IS-LM은 단기 분석에 유용하지만 한계가 있습니다.</p>
      <ul style="margin: 8px 0 0 16px; line-height: 1.8;">
        <li>물가 수준을 고정으로 가정합니다 (인플레이션 분석에 부적합)</li>
        <li>기대(expectation)의 역할을 반영하지 못합니다</li>
        <li>개방 경제(수출/수입, 환율)를 포함하지 않습니다</li>
        <li>더 발전된 모형으로는 AD-AS 모형, IS-LM-BP 모형 등이 있습니다</li>
      </ul>
    </WarningBox>

    <ExerciseBox title="IS-LM 연습">
      <p>현재 균형에서 정부가 재정 지출을 크게 늘렸습니다 (IS 오른쪽 이동).
        동시에 중앙은행이 통화량을 늘렸습니다 (LM 오른쪽 이동).
        이 경우 GDP와 이자율은 어떻게 변하는가?</p>
      <button class="tb-btn" id="islm-quiz-btn" style="margin-top: 8px;">정답 보기</button>
      <p id="islm-quiz-answer" style="display: none; margin-top: 8px; font-weight: bold; color: #059669;">
        GDP는 확실히 증가합니다 (두 정책 모두 GDP를 높이는 방향).
        이자율은 불확실합니다 -- 재정정책은 이자율을 올리고, 통화정책은 내리므로
        어느 쪽이 더 강한지에 따라 달라집니다.
        슬라이더로 직접 실험해 보세요!
      </p>
    </ExerciseBox>
  </div>

  <!-- ===== INTERACTIVE 5: 보고서 생성기 ===== -->
  <div class="tb-card">
    <h2>5. 경제 상황 보고서 생성기</h2>
    <p>
      현재 경제 지표를 입력하면, 자동으로 경제 상황 진단과 정책 제언을 생성합니다.
      실제 경제 분석가처럼 종합적으로 판단해 봅시다.
    </p>

    <SimControls>
      <label>GDP 성장률: <span id="rpt-gdp-val">2.5</span>%</label>
      <input type="range" id="rpt-gdp" min="-5" max="8" value="2.5" step="0.5" />
      <label>물가상승률: <span id="rpt-cpi-val">2.5</span>%</label>
      <input type="range" id="rpt-cpi" min="0" max="8" value="2.5" step="0.5" />
      <label>실업률: <span id="rpt-unemp-val">3.5</span>%</label>
      <input type="range" id="rpt-unemp" min="1" max="10" value="3.5" step="0.5" />
      <label>기준금리: <span id="rpt-rate-val">3.0</span>%</label>
      <input type="range" id="rpt-rate" min="0" max="6" value="3.0" step="0.25" />
    </SimControls>

    <button class="tb-btn" id="rpt-generate" style="margin: 16px 0;">보고서 생성</button>

    <div id="rpt-output" style="padding: 20px; background: #f9fafb; border-radius: 12px; border: 1px solid #e5e7eb; margin: 16px 0; min-height: 100px;">
      <p style="color: #9ca3af;">위의 지표를 설정하고 "보고서 생성" 버튼을 눌러주세요.</p>
    </div>

    <ChartContainer id="rptChart" height="300px" />

    <ExerciseBox title="최종 종합 퀴즈">
      <p><strong>Q1.</strong> GDP가 감소하고, 실업률이 상승하고, 물가가 안정적이다. 어떤 정책이 적절한가?</p>
      <button class="tb-btn" onclick="document.getElementById('final-q1').textContent='정답! 경기 침체이므로 확장적 재정정책(지출 확대) + 확장적 통화정책(금리 인하)이 적절합니다.'; document.getElementById('final-q1').style.color='#059669';">확장적 정책</button>
      <button class="tb-btn" onclick="document.getElementById('final-q1').textContent='오답. 경기 침체 시 긴축 정책은 상황을 악화시킵니다.'; document.getElementById('final-q1').style.color='#ef4444';" style="margin-left: 8px;">긴축적 정책</button>
      <p id="final-q1" style="font-weight: bold; margin-top: 8px;"></p>

      <p style="margin-top: 16px;"><strong>Q2.</strong> GDP 성장률이 높고 물가가 급등하고 있다. 중앙은행의 적절한 대응은?</p>
      <button class="tb-btn" onclick="document.getElementById('final-q2').textContent='정답! 경기 과열과 인플레이션 억제를 위해 금리를 올려야 합니다.'; document.getElementById('final-q2').style.color='#059669';">금리 인상</button>
      <button class="tb-btn" onclick="document.getElementById('final-q2').textContent='오답. 금리 인하는 소비/투자를 더 촉진해 물가를 더 올립니다.'; document.getElementById('final-q2').style.color='#ef4444';" style="margin-left: 8px;">금리 인하</button>
      <p id="final-q2" style="font-weight: bold; margin-top: 8px;"></p>

      <p style="margin-top: 16px;"><strong>Q3.</strong> 실업률이 자연실업률 수준이고, GDP 성장률이 잠재 성장률에 가깝다. 적절한 정책은?</p>
      <button class="tb-btn" onclick="document.getElementById('final-q3').textContent='정답! 경제가 균형 상태이므로 현 기조를 유지하는 것이 적절합니다.'; document.getElementById('final-q3').style.color='#059669';">현 기조 유지</button>
      <button class="tb-btn" onclick="document.getElementById('final-q3').textContent='오답. 균형 상태에서 확장 정책은 경기 과열을 유발할 수 있습니다.'; document.getElementById('final-q3').style.color='#ef4444';" style="margin-left: 8px;">확장적 정책</button>
      <p id="final-q3" style="font-weight: bold; margin-top: 8px;"></p>
    </ExerciseBox>
  </div>

  <!-- ===== MACRO REVIEW ===== -->
  <div class="tb-card">
    <h2>거시경제학 개념 지도</h2>
    <p>11장부터 18장까지 배운 핵심 개념들이 어떻게 연결되는지 정리합니다.</p>

    <ExplainBox title="거시경제의 연결 구조">
      <p><strong>GDP (11장)</strong> -- 경제 규모의 측정</p>
      <p style="margin-left: 20px;">→ <strong>인플레이션 (12장)</strong>: 명목 vs 실질의 차이</p>
      <p style="margin-left: 20px;">→ <strong>실업 (13장)</strong>: GDP가 낮으면 실업 증가 (오쿤의 법칙)</p>
      <p style="margin-left: 40px;">→ <strong>화폐/금융 (14장)</strong>: 통화량이 GDP와 물가에 영향</p>
      <p style="margin-left: 40px;">→ <strong>재정정책 (15장)</strong>: 정부 지출(G)이 GDP에 직접 영향</p>
      <p style="margin-left: 40px;">→ <strong>통화정책 (16장)</strong>: 금리가 투자(I)와 소비(C)에 영향</p>
      <p style="margin-left: 40px;">→ <strong>국제무역 (17장)</strong>: 순수출(NX)이 GDP에 영향</p>
    </ExplainBox>

    <InsightBox title="경제학 공부의 다음 단계">
      <p>이제 미시경제와 거시경제의 기초를 모두 배웠습니다.
        다음 파트에서는 이 도구들을 활용하여 한국의 실제 경제 문제를 분석합니다:</p>
      <ul style="margin: 8px 0 0 16px; line-height: 1.8;">
        <li>19장: 한국 부동산 시장 -- 왜 집값이 오르는가?</li>
        <li>20장: 한국 노동시장 -- 최저임금, 청년실업, 고령화</li>
        <li>21장: 경제위기 시뮬레이션 -- 1997, 2008, 2020</li>
      </ul>
    </InsightBox>
  </div>

  <!-- ===== CONCLUSION ===== -->
  <ConclusionBox title="18장 정리: 거시경제 종합">
    <ul style="margin: 8px 0 0 16px; line-height: 1.8;">
      <li>거시경제는 <strong>GDP, 물가, 실업률, 금리, 환율</strong> 5대 지표로 진단</li>
      <li>경기는 <strong>호황 → 정점 → 불황 → 저점</strong>의 사이클을 반복</li>
      <li>경기 침체 시 <strong>재정정책</strong>(정부 지출 확대)과 <strong>통화정책</strong>(금리 인하)으로 대응</li>
      <li><strong>IS-LM 모형</strong>으로 두 정책의 효과를 분석 가능</li>
      <li>경제 분석은 여러 지표를 <strong>종합적으로</strong> 판단해야 함</li>
    </ul>
    <p style="margin-top: 12px;">
      <strong>축하합니다!</strong> 거시경제학 파트를 모두 완료했습니다.
      다음 파트에서는 배운 개념으로 한국 경제의 실제 이슈를 분석합니다.
    </p>
  </ConclusionBox>

</EconTextbookLayout>

<script is:inline>
function waitForChart(fn) {
  if (typeof Chart !== 'undefined') { fn(); return; }
  var s = document.querySelector('script[src*="chart.js"]');
  if (s) { s.addEventListener('load', fn); return; }
  setTimeout(function() { waitForChart(fn); }, 50);
}

function init() {
  /* ===== 공통 데이터 (2000-2025, 합성) ===== */
  var years = [];
  for (var y = 2000; y <= 2025; y++) years.push(y);
  var gdpGrowth = [8.9,4.5,7.4,3.1,4.9,3.9,5.2,5.5,2.8,0.8,6.8,3.7,2.4,3.2,3.2,2.8,2.9,3.2,2.9,-0.7,4.3,2.6,1.4,2.2,2.6,2.2];
  var cpi = [2.3,4.1,2.8,3.5,3.6,2.8,2.2,2.5,4.7,2.8,3.0,4.0,2.2,1.3,1.3,0.7,1.0,1.9,1.5,0.5,2.5,2.5,5.1,3.6,2.5,2.2];
  var unemp = [4.1,3.8,3.1,3.4,3.5,3.5,3.3,3.0,3.0,3.7,3.4,3.1,3.0,3.1,3.5,3.6,3.7,3.7,3.8,4.5,3.6,2.9,2.7,2.8,3.0,3.2];
  var baseRate = [5.25,4.0,4.25,3.75,3.5,3.25,4.5,5.0,3.0,2.0,2.5,3.25,2.75,2.5,2.0,1.5,1.25,1.5,1.75,0.5,0.75,1.0,3.5,3.5,3.0,2.75];
  var exchangeRate = [1131,1291,1251,1192,1145,1024,955,929,1102,1276,1156,1108,1127,1095,1053,1172,1208,1071,1100,1180,1088,1186,1292,1305,1350,1380];

  /* ========== 1. 종합 대시보드 ========== */
  var dashYearSlider = document.getElementById('dash-year');
  var dashCtx = document.getElementById('dashChart');

  var dashChart = new Chart(dashCtx, {
    type: 'line',
    data: {
      labels: years,
      datasets: [
        { label: 'GDP 성장률 (%)', data: gdpGrowth, borderColor: '#059669', borderWidth: 2, tension: 0.3, pointRadius: 2, yAxisID: 'y' },
        { label: '인플레이션 (%)', data: cpi, borderColor: '#ef4444', borderWidth: 2, tension: 0.3, pointRadius: 2, yAxisID: 'y' },
        { label: '실업률 (%)', data: unemp, borderColor: '#f59e0b', borderWidth: 2, tension: 0.3, pointRadius: 2, yAxisID: 'y' },
        { label: '기준금리 (%)', data: baseRate, borderColor: '#3b82f6', borderWidth: 2, tension: 0.3, pointRadius: 2, yAxisID: 'y' },
        { label: '환율 (원/달러)', data: exchangeRate, borderColor: '#7c3aed', borderWidth: 2, tension: 0.3, pointRadius: 2, yAxisID: 'y1' }
      ]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      scales: {
        y: { title: { display: true, text: '% / 금리' }, position: 'left', min: -2, max: 10 },
        y1: { title: { display: true, text: '원/달러' }, position: 'right', min: 800, max: 1500, grid: { drawOnChartArea: false } }
      },
      plugins: { legend: { position: 'top' } }
    }
  });

  function updateDash() {
    var yr = parseInt(dashYearSlider.value);
    document.getElementById('dash-year-val').textContent = yr;
    var idx = yr - 2000;
    if (idx < 0 || idx >= years.length) return;
    document.getElementById('dash-gdp').textContent = gdpGrowth[idx] + '%';
    document.getElementById('dash-cpi').textContent = cpi[idx] + '%';
    document.getElementById('dash-unemp').textContent = unemp[idx] + '%';
    document.getElementById('dash-rate').textContent = baseRate[idx] + '%';
    document.getElementById('dash-fx').textContent = exchangeRate[idx] + '원';
  }

  dashYearSlider.addEventListener('input', updateDash);
  updateDash();

  /* ========== 2. 경기 사이클 식별 ========== */
  var cycleYears = [];
  for (var cy = 1995; cy <= 2025; cy++) cycleYears.push(cy);
  var cycleGrowth = [
    6.8,7.0,4.5,-5.1,11.3,8.9,4.5,7.4,3.1,4.9,3.9,5.2,5.5,2.8,0.8,
    6.8,3.7,2.4,3.2,3.2,2.8,2.9,3.2,2.9,-0.7,4.3,2.6,1.4,2.2,2.6,2.2
  ];

  var cycleBg = cycleGrowth.map(function(v) {
    if (v < 0) return 'rgba(239,68,68,0.7)';
    if (v < 2) return 'rgba(245,158,11,0.5)';
    return 'rgba(5,150,105,0.5)';
  });

  var cycleCtx = document.getElementById('cycleChart');
  new Chart(cycleCtx, {
    type: 'bar',
    data: {
      labels: cycleYears,
      datasets: [{
        label: 'GDP 성장률 (%)',
        data: cycleGrowth,
        backgroundColor: cycleBg,
        borderWidth: 0,
        borderRadius: 3
      }]
    },
    options: {
      responsive: true,
      scales: {
        x: { title: { display: true, text: '연도' } },
        y: { title: { display: true, text: '성장률 (%)' } }
      },
      plugins: { legend: { display: false } }
    }
  });

  document.getElementById('cycle-reveal').addEventListener('click', function() {
    document.getElementById('cycle-answer').style.display = 'block';
  });

  /* ========== 3. 정책 시뮬레이터 ========== */
  var polFiscal = document.getElementById('pol-fiscal');
  var polMonetary = document.getElementById('pol-monetary');
  var polCtx = document.getElementById('polChart');

  var polChart = new Chart(polCtx, {
    type: 'bar',
    data: {
      labels: ['현재', '재정정책만', '통화정책만', '정책 조합'],
      datasets: [
        { label: 'GDP 성장률 (%)', data: [-2, -2, -2, -2], backgroundColor: 'rgba(5,150,105,0.6)', borderRadius: 4 },
        { label: '실업률 (%)', data: [6, 6, 6, 6], backgroundColor: 'rgba(245,158,11,0.6)', borderRadius: 4 },
        { label: '물가상승률 (%)', data: [1, 1, 1, 1], backgroundColor: 'rgba(239,68,68,0.6)', borderRadius: 4 }
      ]
    },
    options: {
      responsive: true,
      scales: { y: { title: { display: true, text: '%' } } },
      plugins: { legend: { position: 'top' } }
    }
  });

  function updatePol() {
    var fiscal = parseInt(polFiscal.value); // 조원
    var monetary = parseFloat(polMonetary.value); // %p (음수 = 인하)

    document.getElementById('pol-fiscal-val').textContent = fiscal;
    document.getElementById('pol-monetary-val').textContent = monetary;

    // 간단 모형: 재정 승수 1.5, 통화정책 효과
    var fiscalGDP = fiscal * 0.06; // 조원 → % 환산 (대략적)
    var monetaryGDP = -monetary * 0.8; // 금리 인하 → GDP 증가
    var combinedGDP = fiscalGDP + monetaryGDP;

    var baseGDP = -2;
    var baseUnemp = 6;
    var baseCPI = 1;

    var gdpF = baseGDP + fiscalGDP;
    var gdpM = baseGDP + monetaryGDP;
    var gdpC = baseGDP + combinedGDP;

    var unempF = baseUnemp - fiscalGDP * 0.5;
    var unempM = baseUnemp - monetaryGDP * 0.5;
    var unempC = baseUnemp - combinedGDP * 0.5;

    var cpiF = baseCPI + fiscalGDP * 0.3;
    var cpiM = baseCPI + monetaryGDP * 0.3;
    var cpiC = baseCPI + combinedGDP * 0.3;

    document.getElementById('pol-gdp').textContent = (gdpC > 0 ? '+' : '') + gdpC.toFixed(1) + '%';
    document.getElementById('pol-unemp').textContent = unempC.toFixed(1) + '%';
    document.getElementById('pol-cpi').textContent = cpiC.toFixed(1) + '%';

    polChart.data.datasets[0].data = [baseGDP, parseFloat(gdpF.toFixed(1)), parseFloat(gdpM.toFixed(1)), parseFloat(gdpC.toFixed(1))];
    polChart.data.datasets[1].data = [baseUnemp, parseFloat(unempF.toFixed(1)), parseFloat(unempM.toFixed(1)), parseFloat(unempC.toFixed(1))];
    polChart.data.datasets[2].data = [baseCPI, parseFloat(cpiF.toFixed(1)), parseFloat(cpiM.toFixed(1)), parseFloat(cpiC.toFixed(1))];
    polChart.update();
  }

  polFiscal.addEventListener('input', updatePol);
  polMonetary.addEventListener('input', updatePol);
  updatePol();

  document.getElementById('pol-answer-btn').addEventListener('click', function() {
    document.getElementById('pol-answer').style.display = 'block';
  });

  var islmQuizBtn = document.getElementById('islm-quiz-btn');
  if (islmQuizBtn) {
    islmQuizBtn.addEventListener('click', function() {
      document.getElementById('islm-quiz-answer').style.display = 'block';
    });
  }

  /* ========== 4. IS-LM 모형 ========== */
  var islmIS = document.getElementById('islm-is');
  var islmLM = document.getElementById('islm-lm');
  var islmCtx = document.getElementById('islmChart');

  function getISData(shift) {
    var pts = [];
    for (var y = 50; y <= 200; y += 10) {
      var r = 10 - shift * 0.3 - (y - 100) * 0.05;
      pts.push({ x: y, y: r });
    }
    return pts;
  }

  function getLMData(shift) {
    var pts = [];
    for (var y = 50; y <= 200; y += 10) {
      var r = -2 - shift * 0.3 + (y - 100) * 0.06;
      pts.push({ x: y, y: r });
    }
    return pts;
  }

  var islmChart = new Chart(islmCtx, {
    type: 'scatter',
    data: {
      datasets: [
        { label: 'IS', data: getISData(0), showLine: true, borderColor: '#3b82f6', borderWidth: 3, pointRadius: 0, fill: false },
        { label: 'IS (원래)', data: getISData(0), showLine: true, borderColor: '#3b82f6', borderWidth: 1, borderDash: [5, 5], pointRadius: 0, fill: false },
        { label: 'LM', data: getLMData(0), showLine: true, borderColor: '#ef4444', borderWidth: 3, pointRadius: 0, fill: false },
        { label: 'LM (원래)', data: getLMData(0), showLine: true, borderColor: '#ef4444', borderWidth: 1, borderDash: [5, 5], pointRadius: 0, fill: false },
        { label: '균형', data: [], pointRadius: 10, pointBackgroundColor: '#059669', borderColor: '#059669', showLine: false }
      ]
    },
    options: {
      responsive: true,
      scales: {
        x: { title: { display: true, text: 'GDP (Y)' }, min: 50, max: 200 },
        y: { title: { display: true, text: '이자율 (r, %)' }, min: -2, max: 10 }
      },
      plugins: { legend: { position: 'top' } }
    }
  });

  function updateISLM() {
    var isShift = parseInt(islmIS.value);
    var lmShift = parseInt(islmLM.value);
    document.getElementById('islm-is-val').textContent = isShift > 0 ? '+' + isShift : isShift;
    document.getElementById('islm-lm-val').textContent = lmShift > 0 ? '+' + lmShift : lmShift;

    var isData = getISData(isShift);
    var lmData = getLMData(lmShift);

    // 균형 찾기: IS: r = 10 - isShift*0.3 - (Y-100)*0.05
    //            LM: r = -2 - lmShift*0.3 + (Y-100)*0.06
    // 10 - isShift*0.3 - (Y-100)*0.05 = -2 - lmShift*0.3 + (Y-100)*0.06
    // 12 - isShift*0.3 + lmShift*0.3 = (Y-100)*0.11
    var eqY = 100 + (12 - isShift * 0.3 + lmShift * 0.3) / 0.11;
    var eqR = 10 - isShift * 0.3 - (eqY - 100) * 0.05;

    document.getElementById('islm-gdp').textContent = eqY.toFixed(0);
    document.getElementById('islm-rate').textContent = eqR.toFixed(1) + '%';

    islmChart.data.datasets[0].data = isData;
    islmChart.data.datasets[2].data = lmData;
    islmChart.data.datasets[4].data = [{ x: eqY, y: eqR }];
    islmChart.update();
  }

  islmIS.addEventListener('input', updateISLM);
  islmLM.addEventListener('input', updateISLM);
  updateISLM();

  /* ========== 5. 보고서 생성기 ========== */
  var rptGdp = document.getElementById('rpt-gdp');
  var rptCpi = document.getElementById('rpt-cpi');
  var rptUnemp = document.getElementById('rpt-unemp');
  var rptRate = document.getElementById('rpt-rate');
  var rptOutput = document.getElementById('rpt-output');
  var rptCtx = document.getElementById('rptChart');

  var rptChart = new Chart(rptCtx, {
    type: 'radar',
    data: {
      labels: ['GDP 성장률', '물가 안정', '고용', '금리 적정성', '종합 건전성'],
      datasets: [{
        label: '현재 경제 점수',
        data: [5, 5, 5, 5, 5],
        borderColor: '#059669',
        backgroundColor: 'rgba(5,150,105,0.2)',
        borderWidth: 2,
        pointBackgroundColor: '#059669'
      }]
    },
    options: {
      responsive: true,
      scales: { r: { min: 0, max: 10, ticks: { stepSize: 2 } } },
      plugins: { legend: { display: false } }
    }
  });

  [rptGdp, rptCpi, rptUnemp, rptRate].forEach(function(el) {
    el.addEventListener('input', function() {
      document.getElementById(el.id + '-val').textContent = el.value;
    });
  });

  document.getElementById('rpt-generate').addEventListener('click', function() {
    var g = parseFloat(rptGdp.value);
    var c = parseFloat(rptCpi.value);
    var u = parseFloat(rptUnemp.value);
    var r = parseFloat(rptRate.value);

    // 점수 계산 (10점 만점)
    var gScore = Math.max(0, Math.min(10, 5 + g));
    var cScore = Math.max(0, Math.min(10, 10 - Math.abs(c - 2) * 2));
    var uScore = Math.max(0, Math.min(10, 10 - (u - 3) * 1.5));
    var rScore = Math.max(0, Math.min(10, 10 - Math.abs(r - (g + c) / 2) * 1.5));
    var total = (gScore + cScore + uScore + rScore) / 4;

    rptChart.data.datasets[0].data = [
      parseFloat(gScore.toFixed(1)),
      parseFloat(cScore.toFixed(1)),
      parseFloat(uScore.toFixed(1)),
      parseFloat(rScore.toFixed(1)),
      parseFloat(total.toFixed(1))
    ];
    rptChart.update();

    // 경기 판단
    var situation = '';
    if (g >= 3 && c <= 3 && u <= 4) {
      situation = '경기가 양호합니다. 안정적인 성장세를 유지하고 있습니다.';
    } else if (g < 0) {
      situation = '경기 침체 상태입니다. 마이너스 성장이 진행되고 있습니다.';
    } else if (g < 2 && u > 4) {
      situation = '경기 둔화 상태입니다. 성장이 느리고 실업이 높아지고 있습니다.';
    } else if (c > 4) {
      situation = '인플레이션 압력이 높습니다. 물가 관리가 필요합니다.';
    } else if (g >= 5 && c > 3) {
      situation = '경기 과열 조짐이 있습니다. 성장률이 높지만 물가도 오르고 있습니다.';
    } else {
      situation = '경기가 보통 수준입니다.';
    }

    // 정책 제언
    var policy = '';
    if (g < 1 && u > 4) {
      policy = '<strong>재정정책:</strong> 정부 지출 확대 또는 감세를 통한 경기 부양 필요. ' +
        '<strong>통화정책:</strong> 기준금리 인하를 통한 소비/투자 촉진 필요.';
    } else if (c > 4) {
      policy = '<strong>재정정책:</strong> 긴축적 운용 필요. ' +
        '<strong>통화정책:</strong> 기준금리 인상을 통한 물가 안정 필요.';
    } else if (g >= 3 && c <= 3) {
      policy = '현재 정책 기조 유지가 적절합니다. 급격한 정책 변경은 불필요합니다.';
    } else {
      policy = '경제 상황을 주시하며 점진적 정책 조정이 필요합니다.';
    }

    rptOutput.innerHTML =
      '<h3 style="margin: 0 0 12px; color: #059669;">경제 상황 보고서</h3>' +
      '<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px;">' +
        '<div>GDP 성장률: <strong>' + g + '%</strong></div>' +
        '<div>물가상승률: <strong>' + c + '%</strong></div>' +
        '<div>실업률: <strong>' + u + '%</strong></div>' +
        '<div>기준금리: <strong>' + r + '%</strong></div>' +
      '</div>' +
      '<p style="margin-bottom: 8px;"><strong>경기 진단:</strong> ' + situation + '</p>' +
      '<p style="margin-bottom: 8px;"><strong>종합 점수:</strong> ' + total.toFixed(1) + ' / 10.0</p>' +
      '<p><strong>정책 제언:</strong> ' + policy + '</p>';
  });
}

waitForChart(init);
</script>
