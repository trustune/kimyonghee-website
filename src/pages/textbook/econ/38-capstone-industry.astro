      strategies: [
        { name: '현대', price: 5, diff: 8, network: 6, innovation: 9, brand: 9, desc: '제네시스 프리미엄, 전기차 아이오닉, 글로벌 확장' },
        { name: '기아', price: 7, diff: 8, network: 5, innovation: 8, brand: 8, desc: '디자인 혁신, EV6/EV9, 가성비' },
        { name: '수입차', price: 3, diff: 9, network: 4, innovation: 7, brand: 9, desc: '벤츠/BMW/테슬라, 프리미엄 브랜드' },
        { name: 'KG모빌리티', price: 8, diff: 4, network: 3, innovation: 4, brand: 3, desc: '가격 경쟁력, SUV 특화' }
      ],
      game: {
        player1: '현대', player2: '기아',
        strat1: ['전기차 집중', '내연기관 유지'],
        strat2: ['전기차 집중', '내연기관 유지'],
        payoffs: [[450, 430], [380, 350], [350, 380], [400, 400]],
        scenario: '현대와 기아의 전기차 전환 속도를 분석합니다.'
      },
      regulation: '배출가스 규제, 전기차 보조금, 안전 기준, 자율주행 법규',
      outlook: '전기차 전환 가속, 현대기아의 글로벌 시장 점유율 확대, 중국 전기차 진입 위협'
    }
  ];

  var selectedIdx = -1;
  var chartColors = ['#3b82f6', '#ef4444', '#059669', '#f59e0b', '#6366f1', '#ec4899'];

  /* ===== Charts ===== */
  var pieCtx = document.getElementById('capPieChart').getContext('2d');
  var barCtx = document.getElementById('capBarChart').getContext('2d');
  var radarCtx = document.getElementById('capRadarChart').getContext('2d');
  var summCtx = document.getElementById('capSummaryChart').getContext('2d');

  var pieChart = new Chart(pieCtx, {
    type: 'pie',
    data: { labels: [], datasets: [{ data: [], backgroundColor: chartColors }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' }, title: { display: true, text: '시장점유율' } } }
  });

  var barChart = new Chart(barCtx, {
    type: 'bar',
    data: { labels: [], datasets: [{ label: '점유율(%)', data: [], backgroundColor: chartColors }] },
    options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, max: 100 } }, plugins: { legend: { display: false }, title: { display: true, text: '기업별 점유율' } } }
  });

  var radarChart = new Chart(radarCtx, {
    type: 'radar',
    data: {
      labels: ['가격경쟁력', '차별화', '네트워크효과', '혁신', '브랜드'],
      datasets: []
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      scales: { r: { beginAtZero: true, max: 10, ticks: { stepSize: 2 } } },
      plugins: { legend: { position: 'bottom' } }
    }
  });

  var summChart = new Chart(summCtx, {
    type: 'radar',
    data: {
      labels: ['시장 집중도', '진입 장벽', '가격 경쟁', '차별화', '혁신 속도', '규제 강도'],
      datasets: [{ label: '', data: [0, 0, 0, 0, 0, 0], borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.15)', borderWidth: 2 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      scales: { r: { beginAtZero: true, max: 10, ticks: { stepSize: 2 } } },
      plugins: { legend: { display: false } }
    }
  });

  /* ===== 1. Industry Cards ===== */
  var cardsDiv = document.getElementById('industry-cards');
  industries.forEach(function(ind, idx) {
    var card = document.createElement('div');
    card.className = 'industry-card';
    card.style.cssText = 'padding: 16px; background: #f9fafb; border: 2px solid #e5e7eb; border-radius: 12px; cursor: pointer; text-align: center; transition: all 0.2s;';
    card.innerHTML = '<div style="font-size: 1.5em;">' + ind.icon + '</div><div style="font-weight: bold; margin-top: 8px;">' + ind.name + '</div>' +
      '<div style="font-size: 0.85em; color: #6b7280;">' + ind.firms.length + '개 기업</div>';

    card.addEventListener('click', function() {
      selectedIdx = idx;
      document.querySelectorAll('.industry-card').forEach(function(c) {
        c.style.borderColor = '#e5e7eb'; c.style.background = '#f9fafb';
      });
      card.style.borderColor = '#3b82f6'; card.style.background = '#eff6ff';
      updateAll();
    });

    cardsDiv.appendChild(card);
  });

  function updateAll() {
    if (selectedIdx < 0) return;
    var ind = industries[selectedIdx];

    /* Overview */
    var ov = document.getElementById('industry-overview');
    ov.style.display = 'block';
    ov.innerHTML = '<h3 style="margin: 0 0 8px;">' + ind.name + ' 산업 개요</h3>' +
      '<p><strong>주요 기업:</strong> ' + ind.firms.join(', ') + '</p>' +
      '<p><strong>시장 구조:</strong> ' + (ind.shares.length <= 2 ? '복점' : ind.shares[0] > 50 ? '지배적 기업 과점' : '과점') + '</p>' +
      '<p><strong>진입 장벽:</strong> ' + ind.barrierLevel + '</p>';

    /* 2. 시장 구조 */
    var hhi = 0;
    ind.shares.forEach(function(s) { hhi += s * s; });

    pieChart.data.labels = ind.firms;
    pieChart.data.datasets[0].data = ind.shares;
    pieChart.update();

    barChart.data.labels = ind.firms;
    barChart.data.datasets[0].data = ind.shares;
    barChart.update();

    document.getElementById('cap-hhi').textContent = Math.round(hhi).toLocaleString();
    document.getElementById('cap-type').textContent = hhi > 2500 ? '고집중' : hhi > 1500 ? '중간 집중' : '경쟁적';
    document.getElementById('cap-top1').textContent = ind.shares[0] + '%';
    document.getElementById('cap-barrier').textContent = ind.barrierLevel;

    var barrierHtml = '<h4 style="margin: 0 0 8px;">진입 장벽 상세</h4><ul style="margin: 0; padding-left: 20px;">';
    ind.barriers.forEach(function(b) { barrierHtml += '<li>' + b + '</li>'; });
    barrierHtml += '</ul>';
    document.getElementById('cap-barrier-detail').innerHTML = barrierHtml;

    /* 구조 분석 힌트 */
    document.getElementById('cap-struct-ans').innerHTML =
      '<p><strong>HHI = ' + Math.round(hhi) + ':</strong> ' + (hhi > 2500 ? '고집중 시장. 소수 기업이 시장을 지배합니다.' : hhi > 1500 ? '중간 집중도. 과점 구조입니다.' : '비교적 경쟁적인 시장입니다.') + '</p>' +
      '<p><strong>1위 점유율 ' + ind.shares[0] + '%:</strong> ' + (ind.shares[0] > 50 ? '지배적 사업자입니다. 시장 지배력 남용 우려가 있습니다.' : '상당한 점유율이지만 지배적이라고 단정하기는 어렵습니다.') + '</p>' +
      '<p><strong>진입 장벽:</strong> ' + ind.barriers[0] + '</p>';

    /* 3. 전략 분석 */
    radarChart.data.datasets = ind.strategies.map(function(st, si) {
      return {
        label: st.name,
        data: [st.price, st.diff, st.network, st.innovation, st.brand],
        borderColor: chartColors[si],
        backgroundColor: chartColors[si] + '22',
        borderWidth: 2
      };
    });
    radarChart.update();

    var stratHtml = '<table style="width: 100%; border-collapse: collapse;">';
    stratHtml += '<tr style="border-bottom: 2px solid #e5e7eb;"><th style="text-align: left; padding: 8px;">기업</th><th>가격</th><th>차별화</th><th>네트워크</th><th>혁신</th><th>브랜드</th><th style="text-align: left;">전략 설명</th></tr>';
    ind.strategies.forEach(function(st, si) {
      stratHtml += '<tr style="border-bottom: 1px solid #f3f4f6;"><td style="padding: 8px; font-weight: bold; color: ' + chartColors[si] + ';">' + st.name + '</td>' +
        '<td style="text-align: center;">' + st.price + '</td>' +
        '<td style="text-align: center;">' + st.diff + '</td>' +
        '<td style="text-align: center;">' + st.network + '</td>' +
        '<td style="text-align: center;">' + st.innovation + '</td>' +
        '<td style="text-align: center;">' + st.brand + '</td>' +
        '<td style="padding: 8px; font-size: 0.85em;">' + st.desc + '</td></tr>';
    });
    stratHtml += '</table>';
    document.getElementById('cap-strategy-table').innerHTML = stratHtml;

    /* 전략 분석 힌트 */
    var bestDiff = ind.strategies.reduce(function(best, st) { return st.diff > best.diff ? st : best; });
    var bestPrice = ind.strategies.reduce(function(best, st) { return st.price > best.price ? st : best; });
    document.getElementById('cap-strat-ans').innerHTML =
      '<p><strong>가장 차별화된:</strong> ' + bestDiff.name + ' (차별화 ' + bestDiff.diff + '/10)</p>' +
      '<p><strong>가격 경쟁력:</strong> ' + bestPrice.name + ' (가격 경쟁력 ' + bestPrice.price + '/10)</p>' +
      '<p><strong>장기 전략:</strong> 차별화와 혁신이 높은 기업이 장기적으로 유리합니다. 가격 경쟁만으로는 지속 가능하지 않습니다.</p>';

    /* 4. 게임이론 */
    var g = ind.game;
    var setupHtml = '<h4 style="margin: 0 0 8px;">게임 설정: ' + ind.name + '</h4>' +
      '<p>' + g.scenario + '</p>' +
      '<p><strong>' + g.player1 + ':</strong> ' + g.strat1.join(' / ') + '</p>' +
      '<p><strong>' + g.player2 + ':</strong> ' + g.strat2.join(' / ') + '</p>';
    document.getElementById('game-setup').innerHTML = setupHtml;

    var mHtml = '<table style="width: 100%; border-collapse: collapse; text-align: center; margin-top: 8px;">';
    mHtml += '<tr><td></td><td></td><td colspan="2" style="font-weight: bold; padding: 8px; background: #fef2f2;">' + g.player2 + '</td></tr>';
    mHtml += '<tr><td></td><td></td><td style="padding: 8px; font-weight: bold; background: #fef2f2;">' + g.strat2[0] + '</td><td style="padding: 8px; font-weight: bold; background: #fef2f2;">' + g.strat2[1] + '</td></tr>';
    mHtml += '<tr><td rowspan="2" style="font-weight: bold; padding: 8px; background: #eff6ff; writing-mode: vertical-rl; text-orientation: mixed;">' + g.player1 + '</td>';
    mHtml += '<td style="padding: 8px; font-weight: bold; background: #eff6ff;">' + g.strat1[0] + '</td>';
    mHtml += '<td style="padding: 12px; border: 2px solid #e5e7eb;" id="cell-00"><span style="color: #3b82f6;">' + g.payoffs[0][0] + '</span>, <span style="color: #ef4444;">' + g.payoffs[0][1] + '</span></td>';
    mHtml += '<td style="padding: 12px; border: 2px solid #e5e7eb;" id="cell-01"><span style="color: #3b82f6;">' + g.payoffs[1][0] + '</span>, <span style="color: #ef4444;">' + g.payoffs[1][1] + '</span></td></tr>';
    mHtml += '<tr><td style="padding: 8px; font-weight: bold; background: #eff6ff;">' + g.strat1[1] + '</td>';
    mHtml += '<td style="padding: 12px; border: 2px solid #e5e7eb;" id="cell-10"><span style="color: #3b82f6;">' + g.payoffs[2][0] + '</span>, <span style="color: #ef4444;">' + g.payoffs[2][1] + '</span></td>';
    mHtml += '<td style="padding: 12px; border: 2px solid #e5e7eb;" id="cell-11"><span style="color: #3b82f6;">' + g.payoffs[3][0] + '</span>, <span style="color: #ef4444;">' + g.payoffs[3][1] + '</span></td></tr>';
    mHtml += '</table>';
    mHtml += '<p style="margin-top: 8px; font-size: 0.85em; color: #6b7280;"><span style="color: #3b82f6;">' + g.player1 + ' 보수</span>, <span style="color: #ef4444;">' + g.player2 + ' 보수</span> (단위: 억원)</p>';
    document.getElementById('payoff-matrix').innerHTML = mHtml;

    /* 게임 분석 힌트 */
    document.getElementById('cap-game-ans').innerHTML =
      '<p>보수행렬에서 내쉬 균형을 찾으세요. 각 플레이어가 상대 전략이 고정일 때 자신의 최선을 선택하는 조합입니다.</p>' +
      '<p>"내쉬 균형 찾기" 버튼을 눌러 확인할 수 있습니다.</p>';

    /* Summary radar */
    var avgInno = ind.strategies.reduce(function(s, st) { return s + st.innovation; }, 0) / ind.strategies.length;
    var avgDiff = ind.strategies.reduce(function(s, st) { return s + st.diff; }, 0) / ind.strategies.length;
    var avgPrice = ind.strategies.reduce(function(s, st) { return s + st.price; }, 0) / ind.strategies.length;
    var concent = Math.min(10, hhi / 1000);
    var barrierScore = ind.barrierLevel === '매우 높음' ? 9 : ind.barrierLevel === '높음' ? 7 : 5;
    var regScore = ind.regulation.length > 30 ? 7 : 5;

    summChart.data.datasets[0].label = ind.name;
    summChart.data.datasets[0].data = [concent, barrierScore, avgPrice, avgDiff, avgInno, regScore];
    summChart.update();
  }

  /* ===== Game Theory Buttons ===== */
  document.getElementById('game-find-nash').addEventListener('click', function() {
    if (selectedIdx < 0) return;
    var g = industries[selectedIdx].game;
    var p = g.payoffs;

    /* Find Nash: check best responses */
    var nashCells = [];
    /* Player 1 best response given player 2 plays strat 0 */
    var p1_br0 = p[0][0] >= p[2][0] ? 0 : 1; /* row 0 vs row 1 given col 0 */
    var p1_br1 = p[1][0] >= p[3][0] ? 0 : 1;
    /* Player 2 best response given player 1 plays strat 0 */
    var p2_br0 = p[0][1] >= p[1][1] ? 0 : 1;
    var p2_br1 = p[2][1] >= p[3][1] ? 0 : 1;

    /* Cell (0,0): p1 chose 0, p2 chose 0. Nash if p1_br0=0 and p2_br0=0 */
    if (p1_br0 === 0 && p2_br0 === 0) nashCells.push('00');
    if (p1_br0 === 0 && p2_br0 === 1) nashCells.push('01');
    if (p1_br1 === 1 && p2_br1 === 0) nashCells.push('10');
    if (p1_br1 === 1 && p2_br1 === 1) nashCells.push('11');

    ['00', '01', '10', '11'].forEach(function(id) {
      var cell = document.getElementById('cell-' + id);
      if (cell) {
        if (nashCells.indexOf(id) >= 0) {
          cell.style.background = '#f0fdf4';
          cell.style.borderColor = '#059669';
          cell.style.fontWeight = 'bold';
        } else {
          cell.style.background = '';
          cell.style.borderColor = '#e5e7eb';
          cell.style.fontWeight = '';
        }
      }
    });

    var analysis = document.getElementById('game-analysis');
    analysis.style.display = 'block';
    analysis.style.background = '#f0fdf4';
    analysis.style.border = '2px solid #059669';
    analysis.innerHTML = '<h4 style="margin: 0 0 8px; color: #059669;">내쉬 균형 발견</h4>' +
      '<p>초록색으로 표시된 칸이 내쉬 균형입니다. 이 칸에서는 어느 플레이어도 일방적으로 전략을 바꿔 이득을 볼 수 없습니다.</p>';
  });

  document.getElementById('game-find-optimal').addEventListener('click', function() {
    if (selectedIdx < 0) return;
    var g = industries[selectedIdx].game;
    var p = g.payoffs;

    var maxTotal = -1;
    var optCell = '';
    var cells = ['00', '01', '10', '11'];
    cells.forEach(function(id, i) {
      var total = p[i][0] + p[i][1];
      if (total > maxTotal) {
        maxTotal = total;
        optCell = id;
      }
    });

    cells.forEach(function(id) {
      var cell = document.getElementById('cell-' + id);
      if (cell) {
        if (id === optCell) {
          cell.style.background = '#fefce8';
          cell.style.borderColor = '#f59e0b';
          cell.style.fontWeight = 'bold';
        } else {
          cell.style.background = '';
          cell.style.borderColor = '#e5e7eb';
          cell.style.fontWeight = '';
        }
      }
    });

    var analysis = document.getElementById('game-analysis');
    analysis.style.display = 'block';
    analysis.style.background = '#fefce8';
    analysis.style.border = '2px solid #f59e0b';
    analysis.innerHTML = '<h4 style="margin: 0 0 8px; color: #f59e0b;">사회 최적</h4>' +
      '<p>노란색 칸이 두 기업의 보수 합계가 최대인 사회 최적입니다. (합계: ' + maxTotal + ')</p>' +
      '<p>내쉬 균형과 사회 최적이 다르다면, 기업들이 자유롭게 행동하면 사회적으로 최선의 결과가 아닐 수 있습니다.</p>';
  });

  /* ===== 5. 보고서 생성 ===== */
  document.getElementById('report-gen-btn').addEventListener('click', function() {
    if (selectedIdx < 0) {
      alert('먼저 산업을 선택하세요!');
      return;
    }

    var ind = industries[selectedIdx];
    var hhi = 0;
    ind.shares.forEach(function(s) { hhi += s * s; });
    var structType = hhi > 2500 ? '고집중 과점' : hhi > 1500 ? '중간 집중 과점' : '경쟁적';

    var report = document.getElementById('report-output');
    report.style.display = 'block';

    var html = '<h2 style="text-align: center; margin: 0 0 20px; border-bottom: 3px solid #3b82f6; padding-bottom: 12px;">';
    html += ind.name + ' 산업 분석 보고서</h2>';

    html += '<h3>1. 시장 구조</h3>';
    html += '<p><strong>시장 유형:</strong> ' + structType + '</p>';
    html += '<p><strong>HHI:</strong> ' + Math.round(hhi).toLocaleString() + ' (' + (hhi > 2500 ? '고집중' : hhi > 1500 ? '중간 집중' : '경쟁적') + ')</p>';
    html += '<p><strong>주요 기업:</strong></p><ul>';
    ind.firms.forEach(function(f, i) {
      html += '<li>' + f + ': ' + ind.shares[i] + '%</li>';
    });
    html += '</ul>';
    html += '<p><strong>진입 장벽:</strong> ' + ind.barrierLevel + '</p><ul>';
    ind.barriers.forEach(function(b) { html += '<li>' + b + '</li>'; });
    html += '</ul>';

    html += '<h3>2. 경쟁 전략</h3>';
    ind.strategies.forEach(function(st) {
      html += '<p><strong>' + st.name + ':</strong> ' + st.desc + '</p>';
    });

    html += '<h3>3. 전략적 상호작용</h3>';
    html += '<p><strong>게임 시나리오:</strong> ' + ind.game.scenario + '</p>';
    html += '<p>' + ind.game.player1 + '의 전략: ' + ind.game.strat1.join(' vs ') + '</p>';
    html += '<p>' + ind.game.player2 + '의 전략: ' + ind.game.strat2.join(' vs ') + '</p>';

    html += '<h3>4. 규제 환경</h3>';
    html += '<p>' + ind.regulation + '</p>';

    html += '<h3>5. 전망</h3>';
    html += '<p>' + ind.outlook + '</p>';

    html += '<div style="margin-top: 20px; padding: 16px; background: #f0f9ff; border-radius: 8px; border-left: 4px solid #3b82f6;">';
    html += '<h4 style="margin: 0 0 8px;">분석가 의견</h4>';
    if (hhi > 3000) {
      html += '<p>이 산업은 매우 집중된 시장으로, 소비자 후생 측면에서 경쟁 당국의 지속적 감시가 필요합니다. ';
    } else if (hhi > 1500) {
      html += '<p>중간 수준의 집중도를 보이는 과점 시장으로, 기업 간 전략적 상호작용이 활발합니다. ';
    } else {
      html += '<p>비교적 경쟁적인 시장으로, 소비자 선택권이 넓습니다. ';
    }
    html += '향후 ' + (ind.id === 'ott' || ind.id === 'delivery' ? '플랫폼 효과에 의한 승자 독식 가능성' : '기술 혁신에 의한 시장 재편') + '에 주목해야 합니다.</p>';
    html += '</div>';

    report.innerHTML = html;
  });

  /* ===== Button event listeners ===== */
  document.getElementById('cap-struct-btn').addEventListener('click', function() {
    document.getElementById('cap-struct-ans').style.display = 'block';
  });
  document.getElementById('cap-strat-btn').addEventListener('click', function() {
    document.getElementById('cap-strat-ans').style.display = 'block';
  });
  document.getElementById('cap-game-btn').addEventListener('click', function() {
    document.getElementById('cap-game-ans').style.display = 'block';
  });

});
</script>
