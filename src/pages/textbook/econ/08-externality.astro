---
import EconTextbookLayout from '../../../layouts/EconTextbookLayout.astro';
import ExplainBox from '../../../components/textbook/ExplainBox.astro';
import InsightBox from '../../../components/textbook/InsightBox.astro';
import FormulaBox from '../../../components/textbook/FormulaBox.astro';
import WarningBox from '../../../components/textbook/WarningBox.astro';
import ExerciseBox from '../../../components/textbook/ExerciseBox.astro';
import BusinessBox from '../../../components/textbook/BusinessBox.astro';
import ConclusionBox from '../../../components/textbook/ConclusionBox.astro';
import StatBox from '../../../components/textbook/StatBox.astro';
import ChartContainer from '../../../components/textbook/ChartContainer.astro';
import SimControls from '../../../components/textbook/SimControls.astro';
---

<EconTextbookLayout title="외부성" subtitle="내 행동이 남에게 미치는 영향" chapterNum={8} part={1}>

  <!-- ========== HOOK ========== -->
  <div class="tb-card">
    <h2>옆집 공장의 매연</h2>
    <p>
      공장이 물건을 만든다. 공장은 원자재비, 인건비, 전기요금 등을 계산해서 이윤을 극대화한다.
      그런데 공장이 내뿜는 매연 때문에 옆 동네 주민들이 기침을 하고 빨래가 더러워진다.
      이 피해는 공장의 "비용"에 포함되어 있을까? 아니다.
    </p>
    <p>
      이처럼 <strong>거래 당사자가 아닌 제3자에게 영향을 미치는 것</strong>을
      <strong>외부성(externality)</strong>이라 한다.
      나쁜 영향이면 부정적 외부성(오염, 소음), 좋은 영향이면 긍정적 외부성(교육, 백신)이다.
    </p>
  </div>

  <!-- ========== 개념 1: 부정적 외부성 ========== -->
  <div class="tb-card">
    <h2>1. 부정적 외부성: 시장이 너무 많이 만든다</h2>

    <ExplainBox title="비유로 이해하기">
      <p>
        친구가 노래방에서 마이크를 독점하고 소리를 지른다. 친구는 즐겁지만(사적 편익),
        다른 사람들의 귀가 아프다(외부 비용). 친구는 남의 고통을 계산하지 않으니
        "너무 많이" 노래한다.
      </p>
      <p>
        공장도 마찬가지다. 오염 비용을 계산하지 않으니 사회적으로 "너무 많이" 생산한다.
        시장이 스스로는 적정 생산량을 찾지 못하는 것이다. 이것이 시장 실패다.
      </p>
    </ExplainBox>

    <FormulaBox>
      <span class="hl">사회적 비용</span> = 사적 비용 + <span class="res">외부 비용</span><br>
      시장 생산량 &gt; 사회적 최적 생산량 (과잉 생산)
    </FormulaBox>
  </div>

  <!-- ========== 인터랙티브 1: 공장 오염 시뮬레이터 ========== -->
  <div class="tb-card">
    <h2>2. 직접 해보기: 공장 오염 시뮬레이터</h2>

    <ExplainBox>
      생산량 슬라이더를 움직이며 사적 비용, 외부 비용, 사회적 비용을 비교하자.
      시장 균형 생산량과 사회적 최적 생산량의 차이를 관찰하자.
    </ExplainBox>

    <SimControls>
      <label for="pollution-slider">생산량: <strong id="pollution-qty-display">50</strong>단위</label>
      <input type="range" id="pollution-slider" min="0" max="100" value="50" style="width:100%">
    </SimControls>

    <div class="tb-stat-row">
      <StatBox label="사적 비용" id="pol-private" value="-" borderColor="#f59e0b" />
      <StatBox label="외부 비용 (오염)" id="pol-external" value="-" borderColor="#ef4444" />
      <StatBox label="사회적 비용" id="pol-social" value="-" borderColor="#8b5cf6" />
      <StatBox label="사회적 최적 생산량" id="pol-optimal" value="-" borderColor="#059669" />
    </div>

    <ChartContainer id="pollution-chart" height="380px" />

    <InsightBox title="과잉 생산의 문제">
      <p>
        시장 균형(사적 비용 = 편익)에서는 생산이 너무 많다.
        사회적 최적(사회적 비용 = 편익)보다 더 많이 만들기 때문이다.
        그 차이만큼 사회에 순손실이 발생한다.
      </p>
    </InsightBox>
  </div>

  <!-- ========== 인터랙티브 2: 피구세/보조금 도구 ========== -->
  <div class="tb-card">
    <h2>3. 해결 방법: 피구세와 보조금</h2>

    <ExplainBox title="피구세란?">
      <p>
        경제학자 아서 피구(Arthur Pigou)가 제안한 해결책이다.
        외부 비용만큼 세금을 부과하면, 기업이 오염 비용을 자기 비용으로 인식하게 된다.
        그러면 사적 비용이 올라가 생산량이 줄어들고, 사회적 최적에 가까워진다.
      </p>
    </ExplainBox>

    <FormulaBox>
      피구세 = <span class="hl">외부 비용</span> (단위당) &rarr; 사적 비용 + 피구세 = <span class="res">사회적 비용</span>
    </FormulaBox>

    <SimControls>
      <label for="pigou-slider">피구세 (단위당): <strong id="pigou-display">0</strong>원</label>
      <input type="range" id="pigou-slider" min="0" max="50" step="1" value="0" style="width:100%">
    </SimControls>

    <div class="tb-stat-row">
      <StatBox label="새 균형 생산량" id="pigou-qty" value="-" borderColor="#059669" />
      <StatBox label="세수" id="pigou-revenue" value="-" borderColor="#8b5cf6" />
      <StatBox label="오염 감소" id="pigou-reduction" value="-" borderColor="#3b82f6" />
      <StatBox label="사회적 최적 도달?" id="pigou-optimal" value="-" borderColor="#f59e0b" />
    </div>

    <ChartContainer id="pigou-chart" height="380px" />

    <InsightBox title="피구세의 장점">
      <p>
        피구세는 기업에게 "오염을 줄이거나 세금을 내라"는 인센티브를 준다.
        기업은 가장 비용 효율적인 방법으로 오염을 줄이게 된다.
        이것이 직접 규제("생산량을 몇 개 이하로 하라")보다 효율적인 이유다.
      </p>
    </InsightBox>
  </div>

  <!-- ========== 인터랙티브 3: 긍정적 외부성 ========== -->
  <div class="tb-card">
    <h2>4. 긍정적 외부성: 시장이 너무 적게 만든다</h2>

    <ExplainBox title="긍정적 외부성이란?">
      <p>
        교육은 본인에게도 좋지만, 사회 전체에도 좋다.
        교육 수준이 높아지면 범죄가 줄고, 기술이 발전하고, 시민의식이 높아진다.
        하지만 개인은 이런 사회적 혜택을 고려하지 않고 "자기에게 돌아오는 이득"만 보고 결정한다.
      </p>
      <p>
        결과적으로 시장에서는 교육이 <strong>사회적 최적보다 적게</strong> 이루어진다.
        백신도 마찬가지다. 내가 백신을 맞으면 주변 사람도 덜 감염되지만,
        나는 내 건강만 생각하고 결정한다.
      </p>
    </ExplainBox>

    <FormulaBox>
      <span class="hl">사회적 편익</span> = 사적 편익 + <span class="res">외부 편익</span><br>
      시장 소비량 &lt; 사회적 최적 소비량 (과소 소비)
    </FormulaBox>

    <SimControls>
      <label>상품 선택:</label>
      <select id="positive-type" style="padding:8px; border-radius:6px; border:1px solid #d1d5db;">
        <option value="education">교육</option>
        <option value="vaccine">백신</option>
        <option value="rd">기술 연구개발 (R&D)</option>
      </select>
      <label style="margin-left:16px;">보조금: <strong id="subsidy-display">0</strong>%</label>
      <input type="range" id="subsidy-slider" min="0" max="100" step="5" value="0" style="width:200px">
    </SimControls>

    <div class="tb-stat-row">
      <StatBox label="시장 소비량" id="pos-market" value="-" borderColor="#f59e0b" />
      <StatBox label="사회적 최적" id="pos-optimal" value="-" borderColor="#059669" />
      <StatBox label="과소 소비량" id="pos-gap" value="-" borderColor="#ef4444" />
      <StatBox label="보조금 후 소비량" id="pos-after" value="-" borderColor="#3b82f6" />
    </div>

    <ChartContainer id="positive-chart" height="380px" />

    <InsightBox title="보조금의 역할">
      <p>
        긍정적 외부성이 있는 상품에 보조금을 주면 가격이 낮아져 소비가 늘어난다.
        의무교육, 무료 백신, R&D 세액공제 등이 모두 이 원리에 기반한 정책이다.
      </p>
    </InsightBox>
  </div>

  <!-- ========== 추가 개념: 코즈 정리 ========== -->
  <div class="tb-card">
    <h2>5. 코즈 정리: 당사자끼리 해결할 수는 없을까?</h2>

    <ExplainBox title="코즈 정리란?">
      <p>
        경제학자 로널드 코즈(Ronald Coase)는 흥미로운 주장을 했다:
        <strong>소유권이 명확하고 거래 비용이 없으면</strong>, 정부 개입 없이도
        당사자 간 협상으로 외부성 문제를 해결할 수 있다.
      </p>
    </ExplainBox>

    <ExplainBox title="비유로 이해하기">
      <p>
        이웃이 밤마다 기타를 쳐서 시끄럽다.
        만약 "조용할 권리"가 당신에게 있다면, 이웃이 당신에게 돈을 주고 연주 허락을 구해야 한다.
        반대로 "연주할 권리"가 이웃에게 있다면, 당신이 돈을 주고 연주를 멈춰달라고 해야 한다.
      </p>
      <p>
        어느 쪽이든, 두 사람이 합의하면 사회적으로 효율적인 결과가 나온다.
        소유권이 누구에게 있든 최종 결과(연주 시간)는 같다.
        달라지는 것은 "누가 돈을 내느냐"뿐이다.
      </p>
    </ExplainBox>

    <WarningBox title="현실의 한계">
      <p>
        코즈 정리는 이론적으로는 아름답지만 현실에서는 한계가 있다:
      </p>
      <ul>
        <li><strong>거래 비용:</strong> 수천 명의 주민이 공장과 협상하려면 비용이 엄청나다.</li>
        <li><strong>소유권 불명확:</strong> 깨끗한 공기에 대한 소유권은 누구에게 있는가?</li>
        <li><strong>정보 부족:</strong> 오염의 정확한 피해액을 알기 어렵다.</li>
      </ul>
      <p>그래서 현실에서는 대부분 정부의 규제나 피구세가 필요하다.</p>
    </WarningBox>
  </div>

  <!-- ========== 추가: 외부성 사례 분석 ========== -->
  <div class="tb-card">
    <h2>6. 외부성 유형 판별 연습</h2>

    <ExerciseBox title="각 사례의 외부성 유형을 판별하세요">
      <div id="ext-quiz">
        <div style="margin-bottom:10px; padding:10px; background:#f8fafc; border-radius:6px;">
          <p><strong>1.</strong> 꽃집이 예쁜 화분을 진열하자 지나가는 사람들이 기분이 좋아졌다</p>
          <select class="ext-sel" data-q="0" style="padding:6px; border-radius:4px; border:1px solid #d1d5db;">
            <option value="">선택</option><option value="pos">긍정적 외부성</option><option value="neg">부정적 외부성</option>
          </select>
          <span class="ext-res" data-q="0" style="margin-left:8px; font-weight:600;"></span>
        </div>
        <div style="margin-bottom:10px; padding:10px; background:#f8fafc; border-radius:6px;">
          <p><strong>2.</strong> 새벽에 공사를 하여 주변 주민이 잠을 못 잤다</p>
          <select class="ext-sel" data-q="1" style="padding:6px; border-radius:4px; border:1px solid #d1d5db;">
            <option value="">선택</option><option value="pos">긍정적 외부성</option><option value="neg">부정적 외부성</option>
          </select>
          <span class="ext-res" data-q="1" style="margin-left:8px; font-weight:600;"></span>
        </div>
        <div style="margin-bottom:10px; padding:10px; background:#f8fafc; border-radius:6px;">
          <p><strong>3.</strong> 한 사람이 독감 백신을 맞아 주변 사람도 감염 위험이 줄었다</p>
          <select class="ext-sel" data-q="2" style="padding:6px; border-radius:4px; border:1px solid #d1d5db;">
            <option value="">선택</option><option value="pos">긍정적 외부성</option><option value="neg">부정적 외부성</option>
          </select>
          <span class="ext-res" data-q="2" style="margin-left:8px; font-weight:600;"></span>
        </div>
        <div style="margin-bottom:10px; padding:10px; background:#f8fafc; border-radius:6px;">
          <p><strong>4.</strong> 담배 연기가 옆 사람에게 피해를 준다</p>
          <select class="ext-sel" data-q="3" style="padding:6px; border-radius:4px; border:1px solid #d1d5db;">
            <option value="">선택</option><option value="pos">긍정적 외부성</option><option value="neg">부정적 외부성</option>
          </select>
          <span class="ext-res" data-q="3" style="margin-left:8px; font-weight:600;"></span>
        </div>
        <div style="margin-bottom:10px; padding:10px; background:#f8fafc; border-radius:6px;">
          <p><strong>5.</strong> 한 기업의 R&D 결과가 다른 기업에도 파급 효과를 준다</p>
          <select class="ext-sel" data-q="4" style="padding:6px; border-radius:4px; border:1px solid #d1d5db;">
            <option value="">선택</option><option value="pos">긍정적 외부성</option><option value="neg">부정적 외부성</option>
          </select>
          <span class="ext-res" data-q="4" style="margin-left:8px; font-weight:600;"></span>
        </div>
        <div style="margin-bottom:10px; padding:10px; background:#f8fafc; border-radius:6px;">
          <p><strong>6.</strong> 축산 농장의 악취가 인근 주택가에 퍼진다</p>
          <select class="ext-sel" data-q="5" style="padding:6px; border-radius:4px; border:1px solid #d1d5db;">
            <option value="">선택</option><option value="pos">긍정적 외부성</option><option value="neg">부정적 외부성</option>
          </select>
          <span class="ext-res" data-q="5" style="margin-left:8px; font-weight:600;"></span>
        </div>
      </div>
      <button class="tb-btn tb-btn-primary" style="margin-top:12px;" onclick="checkExtQuiz()">채점하기</button>
      <div class="tb-stat-row" style="margin-top:8px;">
        <StatBox label="정답" id="ext-score" value="- / 6" borderColor="#059669" />
      </div>
    </ExerciseBox>
  </div>

  <!-- ========== 비즈니스 적용 ========== -->
  <div class="tb-card">
    <h2>7. 실생활 속 외부성</h2>

    <BusinessBox title="탄소 배출권 거래제">
      <p>
        탄소세 대신 "배출권"을 거래하게 하는 방법도 있다.
        정부가 총 배출량을 정하고, 기업들이 배출권을 사고판다.
        오염을 적게 만드는 기업은 남는 배출권을 팔아 수익을 얻고,
        오염이 많은 기업은 배출권을 비싸게 사야 한다.
        시장 메커니즘을 이용하여 효율적으로 오염을 줄이는 방법이다.
      </p>
    </BusinessBox>

    <BusinessBox title="코로나 백신의 긍정적 외부성">
      <p>
        내가 백신을 맞으면 나만 보호되는 것이 아니라 주변 사람도 감염 위험이 줄어든다.
        이런 긍정적 외부성 때문에 정부는 백신을 무료로 제공하거나 접종을 권장한다.
        시장에 맡기면 "나는 괜찮겠지"라며 접종률이 사회적 최적보다 낮아지기 때문이다.
      </p>
    </BusinessBox>

    <BusinessBox title="꿀벌과 과수원">
      <p>
        꿀벌 농가 옆에 과수원이 있으면, 꿀벌이 꽃의 수분을 도와 과일 수확량이 늘어난다.
        꿀벌 농가는 이 혜택에 대한 대가를 받지 못한다.
        긍정적 외부성의 고전적 사례이며, 실제로 미국에서는 과수원이 꿀벌 농가에
        수분 서비스 비용을 지불하는 시장이 형성되었다.
      </p>
    </BusinessBox>
  </div>

  <!-- ========== 결론 ========== -->
  <ConclusionBox title="8장 핵심 정리">
    <ul>
      <li><strong>외부성:</strong> 거래 당사자가 아닌 제3자에게 미치는 영향. 비용에 반영되지 않으면 시장 실패 발생.</li>
      <li><strong>부정적 외부성:</strong> 오염, 소음 등. 시장이 과잉 생산 &rarr; 피구세로 교정.</li>
      <li><strong>긍정적 외부성:</strong> 교육, 백신 등. 시장이 과소 소비 &rarr; 보조금으로 교정.</li>
      <li><strong>피구세:</strong> 외부 비용만큼 세금 부과 &rarr; 사적 비용을 사회적 비용으로 끌어올림.</li>
      <li><strong>코즈 정리:</strong> 소유권이 명확하고 거래 비용이 없으면 당사자 간 협상으로도 외부성 해결 가능.</li>
    </ul>
    <p style="margin-top: 12px;">
      <strong>다음 장 예고:</strong> 국방, 가로등처럼 누구나 쓸 수 있지만 아무도 비용을 내지 않으려 하는 공공재를 배운다.
    </p>
  </ConclusionBox>

</EconTextbookLayout>

<script is:inline>
function waitForChart(fn) {
  if (typeof Chart !== 'undefined') { fn(); return; }
  var s = document.querySelector('script[src*="chart.js"]');
  if (s) { s.addEventListener('load', fn); return; }
  setTimeout(function() { waitForChart(fn); }, 50);
}

function init() {
  try {
    var key = 'textbook-progress-econ';
    var raw = localStorage.getItem(key);
    var data = raw ? JSON.parse(raw) : { chapters: {} };
    data.chapters['08-externality'] = { visited: true, lastVisit: new Date().toISOString().slice(0, 10) };
    localStorage.setItem(key, JSON.stringify(data));
  } catch(e) {}

  // ========== 인터랙티브 1: 공장 오염 시뮬레이터 ==========
  var polChart = null;
  var optimalQty = 35; // 사회적 최적

  function privateCost(q) { return 2 * q; }
  function externalCost(q) { return 0.5 * q * q / 50; }
  function socialCost(q) { return privateCost(q) + externalCost(q); }
  function marginalBenefit(q) { return Math.max(0, 100 - q); }

  function updatePollution() {
    var qty = parseInt(document.getElementById('pollution-slider').value);
    document.getElementById('pollution-qty-display').textContent = qty;

    var pc = privateCost(qty);
    var ec = externalCost(qty);
    var sc = socialCost(qty);

    document.getElementById('pol-private').textContent = pc.toFixed(0);
    document.getElementById('pol-external').textContent = ec.toFixed(0);
    document.getElementById('pol-social').textContent = sc.toFixed(0);
    document.getElementById('pol-optimal').textContent = optimalQty + '단위';

    // Generate curves
    var xVals = [];
    var mbData = []; var mcPrivate = []; var mcSocial = [];
    for (var q = 0; q <= 100; q += 2) {
      xVals.push(q);
      mbData.push(marginalBenefit(q));
      mcPrivate.push(2); // constant MC
      mcSocial.push(2 + q / 50); // increasing social MC
    }

    if (!polChart) {
      var ctx = document.getElementById('pollution-chart');
      if (!ctx) return;
      polChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: xVals,
          datasets: [
            { label: '한계편익 (수요)', data: mbData, borderColor: '#3b82f6', tension: 0.3, pointRadius: 0, borderWidth: 3 },
            { label: '사적 한계비용', data: mcPrivate, borderColor: '#f59e0b', tension: 0, pointRadius: 0, borderWidth: 3 },
            { label: '사회적 한계비용', data: mcSocial, borderColor: '#ef4444', tension: 0.3, pointRadius: 0, borderWidth: 3, borderDash: [6, 4] },
            { label: '현재 생산량', data: xVals.map(function(x) { return x === qty ? 100 : null; }), pointRadius: 10, pointBackgroundColor: '#8b5cf6', showLine: false }
          ]
        },
        options: {
          responsive: true,
          plugins: { legend: { position: 'top' } },
          scales: {
            x: { title: { display: true, text: '생산량' } },
            y: { title: { display: true, text: '비용 / 편익' }, beginAtZero: true }
          },
          spanGaps: true
        }
      });
    } else {
      polChart.data.datasets[3].data = xVals.map(function(x) { return x === qty ? 100 : null; });
      polChart.update();
    }
  }

  document.getElementById('pollution-slider').addEventListener('input', updatePollution);
  updatePollution();

  // ========== 인터랙티브 2: 피구세 ==========
  var pigouChart = null;
  var marketQty = 49; // MB = private MC -> 100 - q = 2 -> q = 98... simplify

  function updatePigou() {
    var taxRate = parseInt(document.getElementById('pigou-slider').value);
    document.getElementById('pigou-display').textContent = taxRate;

    // New equilibrium: MB = private MC + tax
    // 100 - q = 2 + taxRate -> q = 98 - taxRate
    var newQty = Math.max(0, 98 - taxRate);
    var optTax = 17; // approximate external cost at optimal
    var revenue = taxRate * newQty;
    var reduction = 98 - newQty;
    var isOptimal = Math.abs(taxRate - optTax) <= 3;

    document.getElementById('pigou-qty').textContent = newQty + '단위';
    document.getElementById('pigou-revenue').textContent = revenue.toLocaleString();
    document.getElementById('pigou-reduction').textContent = reduction + '단위';
    document.getElementById('pigou-optimal').textContent = isOptimal ? '거의 도달!' : (taxRate < optTax ? '세금 부족' : '세금 과도');

    var xVals = [];
    var mbData = []; var mcOld = []; var mcNew = [];
    for (var q = 0; q <= 100; q += 2) {
      xVals.push(q);
      mbData.push(marginalBenefit(q));
      mcOld.push(2);
      mcNew.push(2 + taxRate);
    }

    if (!pigouChart) {
      var ctx = document.getElementById('pigou-chart');
      if (!ctx) return;
      pigouChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: xVals,
          datasets: [
            { label: '한계편익', data: mbData, borderColor: '#3b82f6', tension: 0.3, pointRadius: 0, borderWidth: 3 },
            { label: '사적 한계비용', data: mcOld, borderColor: 'rgba(245,158,11,0.4)', tension: 0, pointRadius: 0, borderDash: [4, 4] },
            { label: '사적 비용 + 피구세', data: mcNew, borderColor: '#f59e0b', tension: 0, pointRadius: 0, borderWidth: 3 },
            { label: '사회적 한계비용', data: xVals.map(function(x) { return 2 + x / 50; }), borderColor: '#ef4444', tension: 0.3, pointRadius: 0, borderDash: [6, 4], borderWidth: 2 }
          ]
        },
        options: {
          responsive: true,
          plugins: { legend: { position: 'top' } },
          scales: {
            x: { title: { display: true, text: '생산량' } },
            y: { title: { display: true, text: '비용 / 편익' }, beginAtZero: true, max: 120 }
          }
        }
      });
    } else {
      pigouChart.data.datasets[2].data = mcNew;
      pigouChart.update();
    }
  }

  document.getElementById('pigou-slider').addEventListener('input', updatePigou);
  updatePigou();

  // ========== 인터랙티브 3: 긍정적 외부성 ==========
  var posChart = null;

  var posConfigs = {
    education: { name: '교육', market: 60, optimal: 85, extBenefit: 25 },
    vaccine: { name: '백신', market: 50, optimal: 80, extBenefit: 30 },
    rd: { name: 'R&D', market: 40, optimal: 70, extBenefit: 30 }
  };

  function updatePositive() {
    var type = document.getElementById('positive-type').value;
    var subsidy = parseInt(document.getElementById('subsidy-slider').value);
    document.getElementById('subsidy-display').textContent = subsidy;

    var cfg = posConfigs[type];
    var gap = cfg.optimal - cfg.market;
    var subsidyEffect = subsidy / 100 * gap;
    var afterQty = Math.min(cfg.optimal, Math.round(cfg.market + subsidyEffect));

    document.getElementById('pos-market').textContent = cfg.market + '단위';
    document.getElementById('pos-optimal').textContent = cfg.optimal + '단위';
    document.getElementById('pos-gap').textContent = (cfg.optimal - afterQty) + '단위';
    document.getElementById('pos-after').textContent = afterQty + '단위';

    var xVals = [];
    var privateBenefit = []; var socialBenefit = []; var costCurve = [];
    for (var q = 0; q <= 100; q += 2) {
      xVals.push(q);
      var pb = Math.max(0, 100 - q);
      privateBenefit.push(pb);
      socialBenefit.push(pb + cfg.extBenefit);
      costCurve.push(10 + q * 0.8);
    }

    if (!posChart) {
      var ctx = document.getElementById('positive-chart');
      if (!ctx) return;
      posChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: xVals,
          datasets: [
            { label: '사적 편익 (수요)', data: privateBenefit, borderColor: '#3b82f6', tension: 0.3, pointRadius: 0, borderWidth: 3 },
            { label: '사회적 편익', data: socialBenefit, borderColor: '#059669', tension: 0.3, pointRadius: 0, borderWidth: 3, borderDash: [6, 4] },
            { label: '공급 (비용)', data: costCurve, borderColor: '#f59e0b', tension: 0.3, pointRadius: 0, borderWidth: 3 },
            { label: '시장 소비량', data: xVals.map(function(x) { return x === cfg.market ? 120 : null; }), pointRadius: 10, pointBackgroundColor: '#ef4444', showLine: false },
            { label: '보조금 후', data: xVals.map(function(x) { return x === afterQty ? 120 : null; }), pointRadius: 10, pointBackgroundColor: '#3b82f6', showLine: false },
            { label: '사회적 최적', data: xVals.map(function(x) { return x === cfg.optimal ? 120 : null; }), pointRadius: 10, pointBackgroundColor: '#059669', pointStyle: 'star', showLine: false }
          ]
        },
        options: {
          responsive: true,
          plugins: { legend: { position: 'top' } },
          scales: {
            x: { title: { display: true, text: '소비량' } },
            y: { title: { display: true, text: '편익 / 비용' }, beginAtZero: true, max: 140 }
          },
          spanGaps: true
        }
      });
    } else {
      // Update for new type
      var newPB = []; var newSB = [];
      for (var q2 = 0; q2 <= 100; q2 += 2) {
        var pb2 = Math.max(0, 100 - q2);
        newPB.push(pb2);
        newSB.push(pb2 + cfg.extBenefit);
      }
      posChart.data.datasets[0].data = newPB;
      posChart.data.datasets[1].data = newSB;
      posChart.data.datasets[3].data = xVals.map(function(x) { return x === cfg.market ? 120 : null; });
      posChart.data.datasets[4].data = xVals.map(function(x) { return x === afterQty ? 120 : null; });
      posChart.data.datasets[5].data = xVals.map(function(x) { return x === cfg.optimal ? 120 : null; });
      posChart.update();
    }
  }

  document.getElementById('positive-type').addEventListener('change', updatePositive);
  document.getElementById('subsidy-slider').addEventListener('input', updatePositive);
  updatePositive();

  // ========== 외부성 유형 퀴즈 ==========
  var extAnswers = ['pos', 'neg', 'pos', 'neg', 'pos', 'neg'];

  window.checkExtQuiz = function() {
    var score = 0;
    for (var i = 0; i < extAnswers.length; i++) {
      var sel = document.querySelector('.ext-sel[data-q="' + i + '"]');
      var res = document.querySelector('.ext-res[data-q="' + i + '"]');
      if (!sel || !res) continue;
      if (sel.value === extAnswers[i]) {
        res.textContent = 'O 정답!';
        res.style.color = '#059669';
        score++;
      } else if (sel.value === '') {
        res.textContent = '-';
        res.style.color = '#6b7280';
      } else {
        res.textContent = 'X (정답: ' + (extAnswers[i] === 'pos' ? '긍정적' : '부정적') + ')';
        res.style.color = '#ef4444';
      }
    }
    document.getElementById('ext-score').textContent = score + ' / 6';
  };
}

waitForChart(init);
</script>
