---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/textbook.css';
import chaptersData from '../../../data/textbook-econ.json';
import seriesData from '../../../data/textbook-series.json';

const { parts, chapters } = chaptersData;
const allSeries = seriesData.series;

const chaptersByPart = parts.map(part => ({
  ...part,
  chapters: chapters.filter(ch => ch.part === part.id),
}));

const totalChapters = chapters.length;
---

<BaseLayout
  title="경제학 입문"
  description="미시와 거시경제의 핵심 원리를 시뮬레이션으로 체험하는 경제학 교과서"
>
  <div class="textbook-page" data-pagefind-body>
    <!-- Series switcher -->
    <nav class="tb-series-nav">
      {allSeries.map(s => (
        <a href={s.hubUrl} data-astro-reload class={s.id === 'econ' ? 'active' : ''}>
          {s.title}{s.status === 'planned' && <span class="muted"> (준비중)</span>}
        </a>
      ))}
    </nav>

    <!-- Title block -->
    <header class="tb-toc-head">
      <div class="rule"></div>
      <h1 class="tb-toc-title">경제학 입문</h1>
      <p class="tb-toc-deck">미시와 거시경제의 핵심 원리를 시뮬레이션으로 체험하는 경제학 교재입니다.</p>
      <div class="tb-toc-meta">
        <span>전 {totalChapters}장 · {parts.length}개 파트</span>
        <span class="tb-toc-progress">읽음 <span id="hub-progress-text">0%</span></span>
      </div>
    </header>
    <div class="tb-toc-progressline"><span id="hub-progress-fill" style="width: 0%"></span></div>

    <!-- Chapter List by Part -->
    <div class="tb-container" style="margin-top: 32px;">
      {chaptersByPart.map(part => (
        <section class="tb-part-section" data-part={part.id}>
          <div class="tb-part-head">
            <span class="tb-part-no">Part {part.id}</span>
            <h2 class="tb-part-name">{part.title}</h2>
            <span class="tb-part-desc">{part.description}</span>
          </div>

          <div class="tb-toc-list">
            {part.chapters.map(ch => {
              const isPublished = ch.status === 'published';
              const href = isPublished ? `/textbook/econ/${ch.slug}/` : undefined;
              const Tag = isPublished ? 'a' : 'div';

              return (
                <Tag
                  href={href}
                  data-astro-reload={isPublished ? '' : undefined}
                  class={`tb-toc-item ${ch.capstone ? 'capstone' : ''} ${!isPublished ? 'planned' : ''}`}
                >
                  <span class="tb-toc-num">{String(ch.num).padStart(2, '0')}</span>
                  <div class="tb-toc-main">
                    <div class="tb-toc-name">{ch.title}</div>
                    <div class="tb-toc-sub">{ch.subtitle}</div>
                  </div>
                  <span class="tb-toc-aside">
                    {ch.interactiveCount > 0 && <span class="tb-toc-mark">{ch.interactiveCount} 실습</span>}
                    {!isPublished && <span>준비중</span>}
                    <span class="ch-check tb-toc-check" data-slug={ch.slug}></span>
                  </span>
                </Tag>
              );
            })}
          </div>
        </section>
      ))}

      <div style="text-align: center; padding: 40px 0 20px; color: var(--tb-g600); font-size: 0.9rem;">
        <p><strong>Yonghee Kim</strong> &middot; 선문대학교 경영학과</p>
        <p style="margin-top: 4px;"><a href="https://kimyonghee.com" style="color: var(--tb-primary); text-decoration: none;">kimyonghee.com</a></p>
      </div>
    </div>
  </div>

  <script is:inline>
    function updateProgress() {
      try {
        var raw = localStorage.getItem('textbook-progress-econ');
        if (!raw) return;
        var data = JSON.parse(raw);
        var visited = Object.values(data.chapters || {}).filter(function(c) { return c.visited; }).length;
        var total = document.querySelectorAll('.tb-chapter-item').length;
        var pct = total > 0 ? Math.round(visited / total * 100) : 0;
        var fill = document.getElementById('hub-progress-fill');
        var text = document.getElementById('hub-progress-text');
        if (fill) fill.style.width = pct + '%';
        if (text) text.textContent = pct + '%';

        var slugs = Object.entries(data.chapters || {}).filter(function(e) { return e[1].visited; }).map(function(e) { return e[0]; });
        document.querySelectorAll('.ch-check').forEach(function(el) {
          if (slugs.indexOf(el.getAttribute('data-slug')) !== -1) {
            el.classList.add('done');
            el.textContent = '\u2713';
          }
        });
      } catch(e) {}
    }
    updateProgress();
  </script>
</BaseLayout>
