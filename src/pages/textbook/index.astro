---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/textbook.css';
import chaptersData from '../../data/textbook-chapters.json';
import seriesData from '../../data/textbook-series.json';

const { parts, chapters } = chaptersData;
const allSeries = seriesData.series;

// Group chapters by part
const chaptersByPart = parts.map(part => ({
  ...part,
  chapters: chapters.filter(ch => ch.part === part.id),
}));

const totalChapters = chapters.length;
const publishedCount = chapters.filter(c => c.status === 'published').length;
---

<BaseLayout
  title="통계학과 데이터 사이언스 입문"
  description="기초 통계부터 머신러닝, 딥러닝까지 — 개념과 실습으로 배우는 데이터 분석 교과서"
>
  <div class="textbook-page" data-pagefind-body>
    <!-- Series switcher -->
    <nav class="tb-series-nav">
      {allSeries.map(s => (
        <a href={s.hubUrl} data-astro-reload class={s.id === 'stats' ? 'active' : ''}>
          {s.title}{s.status === 'planned' && <span class="muted"> (준비중)</span>}
        </a>
      ))}
    </nav>

    <!-- Title block -->
    <header class="tb-toc-head">
      <div class="rule"></div>
      <h1 class="tb-toc-title">통계학과 데이터 사이언스 입문</h1>
      <p class="tb-toc-deck">기초 통계부터 머신러닝, 딥러닝까지, 개념과 실습으로 배우는 데이터 분석 교재입니다.</p>
      <div class="tb-toc-meta">
        <span>전 {totalChapters}장 · {parts.length}개 파트</span>
        <span class="tb-toc-progress">읽음 <span id="hub-progress-text">0%</span></span>
      </div>
    </header>
    <div class="tb-toc-progressline"><span id="hub-progress-fill" style="width: 0%"></span></div>

    <!-- Chapter List by Part -->
    <div class="tb-container" style="margin-top: 32px;">
      {chaptersByPart.map(part => (
        <section class="tb-part-section" data-part={part.id}>
          <div class="tb-part-head">
            <span class="tb-part-no">Part {part.id}</span>
            <h2 class="tb-part-name">{part.title}</h2>
            <span class="tb-part-desc">{part.description}</span>
          </div>

          <div class="tb-toc-list">
            {part.chapters.map(ch => {
              const isPublished = ch.status === 'published';
              const href = isPublished
                ? (ch.legacyUrl || `/textbook/${ch.slug}/`)
                : undefined;
              const Tag = isPublished ? 'a' : 'div';

              return (
                <Tag
                  href={href}
                  class={`tb-toc-item ${ch.capstone ? 'capstone' : ''} ${!isPublished ? 'planned' : ''}`}
                >
                  <span class="tb-toc-num">{String(ch.num).padStart(2, '0')}</span>
                  <div class="tb-toc-main">
                    <div class="tb-toc-name">{ch.title}</div>
                    <div class="tb-toc-sub">{ch.subtitle}</div>
                  </div>
                  <span class="tb-toc-aside">
                    {ch.interactiveCount > 0 && <span class="tb-toc-mark">{ch.interactiveCount} 실습</span>}
                    {!isPublished && <span>준비중</span>}
                    <span class="ch-check tb-toc-check" data-slug={ch.slug}></span>
                  </span>
                </Tag>
              );
            })}
          </div>
        </section>
      ))}

      <!-- Credits -->
      <div style="text-align: center; padding: 40px 0 20px; color: var(--tb-g600); font-size: 0.9rem;">
        <p>
          <strong>Yonghee Kim</strong> &middot; 선문대학교 경영학과
        </p>
        <p style="margin-top: 4px;">
          <a href="https://kimyonghee.com" style="color: var(--tb-primary); text-decoration: none;">kimyonghee.com</a>
        </p>
      </div>
    </div>
  </div>

  <script>
    // Client-side progress tracking
    function updateHubProgress() {
      try {
        const raw = localStorage.getItem('textbook-progress');
        if (!raw) return;
        const data = JSON.parse(raw);
        const visited = Object.values(data.chapters || {}).filter(c => c.visited).length;
        const total = document.querySelectorAll('.tb-chapter-item').length;
        const pct = total > 0 ? Math.round(visited / total * 100) : 0;

        const fill = document.getElementById('hub-progress-fill');
        const text = document.getElementById('hub-progress-text');
        if (fill) fill.style.width = pct + '%';
        if (text) text.textContent = pct + '%';

        // Mark visited chapters with checkmark
        const slugs = Object.entries(data.chapters || {})
          .filter(([, v]) => v.visited)
          .map(([k]) => k);

        document.querySelectorAll('.ch-check').forEach(el => {
          if (slugs.includes(el.getAttribute('data-slug') || '')) {
            el.classList.add('done');
            el.textContent = '\u2713';
          }
        });
      } catch {}
    }

    // Force full page reload for all textbook links (ViewTransitions breaks inline scripts)
    document.querySelectorAll('a[href*="/textbook/"]').forEach(function(a) {
      a.setAttribute('data-astro-reload', '');
    });

    document.addEventListener('DOMContentLoaded', updateHubProgress);
    document.addEventListener('astro:page-load', updateHubProgress);
  </script>
</BaseLayout>
