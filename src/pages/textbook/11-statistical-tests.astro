// ==================== T-TEST ====================
let ttestChart = null;

function runTTest() {
  const type = document.getElementById('ttest-type').value;
  const scenario = document.getElementById('ttest-scenario').value;
  const alpha = parseFloat(document.getElementById('ttest-alpha').value);

  let t, df, pVal, sampleInfo;

  if (type === 'one') {
    let data, mu0;
    if (scenario === 'custom') {
      data = document.getElementById('ttest-one-data').value.split(',').map(Number).filter(v => !isNaN(v));
      mu0 = parseFloat(document.getElementById('ttest-mu0').value);
    } else if (scenario === 'salary') {
      data = Array.from({length: 15}, () => Math.round(3500 + normalRandom() * 400));
      mu0 = 3500;
    } else {
      data = Array.from({length: 12}, () => Math.round(80 + normalRandom() * 10));
      mu0 = 75;
    }
    const n = data.length;
    const m = mean(data);
    const s = stdev(data);
    t = (m - mu0) / (s / Math.sqrt(n));
    df = n - 1;
    pVal = tPValue(t, df);
    sampleInfo = `표본 평균 = ${m.toFixed(1)}, 표본 표준편차 = ${s.toFixed(1)}, n = ${n}, 귀무가설 평균 = ${mu0}`;
  } else {
    let g1, g2;
    if (scenario === 'custom') {
      g1 = document.getElementById('ttest-g1-data').value.split(',').map(Number).filter(v => !isNaN(v));
      g2 = document.getElementById('ttest-g2-data').value.split(',').map(Number).filter(v => !isNaN(v));
    } else if (scenario === 'team') {
      g1 = Array.from({length: 15}, () => Math.round(82 + normalRandom() * 8));
      g2 = Array.from({length: 15}, () => Math.round(75 + normalRandom() * 10));
    } else {
      g1 = Array.from({length: 12}, () => Math.round(3800 + normalRandom() * 500));
      g2 = Array.from({length: 12}, () => Math.round(3400 + normalRandom() * 500));
    }
    const m1 = mean(g1), m2 = mean(g2);
    const s1 = stdev(g1), s2 = stdev(g2);
    const n1 = g1.length, n2 = g2.length;
    const se = Math.sqrt(s1*s1/n1 + s2*s2/n2);
    t = (m1 - m2) / se;
    // Welch's df
    const num = (s1*s1/n1 + s2*s2/n2)**2;
    const den = (s1*s1/n1)**2/(n1-1) + (s2*s2/n2)**2/(n2-1);
    df = Math.floor(num / den);
    pVal = tPValue(t, df);
    sampleInfo = `그룹1: 평균=${m1.toFixed(1)}, SD=${s1.toFixed(1)}, n=${n1} | 그룹2: 평균=${m2.toFixed(1)}, SD=${s2.toFixed(1)}, n=${n2}`;
  }

  // Display results
  document.getElementById('ttest-output').style.display = '';
  document.getElementById('ttest-t').textContent = t.toFixed(3);
  document.getElementById('ttest-df').textContent = df;
  document.getElementById('ttest-p').textContent = pVal < 0.001 ? '< 0.001' : pVal.toFixed(4);

  const reject = pVal < alpha;
  const verdictEl = document.getElementById('ttest-verdict');
  verdictEl.textContent = reject ? '귀무가설 기각' : '기각 실패';
  verdictEl.style.color = reject ? 'var(--tb-danger)' : 'var(--tb-success)';

  const interpDiv = document.getElementById('ttest-interpretation');
  interpDiv.innerHTML = `<div class="${reject ? 'tb-warning-box' : 'tb-insight'}">
    <strong>${sampleInfo}</strong><br>
    t(${df}) = ${t.toFixed(3)}, p = ${pVal < 0.001 ? '< 0.001' : pVal.toFixed(4)}<br>
    유의수준 ${alpha}에서 ${reject ? '귀무가설을 기각한다. 통계적으로 유의한 차이가 존재한다.' : '귀무가설을 기각하지 못한다. 유의한 차이를 발견하지 못했다.'}
  </div>`;

  drawTDistribution(t, df, alpha);
}

async function drawTDistribution(tStat, df, alpha) {
  const Chart = await loadChart();
  const canvas = document.getElementById('ttest-chart');
  if (ttestChart) { ttestChart.destroy(); ttestChart = null; }

  const xMin = -4, xMax = 4, step = 0.05;
  const xs = [];
  const ys = [];
  for (let x = xMin; x <= xMax; x += step) {
    xs.push(x.toFixed(2));
    ys.push(tPDF(x, df));
  }

  // Critical values
  // Approximate: use 1.96 for df>30, else iterate
  const tCrit = findTCritical(alpha / 2, df);

  const bgColors = xs.map(x => {
    const xn = parseFloat(x);
    return (xn <= -tCrit || xn >= tCrit) ? 'rgba(239,68,68,0.4)' : 'rgba(37,99,235,0.2)';
  });

  ttestChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: xs,
      datasets: [{
        label: 't-분포',
        data: ys,
        backgroundColor: bgColors,
        borderColor: bgColors.map(c => c.replace('0.4', '0.8').replace('0.2', '0.5')),
        borderWidth: 1,
        barPercentage: 1,
        categoryPercentage: 1,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: false,
      plugins: {
        legend: { display: false },
        title: { display: true, text: `t-분포 (df=${df}), 기각역(빨간색): |t| > ${tCrit.toFixed(3)}`, font: { size: 13, family: "'Paperlogy'" } },
      },
      scales: {
        x: {
          title: { display: true, text: 't' },
          ticks: { maxTicksLimit: 15, callback: function(val, idx) { return idx % 10 === 0 ? this.getLabelForValue(val) : ''; } }
        },
        y: { title: { display: true, text: '밀도' }, beginAtZero: true }
      }
    }
  });
}

function findTCritical(pTail, df) {
  // Simple bisection to find t such that P(T > t) = pTail
  let lo = 0, hi = 10;
  for (let i = 0; i < 100; i++) {
    const mid = (lo + hi) / 2;
    const p = 1 - tCDF(mid, df);
    if (p > pTail) lo = mid;
    else hi = mid;
  }
  return (lo + hi) / 2;
}

// ==================== CHI-SQUARED TEST ====================
let chiChart = null;

const CHI_SCENARIOS = {
  'gender-product': {
    rowLabels: ['남성', '여성'],
    colLabels: ['전자제품', '의류', '식품'],
    data: [[45, 30, 25], [30, 50, 20]]
  },
  'dept-turnover': {
    rowLabels: ['영업', '마케팅', 'IT', '인사'],
    colLabels: ['이직의향 있음', '이직의향 없음'],
    data: [[18, 32], [12, 38], [8, 42], [22, 28]]
  }
};

function getChiData(scenario) {
  if (scenario === 'random') {
    const rows = 2 + Math.floor(Math.random() * 3);
    const cols = 2 + Math.floor(Math.random() * 2);
    const rowLabels = Array.from({length: rows}, (_, i) => '행' + (i + 1));
    const colLabels = Array.from({length: cols}, (_, i) => '열' + (i + 1));
    const data = Array.from({length: rows}, () =>
      Array.from({length: cols}, () => 5 + Math.floor(Math.random() * 50))
    );
    return { rowLabels, colLabels, data };
  }
  return CHI_SCENARIOS[scenario];
}

function runChiSquared() {
  const scenario = document.getElementById('chi-scenario').value;
  const info = getChiData(scenario);
  const { rowLabels, colLabels, data } = info;

  const nRows = data.length, nCols = data[0].length;
  const rowSums = data.map(r => r.reduce((a, b) => a + b, 0));
  const colSums = colLabels.map((_, j) => data.reduce((a, r) => a + r[j], 0));
  const total = rowSums.reduce((a, b) => a + b, 0);

  // Expected frequencies
  const expected = data.map((row, i) => row.map((_, j) => (rowSums[i] * colSums[j]) / total));

  // Render observed table
  const obsHead = document.getElementById('chi-obs-head');
  obsHead.innerHTML = '<tr><th></th>' + colLabels.map(c => '<th>' + c + '</th>').join('') + '<th>합계</th></tr>';
  const obsBody = document.getElementById('chi-obs-body');
  obsBody.innerHTML = data.map((row, i) =>
    '<tr><td><strong>' + rowLabels[i] + '</strong></td>' + row.map(v => '<td>' + v + '</td>').join('') + '<td><strong>' + rowSums[i] + '</strong></td></tr>'
  ).join('') + '<tr><td><strong>합계</strong></td>' + colSums.map(v => '<td><strong>' + v + '</strong></td>').join('') + '<td><strong>' + total + '</strong></td></tr>';

  // Render expected table
  const expHead = document.getElementById('chi-exp-head');
  expHead.innerHTML = '<tr><th></th>' + colLabels.map(c => '<th>' + c + '</th>').join('') + '</tr>';
  const expBody = document.getElementById('chi-exp-body');
  expBody.innerHTML = expected.map((row, i) =>
    '<tr><td><strong>' + rowLabels[i] + '</strong></td>' + row.map(v => '<td>' + v.toFixed(1) + '</td>').join('') + '</tr>'
  ).join('');

  // Chi-squared statistic
  let chi2 = 0;
  for (let i = 0; i < nRows; i++) {
    for (let j = 0; j < nCols; j++) {
      chi2 += (data[i][j] - expected[i][j]) ** 2 / expected[i][j];
    }
  }
  const df = (nRows - 1) * (nCols - 1);
  const pVal = 1 - chiCDF(chi2, df);

  document.getElementById('chi-output').style.display = '';
  document.getElementById('chi-stat').textContent = chi2.toFixed(3);
  document.getElementById('chi-df').textContent = df;
  document.getElementById('chi-p').textContent = pVal < 0.001 ? '< 0.001' : pVal.toFixed(4);
  const reject = pVal < 0.05;
  const chiVerdict = document.getElementById('chi-verdict');
  chiVerdict.textContent = reject ? '독립성 기각' : '독립성 유지';
  chiVerdict.style.color = reject ? 'var(--tb-danger)' : 'var(--tb-success)';

  const interpDiv = document.getElementById('chi-interpretation');
  interpDiv.innerHTML = `<div class="${reject ? 'tb-warning-box' : 'tb-insight'}">
    <strong>카이제곱(${df}) = ${chi2.toFixed(3)}, p = ${pVal < 0.001 ? '< 0.001' : pVal.toFixed(4)}</strong><br>
    ${reject
      ? '두 변수는 통계적으로 유의한 관련이 있다. 즉, 행 변수와 열 변수는 독립이 아니다.'
      : '두 변수 사이에 통계적으로 유의한 관련을 발견하지 못했다. 독립이라는 귀무가설을 기각하지 못한다.'}
  </div>`;

  drawChiHeatmap(rowLabels, colLabels, data, expected);
}

async function drawChiHeatmap(rowLabels, colLabels, observed, expected) {
  const Chart = await loadChart();
  const canvas = document.getElementById('chi-chart');
  if (chiChart) { chiChart.destroy(); chiChart = null; }

  // Compute (O - E) for each cell and create grouped bar chart
  const datasets = rowLabels.map((rl, i) => ({
    label: rl,
    data: colLabels.map((_, j) => observed[i][j] - expected[i][j]),
    backgroundColor: ['#2563eb', '#ef4444', '#22c55e', '#f59e0b', '#7c3aed'][i % 5] + '88',
    borderColor: ['#2563eb', '#ef4444', '#22c55e', '#f59e0b', '#7c3aed'][i % 5],
    borderWidth: 1,
    borderRadius: 4,
  }));

  chiChart = new Chart(canvas, {
    type: 'bar',
    data: { labels: colLabels, datasets },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: {
        title: { display: true, text: '관측빈도 - 기대빈도 (양수 = 기대보다 많음)', font: { size: 13, family: "'Paperlogy'" } },
        legend: { position: 'top' }
      },
      scales: {
        y: { title: { display: true, text: 'O - E' } },
        x: { title: { display: true, text: '열 범주' } }
      }
    }
  });
}

// ==================== ONE-WAY ANOVA ====================
let anovaChart = null;

function runANOVA() {
  const nGroups = parseInt(document.getElementById('anova-groups').value);
  const nPerGroup = parseInt(document.getElementById('anova-n').value);
  const effect = parseFloat(document.getElementById('anova-effect').value);
  const groupNames = ['영업부', '마케팅부', 'IT부', '인사부', '재무부'].slice(0, nGroups);

  // Generate data
  const groups = [];
  const baseMean = 3.5;
  const sd = 0.8;
  for (let g = 0; g < nGroups; g++) {
    const shift = effect * (g - Math.floor(nGroups / 2)) * 0.5;
    const data = Array.from({length: nPerGroup}, () => baseMean + shift + normalRandom() * sd);
    groups.push(data);
  }

  // ANOVA calculation
  const allValues = groups.flat();
  const grandMean = mean(allValues);
  const N = allValues.length;

  let SSB = 0; // Between groups
  groups.forEach(g => {
    const gm = mean(g);
    SSB += g.length * (gm - grandMean) ** 2;
  });

  let SSW = 0; // Within groups
  groups.forEach(g => {
    const gm = mean(g);
    g.forEach(v => SSW += (v - gm) ** 2);
  });

  const dfB = nGroups - 1;
  const dfW = N - nGroups;
  const MSB = SSB / dfB;
  const MSW = SSW / dfW;
  const F = MSB / MSW;
  const pVal = fPValue(F, dfB, dfW);

  // Display results
  document.getElementById('anova-output').style.display = '';
  document.getElementById('anova-f').textContent = F.toFixed(3);
  document.getElementById('anova-df').textContent = `${dfB}, ${dfW}`;
  document.getElementById('anova-p').textContent = pVal < 0.001 ? '< 0.001' : pVal.toFixed(4);
  const reject = pVal < 0.05;
  const anovaVerdict = document.getElementById('anova-verdict');
  anovaVerdict.textContent = reject ? '귀무가설 기각' : '기각 실패';
  anovaVerdict.style.color = reject ? 'var(--tb-danger)' : 'var(--tb-success)';

  // Post-hoc tests (Bonferroni)
  const nComparisons = nGroups * (nGroups - 1) / 2;
  const posthocBody = document.getElementById('posthoc-body');
  posthocBody.innerHTML = '';
  for (let i = 0; i < nGroups; i++) {
    for (let j = i + 1; j < nGroups; j++) {
      const m1 = mean(groups[i]), m2 = mean(groups[j]);
      const s1 = stdev(groups[i]), s2 = stdev(groups[j]);
      const n1 = groups[i].length, n2 = groups[j].length;
      const se = Math.sqrt(s1*s1/n1 + s2*s2/n2);
      const tVal = (m1 - m2) / se;
      const phDf = Math.floor((s1*s1/n1 + s2*s2/n2)**2 / ((s1*s1/n1)**2/(n1-1) + (s2*s2/n2)**2/(n2-1)));
      const phP = tPValue(tVal, phDf);
      const bonP = Math.min(1, phP * nComparisons);
      const sig = bonP < 0.05;
      posthocBody.insertAdjacentHTML('beforeend', `<tr style="${sig ? 'background:#fef2f2;' : ''}">
        <td>${groupNames[i]} vs ${groupNames[j]}</td>
        <td>${(m1 - m2).toFixed(3)}</td>
        <td>${tVal.toFixed(3)}</td>
        <td>${phP < 0.001 ? '< 0.001' : phP.toFixed(4)}</td>
        <td>${bonP < 0.001 ? '< 0.001' : bonP.toFixed(4)}</td>
        <td style="color:${sig ? 'var(--tb-danger)' : 'var(--tb-success)'}; font-weight:700;">${sig ? '유의함' : '유의하지 않음'}</td>
      </tr>`);
    }
  }

  // Interpretation
  const interpDiv = document.getElementById('anova-interpretation');
  interpDiv.innerHTML = `<div class="${reject ? 'tb-warning-box' : 'tb-insight'}">
    <strong>F(${dfB}, ${dfW}) = ${F.toFixed(3)}, p = ${pVal < 0.001 ? '< 0.001' : pVal.toFixed(4)}</strong><br>
    ${reject
      ? '적어도 하나의 그룹 평균이 다른 그룹과 유의하게 다르다. 위 사후검정 결과에서 구체적으로 어떤 쌍이 다른지 확인하라.'
      : '그룹 간 평균에 통계적으로 유의한 차이를 발견하지 못했다. 모든 그룹의 평균이 같다는 귀무가설을 기각하지 못한다.'}
  </div>`;

  drawAnovaChart(groups, groupNames);
}

async function drawAnovaChart(groups, groupNames) {
  const Chart = await loadChart();
  const canvas = document.getElementById('anova-chart');
  if (anovaChart) { anovaChart.destroy(); anovaChart = null; }

  const means = groups.map(g => mean(g));
  const sds = groups.map(g => stdev(g));
  const ns = groups.map(g => g.length);
  const ses = sds.map((s, i) => s / Math.sqrt(ns[i]));
  const colors = ['#2563eb', '#ef4444', '#22c55e', '#f59e0b', '#7c3aed'];

  anovaChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: groupNames,
      datasets: [{
        label: '그룹 평균',
        data: means,
        backgroundColor: groupNames.map((_, i) => colors[i % colors.length] + '66'),
        borderColor: groupNames.map((_, i) => colors[i % colors.length]),
        borderWidth: 2,
        borderRadius: 6,
        errorBars: ses,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: {
        legend: { display: false },
        title: { display: true, text: '그룹별 평균 (오차 막대 = 표준오차)', font: { size: 13, family: "'Paperlogy'" } },
      },
      scales: {
        y: { title: { display: true, text: '점수' } },
        x: { title: { display: true, text: '그룹' } }
      }
    },
    plugins: [{
      id: 'errorBars',
      afterDraw(chart) {
        const ctx = chart.ctx;
        const meta = chart.getDatasetMeta(0);
        meta.data.forEach((bar, i) => {
          const se = ses[i];
          const yCenter = bar.y;
          const yTop = chart.scales.y.getPixelForValue(means[i] + se);
          const yBot = chart.scales.y.getPixelForValue(means[i] - se);
          const x = bar.x;
          ctx.save();
          ctx.strokeStyle = colors[i % colors.length];
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.moveTo(x, yTop);
          ctx.lineTo(x, yBot);
          ctx.moveTo(x - 6, yTop);
          ctx.lineTo(x + 6, yTop);
          ctx.moveTo(x - 6, yBot);
          ctx.lineTo(x + 6, yBot);
          ctx.stroke();
          ctx.restore();
        });
      }
    }]
  });
}

