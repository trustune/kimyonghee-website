<script>
// ==================== CHART.JS LOADER ====================
let ChartJS = null;
async function loadChart() {
  if (ChartJS) return ChartJS;
  const { Chart, registerables } = await import('https://cdn.jsdelivr.net/npm/chart.js@4/+esm');
  Chart.register(...registerables);
  ChartJS = Chart;
  return Chart;
}

// ==================== STATISTICAL HELPER FUNCTIONS ====================
function mean(arr) { return arr.reduce((a, b) => a + b, 0) / arr.length; }
function variance(arr) { const m = mean(arr); return arr.reduce((a, v) => a + (v - m) ** 2, 0) / (arr.length - 1); }
function stdev(arr) { return Math.sqrt(variance(arr)); }

function tCDF(t, df) {
  // Approximation of Student's t CDF using regularized incomplete beta function
  const x = df / (df + t * t);
  const a = df / 2;
  const b = 0.5;
  let ibeta = regIncBeta(x, a, b);
  return t >= 0 ? 1 - 0.5 * ibeta : 0.5 * ibeta;
}

function regIncBeta(x, a, b) {
  // Continued fraction approximation for regularized incomplete beta
  if (x < 0 || x > 1) return 0;
  if (x === 0 || x === 1) return x;
  const lnBeta = lnGamma(a) + lnGamma(b) - lnGamma(a + b);
  const front = Math.exp(Math.log(x) * a + Math.log(1 - x) * b - lnBeta);
  if (x < (a + 1) / (a + b + 2)) {
    return front * cfBeta(x, a, b) / a;
  } else {
    return 1 - front * cfBeta(1 - x, b, a) / b;
  }
}

function cfBeta(x, a, b) {
  const maxIter = 200;
  const eps = 1e-10;
  let am = 1, bm = 1, az = 1;
  let qab = a + b, qap = a + 1, qam = a - 1;
  let bz = 1 - qab * x / qap;
  for (let i = 1; i <= maxIter; i++) {
    let em = i;
    let tem = em + em;
    let d = em * (b - em) * x / ((qam + tem) * (a + tem));
    let ap = az + d * am;
    let bp = bz + d * bm;
    d = -(a + em) * (qab + em) * x / ((a + tem) * (qap + tem));
    let app = ap + d * az;
    let bpp = bp + d * bz;
    let aold = az;
    am = ap / bpp;
    bm = bp / bpp;
    az = app / bpp;
    bz = 1;
    if (Math.abs(az - aold) < eps * Math.abs(az)) break;
  }
  return az;
}

function lnGamma(z) {
  const c = [76.18009172947146, -86.50532032941677, 24.01409824083091,
    -1.231739572450155, 0.1208650973866179e-2, -0.5395239384953e-5];
  let x = z, y = z, tmp = x + 5.5;
  tmp -= (x + 0.5) * Math.log(tmp);
  let ser = 1.000000000190015;
  for (let j = 0; j < 6; j++) ser += c[j] / ++y;
  return -tmp + Math.log(2.5066282746310005 * ser / x);
}

function tPValue(t, df, twoTailed = true) {
  const p = 1 - tCDF(Math.abs(t), df);
  return twoTailed ? 2 * p : p;
}

function chiCDF(x, df) {
  // Approximate chi-squared CDF using regularized incomplete gamma
  if (x <= 0) return 0;
  return regGammaP(df / 2, x / 2);
}

function regGammaP(a, x) {
  if (x < a + 1) {
    let sum = 1 / a, term = 1 / a;
    for (let n = 1; n < 200; n++) {
      term *= x / (a + n);
      sum += term;
      if (Math.abs(term) < 1e-10) break;
    }
    return sum * Math.exp(-x + a * Math.log(x) - lnGamma(a));
  } else {
    let f = 1e-30, c = 1e-30, d = 0;
    for (let i = 1; i < 200; i++) {
      let an = -i * (i - a);
      let bn = 2 * i + 1 - a + x;
      d = bn + an * d; if (Math.abs(d) < 1e-30) d = 1e-30;
      c = bn + an / c; if (Math.abs(c) < 1e-30) c = 1e-30;
      d = 1 / d;
      let delta = c * d;
      f *= delta;
      if (Math.abs(delta - 1) < 1e-10) break;
    }
    return 1 - f * Math.exp(-x + a * Math.log(x) - lnGamma(a));
  }
}

function fCDF(f, df1, df2) {
  if (f <= 0) return 0;
  const x = df1 * f / (df1 * f + df2);
  return regIncBeta(x, df1 / 2, df2 / 2) > 1 ? 1 : regIncBeta(x, df1 / 2, df2 / 2);
}

function fPValue(f, df1, df2) { return 1 - fCDF(f, df1, df2); }

function tPDF(t, df) {
  const coeff = Math.exp(lnGamma((df + 1) / 2) - lnGamma(df / 2)) / Math.sqrt(df * Math.PI);
  return coeff * Math.pow(1 + t * t / df, -(df + 1) / 2);
}

function normalRandom() {
  let u = 0, v = 0;
  while (u === 0) u = Math.random();
  while (v === 0) v = Math.random();
  return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
}

// ==================== DECISION TREE ====================
