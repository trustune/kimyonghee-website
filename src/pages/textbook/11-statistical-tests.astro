let treePath = [];

function renderTreeNode(nodeId) {
  const node = TREE_NODES[nodeId];
  const qText = document.getElementById('tree-q-text');
  const btns = document.getElementById('tree-buttons');
  const resultDiv = document.getElementById('tree-result');
