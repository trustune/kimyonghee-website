function lookupRef() {
  const outcome = document.getElementById('ref-outcome').value;
  const groups = document.getElementById('ref-groups').value;
  const design = document.getElementById('ref-design').value;
  const key = outcome + '-' + groups + '-' + design;
  const ref = REF_DATA[key];

  const resultDiv = document.getElementById('ref-result');
  if (!ref) {
    resultDiv.style.display = '';
    resultDiv.innerHTML = '<p>해당 조합에 대한 검정법을 찾을 수 없습니다. 조건을 다시 확인해 주세요.</p>';
    document.getElementById('ref-test-name').textContent = '';
    return;
  }

  resultDiv.style.display = '';
  document.getElementById('ref-test-name').textContent = ref.name;
  document.getElementById('ref-test-detail').innerHTML = `
    <p><strong>사용 시점:</strong> ${ref.when}</p>
    <p style="margin-top:8px;"><strong>주요 가정:</strong> ${ref.assumptions}</p>
    <p style="margin-top:8px;"><strong>공식:</strong> <code style="background:var(--tb-g100);padding:2px 8px;border-radius:4px;">${ref.formula}</code></p>
    <p style="margin-top:8px;"><strong>예시:</strong> ${ref.example}</p>
    <p style="margin-top:8px;"><strong>비모수 대안:</strong> ${ref.nonparam}</p>
  `;
}

