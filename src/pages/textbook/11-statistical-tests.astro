    resultDiv.innerHTML = `
      <div style="font-size:1.3rem;font-weight:800;color:${node.color};margin-bottom:10px;">${node.name}</div>
      <p style="font-size:0.95rem;margin-bottom:8px;">${node.desc}</p>
