<script is:inline>
// ==================== CHART.JS LOADER ====================

// ==================== SHARED UTILITIES ====================
const MAX=45,DRAW_SIZE=6,THEO=DRAW_SIZE/MAX;
function rng(c,m){const s=new Set();while(s.size<c)s.add(Math.floor(Math.random()*m)+1);return[...s].sort((a,b)=>a-b);}
function ballClass(n){return n<=10?'ball-yellow':n<=20?'ball-blue':n<=30?'ball-red':n<=40?'ball-gray':'ball-green';}
function ballColor(n){return n<=10?'#f59e0b':n<=20?'#2563eb':n<=30?'#ef4444':n<=40?'#64748b':'#22c55e';}
function matchCount(a,b){const s=new Set(b);return a.filter(n=>s.has(n)).length;}
function makeMini(n){const e=document.createElement('div');e.className=`mini-ball ${ballClass(n)}`;e.textContent=n;return e;}
function makeBig(n){const e=document.createElement('div');e.className=`big-ball ${ballClass(n)}`;e.textContent=n;return e;}
function erf(x){const a1=.254829592,a2=-.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=.3275911;const sg=x<0?-1:1;x=Math.abs(x);const t=1/(1+p*x);return sg*(1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x));}
function normCDF(x){return .5*(1+erf(x/Math.SQRT2));}
function chiSurv(x,df){const z=Math.pow(x/df,1/3)-(1-2/(9*df));const se=Math.sqrt(2/(9*df));return Math.min(1,Math.max(0,1-normCDF(z/se)));}
function chiPVal(obs,exp){let chi=0;for(let i=0;i<obs.length;i++)chi+=Math.pow(obs[i]-exp,2)/exp;const df=obs.length-1,z=Math.pow(chi/df,1/3)-(1-2/(9*df)),se=Math.sqrt(2/(9*df));return{chi,p:Math.min(1,Math.max(0,.5*(1+erf(-z/se/Math.SQRT2))))};}

// ==================== TAB SWITCHING ====================
const TAB_IDS=[0,1,2,3,4,5,6,7,8];
