document.querySelectorAll('.tb-tab-btn[data-tab]').forEach(btn=>{
  btn.addEventListener('click',()=>showTab(+btn.dataset.tab));
});

// ==================== TAB 2: FREQUENCY ====================
let freqCounts=new Array(45).fill(0),freqTotal=0,freqChart=null;
function initFreqGrid(){const g=document.getElementById('freq-grid');if(!g)return;g.innerHTML='';for(let i=1;i<=45;i++){const b=document.createElement('div');b.className=`ball ${ballClass(i)}`;b.id=`fball-${i}`;b.innerHTML=`<span class="intensity"></span><span class="num">${i}</span>`;g.appendChild(b);}}
function updateFreqGrid(){const mx=Math.max(...freqCounts,1);for(let i=0;i<45;i++){const b=document.getElementById(`fball-${i+1}`);if(!b)continue;b.querySelector('.intensity').style.background=`rgba(0,0,0,${.5-freqCounts[i]/mx*.5})`;b.querySelector('.num').textContent=freqTotal>0?freqCounts[i]:(i+1);}}
function updateFreqStats(){document.getElementById('freq-total').textContent=freqTotal.toLocaleString();if(!freqTotal){document.getElementById('freq-deviation').textContent='-';document.getElementById('freq-chi').textContent='-';return;}const mx=Math.max(...freqCounts),mn=Math.min(...freqCounts);document.getElementById('freq-deviation').textContent=((mx/freqTotal*100)-(mn/freqTotal*100)).toFixed(1)+'%p';const{p}=chiPVal(freqCounts,freqTotal*6/45);document.getElementById('freq-chi').textContent=p.toFixed(3);const sub=document.getElementById('freq-chi-label');if(sub)sub.textContent=p>.05?'균등 분포와 차이 없음 (p>0.05)':'편향 감지 (p<=0.05)';}
function updateFreqChart(){const labels=Array.from({length:45},(_,i)=>i+1),data=freqCounts.map(c=>freqTotal>0?(c/freqTotal*100):0),colors=labels.map(n=>ballColor(n));if(freqChart){freqChart.data.datasets[0].data=data;freqChart.update('none');}else{const el=document.getElementById('freq-chart');if(!el)return;freqChart=new Chart(el,{type:'bar',data:{labels,datasets:[{label:'출현율 (%)',data,backgroundColor:colors,borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,title:{display:true,text:'출현율 (%)'}},x:{title:{display:true,text:'번호'}}}}});}}
function runFrequency(){const c=+document.getElementById('freq-count').value;for(let i=0;i<c;i++){rng(6,45).forEach(n=>freqCounts[n-1]++);freqTotal++;}updateFreqGrid();updateFreqStats();updateFreqChart();}
function resetFrequency(){freqCounts=new Array(45).fill(0);freqTotal=0;updateFreqGrid();updateFreqStats();updateFreqChart();}

// ==================== TAB 3: LLN ====================
const LLN_TRACK=[7,13,25,33,42],LLN_COLORS=['#f59e0b','#2563eb','#ef4444','#64748b','#22c55e'];
let llnChart=null,llnRunning=false,llnCounts={},llnTotal=0,llnHistory={},llnAnim=null;
function initLLN(){LLN_TRACK.forEach(n=>{llnCounts[n]=0;llnHistory[n]=[];});const sp=document.getElementById('lln-speed');if(sp)sp.addEventListener('input',function(){const v=+this.value;document.getElementById('lln-speed-label').textContent=v<30?'느림':v<70?'보통':'빠름';});}
function startLLN(){if(llnRunning){stopLLN();return;}llnRunning=true;const btn=document.getElementById('lln-start-btn');btn.textContent='일시정지';btn.className='tb-btn tb-btn-warning';const target=+document.getElementById('lln-count').value,speed=+document.getElementById('lln-speed').value,bs=speed<30?1:speed<70?5:20,iv=speed<30?100:speed<70?30:5;function step(){if(!llnRunning||llnTotal>=target){stopLLN();return;}const ab=Math.min(bs,target-llnTotal);for(let b=0;b<ab;b++){const d=rng(6,45);llnTotal++;LLN_TRACK.forEach(n=>{if(d.includes(n))llnCounts[n]++;llnHistory[n].push(llnCounts[n]/llnTotal*100);});if(b===ab-1){const c=document.getElementById('lln-current-draw');c.innerHTML='<span class="draw-label">추첨 #'+llnTotal+':</span>';d.forEach(n=>c.appendChild(makeBig(n)));}}updateLLNChart();updateLLNStats();llnAnim=setTimeout(step,iv);}step();}
function stopLLN(){llnRunning=false;if(llnAnim)clearTimeout(llnAnim);const btn=document.getElementById('lln-start-btn');btn.textContent='계속';btn.className='tb-btn tb-btn-primary';if(llnTotal>=+document.getElementById('lln-count').value){btn.textContent='완료';btn.disabled=true;}}
function resetLLN(){stopLLN();llnTotal=0;LLN_TRACK.forEach(n=>{llnCounts[n]=0;llnHistory[n]=[];});document.getElementById('lln-current').textContent='0';document.getElementById('lln-max-dev').textContent='-';const btn=document.getElementById('lln-start-btn');btn.textContent='시작';btn.disabled=false;btn.className='tb-btn tb-btn-primary';document.getElementById('lln-current-draw').innerHTML='<span class="draw-label">최근 추첨:</span><span style="color:var(--tb-g600)">시작 버튼을 눌러주세요</span>';if(llnChart){llnChart.destroy();llnChart=null;}}
function updateLLNStats(){document.getElementById('lln-current').textContent=llnTotal.toLocaleString();if(!llnTotal)return;const th=6/45*100;document.getElementById('lln-max-dev').textContent=Math.max(...LLN_TRACK.map(n=>Math.abs(llnCounts[n]/llnTotal*100-th))).toFixed(2)+'%p';}
function updateLLNChart(){const mp=500,st=Math.max(1,Math.floor(llnTotal/mp)),labels=[];for(let i=0;i<llnTotal;i+=st)labels.push(i+1);if(labels[labels.length-1]!==llnTotal)labels.push(llnTotal);const ds=LLN_TRACK.map((n,i)=>({label:`번호 ${n}`,data:labels.map(l=>llnHistory[n][l-1]??null),borderColor:LLN_COLORS[i],backgroundColor:LLN_COLORS[i]+'20',borderWidth:2,pointRadius:0,tension:.1}));ds.push({label:'이론값 (13.33%)',data:labels.map(()=>13.33),borderColor:'#000',borderDash:[8,4],borderWidth:2,pointRadius:0,fill:false});const el=document.getElementById('lln-chart');if(!el)return;if(llnChart){llnChart.data.labels=labels;llnChart.data.datasets=ds;llnChart.update('none');}else{llnChart=new Chart(el,{type:'line',data:{labels,datasets:ds},options:{responsive:true,maintainAspectRatio:false,animation:false,plugins:{legend:{position:'top'}},scales:{x:{title:{display:true,text:'추첨 횟수'},ticks:{maxTicksLimit:10}},y:{title:{display:true,text:'출현율 (%)'},min:0,max:30}}}});}}

// ==================== TAB 4: STRATEGY BATTLE ====================
let b1Chart=null;
async function runBattle1(){const count=+document.getElementById('b1-count').value;document.getElementById('b1-pb').style.display='';const hist=[];for(let i=0;i<100;i++)hist.push(rng(6,45));const hc=new Array(45).fill(0);hist.forEach(d=>d.forEach(n=>hc[n-1]++));const sorted=hc.map((c,i)=>({n:i+1,c})).sort((a,b)=>b.c-a.c);const hot=sorted.slice(0,6).map(x=>x.n).sort((a,b)=>a-b),cold=sorted.slice(-6).map(x=>x.n).sort((a,b)=>a-b),pat=[7,14,21,28,35,42];[['hot',hot],['cold',cold],['pattern',pat]].forEach(([k,nums])=>{const c=document.getElementById(`s1-${k}-nums`);c.innerHTML='';nums.forEach(n=>c.appendChild(makeMini(n)));});const sc={hot:0,cold:0,pattern:0,random:0},mh={hot:[],cold:[],pattern:[],random:[]};let done=0;const chunk=Math.min(100,count);while(done<count){const b=Math.min(chunk,count-done);for(let i=0;i<b;i++){const d=rng(6,45),rp=rng(6,45);sc.hot+=matchCount(hot,d);sc.cold+=matchCount(cold,d);sc.pattern+=matchCount(pat,d);sc.random+=matchCount(rp,d);['hot','cold','pattern','random'].forEach(k=>mh[k].push(sc[k]/(done+i+1)));}done+=b;document.getElementById('b1-pf').style.width=(done/count*100)+'%';await new Promise(r=>setTimeout(r,0));}const lr=rng(6,45);const rc=document.getElementById('s1-random-nums');rc.innerHTML='';lr.forEach(n=>rc.appendChild(makeMini(n)));['hot','cold','pattern','random'].forEach(k=>document.getElementById(`s1-${k}-score`).textContent=sc[k].toLocaleString());const mx=Math.max(sc.hot,sc.cold,sc.pattern,sc.random);['hot','cold','pattern','random'].forEach(k=>document.getElementById(`s1-${k}`).classList.toggle('winner',sc[k]===mx));const avgs=Object.fromEntries(Object.entries(sc).map(([k,v])=>[k,v/count]));const diff=(Math.max(...Object.values(avgs))-Math.min(...Object.values(avgs))).toFixed(3);document.getElementById('b1-diff').textContent=diff;document.getElementById('b1-diff').style.color=diff<0.05?'var(--tb-success)':'var(--tb-warning)';document.getElementById('b1-result').style.display='';document.getElementById('b1-pb').style.display='none';document.getElementById('b1-insight').style.display='';const step=Math.max(1,Math.floor(count/200)),cl=[];for(let i=0;i<count;i+=step)cl.push(i+1);const dcol={hot:'#ef4444',cold:'#2563eb',pattern:'#7c3aed',random:'#22c55e'},dnam={hot:'뜨거운 번호',cold:'차가운 번호',pattern:'패턴 전략',random:'완전 랜덤'};const dsets=Object.keys(sc).map(k=>({label:dnam[k],data:cl.map(l=>mh[k][l-1]),borderColor:dcol[k],borderWidth:2,pointRadius:0,tension:.1}));dsets.push({label:'이론값 (0.800)',data:cl.map(()=>.8),borderColor:'#000',borderDash:[8,4],borderWidth:2,pointRadius:0});if(b1Chart)b1Chart.destroy();b1Chart=new Chart(document.getElementById('b1-chart'),{type:'line',data:{labels:cl,datasets:dsets},options:{responsive:true,maintainAspectRatio:false,animation:false,plugins:{legend:{position:'top'}},scales:{x:{title:{display:true,text:'시뮬레이션 횟수'},ticks:{maxTicksLimit:10}},y:{title:{display:true,text:'회당 평균 일치 수'},min:.4,max:1.2}}}});}
function resetBattle1(){['hot','cold','pattern','random'].forEach(k=>{document.getElementById(`s1-${k}-score`).textContent='-';document.getElementById(`s1-${k}-nums`).innerHTML='';document.getElementById(`s1-${k}`).classList.remove('winner');});document.getElementById('b1-result').style.display='none';document.getElementById('b1-pb').style.display='none';document.getElementById('b1-insight').style.display='none';if(b1Chart){b1Chart.destroy();b1Chart=null;}}

// ==================== PART II: SHARED DATA ====================
let draws=[],dataSource='sim';
function genData(n=500){draws=[];for(let i=0;i<n;i++)draws.push(rng(6,45));dataSource='sim';updateDataUI();}
function updateDataUI(){const b=document.getElementById('data-badge');if(!b)return;b.textContent=dataSource==='sim'?`시뮬레이션 (${draws.length}회 랜덤 추첨)`:`실제 로또 데이터 (1회~${draws.length}회차)`;b.className='tb-badge '+(dataSource==='sim'?'tb-badge-sim':'tb-badge-real');document.getElementById('d-total').textContent=draws.length;const tr=Math.floor(draws.length*.8);document.getElementById('d-train').textContent=tr;document.getElementById('d-test').textContent=draws.length-tr;const tb=document.getElementById('data-tbody');if(!tb)return;tb.innerHTML='';const show=[...draws.slice(0,5),null,...draws.slice(-5)];show.forEach((d,i)=>{if(!d){tb.insertAdjacentHTML('beforeend','<tr><td colspan="7" style="color:var(--tb-g600)">...</td></tr>');return;}const idx=i<5?i+1:draws.length-4+(i-6);tb.insertAdjacentHTML('beforeend',`<tr><td>${idx}</td>${d.map(n=>`<td><span class="mini-ball ${ballClass(n)}">${n}</span></td>`).join('')}</tr>`);});}
function regenData(){genData(500);}
// Load real data from pre-fetched static JSON
async function loadReal(){
  const msg=document.getElementById('loading-msg');if(msg)msg.style.display='block';
  try{
    const r=await fetch('/lotto/data.json');
    const raw=await r.json();
    draws=raw.map(d=>d.slice(1).sort((a,b)=>a-b));
    dataSource='real';
    updateDataUI();
  }catch(e){
    console.error('data.json load failed',e);
    genData(500);
  }
  if(msg)msg.style.display='none';
}

// ==================== TAB 6: CONDITIONAL ====================
let condChart=null,explorerChart=null;
function buildNumSelect(){const c=document.getElementById('num-select');if(!c)return;for(let i=1;i<=45;i++){const b=document.createElement('button');b.className='num-btn';b.textContent=i;b.onclick=()=>{c.querySelectorAll('.num-btn').forEach(x=>x.classList.remove('sel'));b.classList.add('sel');runExplorer(i);};c.appendChild(b);}}
function runConditional(){const res=[];for(let n=1;n<=MAX;n++){let ah=0,hc=0,ac=0,cc=0;for(let t=1;t<draws.length;t++){const ip=draws[t-1].includes(n),ic=draws[t].includes(n);if(ip){hc++;if(ic)ah++;}else{cc++;if(ic)ac++;}}res.push({n,hot:hc?ah/hc:0,cold:cc?ac/cc:0,marginal:draws.reduce((a,d)=>a+(d.includes(n)?1:0),0)/draws.length});}if(condChart)condChart.destroy();condChart=new Chart(document.getElementById('cond-chart'),{type:'scatter',data:{datasets:[{label:'Hot: P(n|n 나옴)',data:res.map(r=>({x:r.marginal*100,y:r.hot*100})),backgroundColor:'rgba(239,68,68,.7)',pointRadius:6},{label:'Cold: P(n|n 안나옴)',data:res.map(r=>({x:r.marginal*100,y:r.cold*100})),backgroundColor:'rgba(37,99,235,.7)',pointRadius:6,pointStyle:'rectRot'},{label:'독립선 (y=x)',data:[{x:8,y:8},{x:18,y:18}],type:'line',borderColor:'#000',borderDash:[6,4],borderWidth:2,pointRadius:0,fill:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top'},tooltip:{callbacks:{label:ctx=>`번호 ${res[ctx.dataIndex]?.n}: ${ctx.parsed.y.toFixed(1)}%`}}},scales:{x:{title:{display:true,text:'무조건부 출현율 (%)'},min:6,max:22},y:{title:{display:true,text:'조건부 출현율 (%)'},min:6,max:22}}}});const avgH=(res.reduce((a,r)=>a+r.hot,0)/MAX*100).toFixed(2),avgC=(res.reduce((a,r)=>a+r.cold,0)/MAX*100).toFixed(2),diff=Math.abs(avgH-avgC).toFixed(2);document.getElementById('cond-hot').textContent=avgH+'%';document.getElementById('cond-cold').textContent=avgC+'%';document.getElementById('cond-diff').textContent=diff+'%p';document.getElementById('cond-diff').style.color=diff<1?'var(--tb-success)':'var(--tb-danger)';document.getElementById('cond-stats').style.display='';const ins=document.getElementById('cond-insight');ins.style.display='';ins.innerHTML=diff<2?`<strong>결과:</strong> Hot과 Cold의 차이가 <strong>${diff}%p</strong>로 매우 작습니다. 산점도에서 점들이 대각선 주위에 고르게 분포합니다. → <strong>종속성 증거 없음!</strong>`:`<strong>결과:</strong> 차이가 ${diff}%p이지만, 이는 표본 변동(우연)으로 설명 가능합니다. "새로 생성" 버튼을 눌러 데이터를 바꿔보면 매번 다른 값이 나옵니다.`;}
function runExplorer(num){const counts=new Array(MAX).fill(0);let total=0;for(let t=0;t<draws.length-1;t++){if(draws[t].includes(num)){total++;draws[t+1].forEach(n=>counts[n-1]++);}}const freq=counts.map(c=>total?c/total*100:0);if(explorerChart)explorerChart.destroy();explorerChart=new Chart(document.getElementById('explorer-chart'),{type:'bar',data:{labels:Array.from({length:MAX},(_,i)=>i+1),datasets:[{label:`번호 ${num} 다음 회차 출현율 (%)`,data:freq,backgroundColor:Array.from({length:MAX},(_,i)=>ballColor(i+1)),borderRadius:2},{label:'이론값 (13.33%)',data:new Array(MAX).fill(THEO*100),type:'line',borderColor:'#000',borderDash:[6,4],borderWidth:2,pointRadius:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top'}},scales:{y:{beginAtZero:true,title:{display:true,text:'출현율 (%)'}},x:{title:{display:true,text:'번호'}}}}});const ins=document.getElementById('explorer-insight');ins.style.display='';const sorted=freq.map((f,i)=>({n:i+1,f})).sort((a,b)=>b.f-a.f);ins.innerHTML=`<strong>번호 ${num}</strong>이 나온 뒤 가장 많이 나온 번호: <strong>${sorted.slice(0,5).map(x=>`${x.n}(${x.f.toFixed(1)}%)`).join(', ')}</strong><br>하지만 이론값(13.33%)과 크게 다르지 않습니다. 표본 크기(${total}회)가 작아서 변동이 클 뿐입니다.`;}

// ==================== TAB 7: ACF ====================
let acfChart=null,allAcfChart=null;
function computeACF(num,maxLag){const s=draws.map(d=>d.includes(num)?1:0),N=s.length,mu=s.reduce((a,b)=>a+b,0)/N,v=s.reduce((a,x)=>a+(x-mu)**2,0)/N;if(v===0)return new Array(maxLag+1).fill(0);const acf=[1];for(let k=1;k<=maxLag;k++){let sm=0;for(let t=0;t<N-k;t++)sm+=(s[t]-mu)*(s[t+k]-mu);acf.push(sm/(N*v));}return acf;}
function ljungBox(acf,N,h){let Q=0;for(let k=1;k<=h;k++)Q+=acf[k]**2/(N-k);Q*=N*(N+2);return{Q,df:h,p:chiSurv(Q,h)};}
function runACF(){const num=+document.getElementById('acf-num').value,maxLag=+document.getElementById('acf-lag').value,acf=computeACF(num,maxLag),N=draws.length,ci=1.96/Math.sqrt(N),labels=Array.from({length:maxLag},(_,i)=>i+1),data=acf.slice(1),barColors=data.map(v=>Math.abs(v)>ci?'rgba(239,68,68,.8)':'rgba(37,99,235,.7)');if(acfChart)acfChart.destroy();acfChart=new Chart(document.getElementById('acf-chart'),{type:'bar',data:{labels,datasets:[{label:'자기상관 계수',data,backgroundColor:barColors,borderRadius:2},{label:'+95% CI',data:new Array(maxLag).fill(ci),type:'line',borderColor:'var(--tb-danger)',borderDash:[5,3],borderWidth:2,pointRadius:0,fill:false},{label:'-95% CI',data:new Array(maxLag).fill(-ci),type:'line',borderColor:'var(--tb-danger)',borderDash:[5,3],borderWidth:2,pointRadius:0,fill:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{title:{display:true,text:'ACF'},min:-.15,max:.15},x:{title:{display:true,text:'Lag'}}}}});const lb=ljungBox(acf,N,maxLag);document.getElementById('acf-Q').textContent=lb.Q.toFixed(2);document.getElementById('acf-df').textContent=lb.df;document.getElementById('acf-p').textContent=lb.p.toFixed(4);const sig=lb.p<.05;document.getElementById('acf-verdict').textContent=sig?'자기상관 감지 (p<0.05)':'자기상관 없음 (p>=0.05)';document.getElementById('acf-verdict').style.color=sig?'var(--tb-danger)':'var(--tb-success)';document.getElementById('acf-stats').style.display='';}
function runAllACF(){const maxLag=+document.getElementById('acf-lag').value,pValues=[];for(let n=1;n<=MAX;n++){const acf=computeACF(n,maxLag);pValues.push(ljungBox(acf,draws.length,maxLag).p);}const sigCount=pValues.filter(p=>p<.05).length;document.getElementById('all-acf-sig').textContent=sigCount;document.getElementById('all-acf-verdict').textContent=sigCount<=4?'우연의 범위 (다중검정 효과)':'비정상적으로 많음';document.getElementById('all-acf-verdict').style.color=sigCount<=4?'var(--tb-success)':'var(--tb-danger)';document.getElementById('all-acf-card').style.display='';if(allAcfChart)allAcfChart.destroy();allAcfChart=new Chart(document.getElementById('all-acf-chart'),{type:'bar',data:{labels:Array.from({length:MAX},(_,i)=>i+1),datasets:[{label:'p-value',data:pValues,backgroundColor:pValues.map(p=>p<.05?'rgba(239,68,68,.8)':'rgba(37,99,235,.5)'),borderRadius:2},{label:'유의수준 0.05',data:new Array(MAX).fill(.05),type:'line',borderColor:'var(--tb-danger)',borderDash:[5,3],borderWidth:2,pointRadius:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top'}},scales:{y:{title:{display:true,text:'p-value'},min:0,max:1},x:{title:{display:true,text:'번호'}}}}});}

// ==================== TAB 8: MARKOV BATTLE ====================
let permChart=null;
function trainMarkov(data){const counts=Array.from({length:MAX},()=>new Array(MAX).fill(0)),totals=new Array(MAX).fill(0);for(let t=0;t<data.length-1;t++)data[t].forEach(i=>{totals[i-1]++;data[t+1].forEach(j=>counts[i-1][j-1]++);});return counts.map((row,i)=>row.map(c=>totals[i]?c/totals[i]:THEO));}
function markovPredict(last,prob){const sc=new Array(MAX).fill(0);last.forEach(i=>prob[i-1].forEach((p,j)=>sc[j]+=p));return sc.map((s,i)=>({n:i+1,s})).sort((a,b)=>b.s-a.s).slice(0,DRAW_SIZE).map(x=>x.n).sort((a,b)=>a-b);}
async function runBattle2(){const split=Math.floor(draws.length*.8),train=draws.slice(0,split),test=draws.slice(split),prob=trainMarkov(train);let mS=0,rS=0;for(let t=0;t<test.length;t++){const prev=t===0?train[train.length-1]:test[t-1];mS+=matchCount(markovPredict(prev,prob),test[t]);rS+=matchCount(rng(6,45),test[t]);}const mA=(mS/test.length).toFixed(3),rA=(rS/test.length).toFixed(3),diff=Math.abs(mA-rA).toFixed(3);document.getElementById('bt-markov').textContent=mA;document.getElementById('bt-random').textContent=rA;document.getElementById('bt-diff').textContent=diff;document.getElementById('bt-diff').style.color=diff<0.05?'var(--tb-success)':'var(--tb-warning)';document.getElementById('bt-stats').style.display='';document.getElementById('perm-card').style.display='';document.getElementById('bt-pb').style.display='';const PERMS=500,permScores=[];for(let p=0;p<PERMS;p++){const sh=[...draws];for(let i=sh.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[sh[i],sh[j]]=[sh[j],sh[i]];}const sT=sh.slice(0,split),sE=sh.slice(split),sP=trainMarkov(sT);let sc=0;for(let t=0;t<sE.length;t++){const prev=t===0?sT[sT.length-1]:sE[t-1];sc+=matchCount(markovPredict(prev,sP),sE[t]);}permScores.push(sc/sE.length);if(p%50===0){document.getElementById('bt-pf').style.width=(p/PERMS*100)+'%';await new Promise(r=>setTimeout(r,0));}}document.getElementById('bt-pb').style.display='none';const aV=parseFloat(mA),mn=Math.min(...permScores,aV)-.05,mx=Math.max(...permScores,aV)+.05,bins=20,bw=(mx-mn)/bins,hist=new Array(bins).fill(0);permScores.forEach(v=>{const b=Math.min(bins-1,Math.floor((v-mn)/bw));hist[b]++;});const binL=Array.from({length:bins},(_,i)=>(mn+i*bw+bw/2).toFixed(3));if(permChart)permChart.destroy();permChart=new Chart(document.getElementById('perm-chart'),{type:'bar',data:{labels:binL,datasets:[{label:'셔플 분포',data:hist,backgroundColor:binL.map(l=>Math.abs(parseFloat(l)-aV)<bw?'rgba(239,68,68,.8)':'rgba(37,99,235,.5)'),borderRadius:2}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},title:{display:true,text:`빨간 막대: 실제 모델 정확도 (${mA}) 위치`,color:'var(--tb-danger)',font:{size:14}}},scales:{y:{title:{display:true,text:'빈도'}},x:{title:{display:true,text:'회당 평균 일치 수'},ticks:{maxTicksLimit:10}}}}});const pctile=(permScores.filter(v=>v<aV).length/PERMS*100).toFixed(1),isSig=pctile>97.5||pctile<2.5;document.getElementById('perm-actual').textContent=mA;document.getElementById('perm-mean').textContent=(permScores.reduce((a,b)=>a+b,0)/PERMS).toFixed(3);document.getElementById('perm-pct').textContent=pctile+'%';document.getElementById('perm-verdict').textContent=isSig?'유의한 차이 발견!':'유의하지 않음 (셔플과 동일)';document.getElementById('perm-verdict').style.color=isSig?'var(--tb-danger)':'var(--tb-success)';}
function resetBattle2(){['bt-markov','bt-random','bt-diff'].forEach(id=>document.getElementById(id).textContent='-');document.getElementById('bt-stats').style.display='none';document.getElementById('perm-card').style.display='none';document.getElementById('bt-pb').style.display='none';if(permChart){permChart.destroy();permChart=null;}}

// ==================== INIT ====================
async function lottoInit(){
  // Load Chart.js first
  

  // Mark visited for progress tracking

  initFreqGrid();updateFreqChart();initLLN();buildNumSelect();
  // Populate ACF number selector
  const acfSel=document.getElementById('acf-num');
  if(acfSel){for(let i=1;i<=45;i++){const o=document.createElement('option');o.value=i;o.textContent=i;acfSel.appendChild(o);}}
  document.getElementById('banner-part2').style.display='none';
  loadReal();

  // Bind all button events
  document.getElementById('btn-freq-run')?.addEventListener('click',runFrequency);
  document.getElementById('btn-freq-reset')?.addEventListener('click',resetFrequency);
  document.getElementById('lln-start-btn')?.addEventListener('click',startLLN);
  document.getElementById('btn-lln-reset')?.addEventListener('click',resetLLN);
  document.getElementById('btn-battle1')?.addEventListener('click',runBattle1);
  document.getElementById('btn-battle1-reset')?.addEventListener('click',resetBattle1);
  document.getElementById('btn-regen')?.addEventListener('click',regenData);
  document.getElementById('btn-load-real')?.addEventListener('click',loadReal);
  document.getElementById('btn-conditional')?.addEventListener('click',runConditional);
  document.getElementById('btn-acf')?.addEventListener('click',runACF);
  document.getElementById('btn-acf-all')?.addEventListener('click',runAllACF);
  document.getElementById('btn-battle2')?.addEventListener('click',runBattle2);
  document.getElementById('btn-battle2-reset')?.addEventListener('click',resetBattle2);
}

document.addEventListener('DOMContentLoaded', lottoInit);
</script>

