<script>
// ==================== UTILITY FUNCTIONS ====================
function sigmoid(x) { return 1 / (1 + Math.exp(-Math.max(-500, Math.min(500, x)))); }
function relu(x) { return Math.max(0, x); }
function tanhAct(x) { return Math.tanh(x); }
function step(x) { return x > 0 ? 1 : 0; }

function sigmoidDeriv(x) { const s = sigmoid(x); return s * (1 - s); }
function reluDeriv(x) { return x > 0 ? 1 : 0; }
function tanhDeriv(x) { const t = Math.tanh(x); return 1 - t * t; }
function stepDeriv(_x) { return 0; }

function randRange(a, b) { return a + Math.random() * (b - a); }
function randn() { let u = 0, v = 0; while (u === 0) u = Math.random(); while (v === 0) v = Math.random(); return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v); }

// ==================== DATASETS ====================
const DATA_AND = [ {x:[0,0],y:0}, {x:[0,1],y:0}, {x:[1,0],y:0}, {x:[1,1],y:1} ];
const DATA_OR  = [ {x:[0,0],y:0}, {x:[0,1],y:1}, {x:[1,0],y:1}, {x:[1,1],y:1} ];
const DATA_XOR = [ {x:[0,0],y:0}, {x:[0,1],y:1}, {x:[1,0],y:1}, {x:[1,1],y:0} ];

function generateClusters(n) {
  const data = [];
  for (let i = 0; i < n; i++) {
    if (i < n / 2) {
      data.push({ x: [randn() * 0.5 + 1.5, randn() * 0.5 + 1.5], y: 0 });
    } else {
      data.push({ x: [randn() * 0.5 - 1.5, randn() * 0.5 - 1.5], y: 1 });
    }
  }
  return data;
}

function generateSpiral(n) {
  const data = [];
  const half = Math.floor(n / 2);
  for (let c = 0; c < 2; c++) {
    for (let i = 0; i < half; i++) {
      const r = (i / half) * 3;
      const t = 1.25 * i / half * 2 * Math.PI + (c * Math.PI);
      const x = r * Math.cos(t) + randn() * 0.25;
      const y = r * Math.sin(t) + randn() * 0.25;
      data.push({ x: [x, y], y: c });
    }
  }
  return data;
}

// ==================== SIMPLE 2-LAYER NETWORK ====================
class SimpleNetwork {
  constructor(inputSize, hiddenSize, outputSize) {
    this.inputSize = inputSize;
    this.hiddenSize = hiddenSize;
    this.outputSize = outputSize;
    this.initWeights();
  }

  initWeights() {
    const s1 = Math.sqrt(2 / this.inputSize);
    const s2 = Math.sqrt(2 / this.hiddenSize);
    this.w1 = Array.from({length: this.hiddenSize}, () =>
      Array.from({length: this.inputSize}, () => randn() * s1)
    );
    this.b1 = Array.from({length: this.hiddenSize}, () => 0);
    this.w2 = Array.from({length: this.outputSize}, () =>
      Array.from({length: this.hiddenSize}, () => randn() * s2)
    );
    this.b2 = Array.from({length: this.outputSize}, () => 0);
  }

  forward(x) {
    // Hidden layer: tanh activation
    this.z1 = this.b1.map((b, i) => {
      let sum = b;
      for (let j = 0; j < this.inputSize; j++) sum += this.w1[i][j] * x[j];
      return sum;
    });
    this.h = this.z1.map(z => Math.tanh(z));

    // Output layer: sigmoid activation
    this.z2 = this.b2.map((b, i) => {
      let sum = b;
      for (let j = 0; j < this.hiddenSize; j++) sum += this.w2[i][j] * this.h[j];
      return sum;
    });
    this.out = this.z2.map(z => sigmoid(z));
    return this.out[0];
  }

  backward(x, y, lr) {
    const a = this.out[0];
    const eps = 1e-7;
    // Output gradient
    const dz2 = a - y;

    // Update output weights
    for (let j = 0; j < this.hiddenSize; j++) {
      this.w2[0][j] -= lr * dz2 * this.h[j];
    }
    this.b2[0] -= lr * dz2;

    // Hidden gradients
    for (let i = 0; i < this.hiddenSize; i++) {
      const dh = dz2 * this.w2[0][i];
      const dz1 = dh * (1 - this.h[i] * this.h[i]); // tanh derivative
      for (let j = 0; j < this.inputSize; j++) {
        this.w1[i][j] -= lr * dz1 * x[j];
      }
      this.b1[i] -= lr * dz1;
    }
  }

  predict(x) {
    return this.forward(x) > 0.5 ? 1 : 0;
  }
}

// ==================== INTERACTIVE 1: SINGLE NEURON PLAYGROUND ====================
let neuronDataset = DATA_AND;
let neuronDatasetName = 'AND';

function drawNeuronCanvas() {
  const canvas = document.getElementById('neuron-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const w1 = parseFloat(document.getElementById('slider-w1').value);
  const w2 = parseFloat(document.getElementById('slider-w2').value);
  const b  = parseFloat(document.getElementById('slider-b').value);

  // Draw coordinate system
  const pad = 40;
  const plotW = W - 2 * pad;
  const plotH = H - 2 * pad;

  // Map data coords to canvas: data range [-0.5, 1.5] for logic gates
  const xMin = -0.5, xMax = 1.5, yMin = -0.5, yMax = 1.5;
  function toCanvasX(x) { return pad + (x - xMin) / (xMax - xMin) * plotW; }
  function toCanvasY(y) { return H - pad - (y - yMin) / (yMax - yMin) * plotH; }

  // Draw background coloring (decision regions)
  const res = 4;
  for (let px = pad; px < W - pad; px += res) {
    for (let py = pad; py < H - pad; py += res) {
      const dx = xMin + (px - pad) / plotW * (xMax - xMin);
      const dy = yMax - (py - pad) / plotH * (yMax - yMin);
      const z = w1 * dx + w2 * dy + b;
      const a = sigmoid(z);
      if (a > 0.5) {
        ctx.fillStyle = 'rgba(239, 68, 68, 0.08)';
      } else {
        ctx.fillStyle = 'rgba(37, 99, 235, 0.08)';
      }
      ctx.fillRect(px, py, res, res);
    }
  }

  // Draw grid
  ctx.strokeStyle = '#e2e8f0';
  ctx.lineWidth = 0.5;
  for (let v = 0; v <= 1; v += 0.5) {
    ctx.beginPath();
    ctx.moveTo(toCanvasX(v), pad);
    ctx.lineTo(toCanvasX(v), H - pad);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(pad, toCanvasY(v));
    ctx.lineTo(W - pad, toCanvasY(v));
    ctx.stroke();
  }

  // Draw axes
  ctx.strokeStyle = '#94a3b8';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(pad, H - pad);
  ctx.lineTo(W - pad, H - pad);
  ctx.moveTo(pad, pad);
  ctx.lineTo(pad, H - pad);
  ctx.stroke();

  // Axis labels
  ctx.fillStyle = '#475569';
  ctx.font = '12px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('x1', W / 2, H - 8);
  ctx.save();
  ctx.translate(12, H / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillText('x2', 0, 0);
  ctx.restore();

  // Tick labels
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';
  [0, 0.5, 1].forEach(v => {
    ctx.fillText(v.toString(), toCanvasX(v), H - pad + 5);
  });
  ctx.textAlign = 'right';
  ctx.textBaseline = 'middle';
  [0, 0.5, 1].forEach(v => {
    ctx.fillText(v.toString(), pad - 5, toCanvasY(v));
  });

  // Draw decision boundary: w1*x1 + w2*x2 + b = 0
  ctx.strokeStyle = '#7c3aed';
  ctx.lineWidth = 2.5;
  ctx.setLineDash([6, 4]);
  ctx.beginPath();

  if (Math.abs(w2) > 0.001) {
    const x1a = xMin;
    const x2a = -(w1 * x1a + b) / w2;
    const x1b = xMax;
    const x2b = -(w1 * x1b + b) / w2;
    ctx.moveTo(toCanvasX(x1a), toCanvasY(x2a));
    ctx.lineTo(toCanvasX(x1b), toCanvasY(x2b));
  } else if (Math.abs(w1) > 0.001) {
    const x1 = -b / w1;
    ctx.moveTo(toCanvasX(x1), pad);
    ctx.lineTo(toCanvasX(x1), H - pad);
  }
  ctx.stroke();
  ctx.setLineDash([]);

  // Draw data points
  let correct = 0;
  neuronDataset.forEach(d => {
    const cx = toCanvasX(d.x[0]);
    const cy = toCanvasY(d.x[1]);
    const z = w1 * d.x[0] + w2 * d.x[1] + b;
    const pred = sigmoid(z) > 0.5 ? 1 : 0;
    const isCorrect = pred === d.y;
    if (isCorrect) correct++;

    ctx.beginPath();
    ctx.arc(cx, cy, 10, 0, 2 * Math.PI);
    ctx.fillStyle = d.y === 1 ? '#ef4444' : '#2563eb';
    ctx.fill();
    ctx.strokeStyle = isCorrect ? '#22c55e' : '#fbbf24';
    ctx.lineWidth = isCorrect ? 2 : 3;
    ctx.stroke();

    // Label
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 10px Paperlogy, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(d.y.toString(), cx, cy);
  });

  const accuracy = Math.round(correct / neuronDataset.length * 100);
  const accEl = document.getElementById('neuron-accuracy');
  if (accEl) accEl.textContent = accuracy + '%';
}

function setupNeuronPlayground() {
  const sliders = ['slider-w1', 'slider-w2', 'slider-b'];
  const displays = ['w1-val', 'w2-val', 'b-val'];

  sliders.forEach((id, i) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.addEventListener('input', () => {
      document.getElementById(displays[i]).textContent = parseFloat(el.value).toFixed(1);
      drawNeuronCanvas();
    });
  });

  function setDataset(data, name) {
    neuronDataset = data;
    neuronDatasetName = name;
    const dsEl = document.getElementById('neuron-dataset');
    if (dsEl) dsEl.textContent = name;
    drawNeuronCanvas();
  }

  document.getElementById('btn-data-and')?.addEventListener('click', () => setDataset(DATA_AND, 'AND'));
  document.getElementById('btn-data-or')?.addEventListener('click', () => setDataset(DATA_OR, 'OR'));
  document.getElementById('btn-data-xor')?.addEventListener('click', () => setDataset(DATA_XOR, 'XOR'));

  drawNeuronCanvas();
}

// ==================== INTERACTIVE 2: ACTIVATION FUNCTION EXPLORER ====================
let actFuncChart = null;
let actDerivChart = null;
let ChartJS = null;

async function loadChart() {
  if (ChartJS) return;
  const mod = await import('https://cdn.jsdelivr.net/npm/chart.js@4/+esm');
  ChartJS = mod.Chart;
  mod.Chart.register(...mod.registerables);
}

async function drawActivationCharts() {
  await loadChart();

  const showSigmoid = document.getElementById('chk-sigmoid')?.checked;
  const showRelu = document.getElementById('chk-relu')?.checked;
  const showTanh = document.getElementById('chk-tanh')?.checked;
  const showStep = document.getElementById('chk-step')?.checked;
  const xVal = parseFloat(document.getElementById('slider-act-x')?.value || '0');

  const xs = [];
  for (let x = -5; x <= 5; x += 0.1) xs.push(Math.round(x * 10) / 10);

  const datasets = [];
  const derivDatasets = [];

  const colors = {
    sigmoid: '#2563eb',
    relu: '#ef4444',
    tanh: '#22c55e',
    step: '#7c3aed'
  };

  if (showSigmoid) {
    datasets.push({ label: 'Sigmoid', data: xs.map(x => sigmoid(x)), borderColor: colors.sigmoid, backgroundColor: 'transparent', pointRadius: 0, borderWidth: 2 });
    derivDatasets.push({ label: 'Sigmoid\'', data: xs.map(x => sigmoidDeriv(x)), borderColor: colors.sigmoid, backgroundColor: 'transparent', pointRadius: 0, borderWidth: 2 });
  }
  if (showRelu) {
    datasets.push({ label: 'ReLU', data: xs.map(x => relu(x)), borderColor: colors.relu, backgroundColor: 'transparent', pointRadius: 0, borderWidth: 2 });
    derivDatasets.push({ label: 'ReLU\'', data: xs.map(x => reluDeriv(x)), borderColor: colors.relu, backgroundColor: 'transparent', pointRadius: 0, borderWidth: 2 });
  }
  if (showTanh) {
    datasets.push({ label: 'Tanh', data: xs.map(x => tanhAct(x)), borderColor: colors.tanh, backgroundColor: 'transparent', pointRadius: 0, borderWidth: 2 });
    derivDatasets.push({ label: 'Tanh\'', data: xs.map(x => tanhDeriv(x)), borderColor: colors.tanh, backgroundColor: 'transparent', pointRadius: 0, borderWidth: 2 });
  }
  if (showStep) {
    datasets.push({ label: 'Step', data: xs.map(x => step(x)), borderColor: colors.step, backgroundColor: 'transparent', pointRadius: 0, borderWidth: 2, borderDash: [5, 3] });
    derivDatasets.push({ label: 'Step\'', data: xs.map(x => stepDeriv(x)), borderColor: colors.step, backgroundColor: 'transparent', pointRadius: 0, borderWidth: 2, borderDash: [5, 3] });
  }

  // Add vertical indicator line for current x
  const vertLine = {
    id: 'vertLine',
    afterDraw(chart) {
      const xScale = chart.scales.x;
      const yScale = chart.scales.y;
      const idx = xs.findIndex(v => Math.abs(v - xVal) < 0.05);
      if (idx < 0) return;
      const xPixel = xScale.getPixelForValue(idx);
      const ctx = chart.ctx;
      ctx.save();
      ctx.strokeStyle = '#94a3b8';
      ctx.lineWidth = 1;
      ctx.setLineDash([4, 4]);
      ctx.beginPath();
      ctx.moveTo(xPixel, yScale.top);
      ctx.lineTo(xPixel, yScale.bottom);
      ctx.stroke();
      ctx.restore();
    }
  };

  const labels = xs.map(x => x.toFixed(1));
  const chartOpts = {
    responsive: true, maintainAspectRatio: false, animation: false,
    plugins: { legend: { position: 'top', labels: { font: { family: "'Paperlogy'", size: 11 }, boxWidth: 20 } } },
    scales: {
      x: { type: 'category', ticks: { callback: (_, i) => i % 10 === 0 ? xs[i] : '', font: { size: 10 } } },
      y: { beginAtZero: false, ticks: { font: { size: 10 } } }
    }
  };

  // Function chart
  const funcCanvas = document.getElementById('act-func-chart');
  if (actFuncChart) actFuncChart.destroy();
  actFuncChart = new ChartJS(funcCanvas, {
    type: 'line', data: { labels, datasets }, options: chartOpts, plugins: [vertLine]
  });

  // Derivative chart
  const derivCanvas = document.getElementById('act-deriv-chart');
  if (actDerivChart) actDerivChart.destroy();
  actDerivChart = new ChartJS(derivCanvas, {
    type: 'line', data: { labels, datasets: derivDatasets }, options: chartOpts, plugins: [vertLine]
  });

  // Update stat boxes
  const el = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };
  el('stat-sigmoid', sigmoid(xVal).toFixed(4));
  el('stat-relu', relu(xVal).toFixed(4));
  el('stat-tanh', tanhAct(xVal).toFixed(4));
  el('stat-step', step(xVal).toString());
}

function setupActivationExplorer() {
  const xSlider = document.getElementById('slider-act-x');
  if (!xSlider) return;
  xSlider.addEventListener('input', () => {
    document.getElementById('act-x-val').textContent = parseFloat(xSlider.value).toFixed(1);
    drawActivationCharts();
  });

  ['chk-sigmoid', 'chk-relu', 'chk-tanh', 'chk-step'].forEach(id => {
    document.getElementById(id)?.addEventListener('change', drawActivationCharts);
  });

  drawActivationCharts();
}

// ==================== INTERACTIVE 3: GRADIENT DESCENT VISUALIZER ====================
let gdStartPoint = null;
let gdPath = [];
let gdAnimFrame = null;
let gdRunning = false;

// Loss surface: L(w1, w2) with minimum at (2, -1)
function gdLoss(w1, w2) {
  return 0.5 * ((w1 - 2) * (w1 - 2)) + 1.5 * ((w2 + 1) * (w2 + 1)) + 0.3 * (w1 - 2) * (w2 + 1);
}
function gdGrad(w1, w2) {
  const dw1 = (w1 - 2) + 0.3 * (w2 + 1);
  const dw2 = 3 * (w2 + 1) + 0.3 * (w1 - 2);
  return [dw1, dw2];
}

function drawGDCanvas() {
  const canvas = document.getElementById('gd-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const wMin = -3, wMax = 7;
  function toX(w) { return (w - wMin) / (wMax - wMin) * W; }
  function toY(w) { return (1 - (w - wMin) / (wMax - wMin)) * H; }
  function fromX(px) { return wMin + px / W * (wMax - wMin); }
  function fromY(py) { return wMax - py / H * (wMax - wMin); }

  // Draw contour plot
  const maxLoss = 40;
  const contourLevels = [0.5, 1, 2, 4, 8, 12, 18, 25, 35];

  // Background heatmap
  const imgData = ctx.createImageData(W, H);
  for (let py = 0; py < H; py++) {
    for (let px = 0; px < W; px++) {
      const w1 = fromX(px);
      const w2 = fromY(py);
      const L = gdLoss(w1, w2);
      const t = Math.min(1, L / maxLoss);
      const r = Math.round(255 * t);
      const g = Math.round(255 * (1 - t * 0.7));
      const b = Math.round(255 * (1 - t));
      const idx = (py * W + px) * 4;
      imgData.data[idx] = r;
      imgData.data[idx + 1] = g;
      imgData.data[idx + 2] = b;
      imgData.data[idx + 3] = 60;
    }
  }
  ctx.putImageData(imgData, 0, 0);

  // Draw contour lines
  ctx.strokeStyle = '#475569';
  ctx.lineWidth = 0.8;
  const step = 2;
  contourLevels.forEach(level => {
    for (let py = 0; py < H; py += step) {
      for (let px = 0; px < W; px += step) {
        const w1 = fromX(px);
        const w2 = fromY(py);
        const w1r = fromX(px + step);
        const w2d = fromY(py + step);
        const v00 = gdLoss(w1, w2);
        const v10 = gdLoss(w1r, w2);
        const v01 = gdLoss(w1, w2d);
        if ((v00 - level) * (v10 - level) < 0 || (v00 - level) * (v01 - level) < 0) {
          ctx.fillStyle = 'rgba(71, 85, 105, 0.4)';
          ctx.fillRect(px, py, 1, 1);
        }
      }
    }
  });

  // Draw minimum point marker
  ctx.beginPath();
  ctx.arc(toX(2), toY(-1), 6, 0, 2 * Math.PI);
  ctx.fillStyle = '#22c55e';
  ctx.fill();
  ctx.strokeStyle = '#fff';
  ctx.lineWidth = 2;
  ctx.stroke();

  // Axis labels
  ctx.fillStyle = '#475569';
  ctx.font = '12px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('w1', W / 2, H - 5);
  ctx.save();
  ctx.translate(12, H / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillText('w2', 0, 0);
  ctx.restore();

  // Draw path
  if (gdPath.length > 1) {
    ctx.strokeStyle = '#ef4444';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(toX(gdPath[0][0]), toY(gdPath[0][1]));
    for (let i = 1; i < gdPath.length; i++) {
      ctx.lineTo(toX(gdPath[i][0]), toY(gdPath[i][1]));
    }
    ctx.stroke();

    // Draw dots along path
    gdPath.forEach((p, i) => {
      ctx.beginPath();
      ctx.arc(toX(p[0]), toY(p[1]), i === gdPath.length - 1 ? 5 : 3, 0, 2 * Math.PI);
      ctx.fillStyle = i === gdPath.length - 1 ? '#ef4444' : '#f87171';
      ctx.fill();
    });
  }

  // Draw start point
  if (gdStartPoint && gdPath.length <= 1) {
    ctx.beginPath();
    ctx.arc(toX(gdStartPoint[0]), toY(gdStartPoint[1]), 6, 0, 2 * Math.PI);
    ctx.fillStyle = '#2563eb';
    ctx.fill();
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 2;
    ctx.stroke();
  }

  // Update stats
  if (gdPath.length > 0) {
    const last = gdPath[gdPath.length - 1];
    const el = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };
    el('gd-loss', gdLoss(last[0], last[1]).toFixed(4));
    el('gd-steps', (gdPath.length - 1).toString());
    el('gd-w1', last[0].toFixed(3));
    el('gd-w2', last[1].toFixed(3));
  }
}

function setupGradientDescent() {
  const canvas = document.getElementById('gd-canvas');
  if (!canvas) return;

  const wMin = -3, wMax = 7;
  function fromX(px) { return wMin + px / canvas.width * (wMax - wMin); }
  function fromY(py) { return wMax - py / canvas.height * (wMax - wMin); }

  canvas.addEventListener('click', (e) => {
    if (gdRunning) return;
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    const px = (e.clientX - rect.left) * scaleX;
    const py = (e.clientY - rect.top) * scaleY;
    gdStartPoint = [fromX(px), fromY(py)];
    gdPath = [gdStartPoint.slice()];
    drawGDCanvas();
  });

  const lrSlider = document.getElementById('slider-lr');
  lrSlider?.addEventListener('input', () => {
    document.getElementById('lr-val').textContent = parseFloat(lrSlider.value).toFixed(3);
  });

  document.getElementById('btn-gd-run')?.addEventListener('click', () => {
    if (gdRunning || !gdStartPoint) return;
    if (gdPath.length <= 1) gdPath = [gdStartPoint.slice()];
    gdRunning = true;
    const lr = parseFloat(document.getElementById('slider-lr')?.value || '0.05');
    let stepCount = 0;
    const maxSteps = 200;

    function gdStep() {
      if (!gdRunning || stepCount >= maxSteps) {
        gdRunning = false;
        return;
      }
      const current = gdPath[gdPath.length - 1];
      const [dw1, dw2] = gdGrad(current[0], current[1]);
      const newW1 = current[0] - lr * dw1;
      const newW2 = current[1] - lr * dw2;

      // Stop if out of bounds or converged
      if (newW1 < -3 || newW1 > 7 || newW2 < -3 || newW2 > 7) {
        gdRunning = false;
        drawGDCanvas();
        return;
      }
      if (Math.abs(dw1) < 0.0001 && Math.abs(dw2) < 0.0001) {
        gdRunning = false;
        drawGDCanvas();
        return;
      }

      gdPath.push([newW1, newW2]);
      stepCount++;
      drawGDCanvas();
      gdAnimFrame = requestAnimationFrame(gdStep);
    }
    gdStep();
  });

  document.getElementById('btn-gd-reset')?.addEventListener('click', () => {
    gdRunning = false;
    if (gdAnimFrame) cancelAnimationFrame(gdAnimFrame);
    gdStartPoint = null;
    gdPath = [];
    const el = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };
    el('gd-loss', '-');
    el('gd-steps', '0');
    el('gd-w1', '-');
    el('gd-w2', '-');
    drawGDCanvas();
  });

  drawGDCanvas();
}

// ==================== INTERACTIVE 4: XOR NETWORK ====================
let xorNet = null;
let xorLossChart = null;
let xorTraining = false;
let xorAnimFrame = null;

function drawXORBoundary() {
  const canvas = document.getElementById('xor-boundary-canvas');
  if (!canvas || !xorNet) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const pad = 30;
  const plotW = W - 2 * pad;
  const plotH = H - 2 * pad;

  // Draw decision boundary heatmap
  const res = 3;
  for (let px = pad; px < W - pad; px += res) {
    for (let py = pad; py < H - pad; py += res) {
      const x1 = (px - pad) / plotW * 2 - 0.5;
      const x2 = 1.5 - (py - pad) / plotH * 2;
      const out = xorNet.forward([x1, x2]);
      const r = Math.round(239 * out + 37 * (1 - out));
      const g = Math.round(68 * out + 99 * (1 - out));
      const b = Math.round(68 * out + 235 * (1 - out));
      ctx.fillStyle = `rgba(${r}, ${g}, ${b}, 0.25)`;
      ctx.fillRect(px, py, res, res);
    }
  }

  // Draw data points
  function toX(v) { return pad + (v + 0.5) / 2 * plotW; }
  function toY(v) { return H - pad - (v + 0.5) / 2 * plotH; }

  DATA_XOR.forEach(d => {
    ctx.beginPath();
    ctx.arc(toX(d.x[0]), toY(d.x[1]), 12, 0, 2 * Math.PI);
    ctx.fillStyle = d.y === 1 ? '#ef4444' : '#2563eb';
    ctx.fill();
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 2;
    ctx.stroke();
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 11px Paperlogy, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(d.y.toString(), toX(d.x[0]), toY(d.x[1]));
  });

  // Axes
  ctx.strokeStyle = '#94a3b8';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(pad, H - pad);
  ctx.lineTo(W - pad, H - pad);
  ctx.moveTo(pad, pad);
  ctx.lineTo(pad, H - pad);
  ctx.stroke();

  ctx.fillStyle = '#475569';
  ctx.font = '11px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('x1', W / 2, H - 8);
  ctx.save();
  ctx.translate(10, H / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillText('x2', 0, 0);
  ctx.restore();
}

async function setupXORTraining() {
  await loadChart();

  xorNet = new SimpleNetwork(2, 4, 1);
  drawXORBoundary();

  const lrSlider = document.getElementById('slider-xor-lr');
  lrSlider?.addEventListener('input', () => {
    document.getElementById('xor-lr-val').textContent = parseFloat(lrSlider.value).toFixed(1);
  });

  document.getElementById('btn-xor-train')?.addEventListener('click', () => {
    if (xorTraining) return;
    xorTraining = true;
    const lr = parseFloat(lrSlider?.value || '2.0');
    let epoch = 0;
    const maxEpochs = 1500;
    const lossHistory = [];

    function trainStep() {
      if (!xorTraining || epoch >= maxEpochs) {
        xorTraining = false;
        return;
      }

      // Train 10 epochs per frame for speed
      for (let i = 0; i < 10 && epoch < maxEpochs; i++) {
        let totalLoss = 0;
        DATA_XOR.forEach(d => {
          const out = xorNet.forward(d.x);
          const eps = 1e-7;
          totalLoss += -(d.y * Math.log(out + eps) + (1 - d.y) * Math.log(1 - out + eps));
          xorNet.backward(d.x, d.y, lr);
        });
        lossHistory.push(totalLoss / 4);
        epoch++;
      }

      // Compute accuracy
      let correct = 0;
      DATA_XOR.forEach(d => {
        if (xorNet.predict(d.x) === d.y) correct++;
      });
      const acc = Math.round(correct / 4 * 100);
      const lastLoss = lossHistory[lossHistory.length - 1];

      const el = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };
      el('xor-epoch', epoch.toString());
      el('xor-loss', lastLoss.toFixed(4));
      el('xor-acc', acc + '%');

      drawXORBoundary();
      updateXORLossChart(lossHistory);

      if (acc === 100 && lastLoss < 0.05) {
        xorTraining = false;
        return;
      }
      xorAnimFrame = requestAnimationFrame(trainStep);
    }
    trainStep();
  });

  document.getElementById('btn-xor-reset')?.addEventListener('click', () => {
    xorTraining = false;
    if (xorAnimFrame) cancelAnimationFrame(xorAnimFrame);
    xorNet = new SimpleNetwork(2, 4, 1);
    const el = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };
    el('xor-epoch', '0');
    el('xor-loss', '-');
    el('xor-acc', '-');
    if (xorLossChart) { xorLossChart.destroy(); xorLossChart = null; }
    drawXORBoundary();
  });
}

function updateXORLossChart(history) {
  const canvas = document.getElementById('xor-loss-chart');
  if (!canvas || !ChartJS) return;

  // Subsample for performance
  const maxPoints = 200;
  let data, labels;
  if (history.length <= maxPoints) {
    data = history;
    labels = history.map((_, i) => i);
  } else {
    const stride = Math.ceil(history.length / maxPoints);
    data = history.filter((_, i) => i % stride === 0);
    labels = data.map((_, i) => i * stride);
  }

  if (xorLossChart) {
    xorLossChart.data.labels = labels;
    xorLossChart.data.datasets[0].data = data;
    xorLossChart.update('none');
  } else {
    xorLossChart = new ChartJS(canvas, {
      type: 'line',
      data: { labels, datasets: [{ label: '손실', data, borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.1)', fill: true, pointRadius: 0, borderWidth: 2 }] },
      options: {
        responsive: true, maintainAspectRatio: false, animation: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { title: { display: true, text: '에포크', font: { family: "'Paperlogy'" } }, ticks: { maxTicksLimit: 6, font: { size: 10 } } },
          y: { title: { display: true, text: '손실', font: { family: "'Paperlogy'" } }, beginAtZero: true, ticks: { font: { size: 10 } } }
        }
      }
    });
  }
}

// ==================== INTERACTIVE 5: FULL NN CLASSIFICATION ====================
let nnNet = null;
let nnData = [];
let nnLossChart = null;
let nnTraining = false;
let nnAnimFrame = null;

function drawNNBoundary() {
  const canvas = document.getElementById('nn-boundary-canvas');
  if (!canvas || !nnNet) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const pad = 20;
  const plotW = W - 2 * pad;
  const plotH = H - 2 * pad;

  // Determine data range
  let xMin = -4, xMax = 4, yMin = -4, yMax = 4;

  // Draw decision boundary heatmap
  const res = 4;
  for (let px = pad; px < W - pad; px += res) {
    for (let py = pad; py < H - pad; py += res) {
      const x1 = xMin + (px - pad) / plotW * (xMax - xMin);
      const x2 = yMax - (py - pad) / plotH * (yMax - yMin);
      const out = nnNet.forward([x1, x2]);
      const r = Math.round(239 * out + 37 * (1 - out));
      const g = Math.round(68 * out + 99 * (1 - out));
      const b = Math.round(68 * out + 235 * (1 - out));
      ctx.fillStyle = `rgba(${r}, ${g}, ${b}, 0.3)`;
      ctx.fillRect(px, py, res, res);
    }
  }

  // Draw data points
  function toX(v) { return pad + (v - xMin) / (xMax - xMin) * plotW; }
  function toY(v) { return H - pad - (v - yMin) / (yMax - yMin) * plotH; }

  nnData.forEach(d => {
    ctx.beginPath();
    ctx.arc(toX(d.x[0]), toY(d.x[1]), 4, 0, 2 * Math.PI);
    ctx.fillStyle = d.y === 1 ? '#ef4444' : '#2563eb';
    ctx.fill();
  });
}

function updateNNLossChart(history) {
  const canvas = document.getElementById('nn-loss-chart');
  if (!canvas || !ChartJS) return;

  const maxPoints = 200;
  let data, labels;
  if (history.length <= maxPoints) {
    data = history;
    labels = history.map((_, i) => i);
  } else {
    const stride = Math.ceil(history.length / maxPoints);
    data = history.filter((_, i) => i % stride === 0);
    labels = data.map((_, i) => i * stride);
  }

  if (nnLossChart) {
    nnLossChart.data.labels = labels;
    nnLossChart.data.datasets[0].data = data;
    nnLossChart.update('none');
  } else {
    nnLossChart = new ChartJS(canvas, {
      type: 'line',
      data: { labels, datasets: [{ label: '손실', data, borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.1)', fill: true, pointRadius: 0, borderWidth: 2 }] },
      options: {
        responsive: true, maintainAspectRatio: false, animation: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { title: { display: true, text: '에포크', font: { family: "'Paperlogy'" } }, ticks: { maxTicksLimit: 6, font: { size: 10 } } },
          y: { title: { display: true, text: '손실', font: { family: "'Paperlogy'" } }, beginAtZero: true, ticks: { font: { size: 10 } } }
        }
      }
    });
  }
}

async function setupNNClassification() {
  await loadChart();

  function createNet() {
    const hidden = parseInt(document.getElementById('sel-hidden')?.value || '4');
    nnNet = new SimpleNetwork(2, hidden, 1);
    document.getElementById('nn-hidden').textContent = hidden.toString();
  }

  function createData() {
    const type = document.getElementById('sel-dataset')?.value || 'clusters';
    if (type === 'spiral') {
      nnData = generateSpiral(200);
    } else {
      nnData = generateClusters(200);
    }
  }

  createData();
  createNet();
  drawNNBoundary();

  const lrSlider = document.getElementById('slider-nn-lr');
  lrSlider?.addEventListener('input', () => {
    document.getElementById('nn-lr-val').textContent = parseFloat(lrSlider.value).toFixed(2);
  });

  document.getElementById('btn-nn-train')?.addEventListener('click', () => {
    if (nnTraining) return;
    nnTraining = true;
    const lr = parseFloat(lrSlider?.value || '0.5');
    let epoch = 0;
    const maxEpochs = 500;
    const lossHistory = [];

    function trainStep() {
      if (!nnTraining || epoch >= maxEpochs) {
        nnTraining = false;
        return;
      }

      // Train multiple epochs per frame
      for (let i = 0; i < 5 && epoch < maxEpochs; i++) {
        let totalLoss = 0;
        // Shuffle data each epoch
        const shuffled = [...nnData].sort(() => Math.random() - 0.5);
        shuffled.forEach(d => {
          const out = nnNet.forward(d.x);
          const eps = 1e-7;
          totalLoss += -(d.y * Math.log(out + eps) + (1 - d.y) * Math.log(1 - out + eps));
          nnNet.backward(d.x, d.y, lr / nnData.length * 10);
        });
        lossHistory.push(totalLoss / nnData.length);
        epoch++;
      }

      // Compute accuracy
      let correct = 0;
      nnData.forEach(d => { if (nnNet.predict(d.x) === d.y) correct++; });
      const acc = Math.round(correct / nnData.length * 100);
      const lastLoss = lossHistory[lossHistory.length - 1];

      const el = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };
      el('nn-epoch', epoch.toString());
      el('nn-loss', lastLoss.toFixed(4));
      el('nn-acc', acc + '%');

      drawNNBoundary();
      updateNNLossChart(lossHistory);
      nnAnimFrame = requestAnimationFrame(trainStep);
    }
    trainStep();
  });

  document.getElementById('btn-nn-reset')?.addEventListener('click', () => {
    nnTraining = false;
    if (nnAnimFrame) cancelAnimationFrame(nnAnimFrame);
    createData();
    createNet();
    const el = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };
    el('nn-epoch', '0');
    el('nn-loss', '-');
    el('nn-acc', '-');
    if (nnLossChart) { nnLossChart.destroy(); nnLossChart = null; }
    drawNNBoundary();
  });

  document.getElementById('sel-hidden')?.addEventListener('change', () => {
    if (!nnTraining) { createNet(); drawNNBoundary(); }
  });

  document.getElementById('sel-dataset')?.addEventListener('change', () => {
    if (!nnTraining) {
      createData();
      createNet();
      if (nnLossChart) { nnLossChart.destroy(); nnLossChart = null; }
      const el = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };
      el('nn-epoch', '0');
      el('nn-loss', '-');
      el('nn-acc', '-');
      drawNNBoundary();
    }
  });
}

