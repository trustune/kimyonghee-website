---
import TextbookLayout from '../../layouts/TextbookLayout.astro';
import ExplainBox from '../../components/textbook/ExplainBox.astro';
import InsightBox from '../../components/textbook/InsightBox.astro';
import FormulaBox from '../../components/textbook/FormulaBox.astro';
import WarningBox from '../../components/textbook/WarningBox.astro';
import ExerciseBox from '../../components/textbook/ExerciseBox.astro';
import BusinessBox from '../../components/textbook/BusinessBox.astro';
import ConclusionBox from '../../components/textbook/ConclusionBox.astro';
import StatBox from '../../components/textbook/StatBox.astro';
import ChartContainer from '../../components/textbook/ChartContainer.astro';
import SimControls from '../../components/textbook/SimControls.astro';
---

<TextbookLayout
  title="연관규칙과 추천시스템"
  subtitle="'이 상품도 샀습니다'"
  chapterNum={30}
  part={5}
>

  <!-- ===== SECTION 1: HOOK ===== -->
  <div class="tb-card">
    <h2>아마존 매출의 35%는 추천에서 나온다</h2>
    <p>
      온라인 쇼핑에서 "이 상품을 구매한 고객이 함께 구매한 상품", 넷플릭스의 "당신이 좋아할 만한 콘텐츠" --
      이 추천은 어떻게 만들어질까요?
    </p>
    <p style="margin-top: 12px;">
      이 장에서는 두 가지 핵심 기법을 배웁니다.
      <strong>연관규칙(Association Rules)</strong>은 "A를 사면 B도 산다"는 패턴을 찾고,
      <strong>협업 필터링(Collaborative Filtering)</strong>은 "나와 취향이 비슷한 사람이 좋아하는 것"을 추천합니다.
    </p>

    <BusinessBox>
      <strong>비즈니스 임팩트:</strong>
      넷플릭스 시청의 80%가 추천에서 시작됩니다.
      편의점의 상품 배치는 연관규칙 분석 결과를 반영합니다.
      "맥주 옆에 기저귀"라는 유명한 이야기도 장바구니 분석에서 나왔습니다.
    </BusinessBox>
  </div>

  <!-- ===== SECTION 2: 연관규칙 이론 ===== -->
  <div class="tb-card">
    <h2>연관규칙의 세 가지 핵심 지표</h2>
    <p>
      연관규칙은 트랜잭션(거래) 데이터에서 "함께 구매되는 패턴"을 찾습니다.
      규칙의 유용성을 평가하는 세 가지 지표가 있습니다.
    </p>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin:14px 0;">
      <div style="background:var(--tb-primary-light);padding:16px;border-radius:var(--tb-radius);text-align:center;">
        <h3 style="color:var(--tb-primary);font-size:1rem;">지지도 (Support)</h3>
        <p style="font-size:.85rem;margin-top:6px;">A와 B가 함께 나타나는 거래 비율</p>
        <div class="tb-formula" style="font-size:.9rem;padding:10px;">
          P(A <span class="hl">and</span> B)
        </div>
      </div>
      <div style="background:#f0fdf4;padding:16px;border-radius:var(--tb-radius);text-align:center;">
        <h3 style="color:var(--tb-success);font-size:1rem;">신뢰도 (Confidence)</h3>
        <p style="font-size:.85rem;margin-top:6px;">A를 산 사람 중 B도 산 비율</p>
        <div class="tb-formula" style="font-size:.9rem;padding:10px;">
          P(B <span class="hl">|</span> A) = P(A,B) / P(A)
        </div>
      </div>
      <div style="background:#fef3c7;padding:16px;border-radius:var(--tb-radius);text-align:center;">
        <h3 style="color:var(--tb-warning);font-size:1rem;">향상도 (Lift)</h3>
        <p style="font-size:.85rem;margin-top:6px;">독립일 때보다 얼마나 더 함께 나타나는가</p>
        <div class="tb-formula" style="font-size:.9rem;padding:10px;">
          P(A,B) / (<span class="hl">P(A) * P(B)</span>)
        </div>
      </div>
    </div>

    <ExplainBox>
      <strong>해석:</strong>
      Lift = 1이면 A와 B는 독립 (관계 없음).
      Lift &gt; 1이면 양의 연관 (함께 사는 경향).
      Lift &lt; 1이면 음의 연관 (하나를 사면 다른 건 안 사는 경향).
      실무에서는 지지도 &gt; 1%, 신뢰도 &gt; 30%, Lift &gt; 1.5를 임계값으로 사용하는 경우가 많습니다.
    </ExplainBox>
  </div>

  <!-- ===== SECTION 3: 인터랙티브 1 - 장바구니 분석 ===== -->
  <div class="tb-card">
    <h2>실습 1: 편의점 장바구니 분석</h2>
    <p>
      한국 편의점 영수증 200건을 분석합니다.
      지지도와 신뢰도 슬라이더를 조절하면 규칙이 나타나거나 사라집니다.
      네트워크 그래프에서 상품 간 관계를 시각적으로 확인하세요.
    </p>

    <ExerciseBox>
      <strong>해보기:</strong>
      (1) "데이터 생성"으로 영수증 데이터를 생성하세요.
      (2) 지지도와 신뢰도 슬라이더를 조절해보세요.
      (3) 네트워크 그래프에서 허브 상품(연결이 많은 상품)을 찾으세요.
    </ExerciseBox>

    <SimControls>
      <button class="tb-btn tb-btn-primary" id="btn-basket-gen">데이터 생성</button>
      <label>최소 지지도:</label>
      <input type="range" id="slider-support" min="1" max="20" value="5" style="width:150px;">
      <span class="tb-speed-label" id="label-support">5%</span>
      <label>최소 신뢰도:</label>
      <input type="range" id="slider-confidence" min="10" max="80" value="30" style="width:150px;">
      <span class="tb-speed-label" id="label-confidence">30%</span>
    </SimControls>

    <canvas id="canvas-basket" width="700" height="450" style="width:100%;border:1px solid var(--tb-g200);border-radius:var(--tb-radius);background:#fff;"></canvas>

    <div id="basket-rules" style="display:none;margin-top:14px;">
      <div class="tb-stat-row">
        <StatBox label="총 영수증" id="stat-basket-total" />
        <StatBox label="발견된 규칙" id="stat-basket-rules" />
        <StatBox label="최고 Lift" id="stat-basket-lift" />
      </div>
      <div class="tb-data-table-wrap" style="max-height:200px;margin-top:14px;">
        <table class="tb-data-table" id="rules-table">
          <thead>
            <tr><th>규칙</th><th>지지도</th><th>신뢰도</th><th>Lift</th></tr>
          </thead>
          <tbody id="rules-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ===== SECTION 4: 인터랙티브 2 - 수동 계산기 ===== -->
  <div class="tb-card">
    <h2>실습 2: Support / Confidence / Lift 직접 계산</h2>
    <p>
      전체 거래 수와 각 항목의 거래 수를 입력하면
      세 가지 지표를 자동 계산합니다. 벤 다이어그램으로 시각적으로 확인하세요.
    </p>

    <ExerciseBox>
      <strong>해보기:</strong>
      숫자를 바꿔가며 세 지표가 어떻게 변하는지 관찰하세요.
      Lift가 1보다 크면 함께 사는 경향, 1이면 독립입니다.
    </ExerciseBox>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin:14px 0;">
      <div>
        <div class="tb-controls" style="flex-direction:column;align-items:stretch;gap:10px;">
          <div>
            <label style="font-weight:700;font-size:.88rem;">전체 거래 수 (N):</label>
            <input type="number" id="calc-n" value="1000" min="10" max="10000" style="padding:6px 10px;border:2px solid var(--tb-g300);border-radius:8px;width:100px;font-family:var(--tb-font);">
          </div>
          <div>
            <label style="font-weight:700;font-size:.88rem;">A를 포함한 거래:</label>
            <input type="number" id="calc-a" value="300" min="1" max="10000" style="padding:6px 10px;border:2px solid var(--tb-g300);border-radius:8px;width:100px;font-family:var(--tb-font);">
          </div>
          <div>
            <label style="font-weight:700;font-size:.88rem;">B를 포함한 거래:</label>
            <input type="number" id="calc-b" value="400" min="1" max="10000" style="padding:6px 10px;border:2px solid var(--tb-g300);border-radius:8px;width:100px;font-family:var(--tb-font);">
          </div>
          <div>
            <label style="font-weight:700;font-size:.88rem;">A와 B 모두 포함:</label>
            <input type="number" id="calc-ab" value="150" min="0" max="10000" style="padding:6px 10px;border:2px solid var(--tb-g300);border-radius:8px;width:100px;font-family:var(--tb-font);">
          </div>
          <button class="tb-btn tb-btn-primary" id="btn-calc" style="margin-top:8px;">계산</button>
        </div>
      </div>
      <div>
        <canvas id="canvas-venn" width="300" height="250" style="width:100%;border:1px solid var(--tb-g200);border-radius:var(--tb-radius);background:#fff;"></canvas>
      </div>
    </div>

    <div class="tb-stat-row" id="calc-result" style="display:none;">
      <StatBox label="Support" id="stat-calc-support" />
      <StatBox label="Confidence (A->B)" id="stat-calc-conf" />
      <StatBox label="Lift" id="stat-calc-lift" />
      <StatBox label="해석" id="stat-calc-interp" />
    </div>
  </div>

  <!-- ===== SECTION 5: 협업 필터링 이론 ===== -->
  <div class="tb-card">
    <h2>협업 필터링: 취향이 비슷한 사람 찾기</h2>
    <p>
      연관규칙은 상품 간 관계를 찾지만, <strong>협업 필터링(Collaborative Filtering)</strong>은
      <strong>사용자 간 유사도</strong>를 기반으로 추천합니다.
    </p>

    <ExplainBox>
      <strong>비유:</strong> 친구 A가 나와 영화 취향이 90% 일치합니다.
      A가 재미있게 본 영화 중 내가 아직 안 본 것이 있다면?
      높은 확률로 나도 좋아할 것입니다.
      이것이 <strong>사용자 기반 협업 필터링</strong>의 핵심입니다.
    </ExplainBox>

    <FormulaBox>
      사용자 유사도 (코사인): <span class="hl">sim(u,v) = sum(r_u * r_v) / (||r_u|| * ||r_v||)</span><br>
      예측 평점 = 유사 사용자들의 <span class="res">가중 평균</span>
    </FormulaBox>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:14px 0;">
      <div style="background:var(--tb-primary-light);padding:16px;border-radius:var(--tb-radius);">
        <h3 style="color:var(--tb-primary);margin-bottom:6px;">사용자 기반 (User-based)</h3>
        <p style="font-size:.85rem;">"나와 취향이 비슷한 <strong>사용자</strong>가 좋아하는 것을 추천"</p>
        <p style="font-size:.82rem;color:var(--tb-g600);margin-top:6px;">장점: 직관적. 단점: 사용자 수가 많으면 느림.</p>
      </div>
      <div style="background:#f0fdf4;padding:16px;border-radius:var(--tb-radius);">
        <h3 style="color:var(--tb-success);margin-bottom:6px;">아이템 기반 (Item-based)</h3>
        <p style="font-size:.85rem;">"내가 좋아한 것과 비슷한 <strong>아이템</strong>을 추천"</p>
        <p style="font-size:.82rem;color:var(--tb-g600);margin-top:6px;">장점: 안정적, 확장 가능. 아마존이 사용.</p>
      </div>
    </div>
  </div>

  <!-- ===== SECTION 6: 인터랙티브 3 - 협업 필터링 ===== -->
  <div class="tb-card">
    <h2>실습 3: 영화 추천 시스템</h2>
    <p>
      20편의 한국 영화가 있습니다. 5편에 별점을 매기면
      시스템이 유사 사용자를 찾아 나머지 영화의 예측 평점을 계산합니다.
    </p>

    <ExerciseBox>
      <strong>해보기:</strong>
      (1) 5편의 영화에 별점(1-5)을 매기세요.
      (2) "추천 받기"를 누르면 유사 사용자를 찾고 추천합니다.
      (3) 별점을 바꿔서 추천이 어떻게 달라지는지 확인하세요.
    </ExerciseBox>

    <div id="movie-rating-panel">
      <div style="font-weight:700;margin-bottom:10px;">별점을 매겨주세요 (5편 이상):</div>
      <div id="movie-list" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;"></div>
    </div>

    <SimControls>
      <button class="tb-btn tb-btn-primary" id="btn-recommend">추천 받기</button>
      <button class="tb-btn tb-btn-danger" id="btn-reset-ratings">초기화</button>
    </SimControls>

    <div id="recommend-result" style="display:none;margin-top:14px;">
      <div style="font-weight:700;margin-bottom:10px;">당신을 위한 추천 영화 (예측 평점순):</div>
      <div id="recommend-list" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;"></div>

      <div class="tb-explain" style="margin-top:14px;">
        <strong>유사 사용자:</strong>
        <span id="similar-users-info"></span>
      </div>
    </div>
  </div>

  <!-- ===== SECTION 7: 인터랙티브 4 - 콘텐츠 vs 협업 비교 ===== -->
  <div class="tb-card">
    <h2>실습 4: 콘텐츠 기반 vs 협업 필터링 비교</h2>
    <p>
      같은 사용자에 대해 두 방식의 추천 결과를 나란히 비교합니다.
      콘텐츠 기반은 <strong>영화 장르</strong>를, 협업은 <strong>다른 사용자 평점</strong>을 사용합니다.
    </p>

    <ExerciseBox>
      <strong>해보기:</strong>
      (1) 두 방식을 토글하며 추천 결과를 비교하세요.
      (2) 콜드 스타트 문제: 새 사용자에게는 어떤 방식이 유리할까요?
    </ExerciseBox>

    <SimControls>
      <button class="tb-btn tb-btn-primary" id="btn-content-rec">콘텐츠 기반 추천</button>
      <button class="tb-btn tb-btn-success" id="btn-collab-rec">협업 필터링 추천</button>
    </SimControls>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:14px;">
      <div>
        <div style="text-align:center;font-weight:700;margin-bottom:8px;color:var(--tb-primary);">콘텐츠 기반</div>
        <div id="content-rec-list" class="rec-panel" style="min-height:200px;background:var(--tb-g100);border-radius:var(--tb-radius);padding:14px;">
          <div style="color:var(--tb-g600);font-size:.88rem;">먼저 위에서 별점을 매기고 추천을 실행하세요.</div>
        </div>
      </div>
      <div>
        <div style="text-align:center;font-weight:700;margin-bottom:8px;color:var(--tb-success);">협업 필터링</div>
        <div id="collab-rec-list" class="rec-panel" style="min-height:200px;background:var(--tb-g100);border-radius:var(--tb-radius);padding:14px;">
          <div style="color:var(--tb-g600);font-size:.88rem;">먼저 위에서 별점을 매기고 추천을 실행하세요.</div>
        </div>
      </div>
    </div>

    <div id="cold-start-msg" style="display:none;" class="tb-warning-box" style="margin-top:14px;"></div>

    <WarningBox>
      <strong>콜드 스타트 문제:</strong>
      협업 필터링은 평점 데이터가 없는 신규 사용자/신규 아이템에 무력합니다.
      콘텐츠 기반은 아이템 속성만 있으면 추천 가능합니다.
      실무에서는 두 방식을 결합한 <strong>하이브리드 추천</strong>을 사용합니다.
    </WarningBox>
  </div>

  <!-- ===== SECTION 8: 추천 시스템의 발전 ===== -->
  <div class="tb-card">
    <h2>추천 시스템의 진화</h2>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:14px 0;">
      <div style="background:var(--tb-primary-light);padding:14px;border-radius:var(--tb-radius);">
        <h3 style="color:var(--tb-primary);font-size:.95rem;margin-bottom:6px;">1세대: 규칙 기반</h3>
        <p style="font-size:.82rem;">연관규칙, 인기 순위. 단순하지만 개인화 부족.</p>
      </div>
      <div style="background:#f0fdf4;padding:14px;border-radius:var(--tb-radius);">
        <h3 style="color:var(--tb-success);font-size:.95rem;margin-bottom:6px;">2세대: 협업 필터링</h3>
        <p style="font-size:.82rem;">행렬 분해(SVD), ALS. 넷플릭스 프라이즈 우승 기법.</p>
      </div>
      <div style="background:#fdf4ff;padding:14px;border-radius:var(--tb-radius);">
        <h3 style="color:var(--tb-purple);font-size:.95rem;margin-bottom:6px;">3세대: 딥러닝</h3>
        <p style="font-size:.82rem;">임베딩, Transformer, GPT 기반. 텍스트/이미지까지 활용.</p>
      </div>
    </div>

    <InsightBox>
      <strong>윤리적 고려:</strong>
      추천 시스템은 "필터 버블(filter bubble)"을 만들 수 있습니다.
      내가 좋아하는 것만 계속 보여주면 시야가 좁아지고,
      편향이 강화됩니다.
      다양성(diversity)과 공정성(fairness)을 추천에 포함시키는 것이 최신 연구 트렌드입니다.
    </InsightBox>
  </div>

  <!-- ===== CONCLUSION ===== -->
  <ConclusionBox>
    <strong>이 장의 핵심</strong>
    <ul style="margin-top: 8px; padding-left: 20px;">
      <li>연관규칙은 Support, Confidence, Lift로 상품 간 관계를 측정한다.</li>
      <li>협업 필터링은 유사 사용자(또는 유사 아이템)를 기반으로 추천한다.</li>
      <li>콘텐츠 기반과 협업 필터링은 각각 장단점이 있으며, 하이브리드가 최선이다.</li>
      <li>콜드 스타트 문제는 추천 시스템의 근본적 도전이다.</li>
      <li>필터 버블 등 윤리적 문제도 고려해야 한다.</li>
    </ul>
    <p style="margin-top: 12px;">
      <strong>다음 장 예고:</strong>
      Part 5의 모든 비지도 학습 기법을 총동원하는 캡스톤 프로젝트입니다.
    </p>
  </ConclusionBox>

</TextbookLayout>

<script>
// ==================== DATA ====================
const CONV_ITEMS = ['삼각김밥', '컵라면', '우유', '빵', '커피', '음료수', '과자', '초콜릿', '아이스크림', '도시락', '샌드위치', '맥주', '소주', '안주', '생수'];

const MOVIES = [
  { id: 0, title: '기생충', genre: ['드라마', '스릴러'] },
  { id: 1, title: '부산행', genre: ['액션', '스릴러'] },
  { id: 2, title: '극한직업', genre: ['코미디', '액션'] },
  { id: 3, title: '어벤져스', genre: ['액션', 'SF'] },
  { id: 4, title: '인터스텔라', genre: ['SF', '드라마'] },
  { id: 5, title: '올드보이', genre: ['스릴러', '드라마'] },
  { id: 6, title: '건축학개론', genre: ['로맨스', '드라마'] },
  { id: 7, title: '타짜', genre: ['범죄', '드라마'] },
  { id: 8, title: '스파이더맨', genre: ['액션', 'SF'] },
  { id: 9, title: '님은 먼곳에', genre: ['드라마', '로맨스'] },
  { id: 10, title: '범죄도시', genre: ['액션', '범죄'] },
  { id: 11, title: '터미네이터', genre: ['액션', 'SF'] },
  { id: 12, title: '노트북', genre: ['로맨스', '드라마'] },
  { id: 13, title: '반도', genre: ['액션', '스릴러'] },
  { id: 14, title: '신세계', genre: ['범죄', '드라마'] },
  { id: 15, title: '택시운전사', genre: ['드라마', '역사'] },
  { id: 16, title: '해운대', genre: ['액션', '드라마'] },
  { id: 17, title: '과속스캔들', genre: ['코미디', '드라마'] },
  { id: 18, title: '마션', genre: ['SF', '드라마'] },
  { id: 19, title: '클래식', genre: ['로맨스', '드라마'] }
];

const ALL_GENRES = ['드라마', '액션', '스릴러', 'SF', '코미디', '로맨스', '범죄', '역사'];

// Simulated other users (20 users x 20 movies)
let otherUsers = [];
let transactions = [];
let userRatings = {};

function generateOtherUsers() {
  otherUsers = [];
  // Create users with genre preferences
  for (let u = 0; u < 30; u++) {
    const prefGenres = ALL_GENRES.filter(() => Math.random() > 0.5);
    if (prefGenres.length === 0) prefGenres.push(ALL_GENRES[Math.floor(Math.random() * ALL_GENRES.length)]);
    const ratings = {};
    MOVIES.forEach(m => {
      if (Math.random() > 0.4) { // 60% chance of rating
        const genreMatch = m.genre.some(g => prefGenres.includes(g));
        const base = genreMatch ? 4 : 2.5;
        ratings[m.id] = Math.min(5, Math.max(1, Math.round(base + (Math.random() - 0.5) * 2)));
      }
    });
    otherUsers.push({ id: u, ratings, prefGenres });
  }
}

// ==================== INTERACTIVE 1: MARKET BASKET ====================
function generateTransactions() {
  transactions = [];
  // Define item affinities
  const affinities = {
    '삼각김밥': ['컵라면', '음료수', '우유'],
    '컵라면': ['삼각김밥', '음료수', '생수'],
    '맥주': ['소주', '안주', '과자'],
    '소주': ['맥주', '안주'],
    '커피': ['빵', '샌드위치'],
    '빵': ['커피', '우유'],
    '도시락': ['음료수', '생수'],
    '과자': ['음료수', '초콜릿'],
    '아이스크림': ['음료수', '초콜릿']
  };

  for (let i = 0; i < 200; i++) {
    const basket = new Set();
    // Random seed item
    const seed = CONV_ITEMS[Math.floor(Math.random() * CONV_ITEMS.length)];
    basket.add(seed);
    // Add affinity items
    const aff = affinities[seed] || [];
    aff.forEach(item => { if (Math.random() > 0.4) basket.add(item); });
    // Random additional items
    const extra = Math.floor(Math.random() * 3);
    for (let j = 0; j < extra; j++) {
      basket.add(CONV_ITEMS[Math.floor(Math.random() * CONV_ITEMS.length)]);
    }
    transactions.push([...basket]);
  }

  drawBasketNetwork();
}

function drawBasketNetwork() {
  const minSupport = parseInt(document.getElementById('slider-support').value) / 100;
  const minConfidence = parseInt(document.getElementById('slider-confidence').value) / 100;
  const n = transactions.length;

  // Compute item frequencies
  const itemFreq = {};
  CONV_ITEMS.forEach(item => { itemFreq[item] = 0; });
  transactions.forEach(t => t.forEach(item => { itemFreq[item] = (itemFreq[item] || 0) + 1; }));

  // Compute pairwise frequencies
  const pairFreq = {};
  transactions.forEach(t => {
    for (let i = 0; i < t.length; i++) {
      for (let j = i + 1; j < t.length; j++) {
        const key = [t[i], t[j]].sort().join('|');
        pairFreq[key] = (pairFreq[key] || 0) + 1;
      }
    }
  });

  // Generate rules
  const rules = [];
  Object.entries(pairFreq).forEach(([key, count]) => {
    const [a, b] = key.split('|');
    const support = count / n;
    if (support < minSupport) return;

    const confAB = count / itemFreq[a];
    const confBA = count / itemFreq[b];
    const lift = support / ((itemFreq[a] / n) * (itemFreq[b] / n));

    if (confAB >= minConfidence) rules.push({ from: a, to: b, support, confidence: confAB, lift });
    if (confBA >= minConfidence) rules.push({ from: b, to: a, support, confidence: confBA, lift });
  });

  rules.sort((a, b) => b.lift - a.lift);

  // Draw network
  const canvas = document.getElementById('canvas-basket');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  // Position items in circle
  const activeItems = new Set();
  rules.forEach(r => { activeItems.add(r.from); activeItems.add(r.to); });
  const items = [...activeItems];
  if (items.length === 0) {
    ctx.fillStyle = '#94a3b8'; ctx.font = '14px Paperlogy'; ctx.textAlign = 'center';
    ctx.fillText('조건을 만족하는 규칙이 없습니다. 슬라이더를 낮춰보세요.', W / 2, H / 2);
    document.getElementById('basket-rules').style.display = '';
    document.getElementById('stat-basket-total').textContent = n;
    document.getElementById('stat-basket-rules').textContent = '0';
    document.getElementById('stat-basket-lift').textContent = '-';
    return;
  }

  const positions = {};
  items.forEach((item, i) => {
    const angle = (2 * Math.PI * i) / items.length - Math.PI / 2;
    const rx = W * 0.35, ry = H * 0.35;
    positions[item] = {
      x: W / 2 + rx * Math.cos(angle),
      y: H / 2 + ry * Math.sin(angle)
    };
  });

  // Draw edges
  rules.forEach(r => {
    const from = positions[r.from];
    const to = positions[r.to];
    if (!from || !to) return;
    const alpha = Math.min(1, r.lift / 3);
    ctx.beginPath();
    ctx.strokeStyle = `rgba(37, 99, 235, ${alpha})`;
    ctx.lineWidth = Math.max(1, r.confidence * 5);
    ctx.moveTo(from.x, from.y);
    ctx.lineTo(to.x, to.y);
    ctx.stroke();

    // Arrow
    const angle = Math.atan2(to.y - from.y, to.x - from.x);
    const arrowX = to.x - 25 * Math.cos(angle);
    const arrowY = to.y - 25 * Math.sin(angle);
    ctx.beginPath();
    ctx.fillStyle = `rgba(37, 99, 235, ${alpha})`;
    ctx.moveTo(arrowX, arrowY);
    ctx.lineTo(arrowX - 8 * Math.cos(angle - 0.4), arrowY - 8 * Math.sin(angle - 0.4));
    ctx.lineTo(arrowX - 8 * Math.cos(angle + 0.4), arrowY - 8 * Math.sin(angle + 0.4));
    ctx.closePath();
    ctx.fill();
  });

  // Draw nodes
  items.forEach(item => {
    const pos = positions[item];
    const freq = itemFreq[item] / n;
    const radius = 12 + freq * 30;
    ctx.beginPath();
    ctx.arc(pos.x, pos.y, radius, 0, 2 * Math.PI);
    ctx.fillStyle = '#fff';
    ctx.fill();
    ctx.strokeStyle = '#2563eb';
    ctx.lineWidth = 2;
    ctx.stroke();

    ctx.fillStyle = '#1e293b';
    ctx.font = 'bold 11px Paperlogy';
    ctx.textAlign = 'center';
    ctx.fillText(item, pos.x, pos.y + 4);
  });

  // Update table
  document.getElementById('basket-rules').style.display = '';
  document.getElementById('stat-basket-total').textContent = n;
  document.getElementById('stat-basket-rules').textContent = rules.length;
  document.getElementById('stat-basket-lift').textContent = rules.length > 0 ? rules[0].lift.toFixed(2) : '-';

  const tbody = document.getElementById('rules-tbody');
  tbody.innerHTML = '';
  rules.slice(0, 15).forEach(r => {
    tbody.insertAdjacentHTML('beforeend', `<tr>
      <td style="font-weight:700;">${r.from} -> ${r.to}</td>
      <td>${(r.support * 100).toFixed(1)}%</td>
      <td>${(r.confidence * 100).toFixed(1)}%</td>
      <td style="color:${r.lift > 1.5 ? 'var(--tb-success)' : r.lift < 1 ? 'var(--tb-danger)' : 'var(--tb-g600)'};font-weight:700;">${r.lift.toFixed(2)}</td>
    </tr>`);
  });
}

// ==================== INTERACTIVE 2: MANUAL CALCULATOR ====================
function calculateMetrics() {
  const N = parseInt(document.getElementById('calc-n').value);
  const A = parseInt(document.getElementById('calc-a').value);
  const B = parseInt(document.getElementById('calc-b').value);
  const AB = parseInt(document.getElementById('calc-ab').value);

  const support = AB / N;
  const confidence = AB / A;
  const lift = support / ((A / N) * (B / N));

  document.getElementById('calc-result').style.display = '';
  document.getElementById('stat-calc-support').textContent = (support * 100).toFixed(1) + '%';
  document.getElementById('stat-calc-conf').textContent = (confidence * 100).toFixed(1) + '%';
  document.getElementById('stat-calc-lift').textContent = lift.toFixed(2);
  document.getElementById('stat-calc-interp').textContent =
    lift > 1.5 ? '강한 양의 연관' : lift > 1.05 ? '약한 양의 연관' :
    lift > 0.95 ? '독립 (무관)' : '음의 연관';

  // Draw Venn diagram
  const canvas = document.getElementById('canvas-venn');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const cx = W / 2, cy = H / 2 - 10;
  const r = 60;
  const overlap = Math.min(1, AB / Math.min(A, B)) * r * 0.8;

  // Circle A
  ctx.beginPath();
  ctx.arc(cx - r / 2 + overlap / 4, cy, r, 0, 2 * Math.PI);
  ctx.fillStyle = 'rgba(37, 99, 235, 0.2)';
  ctx.fill();
  ctx.strokeStyle = '#2563eb'; ctx.lineWidth = 2; ctx.stroke();

  // Circle B
  ctx.beginPath();
  ctx.arc(cx + r / 2 - overlap / 4, cy, r, 0, 2 * Math.PI);
  ctx.fillStyle = 'rgba(239, 68, 68, 0.2)';
  ctx.fill();
  ctx.strokeStyle = '#ef4444'; ctx.lineWidth = 2; ctx.stroke();

  // Labels
  ctx.fillStyle = '#2563eb'; ctx.font = 'bold 14px Paperlogy'; ctx.textAlign = 'center';
  ctx.fillText('A', cx - r, cy);
  ctx.fillText(A.toString(), cx - r, cy + 18);
  ctx.fillStyle = '#ef4444';
  ctx.fillText('B', cx + r, cy);
  ctx.fillText(B.toString(), cx + r, cy + 18);
  ctx.fillStyle = '#7c3aed'; ctx.font = 'bold 16px Paperlogy';
  ctx.fillText(AB.toString(), cx, cy + 5);
  ctx.font = '11px Paperlogy';
  ctx.fillText('A ∩ B', cx, cy - 12);

  ctx.fillStyle = '#64748b'; ctx.font = '11px Paperlogy';
  ctx.fillText(`N = ${N}`, cx, H - 10);
}

// ==================== INTERACTIVE 3: COLLABORATIVE FILTERING ====================
function initMoviePanel() {
  generateOtherUsers();
  const container = document.getElementById('movie-list');
  container.innerHTML = '';
  userRatings = {};

  MOVIES.forEach(m => {
    const card = document.createElement('div');
    card.className = 'movie-card';
    card.innerHTML = `
      <div style="font-weight:700;font-size:.88rem;">${m.title}</div>
      <div style="font-size:.78rem;color:var(--tb-g600);">${m.genre.join(', ')}</div>
      <div class="star-row" data-movie="${m.id}" style="margin-top:4px;">
        ${[1,2,3,4,5].map(s => `<span class="star" data-star="${s}" style="cursor:pointer;font-size:1.2rem;color:var(--tb-g300);">*</span>`).join('')}
      </div>
    `;
    container.appendChild(card);
  });

  // Star click handlers
  document.querySelectorAll('.star-row').forEach(row => {
    row.querySelectorAll('.star').forEach(star => {
      star.addEventListener('click', () => {
        const movieId = parseInt(row.dataset.movie);
        const rating = parseInt(star.dataset.star);
        userRatings[movieId] = rating;
        row.querySelectorAll('.star').forEach(s => {
          s.style.color = parseInt(s.dataset.star) <= rating ? '#f59e0b' : 'var(--tb-g300)';
          s.textContent = parseInt(s.dataset.star) <= rating ? '*' : '*';
        });
      });
    });
  });
}

function getRecommendations() {
  const rated = Object.keys(userRatings).map(Number);
  if (rated.length < 3) {
    alert('최소 3편의 영화에 별점을 매겨주세요.');
    return;
  }

  // Compute similarity with each other user
  const similarities = otherUsers.map(u => {
    const common = rated.filter(m => u.ratings[m] !== undefined);
    if (common.length < 2) return { userId: u.id, sim: 0, commonCount: 0, user: u };
    let dotProd = 0, normA = 0, normB = 0;
    common.forEach(m => {
      dotProd += userRatings[m] * u.ratings[m];
      normA += userRatings[m] ** 2;
      normB += u.ratings[m] ** 2;
    });
    const sim = (normA && normB) ? dotProd / (Math.sqrt(normA) * Math.sqrt(normB)) : 0;
    return { userId: u.id, sim, commonCount: common.length, user: u };
  }).filter(s => s.sim > 0).sort((a, b) => b.sim - a.sim);

  const topK = similarities.slice(0, 5);

  // Predict ratings for unrated movies
  const predictions = [];
  MOVIES.forEach(m => {
    if (userRatings[m.id] !== undefined) return;
    let weightedSum = 0, weightSum = 0;
    topK.forEach(s => {
      if (s.user.ratings[m.id] !== undefined) {
        weightedSum += s.sim * s.user.ratings[m.id];
        weightSum += s.sim;
      }
    });
    if (weightSum > 0) {
      predictions.push({ movie: m, predicted: weightedSum / weightSum });
    }
  });

  predictions.sort((a, b) => b.predicted - a.predicted);

  // Display
  document.getElementById('recommend-result').style.display = '';
  const list = document.getElementById('recommend-list');
  list.innerHTML = '';
  predictions.slice(0, 8).forEach((p, i) => {
    const card = document.createElement('div');
    card.className = 'movie-card';
    card.style.borderLeft = `4px solid ${p.predicted >= 4 ? 'var(--tb-success)' : p.predicted >= 3 ? 'var(--tb-warning)' : 'var(--tb-g300)'}`;
    card.innerHTML = `
      <div style="font-weight:700;font-size:.88rem;">#${i + 1} ${p.movie.title}</div>
      <div style="font-size:.78rem;color:var(--tb-g600);">${p.movie.genre.join(', ')}</div>
      <div style="font-weight:800;color:var(--tb-primary);margin-top:4px;">예측: ${p.predicted.toFixed(1)} / 5</div>
    `;
    list.appendChild(card);
  });

  document.getElementById('similar-users-info').textContent =
    `가장 유사한 사용자 ${topK.length}명 (유사도: ${topK.map(s => s.sim.toFixed(2)).join(', ')})`;
}

// ==================== INTERACTIVE 4: CONTENT vs COLLABORATIVE ====================
function contentBasedRecommend() {
  const rated = Object.keys(userRatings).map(Number);
  if (rated.length < 3) { alert('먼저 별점을 매겨주세요.'); return; }

  // Compute genre preference
  const genreScores = {};
  ALL_GENRES.forEach(g => { genreScores[g] = 0; });
  rated.forEach(mid => {
    const movie = MOVIES[mid];
    movie.genre.forEach(g => { genreScores[g] += userRatings[mid]; });
  });

  // Score unrated movies by genre match
  const predictions = [];
  MOVIES.forEach(m => {
    if (userRatings[m.id] !== undefined) return;
    let score = 0;
    m.genre.forEach(g => { score += genreScores[g] || 0; });
    score /= m.genre.length;
    predictions.push({ movie: m, score });
  });
  predictions.sort((a, b) => b.score - a.score);

  const list = document.getElementById('content-rec-list');
  list.innerHTML = '';
  predictions.slice(0, 5).forEach((p, i) => {
    list.innerHTML += `<div style="padding:8px 0;border-bottom:1px solid var(--tb-g200);">
      <strong>#${i + 1}</strong> ${p.movie.title}
      <span style="font-size:.82rem;color:var(--tb-g600);">(${p.movie.genre.join(', ')})</span>
      <span style="float:right;font-weight:700;color:var(--tb-primary);">${p.score.toFixed(1)}</span>
    </div>`;
  });
}

function collabBasedRecommend() {
  const rated = Object.keys(userRatings).map(Number);
  if (rated.length < 3) { alert('먼저 별점을 매겨주세요.'); return; }

  // Same as getRecommendations but display in different panel
  const similarities = otherUsers.map(u => {
    const common = rated.filter(m => u.ratings[m] !== undefined);
    if (common.length < 2) return { sim: 0, user: u };
    let dotProd = 0, normA = 0, normB = 0;
    common.forEach(m => {
      dotProd += userRatings[m] * u.ratings[m];
      normA += userRatings[m] ** 2;
      normB += u.ratings[m] ** 2;
    });
    const sim = (normA && normB) ? dotProd / (Math.sqrt(normA) * Math.sqrt(normB)) : 0;
    return { sim, user: u };
  }).filter(s => s.sim > 0).sort((a, b) => b.sim - a.sim).slice(0, 5);

  const predictions = [];
  MOVIES.forEach(m => {
    if (userRatings[m.id] !== undefined) return;
    let wSum = 0, wDenom = 0;
    similarities.forEach(s => {
      if (s.user.ratings[m.id] !== undefined) {
        wSum += s.sim * s.user.ratings[m.id];
        wDenom += s.sim;
      }
    });
    if (wDenom > 0) predictions.push({ movie: m, score: wSum / wDenom });
  });
  predictions.sort((a, b) => b.score - a.score);

  const list = document.getElementById('collab-rec-list');
  list.innerHTML = '';
  predictions.slice(0, 5).forEach((p, i) => {
    list.innerHTML += `<div style="padding:8px 0;border-bottom:1px solid var(--tb-g200);">
      <strong>#${i + 1}</strong> ${p.movie.title}
      <span style="font-size:.82rem;color:var(--tb-g600);">(${p.movie.genre.join(', ')})</span>
      <span style="float:right;font-weight:700;color:var(--tb-success);">${p.score.toFixed(1)}</span>
    </div>`;
  });

  // Show cold start explanation
  const coldStart = document.getElementById('cold-start-msg');
  coldStart.style.display = '';
  coldStart.innerHTML = `<strong>비교:</strong> 콘텐츠 기반은 장르 선호도만으로 추천하므로 다양성이 낮습니다. 협업 필터링은 다른 사용자의 취향을 반영하므로 예상치 못한 발견(serendipity)을 제공할 수 있습니다.`;
}

// ==================== INIT ====================
function init() {
  import('../../textbook/lib/progress').then(m => m.markVisited('30-recommendation')).catch(() => {});

  initMoviePanel();

  document.getElementById('btn-basket-gen').addEventListener('click', generateTransactions);
  document.getElementById('slider-support').addEventListener('input', (e) => {
    document.getElementById('label-support').textContent = e.target.value + '%';
    if (transactions.length > 0) drawBasketNetwork();
  });
  document.getElementById('slider-confidence').addEventListener('input', (e) => {
    document.getElementById('label-confidence').textContent = e.target.value + '%';
    if (transactions.length > 0) drawBasketNetwork();
  });

  document.getElementById('btn-calc').addEventListener('click', calculateMetrics);
  document.getElementById('btn-recommend').addEventListener('click', getRecommendations);
  document.getElementById('btn-reset-ratings').addEventListener('click', () => {
    userRatings = {};
    document.querySelectorAll('.star').forEach(s => { s.style.color = 'var(--tb-g300)'; });
    document.getElementById('recommend-result').style.display = 'none';
  });

  document.getElementById('btn-content-rec').addEventListener('click', contentBasedRecommend);
  document.getElementById('btn-collab-rec').addEventListener('click', collabBasedRecommend);
}

document.addEventListener('astro:page-load', init);
</script>

