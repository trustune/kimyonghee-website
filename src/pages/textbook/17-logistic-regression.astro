<script>
// ==================== UTILITY ====================
function randNorm(mu = 0, sigma = 1) {
  let u = 0, v = 0;
  while (u === 0) u = Math.random();
  while (v === 0) v = Math.random();
  return mu + sigma * Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);
}

function sigmoid(z) {
  return 1 / (1 + Math.exp(-z));
}

// ==================== DATA GENERATION ====================
let whyData = { x: [], y: [] };
let sigData = { x: [], y: [] };
let rocData = { actual: [], probs: [] };
let churnCoefs = { b0: 0, overtime: 0, income: 0, years: 0, satisfaction: 0 };

function generateWhyData(n = 50) {
  const x = [], y = [];
  const trueB0 = -3, trueB1 = 0.6;
  for (let i = 0; i < n; i++) {
    const xi = 1 + Math.random() * 10;
    const p = sigmoid(trueB0 + trueB1 * xi);
    const yi = Math.random() < p ? 1 : 0;
    x.push(xi);
    y.push(yi);
  }
  whyData = { x, y };
}

function generateSigData(n = 40) {
  const x = [], y = [];
  const trueB0 = -2, trueB1 = 0.5;
  for (let i = 0; i < n; i++) {
    const xi = Math.random() * 12;
    const p = sigmoid(trueB0 + trueB1 * xi);
    const yi = Math.random() < p ? 1 : 0;
    x.push(xi);
    y.push(yi);
  }
  sigData = { x, y };
}

function generateROCData(n = 150) {
  const actual = [], probs = [];
  // Simulate employee churn
  const trueCoefs = { b0: -1.2, overtime: 0.85, income: -0.004, years: -0.08, satisfaction: -0.5 };
  churnCoefs = trueCoefs;

  for (let i = 0; i < n; i++) {
    const overtime = Math.random() > 0.6 ? 1 : 0;
    const income = 200 + Math.random() * 600;
    const years = Math.floor(Math.random() * 20);
    const satisfaction = 1 + Math.floor(Math.random() * 4);

    const z = trueCoefs.b0 + trueCoefs.overtime * overtime +
              trueCoefs.income * income + trueCoefs.years * years +
              trueCoefs.satisfaction * satisfaction;
    const p = sigmoid(z);
    const y = Math.random() < p ? 1 : 0;
    actual.push(y);
    probs.push(p + randNorm(0, 0.05)); // Add some noise to probs
  }

  // Clamp probs to [0.001, 0.999]
  for (let i = 0; i < probs.length; i++) {
    probs[i] = Math.max(0.001, Math.min(0.999, probs[i]));
  }

  rocData = { actual, probs };
}

// ==================== WHY NOT LINEAR (Exercise 1) ====================
let whyMode = 'none';

function drawWhyCanvas() {
  const canvas = document.getElementById('why-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const pad = { l: 60, r: 30, t: 20, b: 40 };

  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#f8fafc';
  ctx.fillRect(0, 0, W, H);

  if (whyData.x.length === 0) return;

  const xMin = Math.min(...whyData.x) - 1;
  const xMax = Math.max(...whyData.x) + 1;
  const yMin = -0.3;
  const yMax = 1.3;

  const sx = (v) => pad.l + (v - xMin) / (xMax - xMin) * (W - pad.l - pad.r);
  const sy = (v) => H - pad.b - (v - yMin) / (yMax - yMin) * (H - pad.t - pad.b);

  // Grid lines at y=0, 0.5, 1
  ctx.strokeStyle = '#e2e8f0';
  ctx.lineWidth = 1;
  [0, 0.5, 1].forEach(v => {
    ctx.beginPath(); ctx.moveTo(pad.l, sy(v)); ctx.lineTo(W - pad.r, sy(v)); ctx.stroke();
  });

  // Danger zones: y < 0 and y > 1
  ctx.fillStyle = 'rgba(239, 68, 68, 0.06)';
  ctx.fillRect(pad.l, sy(yMax), W - pad.l - pad.r, sy(1) - sy(yMax));
  ctx.fillRect(pad.l, sy(0), W - pad.l - pad.r, sy(yMin) - sy(0));

  ctx.fillStyle = '#ef444466';
  ctx.font = '11px Paperlogy, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText('확률 > 1 (불가능)', pad.l + 8, sy(1.15));
  ctx.fillText('확률 < 0 (불가능)', pad.l + 8, sy(-0.15));

  // y = 0 and y = 1 reference lines
  ctx.strokeStyle = '#94a3b8';
  ctx.lineWidth = 1.5;
  ctx.setLineDash([6, 4]);
  [0, 1].forEach(v => {
    ctx.beginPath(); ctx.moveTo(pad.l, sy(v)); ctx.lineTo(W - pad.r, sy(v)); ctx.stroke();
  });
  ctx.setLineDash([]);

  // Linear regression fit
  if (whyMode === 'linear' || whyMode === 'logistic') {
    const n = whyData.x.length;
    const mx = whyData.x.reduce((a, b) => a + b, 0) / n;
    const my = whyData.y.reduce((a, b) => a + b, 0) / n;
    let num = 0, den = 0;
    for (let i = 0; i < n; i++) {
      num += (whyData.x[i] - mx) * (whyData.y[i] - my);
      den += (whyData.x[i] - mx) ** 2;
    }
    const b1lin = den !== 0 ? num / den : 0;
    const b0lin = my - b1lin * mx;

    // Draw linear line
    ctx.strokeStyle = '#ef4444';
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    ctx.moveTo(sx(xMin), sy(b0lin + b1lin * xMin));
    ctx.lineTo(sx(xMax), sy(b0lin + b1lin * xMax));
    ctx.stroke();

    // Count violations
    let below = 0, above = 0;
    for (let xi = xMin; xi <= xMax; xi += 0.1) {
      const pred = b0lin + b1lin * xi;
      if (pred < 0) below++;
      if (pred > 1) above++;
    }

    document.getElementById('why-below').textContent = below > 0 ? 'O' : '-';
    document.getElementById('why-above').textContent = above > 0 ? 'O' : '-';
  }

  // Logistic fit
  if (whyMode === 'logistic') {
    // Simple gradient descent for MLE
    const fitResult = fitLogistic(whyData.x, whyData.y);

    ctx.strokeStyle = '#2563eb';
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    let first = true;
    for (let xi = xMin; xi <= xMax; xi += 0.05) {
      const p = sigmoid(fitResult.b0 + fitResult.b1 * xi);
      const py = sy(p);
      if (first) { ctx.moveTo(sx(xi), py); first = false; }
      else ctx.lineTo(sx(xi), py);
    }
    ctx.stroke();

    document.getElementById('why-below').textContent = '-';
    document.getElementById('why-above').textContent = '-';
  }

  // Data points
  whyData.x.forEach((xi, i) => {
    const yi = whyData.y[i];
    ctx.fillStyle = yi === 1 ? '#2563eb' : '#ef4444';
    ctx.beginPath();
    ctx.arc(sx(xi), sy(yi), 5, 0, Math.PI * 2);
    ctx.fill();
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 1.5;
    ctx.stroke();
  });

  // Labels
  ctx.fillStyle = '#475569';
  ctx.font = '12px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('X', W / 2, H - 6);
  ctx.textAlign = 'right';
  ctx.fillText('0', pad.l - 8, sy(0) + 4);
  ctx.fillText('1', pad.l - 8, sy(1) + 4);

  // Model label
  const labels = { none: '(모형 없음)', linear: '선형회귀 (LPM)', logistic: '선형 + 로지스틱' };
  document.getElementById('why-model').textContent = labels[whyMode] || '';
}

// ==================== LOGISTIC FIT (Gradient Descent) ====================
function fitLogistic(xArr, yArr, maxIter = 200) {
  let b0 = 0, b1 = 0;
  const n = xArr.length;
  const lr = 0.01;

  for (let iter = 0; iter < maxIter; iter++) {
    let gb0 = 0, gb1 = 0;
    for (let i = 0; i < n; i++) {
      const p = sigmoid(b0 + b1 * xArr[i]);
      const err = yArr[i] - p;
      gb0 += err;
      gb1 += err * xArr[i];
    }
    b0 += lr * gb0 / n;
    b1 += lr * gb1 / n;
  }

  return { b0, b1 };
}

function logLikelihood(xArr, yArr, b0, b1) {
  let ll = 0;
  for (let i = 0; i < xArr.length; i++) {
    const p = sigmoid(b0 + b1 * xArr[i]);
    const pc = Math.max(1e-10, Math.min(1 - 1e-10, p));
    ll += yArr[i] * Math.log(pc) + (1 - yArr[i]) * Math.log(1 - pc);
  }
  return ll;
}

// ==================== SIGMOID EXPLORER (Exercise 2) ====================
function drawSigCanvas() {
  const canvas = document.getElementById('sig-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const pad = { l: 60, r: 30, t: 20, b: 40 };

  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#f8fafc';
  ctx.fillRect(0, 0, W, H);

  const b0 = parseFloat(document.getElementById('sig-b0').value);
  const b1 = parseFloat(document.getElementById('sig-b1').value);

  const xMin = -1, xMax = 13;
  const yMin = -0.1, yMax = 1.1;

  const sx = (v) => pad.l + (v - xMin) / (xMax - xMin) * (W - pad.l - pad.r);
  const sy = (v) => H - pad.b - (v - yMin) / (yMax - yMin) * (H - pad.t - pad.b);

  // Grid
  ctx.strokeStyle = '#e2e8f0';
  ctx.lineWidth = 1;
  [0, 0.25, 0.5, 0.75, 1].forEach(v => {
    ctx.beginPath(); ctx.moveTo(pad.l, sy(v)); ctx.lineTo(W - pad.r, sy(v)); ctx.stroke();
  });

  // p = 0.5 line (dashed)
  ctx.strokeStyle = '#94a3b8';
  ctx.lineWidth = 1;
  ctx.setLineDash([4, 4]);
  ctx.beginPath();
  ctx.moveTo(pad.l, sy(0.5));
  ctx.lineTo(W - pad.r, sy(0.5));
  ctx.stroke();
  ctx.setLineDash([]);

  // Decision boundary vertical line
  if (Math.abs(b1) > 0.001) {
    const boundary = -b0 / b1;
    if (boundary >= xMin && boundary <= xMax) {
      ctx.strokeStyle = '#7c3aed66';
      ctx.lineWidth = 2;
      ctx.setLineDash([6, 4]);
      ctx.beginPath();
      ctx.moveTo(sx(boundary), sy(yMin));
      ctx.lineTo(sx(boundary), sy(yMax));
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = '#7c3aed';
      ctx.font = '11px Paperlogy, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('p=0.5', sx(boundary), sy(yMax) + 12);
    }
    document.getElementById('sig-boundary').textContent = (-b0 / b1).toFixed(2);
  } else {
    document.getElementById('sig-boundary').textContent = '-';
  }

  // Sigmoid curve
  ctx.strokeStyle = '#2563eb';
  ctx.lineWidth = 3;
  ctx.beginPath();
  let first = true;
  for (let xi = xMin; xi <= xMax; xi += 0.05) {
    const p = sigmoid(b0 + b1 * xi);
    if (first) { ctx.moveTo(sx(xi), sy(p)); first = false; }
    else ctx.lineTo(sx(xi), sy(p));
  }
  ctx.stroke();

  // Data points
  if (sigData.x.length > 0) {
    sigData.x.forEach((xi, i) => {
      const yi = sigData.y[i];
      ctx.fillStyle = yi === 1 ? '#2563eb' : '#ef4444';
      ctx.globalAlpha = 0.7;
      ctx.beginPath();
      ctx.arc(sx(xi), sy(yi), 5, 0, Math.PI * 2);
      ctx.fill();
      ctx.globalAlpha = 1;
    });
  }

  // Axis labels
  ctx.fillStyle = '#475569';
  ctx.font = '12px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('X', W / 2, H - 6);
  ctx.textAlign = 'right';
  [0, 0.25, 0.5, 0.75, 1].forEach(v => {
    ctx.fillText(v.toFixed(2), pad.l - 8, sy(v) + 4);
  });

  // Log-likelihood
  if (sigData.x.length > 0) {
    const ll = logLikelihood(sigData.x, sigData.y, b0, b1);
    document.getElementById('sig-ll').textContent = ll.toFixed(2);
  }
}

// ==================== ROC CURVE (Exercise 3) ====================
function computeROCPoints() {
  const thresholds = [];
  for (let t = 0; t <= 1.001; t += 0.01) thresholds.push(t);

  const points = thresholds.map(t => {
    let tp = 0, fp = 0, tn = 0, fn = 0;
    for (let i = 0; i < rocData.actual.length; i++) {
      const pred = rocData.probs[i] >= t ? 1 : 0;
      if (rocData.actual[i] === 1 && pred === 1) tp++;
      else if (rocData.actual[i] === 0 && pred === 1) fp++;
      else if (rocData.actual[i] === 0 && pred === 0) tn++;
      else fn++;
    }
    const tpr = (tp + fn) > 0 ? tp / (tp + fn) : 0; // sensitivity
    const fpr = (fp + tn) > 0 ? fp / (fp + tn) : 0; // 1 - specificity
    return { t, tp, fp, tn, fn, tpr, fpr };
  });

  return points;
}

function drawROCCanvas(rocPoints, currentThreshold) {
  const canvas = document.getElementById('roc-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const pad = { l: 50, r: 20, t: 20, b: 40 };

  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#f8fafc';
  ctx.fillRect(0, 0, W, H);

  const sx = (v) => pad.l + v * (W - pad.l - pad.r);
  const sy = (v) => H - pad.b - v * (H - pad.t - pad.b);

  // Diagonal (random classifier)
  ctx.strokeStyle = '#cbd5e1';
  ctx.lineWidth = 1.5;
  ctx.setLineDash([6, 4]);
  ctx.beginPath();
  ctx.moveTo(sx(0), sy(0));
  ctx.lineTo(sx(1), sy(1));
  ctx.stroke();
  ctx.setLineDash([]);

  // AUC fill
  ctx.fillStyle = 'rgba(37, 99, 235, 0.1)';
  ctx.beginPath();
  ctx.moveTo(sx(0), sy(0));
  rocPoints.forEach(p => ctx.lineTo(sx(p.fpr), sy(p.tpr)));
  ctx.lineTo(sx(1), sy(0));
  ctx.closePath();
  ctx.fill();

  // ROC curve
  ctx.strokeStyle = '#2563eb';
  ctx.lineWidth = 2.5;
  ctx.beginPath();
  let first = true;
  rocPoints.forEach(p => {
    if (first) { ctx.moveTo(sx(p.fpr), sy(p.tpr)); first = false; }
    else ctx.lineTo(sx(p.fpr), sy(p.tpr));
  });
  ctx.stroke();

  // Current threshold point
  const closest = rocPoints.reduce((best, p) =>
    Math.abs(p.t - currentThreshold) < Math.abs(best.t - currentThreshold) ? p : best
  );

  ctx.fillStyle = '#ef4444';
  ctx.beginPath();
  ctx.arc(sx(closest.fpr), sy(closest.tpr), 7, 0, Math.PI * 2);
  ctx.fill();
  ctx.strokeStyle = '#fff';
  ctx.lineWidth = 2;
  ctx.stroke();

  // Label
  ctx.fillStyle = '#ef4444';
  ctx.font = '11px Paperlogy, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText(`t=${currentThreshold.toFixed(2)}`, sx(closest.fpr) + 10, sy(closest.tpr) - 5);

  // Axes
  ctx.fillStyle = '#475569';
  ctx.font = '12px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('FPR (1 - 특이도)', W / 2, H - 6);
  ctx.save();
  ctx.translate(14, H / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillText('TPR (민감도)', 0, 0);
  ctx.restore();

  // AUC calculation (trapezoidal)
  let auc = 0;
  for (let i = 1; i < rocPoints.length; i++) {
    const dx = Math.abs(rocPoints[i].fpr - rocPoints[i - 1].fpr);
    const avgY = (rocPoints[i].tpr + rocPoints[i - 1].tpr) / 2;
    auc += dx * avgY;
  }
  document.getElementById('roc-auc').textContent = Math.abs(auc).toFixed(4);

  return closest;
}

function updateROC() {
  const threshold = parseFloat(document.getElementById('roc-threshold').value);
  document.getElementById('roc-thresh-val').textContent = threshold.toFixed(2);

  const rocPoints = computeROCPoints();
  const closest = drawROCCanvas(rocPoints, threshold);

  // Update confusion matrix
  document.getElementById('cm-tp').textContent = closest.tp;
  document.getElementById('cm-fp').textContent = closest.fp;
  document.getElementById('cm-tn').textContent = closest.tn;
  document.getElementById('cm-fn').textContent = closest.fn;

  const total = closest.tp + closest.fp + closest.tn + closest.fn;
  const accuracy = total > 0 ? (closest.tp + closest.tn) / total : 0;
  const sensitivity = (closest.tp + closest.fn) > 0 ? closest.tp / (closest.tp + closest.fn) : 0;
  const specificity = (closest.tn + closest.fp) > 0 ? closest.tn / (closest.tn + closest.fp) : 0;

  document.getElementById('roc-accuracy').textContent = (accuracy * 100).toFixed(1) + '%';
  document.getElementById('roc-sensitivity').textContent = (sensitivity * 100).toFixed(1) + '%';
  document.getElementById('roc-specificity').textContent = (specificity * 100).toFixed(1) + '%';
}

// ==================== ODDS RATIO TABLE (Exercise 4) ====================
function buildORTable() {
  const vars = [
    { name: '야근(overtime)', coef: 0.85, se: 0.18 },
    { name: '월소득(만원)', coef: -0.004, se: 0.001 },
    { name: '근속연수', coef: -0.08, se: 0.025 },
    { name: '직무만족도(1-4)', coef: -0.50, se: 0.12 },
  ];

  churnCoefs = { b0: -1.2, overtime: 0.85, income: -0.004, years: -0.08, satisfaction: -0.50 };

  const body = document.getElementById('or-body');
  body.innerHTML = `
    <tr>
      <td><strong>절편</strong></td>
      <td>-1.200</td>
      <td>-</td>
      <td>-</td>
      <td style="font-size:.82rem;text-align:left">기준점</td>
    </tr>
  `;

  vars.forEach(v => {
    const or = Math.exp(v.coef);
    const ciLow = Math.exp(v.coef - 1.96 * v.se);
    const ciHigh = Math.exp(v.coef + 1.96 * v.se);

    let interp = '';
    if (or > 1) {
      interp = `1 단위 증가 시 이탈 오즈가 ${or.toFixed(2)}배`;
    } else {
      interp = `1 단위 증가 시 이탈 오즈가 ${(1/or).toFixed(2)}분의 1로 감소`;
    }

    body.innerHTML += `
      <tr>
        <td><strong>${v.name}</strong></td>
        <td>${v.coef.toFixed(3)}</td>
        <td style="color: ${or > 1 ? 'var(--tb-danger)' : 'var(--tb-success)'}; font-weight: 700;">${or.toFixed(3)}</td>
        <td style="font-size:.85rem;">[${ciLow.toFixed(3)}, ${ciHigh.toFixed(3)}]</td>
        <td style="font-size:.82rem;text-align:left">${interp}</td>
      </tr>
    `;
  });
}

function updatePrediction() {
  const overtime = parseInt(document.getElementById('pred-overtime').value);
  const income = parseInt(document.getElementById('pred-income').value);
  const years = parseInt(document.getElementById('pred-years').value);
  const satisfaction = parseInt(document.getElementById('pred-satisfaction').value);

  document.getElementById('pred-income-val').textContent = income;
  document.getElementById('pred-years-val').textContent = years;
  document.getElementById('pred-sat-val').textContent = satisfaction;

  const z = churnCoefs.b0 +
            churnCoefs.overtime * overtime +
            churnCoefs.income * income +
            churnCoefs.years * years +
            churnCoefs.satisfaction * satisfaction;

  const p = sigmoid(z);
  const probEl = document.getElementById('pred-prob');
  const verdictEl = document.getElementById('pred-verdict');

  probEl.textContent = (p * 100).toFixed(1) + '%';
  probEl.style.color = p > 0.5 ? 'var(--tb-danger)' : 'var(--tb-success)';

  if (p > 0.7) {
    verdictEl.textContent = '높은 이탈 위험 -- 즉각적인 관리가 필요합니다';
    verdictEl.style.color = 'var(--tb-danger)';
  } else if (p > 0.5) {
    verdictEl.textContent = '이탈 가능성이 있음 -- 모니터링 대상';
    verdictEl.style.color = 'var(--tb-warning)';
  } else if (p > 0.3) {
    verdictEl.textContent = '보통 수준 -- 정기적 관리';
    verdictEl.style.color = 'var(--tb-g600)';
  } else {
    verdictEl.textContent = '이탈 위험 낮음 -- 안정적';
    verdictEl.style.color = 'var(--tb-success)';
  }
}

// ==================== COST OPTIMIZATION (Exercise 5) ====================
function drawCostCanvas() {
  const canvas = document.getElementById('cost-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const pad = { l: 70, r: 30, t: 20, b: 40 };

  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#f8fafc';
  ctx.fillRect(0, 0, W, H);

  const costFN = parseInt(document.getElementById('cost-fn').value);
  const costFP = parseInt(document.getElementById('cost-fp').value);

  document.getElementById('cost-fn-val').textContent = costFN + '만원';
  document.getElementById('cost-fp-val').textContent = costFP + '만원';

  // Compute total cost for each threshold
  const thresholds = [];
  const costs = [];
  let minCost = Infinity, optimalThresh = 0.5;
  let defaultCost = 0;

  for (let t = 0.01; t <= 0.99; t += 0.01) {
    let tp = 0, fp = 0, tn = 0, fn = 0;
    for (let i = 0; i < rocData.actual.length; i++) {
      const pred = rocData.probs[i] >= t ? 1 : 0;
      if (rocData.actual[i] === 1 && pred === 1) tp++;
      else if (rocData.actual[i] === 0 && pred === 1) fp++;
      else if (rocData.actual[i] === 0 && pred === 0) tn++;
      else fn++;
    }
    const totalCost = fn * costFN + fp * costFP;
    thresholds.push(t);
    costs.push(totalCost);

    if (totalCost < minCost) {
      minCost = totalCost;
      optimalThresh = t;
    }
    if (Math.abs(t - 0.5) < 0.006) {
      defaultCost = totalCost;
    }
  }

  const costMax = Math.max(...costs) * 1.1;

  const sx = (v) => pad.l + (v - 0) / 1 * (W - pad.l - pad.r);
  const sy = (v) => H - pad.b - (v / costMax) * (H - pad.t - pad.b);

  // Grid
  ctx.strokeStyle = '#e2e8f0';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const v = costMax * i / 4;
    ctx.beginPath(); ctx.moveTo(pad.l, sy(v)); ctx.lineTo(W - pad.r, sy(v)); ctx.stroke();
    ctx.fillStyle = '#94a3b8';
    ctx.font = '10px Paperlogy, sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText(Math.round(v).toLocaleString(), pad.l - 6, sy(v) + 3);
  }

  // Cost curve
  ctx.strokeStyle = '#2563eb';
  ctx.lineWidth = 2.5;
  ctx.beginPath();
  thresholds.forEach((t, i) => {
    const px = sx(t), py = sy(costs[i]);
    if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
  });
  ctx.stroke();

  // Default threshold (0.5) marker
  ctx.strokeStyle = '#94a3b8';
  ctx.lineWidth = 1.5;
  ctx.setLineDash([4, 4]);
  ctx.beginPath();
  ctx.moveTo(sx(0.5), sy(0));
  ctx.lineTo(sx(0.5), sy(costMax));
  ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle = '#94a3b8';
  ctx.font = '11px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('기본 (0.5)', sx(0.5), sy(costMax) + 12);

  // Optimal threshold marker
  ctx.strokeStyle = '#22c55e';
  ctx.lineWidth = 2;
  ctx.setLineDash([4, 4]);
  ctx.beginPath();
  ctx.moveTo(sx(optimalThresh), sy(0));
  ctx.lineTo(sx(optimalThresh), sy(costMax));
  ctx.stroke();
  ctx.setLineDash([]);

  ctx.fillStyle = '#22c55e';
  ctx.beginPath();
  ctx.arc(sx(optimalThresh), sy(minCost), 6, 0, Math.PI * 2);
  ctx.fill();

  ctx.fillStyle = '#22c55e';
  ctx.font = '12px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('최적: ' + optimalThresh.toFixed(2), sx(optimalThresh), sy(minCost) - 12);

  // Axis label
  ctx.fillStyle = '#475569';
  ctx.font = '12px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('분류 임계값', W / 2, H - 6);
  ctx.save();
  ctx.translate(16, H / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillText('총비용 (만원)', 0, 0);
  ctx.restore();

  // Stats
  document.getElementById('cost-optimal-thresh').textContent = optimalThresh.toFixed(2);
  document.getElementById('cost-min-cost').textContent = Math.round(minCost).toLocaleString();
  document.getElementById('cost-default').textContent = Math.round(defaultCost).toLocaleString();
  document.getElementById('cost-savings').textContent = Math.round(defaultCost - minCost).toLocaleString();
}

// ==================== INITIALIZATION ====================
function init() {
  try {
    import('../../textbook/lib/progress').then(m => m.markVisited('17-logistic-regression')).catch(() => {});
  } catch(e) {}

  // Generate data
  generateWhyData();
  generateSigData();
  generateROCData();

  // Draw initial states
  drawWhyCanvas();
  drawSigCanvas();
  updateROC();
  buildORTable();
  updatePrediction();
  drawCostCanvas();

  // Exercise 1: Why not linear
  document.getElementById('btn-show-linear').addEventListener('click', () => {
    whyMode = 'linear';
    drawWhyCanvas();
  });
  document.getElementById('btn-show-logistic').addEventListener('click', () => {
    whyMode = 'logistic';
    drawWhyCanvas();
  });
  document.getElementById('btn-why-new-data').addEventListener('click', () => {
    generateWhyData();
    whyMode = 'none';
    drawWhyCanvas();
  });

  // Exercise 2: Sigmoid explorer
  const sigB0 = document.getElementById('sig-b0');
  const sigB1 = document.getElementById('sig-b1');
  sigB0.addEventListener('input', () => {
    document.getElementById('sig-b0-val').textContent = parseFloat(sigB0.value).toFixed(1);
    drawSigCanvas();
  });
  sigB1.addEventListener('input', () => {
    document.getElementById('sig-b1-val').textContent = parseFloat(sigB1.value).toFixed(2);
    drawSigCanvas();
  });

  document.getElementById('btn-sig-fit').addEventListener('click', () => {
    if (sigData.x.length === 0) return;
    const fit = fitLogistic(sigData.x, sigData.y);
    sigB0.value = fit.b0.toFixed(1);
    sigB1.value = fit.b1.toFixed(2);
    document.getElementById('sig-b0-val').textContent = fit.b0.toFixed(1);
    document.getElementById('sig-b1-val').textContent = fit.b1.toFixed(2);
    drawSigCanvas();
  });

  document.getElementById('btn-sig-new-data').addEventListener('click', () => {
    generateSigData();
    drawSigCanvas();
  });

  // Exercise 3: ROC
  document.getElementById('roc-threshold').addEventListener('input', updateROC);
  document.getElementById('btn-roc-new-data').addEventListener('click', () => {
    generateROCData();
    updateROC();
    drawCostCanvas();
  });

  // Exercise 4: Prediction
  ['pred-overtime', 'pred-income', 'pred-years', 'pred-satisfaction'].forEach(id => {
    document.getElementById(id).addEventListener('input', updatePrediction);
  });

  // Exercise 5: Cost optimization
  document.getElementById('cost-fn').addEventListener('input', drawCostCanvas);
  document.getElementById('cost-fp').addEventListener('input', drawCostCanvas);
}

document.addEventListener('astro:page-load', init);
