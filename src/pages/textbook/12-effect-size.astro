// ==================== COHEN'S D EXPLORER ====================
let cohendChart = null;

const COHEND_EXAMPLES = {
  negligible: '사실상 차이 없음. 두 그룹의 분포가 거의 완전히 겹친다.',
  small: '작은 효과. 비타민C 복용이 감기 지속일수를 약 0.5일 줄이는 효과 수준. 육안으로 구분하기 어렵다.',
  medium: '보통 효과. 성별 간 수학 불안 점수 차이 수준. 주의 깊게 보면 차이가 보인다.',
  large: '큰 효과. 인지행동치료의 우울증 감소 효과 수준. 두 그룹의 차이가 명확히 보인다.',
  huge: '매우 큰 효과. 전문 운동선수 vs 일반인의 신체 능력 차이 수준. 두 분포가 거의 분리된다.'
};

async function drawCohenD() {
  const Chart = await loadChart();
  const canvas = document.getElementById('cohend-chart');
  if (cohendChart) { cohendChart.destroy(); cohendChart = null; }

  const d = parseFloat(document.getElementById('cohend-slider').value);
  document.getElementById('cohend-label').textContent = d.toFixed(2);
  document.getElementById('cohend-d').textContent = d.toFixed(2);

  // Determine level
  let level, levelText;
  if (d < 0.1) { level = 'negligible'; levelText = '무시할 수준'; }
  else if (d < 0.35) { level = 'small'; levelText = '작음 (small)'; }
  else if (d < 0.65) { level = 'medium'; levelText = '보통 (medium)'; }
  else if (d < 1.2) { level = 'large'; levelText = '큼 (large)'; }
  else { level = 'huge'; levelText = '매우 큼'; }

  document.getElementById('cohend-level').textContent = levelText;

  // Overlap calculation (approximation: 2 * normalCDF(-d/2))
  const overlap = 2 * normalCDF(-d / 2) * 100;
  // Actually, the overlap for two normal distributions separated by d is:
  // OVL = 2 * Phi(-d/2) where Phi is the standard normal CDF
  const ovl = (2 * normalCDF(-Math.abs(d) / 2) * 100);
  document.getElementById('cohend-overlap').textContent = (100 - (100 - ovl)).toFixed(1) + '%';

  document.getElementById('cohend-example').innerHTML =
    '<strong>' + levelText + ':</strong> ' + COHEND_EXAMPLES[level];

  // Draw two overlapping distributions
  const xMin = -4, xMax = 4 + d, step = 0.05;
  const xs = [];
  const y1 = [], y2 = [];
  for (let x = xMin; x <= xMax; x += step) {
    xs.push(x.toFixed(2));
    y1.push(normalPDF(x, 0, 1));
    y2.push(normalPDF(x, d, 1));
  }

  cohendChart = new Chart(canvas, {
    type: 'line',
    data: {
      labels: xs,
      datasets: [
        {
          label: '그룹 1 (M=0)',
          data: y1,
          borderColor: '#2563eb',
          backgroundColor: '#2563eb22',
          fill: true,
          tension: 0.4,
          pointRadius: 0,
          borderWidth: 2,
        },
        {
          label: '그룹 2 (M=' + d.toFixed(2) + ')',
          data: y2,
          borderColor: '#ef4444',
          backgroundColor: '#ef444422',
          fill: true,
          tension: 0.4,
          pointRadius: 0,
          borderWidth: 2,
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: false,
      plugins: {
        title: {
          display: true,
          text: 'Cohen\'s d = ' + d.toFixed(2) + ' -- 두 정규분포의 분리 정도',
          font: { size: 13, family: "'Paperlogy'" }
        },
        legend: { position: 'top' }
      },
      scales: {
        x: {
          title: { display: true, text: '표준편차 단위' },
          ticks: { maxTicksLimit: 15, callback: function(val, idx) { return idx % 10 === 0 ? this.getLabelForValue(val) : ''; } }
        },
        y: { title: { display: true, text: '밀도' }, beginAtZero: true }
      }
    }
  });
}

// ==================== REPLICATION GAME ====================
let studies = [];
let userPredictions = {};

function generateStudies() {
  studies = [];
  userPredictions = {};
  for (let i = 0; i < 10; i++) {
    const n = [8, 12, 15, 20, 25, 40, 60, 100, 200, 500][Math.floor(Math.random() * 10)];
    const trueD = Math.random() < 0.3 ? 0 : (0.1 + Math.random() * 1.2); // 30% null effects
    // Simulate original study
    let origP, origD;
    // Generate data and compute observed effect
    const g1 = Array.from({length: n}, () => normalRandom());
    const g2 = Array.from({length: n}, () => normalRandom() + trueD);
    const m1 = g1.reduce((a,b)=>a+b,0)/n, m2 = g2.reduce((a,b)=>a+b,0)/n;
    const pooledVar = (g1.reduce((a,v)=>a+(v-m1)**2,0) + g2.reduce((a,v)=>a+(v-m2)**2,0)) / (2*n - 2);
    origD = (m2 - m1) / Math.sqrt(pooledVar);
    origP = zTestPValue(n, Math.abs(origD));

    // Was original significant?
    const origSig = origP < 0.05;

    studies.push({
      id: i + 1,
      n,
      trueD,
      origD: Math.abs(origD),
      origP,
      origSig,
    });
  }

  renderStudies();
}

function renderStudies() {
  const container = document.getElementById('replication-studies');
  container.innerHTML = '';
  document.getElementById('repl-results').style.display = 'none';

  const grid = document.createElement('div');
  grid.style.cssText = 'display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:12px;';

  studies.forEach(s => {
    const card = document.createElement('div');
    card.style.cssText = 'padding:14px; border:2px solid var(--tb-g300); border-radius:var(--tb-radius); cursor:pointer; transition:0.2s;';
    card.dataset.id = s.id;

    const sigLabel = s.origSig
      ? '<span style="color:var(--tb-danger);font-weight:700;">p < 0.05</span>'
      : '<span style="color:var(--tb-g600);">p >= 0.05</span>';

    card.innerHTML = `
      <div style="font-weight:700; margin-bottom:6px;">연구 ${s.id}</div>
      <div style="font-size:0.85rem; color:var(--tb-g600);">
        n = ${s.n} (각 그룹) | d = ${s.origD.toFixed(2)} | p = ${s.origP < 0.001 ? '< 0.001' : s.origP.toFixed(3)}
      </div>
      <div style="font-size:0.85rem; margin-top:4px;">${sigLabel}</div>
      <div style="margin-top:8px; font-size:0.82rem; color:var(--tb-primary); font-weight:600;" id="pred-${s.id}">
        클릭하여 예측: 재현 성공/실패
      </div>
    `;

    card.addEventListener('click', () => {
      if (!userPredictions[s.id]) {
        userPredictions[s.id] = 'success';
        card.style.borderColor = 'var(--tb-success)';
        card.style.background = '#f0fdf4';
        document.getElementById('pred-' + s.id).textContent = '예측: 재현 성공';
      } else if (userPredictions[s.id] === 'success') {
        userPredictions[s.id] = 'fail';
        card.style.borderColor = 'var(--tb-danger)';
        card.style.background = '#fef2f2';
        document.getElementById('pred-' + s.id).textContent = '예측: 재현 실패';
      } else {
        delete userPredictions[s.id];
        card.style.borderColor = 'var(--tb-g300)';
        card.style.background = '';
        document.getElementById('pred-' + s.id).textContent = '클릭하여 예측: 재현 성공/실패';
      }
    });

    grid.appendChild(card);
  });
  container.appendChild(grid);
}

function runReplication() {
  let correct = 0, total = 0;
  let replicated = 0;
  let weakOrigCount = 0, weakReplCount = 0;

  studies.forEach(s => {
    // Run replication: same n, true effect
    const n = s.n;
    const g1 = Array.from({length: n}, () => normalRandom());
    const g2 = Array.from({length: n}, () => normalRandom() + s.trueD);
    const m1 = g1.reduce((a,b)=>a+b,0)/n, m2 = g2.reduce((a,b)=>a+b,0)/n;
    const pooledVar = (g1.reduce((a,v)=>a+(v-m1)**2,0) + g2.reduce((a,v)=>a+(v-m2)**2,0)) / (2*n - 2);
    const replD = (m2 - m1) / Math.sqrt(pooledVar);
    const replP = zTestPValue(n, Math.abs(replD));
    const replSig = replP < 0.05;

    // "Replicated" if original was significant and replication is also significant in same direction
    s.replSuccess = s.origSig && replSig && (replD > 0 === s.origD > 0);
    s.replP = replP;
    s.replD = Math.abs(replD);

    if (s.replSuccess) replicated++;

    // Track weak originals
    if (s.origSig && s.n <= 25 && s.origP > 0.01) {
      weakOrigCount++;
      if (s.replSuccess) weakReplCount++;
    }

    // Check user prediction
    if (userPredictions[s.id]) {
      total++;
      const predicted = userPredictions[s.id] === 'success';
      const actual = s.replSuccess;
      if (predicted === actual) correct++;
    }

    // Update card
    const card = document.querySelector(`[data-id="${s.id}"]`);
    if (card) {
      const resultColor = s.replSuccess ? 'var(--tb-success)' : 'var(--tb-danger)';
      const resultText = s.replSuccess ? '재현 성공' : '재현 실패';
      card.style.borderColor = resultColor;
      const predEl = document.getElementById('pred-' + s.id);
      predEl.innerHTML = `<span style="color:${resultColor};">결과: ${resultText}</span> (repl p = ${s.replP < 0.001 ? '<0.001' : s.replP.toFixed(3)}, d = ${s.replD.toFixed(2)})`;
    }
  });

  document.getElementById('repl-results').style.display = '';
  document.getElementById('repl-accuracy').textContent = total > 0 ? Math.round(correct / total * 100) + '%' : '예측 없음';
  document.getElementById('repl-success').textContent = replicated;
  document.getElementById('repl-weak').textContent = weakOrigCount > 0
    ? weakReplCount + '/' + weakOrigCount + ' (' + Math.round(weakReplCount/weakOrigCount*100) + '%)'
    : 'N/A';

  const interpDiv = document.getElementById('repl-interpretation');
  interpDiv.innerHTML = `<div class="tb-insight">
    <strong>시뮬레이션 결과:</strong>
    10개 연구 중 ${replicated}개가 재현에 성공했다.
    ${weakOrigCount > 0 ? '특히, 작은 표본(n<=25)에서 겨우 유의했던 연구의 재현률은 ' + Math.round(weakReplCount/weakOrigCount*100) + '%에 불과했다.' : ''}
    이는 표본크기가 작고 효과가 불확실한 연구일수록 재현 가능성이 낮다는 것을 보여준다.
  </div>`;
}

// ==================== POWER ANALYSIS ====================
let powerChart = null;

async function runPowerAnalysis() {
  const Chart = await loadChart();
  const d = parseFloat(document.getElementById('power-d').value);
  const alpha = parseFloat(document.getElementById('power-alpha').value);
  const target = parseFloat(document.getElementById('power-target').value);

  const nReq = requiredN(d, alpha, target);

  document.getElementById('power-output').style.display = '';
  document.getElementById('power-n').textContent = nReq;
  document.getElementById('power-d-val').textContent = d;
  document.getElementById('power-target-val').textContent = (target * 100) + '%';
  document.getElementById('power-alpha-val').textContent = alpha;

  // Draw power curve
  const canvas = document.getElementById('power-chart');
  if (powerChart) { powerChart.destroy(); powerChart = null; }

  const ns = [];
  const powers = [];
  const maxN = Math.max(nReq * 2, 200);
  const step = Math.max(1, Math.floor(maxN / 100));
  for (let n = 5; n <= maxN; n += step) {
    ns.push(n);
    powers.push(powerCalc(n, d, alpha));
  }

  powerChart = new Chart(canvas, {
    type: 'line',
    data: {
      labels: ns,
      datasets: [
        {
          label: '검정력 (Power)',
          data: powers,
          borderColor: '#2563eb',
          backgroundColor: '#2563eb22',
          fill: true,
          tension: 0.3,
          pointRadius: 0,
          borderWidth: 2,
        },
        {
          label: '목표 검정력 (' + (target*100) + '%)',
          data: ns.map(() => target),
          borderColor: '#ef4444',
          borderDash: [6, 4],
          pointRadius: 0,
          borderWidth: 2,
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: false,
      plugins: {
        title: {
          display: true,
          text: '검정력 곡선 (d=' + d + ', alpha=' + alpha + ')',
          font: { size: 13, family: "'Paperlogy'" }
        },
        legend: { position: 'top' },
        annotation: {}
      },
      scales: {
        x: { title: { display: true, text: '각 그룹 표본크기 (n)' }, ticks: { maxTicksLimit: 20 } },
        y: { title: { display: true, text: '검정력' }, min: 0, max: 1, ticks: { callback: v => (v*100)+'%' } }
      }
    }
  });

  const interpDiv = document.getElementById('power-interpretation');
  interpDiv.innerHTML = `<div class="tb-explain">
    <strong>해석:</strong>
    효과크기 d = ${d}, 유의수준 alpha = ${alpha}에서 ${(target*100)}% 검정력을 달성하려면
    <strong>각 그룹에 최소 ${nReq}명</strong>이 필요하다 (총 ${nReq * 2}명).
    ${nReq > 500 ? '이는 상당히 큰 표본이 필요함을 의미한다. 효과크기가 작을수록 필요한 표본이 급증한다.' : ''}
    ${d <= 0.2 ? '작은 효과를 검출하려면 매우 큰 표본이 필요하다 -- 연구 계획 단계에서 현실적 가능성을 검토해야 한다.' : ''}
  </div>`;
}

// ==================== INIT ====================
function init() {

  // Scenario comparison
  updateScenarioA();
  updateScenarioB();
  document.getElementById('scA-n').addEventListener('input', updateScenarioA);
  document.getElementById('scA-d').addEventListener('input', updateScenarioA);
  document.getElementById('scB-n').addEventListener('input', updateScenarioB);
  document.getElementById('scB-d').addEventListener('input', updateScenarioB);

  // Cohen's d explorer
  const dSlider = document.getElementById('cohend-slider');
  dSlider.addEventListener('input', drawCohenD);
  document.getElementById('btn-cohend-small').addEventListener('click', () => { dSlider.value = 0.2; drawCohenD(); });
  document.getElementById('btn-cohend-medium').addEventListener('click', () => { dSlider.value = 0.5; drawCohenD(); });
  document.getElementById('btn-cohend-large').addEventListener('click', () => { dSlider.value = 0.8; drawCohenD(); });
  drawCohenD();

  // Replication game
  generateStudies();
  document.getElementById('btn-repl-run').addEventListener('click', runReplication);
  document.getElementById('btn-repl-new').addEventListener('click', generateStudies);

  // Power analysis
  document.getElementById('btn-power').addEventListener('click', runPowerAnalysis);
}

document.addEventListener('DOMContentLoaded', init);
