// ==================== INIT ====================
function init() {
  try {
    import('../../textbook/lib/progress').then(m => m.markVisited('02-roadmap')).catch(() => {});
  } catch(e) {}

  updateProgressStats();
  initWorkflow();
  initPartsOverview();
  drawCurriculumMap();
  initMatchingQuiz();

  // Canvas click
  const canvas = document.getElementById('curriculum-canvas');
  if (canvas) canvas.addEventListener('click', handleCanvasClick);

  // Toggle arrows
  document.getElementById('btn-show-prereqs').addEventListener('click', () => {
    showArrows = !showArrows;
    document.getElementById('btn-show-prereqs').textContent = showArrows ? '화살표 숨기기' : '선수 관계 화살표 표시';
    drawCurriculumMap();
  });

  // Where am I
  document.getElementById('btn-where-am-i').addEventListener('click', () => {
    const visited = getVisited();
    const completedNums = CHAPTERS.filter(c => visited.includes(c.slug)).map(c => c.num);
    const nextUp = CHAPTERS.find(c =>
      !visited.includes(c.slug) &&
      c.prereqs.every(p => completedNums.includes(p))
    );
    if (nextUp) {
      selectedChapter = nextUp.num;
      drawCurriculumMap();
      showChapterDetail(nextUp);
    }
  });

  // Question classifier
  document.getElementById('btn-classify-q').addEventListener('click', classifyQuestion);
  document.getElementById('btn-example-q').addEventListener('click', showExampleQuestion);

  // Quiz
  document.getElementById('btn-check-match').addEventListener('click', checkMatchingQuiz);
  document.getElementById('btn-reset-match').addEventListener('click', initMatchingQuiz);

  // Learning paths
  document.querySelectorAll('.path-btn').forEach(btn => {
    btn.addEventListener('click', () => showLearningPath(btn.dataset.path));
  });
}

document.addEventListener('DOMContentLoaded', init);
document.addEventListener('astro:page-load', init);
</script>

