// ==================== CURRICULUM MAP (Canvas) ====================
let showArrows = true;
let selectedChapter = null;

function getNodePositions() {
  const positions = {};
  const canvasW = 1100;
  const startY = 40;
  const rowH = 90;

  PARTS.forEach((part, pi) => {
    const chapters = part.chapters;
    const y = startY + pi * rowH;
    const totalW = canvasW - 160;
    const spacing = chapters.length > 1 ? totalW / (chapters.length - 1) : 0;
    const startX = chapters.length > 1 ? 130 : canvasW / 2;

    chapters.forEach((cnum, ci) => {
      positions[cnum] = {
        x: startX + ci * spacing,
        y: y + 30,
        part: pi,
        color: part.color
      };
    });
  });

  return positions;
}

function drawCurriculumMap() {
  const canvas = document.getElementById('curriculum-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const w = canvas.width;
  const h = canvas.height;

  // Handle DPI
  const dpr = window.devicePixelRatio || 1;
  canvas.style.width = w + 'px';
  canvas.style.height = h + 'px';

  ctx.clearRect(0, 0, w, h);

  const positions = getNodePositions();
  const visited = getVisited();
  const rowH = 90;
  const startY = 40;

  // Draw part backgrounds
  PARTS.forEach((part, pi) => {
    const y = startY + pi * rowH - 15;
    ctx.fillStyle = part.color + '10';
    ctx.fillRect(0, y, w, rowH - 8);

    // Part label
    ctx.fillStyle = part.color;
    ctx.font = 'bold 12px Paperlogy, sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText(`P${part.id}: ${part.title}`, 10, y + 40);
  });

  // Draw prerequisite arrows
  if (showArrows) {
    ctx.strokeStyle = '#94a3b8';
    ctx.lineWidth = 1;
    CHAPTERS.forEach(ch => {
      const to = positions[ch.num];
      if (!to) return;
      ch.prereqs.forEach(pre => {
        const from = positions[pre];
        if (!from) return;
        ctx.beginPath();
        ctx.moveTo(from.x, from.y + 15);
        ctx.lineTo(to.x, to.y - 15);
        ctx.stroke();

        // Arrow head
        const angle = Math.atan2(to.y - 15 - (from.y + 15), to.x - from.x);
        ctx.beginPath();
        ctx.moveTo(to.x, to.y - 15);
        ctx.lineTo(to.x - 8 * Math.cos(angle - 0.4), to.y - 15 - 8 * Math.sin(angle - 0.4));
        ctx.lineTo(to.x - 8 * Math.cos(angle + 0.4), to.y - 15 - 8 * Math.sin(angle + 0.4));
        ctx.closePath();
        ctx.fillStyle = '#94a3b8';
        ctx.fill();
      });
    });
  }

  // Draw nodes
  CHAPTERS.forEach(ch => {
    const pos = positions[ch.num];
    if (!pos) return;
    const isVisited = visited.includes(ch.slug);
    const isSelected = selectedChapter === ch.num;
    const r = 16;

    // Node circle
    ctx.beginPath();
    ctx.arc(pos.x, pos.y, r, 0, Math.PI * 2);
    if (isSelected) {
      ctx.fillStyle = pos.color;
      ctx.fill();
      ctx.strokeStyle = '#1e293b';
      ctx.lineWidth = 3;
      ctx.stroke();
    } else if (isVisited) {
      ctx.fillStyle = '#22c55e';
      ctx.fill();
      ctx.strokeStyle = '#16a34a';
      ctx.lineWidth = 2;
      ctx.stroke();
    } else {
      ctx.fillStyle = '#ffffff';
      ctx.fill();
      ctx.strokeStyle = pos.color;
      ctx.lineWidth = 2;
      ctx.stroke();
    }

    // Chapter number
    ctx.fillStyle = isSelected || isVisited ? '#ffffff' : pos.color;
    ctx.font = 'bold 11px Paperlogy, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(String(ch.num), pos.x, pos.y);
  });
}

function handleCanvasClick(e) {
  const canvas = document.getElementById('curriculum-canvas');
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.width / rect.width;
  const scaleY = canvas.height / rect.height;
  const mx = (e.clientX - rect.left) * scaleX;
  const my = (e.clientY - rect.top) * scaleY;

  const positions = getNodePositions();
  let clicked = null;

  for (const ch of CHAPTERS) {
    const pos = positions[ch.num];
    if (!pos) continue;
    const dist = Math.sqrt((mx - pos.x) ** 2 + (my - pos.y) ** 2);
    if (dist < 20) {
      clicked = ch;
      break;
    }
  }

  if (clicked) {
    selectedChapter = clicked.num;
    drawCurriculumMap();
    showChapterDetail(clicked);
  }
}

function showChapterDetail(ch) {
  const panel = document.getElementById('chapter-detail-panel');
  panel.style.display = '';
  const visited = getVisited();
  const isVisited = visited.includes(ch.slug);
  const part = PARTS.find(p => p.chapters.includes(ch.num));

  document.getElementById('detail-title').textContent = `${ch.num}장: ${ch.title}`;
  document.getElementById('detail-subtitle').textContent = ch.desc;
  document.getElementById('detail-prereqs').innerHTML =
    ch.prereqs.length > 0
      ? '<strong>선수 과목:</strong> ' + ch.prereqs.map(p => {
          const pre = CHAPTERS.find(c => c.num === p);
          return `${p}장 (${pre ? pre.title : ''})`;
        }).join(', ')
      : '<strong>선수 과목:</strong> 없음 (시작 가능)';
  document.getElementById('detail-learn').innerHTML = `<strong>배울 내용:</strong> ${ch.learn}`;
  document.getElementById('detail-status').innerHTML = isVisited
    ? '<span style="color:var(--tb-success);font-weight:700;">완료</span>'
    : `<span style="color:var(--tb-g600);">Part ${part ? part.id : '?'} - ${part ? part.title : ''}</span>`;
}

// ==================== RESEARCH QUESTION CLASSIFIER ====================
const QUESTION_KEYWORDS = {
  descriptive: {
    keywords: ['평균', '분포', '현황', '어떤', '얼마나', '현재', '비율', '빈도', '몇', '상태', '추이', '요약', '기술'],
    label: '기술적 (Descriptive)',
    desc: '현재 상태를 요약하고 설명하는 질문입니다.',
    chapters: [3, 4, 5, 6, 7],
    color: '#2563eb'
  },
  inferential: {
    keywords: ['차이', '유의', '검정', '비교', '통계적', '다른가', '같은가', '효과', '관계', '달라', '신뢰', '유의미'],
    label: '추론적 (Inferential)',
    desc: '표본 결과로부터 모집단에 대한 결론을 도출하는 질문입니다.',
    chapters: [8, 9, 10, 11, 12, 13, 14],
    color: '#7c3aed'
  },
  predictive: {
    keywords: ['예측', '미래', '전망', '다음', '얼마', '될까', '예상', '추정', '분류', '판별', '예보', '모델'],
    label: '예측적 (Predictive)',
    desc: '미래의 결과를 예측하거나 새로운 데이터를 분류하는 질문입니다.',
    chapters: [15, 16, 17, 18, 22, 23, 24, 25, 26, 27, 28],
    color: '#ea580c'
  },
  causal: {
    keywords: ['영향', '원인', '인과', '때문', '때문에', '일으키', '효과', '미치', '변화시', '개선', '증가시', '감소시', '처리', '실험'],
    label: '인과적 (Causal)',
    desc: 'X가 Y를 일으키는지, 원인-결과 관계를 파악하는 질문입니다.',
    chapters: [10, 11, 15, 16, 17, 18],
    color: '#059669'
  }
};

function classifyQuestion() {
  const input = document.getElementById('question-input').value.trim();
  if (!input) return;

  const scores = {};
  for (const [type, info] of Object.entries(QUESTION_KEYWORDS)) {
    scores[type] = 0;
    info.keywords.forEach(kw => {
      if (input.includes(kw)) scores[type]++;
    });
  }

  // Find best match (default to descriptive)
  let bestType = 'descriptive';
  let bestScore = 0;
  for (const [type, score] of Object.entries(scores)) {
    if (score > bestScore) {
      bestType = type;
      bestScore = score;
    }
  }

  const info = QUESTION_KEYWORDS[bestType];
  const resultDiv = document.getElementById('classification-result');
  resultDiv.style.display = '';
  resultDiv.innerHTML = `
    <div class="tb-explain" style="border-left-color: ${info.color};">
      <strong style="color: ${info.color};">${info.label}</strong>
      <p style="margin-top: 6px;">${info.desc}</p>
      <p style="margin-top: 8px; font-size: .9rem;">
        <strong>추천 장:</strong> ${info.chapters.map(n => {
          const ch = CHAPTERS.find(c => c.num === n);
          return `${n}장 (${ch ? ch.title : ''})`;
        }).join(', ')}
      </p>
      ${bestScore === 0 ? '<p style="margin-top:8px;font-size:.85rem;color:var(--tb-g600);">키워드가 명확하지 않아 기본적으로 기술적 분석으로 분류했습니다. 질문을 더 구체적으로 작성해 보세요.</p>' : ''}
    </div>
  `;

  // Highlight matching type card
  document.querySelectorAll('.q-type-card').forEach(card => {
    card.classList.remove('q-type-active');
    if (card.dataset.type === bestType) card.classList.add('q-type-active');
  });
}

