  { q: '온라인 광고의 클릭률과 전환율 사이에 관계가 있는가?', a: 'inferential', hint: '관계 검증 -- 추론적 질문' },
  { q: '신규 매장 위치에 따라 첫해 매출이 얼마나 될지 추정하라', a: 'predictive', hint: '새로운 상황에 대한 예측' },
];

let currentQuizItems = [];

function initMatchingQuiz() {
  const container = document.getElementById('matching-quiz');
  container.innerHTML = '';
  document.getElementById('quiz-results').style.display = 'none';

  const shuffled = [...QUIZ_POOL].sort(() => Math.random() - 0.5);
  currentQuizItems = shuffled.slice(0, 5);

  currentQuizItems.forEach((item, i) => {
    const div = document.createElement('div');
    div.style.cssText = 'padding: 12px 0; border-bottom: 1px solid var(--tb-g200);';
    div.innerHTML = `
      <p style="font-weight: 600; margin-bottom: 8px;">${i + 1}. ${item.q}</p>
      <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <label class="quiz-option"><input type="radio" name="mq${i}" value="descriptive"> 기술적</label>
        <label class="quiz-option"><input type="radio" name="mq${i}" value="inferential"> 추론적</label>
        <label class="quiz-option"><input type="radio" name="mq${i}" value="predictive"> 예측적</label>
        <label class="quiz-option"><input type="radio" name="mq${i}" value="causal"> 인과적</label>
      </div>
      <div class="mq-feedback" data-idx="${i}" style="display:none; margin-top: 6px; font-size: .88rem;"></div>
    `;
    container.appendChild(div);
  });
}

function checkMatchingQuiz() {
  let correct = 0;

  currentQuizItems.forEach((item, i) => {
    const selected = document.querySelector(`input[name="mq${i}"]:checked`);
    const fb = document.querySelector(`.mq-feedback[data-idx="${i}"]`);
    fb.style.display = '';

    if (!selected) {
      fb.textContent = '선택하지 않았습니다.';
      fb.style.color = 'var(--tb-g600)';
      return;
    }

    if (selected.value === item.a) {
      correct++;
      fb.textContent = '정답! ' + item.hint;
      fb.style.color = 'var(--tb-success)';
      selected.parentElement.style.background = '#dcfce7';
    } else {
      fb.textContent = '오답. ' + item.hint;
      fb.style.color = 'var(--tb-danger)';
      selected.parentElement.style.background = '#fee2e2';
    }
  });

  document.getElementById('quiz-results').style.display = '';
  document.getElementById('match-correct').textContent = correct;
  document.getElementById('match-total').textContent = currentQuizItems.length;
  document.getElementById('match-rate').textContent = Math.round(correct / currentQuizItems.length * 100) + '%';
}

