<script>
// ==================== UTILITY ====================
const el = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };

// ==================== CHART.JS LOADER ====================
let ChartJS = null;
async function loadChart() {
  if (ChartJS) return;
  const mod = await import('https://cdn.jsdelivr.net/npm/chart.js@4/+esm');
  ChartJS = mod.Chart;
}

// ==================== INTERACTIVE 1: ATTENTION VISUALIZER ====================
const SENTENCES = [
  { words: ['은행', '에서', '돈', '을', '빌렸다'], attn: [[0.15,0.05,0.45,0.05,0.30],[0.30,0.10,0.20,0.10,0.30],[0.40,0.05,0.15,0.10,0.30],[0.10,0.20,0.30,0.20,0.20],[0.25,0.10,0.35,0.05,0.25]] },
  { words: ['은행나무', '잎', '이', '떨어진다'], attn: [[0.30,0.40,0.05,0.25],[0.35,0.20,0.05,0.40],[0.15,0.15,0.40,0.30],[0.20,0.35,0.05,0.40]] },
  { words: ['나', '는', '어제', '학교', '에서', '친구', '를', '만났다'], attn: [[0.20,0.05,0.10,0.10,0.05,0.15,0.05,0.30],[0.30,0.15,0.10,0.10,0.05,0.10,0.05,0.15],[0.10,0.05,0.25,0.10,0.10,0.10,0.05,0.25],[0.05,0.05,0.10,0.25,0.30,0.10,0.05,0.10],[0.05,0.05,0.10,0.35,0.20,0.10,0.05,0.10],[0.15,0.05,0.10,0.10,0.10,0.20,0.10,0.20],[0.10,0.05,0.05,0.05,0.05,0.40,0.15,0.20],[0.20,0.05,0.15,0.10,0.05,0.20,0.05,0.20]] },
  { words: ['그', '영화', '는', '정말', '감동적', '이었다'], attn: [[0.10,0.40,0.05,0.15,0.20,0.10],[0.10,0.15,0.05,0.20,0.35,0.15],[0.15,0.30,0.10,0.15,0.15,0.15],[0.05,0.10,0.05,0.15,0.45,0.20],[0.05,0.15,0.05,0.30,0.20,0.25],[0.10,0.15,0.05,0.20,0.35,0.15]] }
];

let selectedWord = -1;

function drawHeatmap(sentIdx) {
  const canvas = document.getElementById('attn-heatmap');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const sent = SENTENCES[sentIdx];
  const n = sent.words.length;
  const pad = 60;
  const cellW = (W - pad) / n;
  const cellH = (H - pad) / n;

  // Column labels (top)
  ctx.font = '11px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillStyle = '#475569';
  sent.words.forEach((w, i) => {
    ctx.fillText(w, pad + i * cellW + cellW / 2, pad - 8);
  });

  // Row labels (left)
  ctx.textAlign = 'right';
  sent.words.forEach((w, i) => {
    ctx.fillText(w, pad - 8, pad + i * cellH + cellH / 2 + 4);
  });

  // Heatmap cells
  for (let r = 0; r < n; r++) {
    for (let c = 0; c < n; c++) {
      const val = sent.attn[r][c];
      const intensity = Math.round(val * 255);
      ctx.fillStyle = `rgb(${255 - intensity}, ${255 - intensity * 0.5}, 255)`;
      ctx.fillRect(pad + c * cellW, pad + r * cellH, cellW - 1, cellH - 1);

      // Value text
      ctx.fillStyle = val > 0.3 ? '#fff' : '#475569';
      ctx.font = '10px Paperlogy, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(val.toFixed(2), pad + c * cellW + cellW / 2, pad + r * cellH + cellH / 2);
    }
  }

  // Highlight selected row
  if (selectedWord >= 0 && selectedWord < n) {
    ctx.strokeStyle = '#2563eb';
    ctx.lineWidth = 2;
    ctx.strokeRect(pad, pad + selectedWord * cellH, (W - pad), cellH);
  }
}

function drawAttnLines(sentIdx) {
  const canvas = document.getElementById('attn-lines');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const sent = SENTENCES[sentIdx];
  const n = sent.words.length;
  const yTop = 60, yBottom = H - 60;
  const xPad = 40;

  // Draw words on top and bottom
  ctx.font = '13px Paperlogy, sans-serif';
  ctx.textAlign = 'center';

  sent.words.forEach((w, i) => {
    const x = xPad + (i / (n - 1 || 1)) * (W - 2 * xPad);

    ctx.fillStyle = (i === selectedWord) ? '#2563eb' : '#475569';
    ctx.font = (i === selectedWord) ? 'bold 14px Paperlogy, sans-serif' : '13px Paperlogy, sans-serif';
    ctx.fillText(w, x, yTop - 10);
    ctx.fillText(w, x, yBottom + 20);

    // Dots
    ctx.beginPath();
    ctx.arc(x, yTop, 5, 0, Math.PI * 2);
    ctx.fillStyle = (i === selectedWord) ? '#2563eb' : '#94a3b8';
    ctx.fill();

    ctx.beginPath();
    ctx.arc(x, yBottom, 5, 0, Math.PI * 2);
    ctx.fill();
  });

  // Draw attention lines from selected word
  if (selectedWord >= 0 && selectedWord < n) {
    const fromX = xPad + (selectedWord / (n - 1 || 1)) * (W - 2 * xPad);
    sent.attn[selectedWord].forEach((weight, j) => {
      const toX = xPad + (j / (n - 1 || 1)) * (W - 2 * xPad);
      ctx.beginPath();
      ctx.moveTo(fromX, yTop + 8);
      ctx.lineTo(toX, yBottom - 8);
      ctx.strokeStyle = `rgba(37, 99, 235, ${Math.min(weight * 2.5, 1)})`;
      ctx.lineWidth = Math.max(1, weight * 8);
      ctx.stroke();
    });
    el('attn-focus-word', `"${sent.words[selectedWord]}"이(가) 주목하는 단어`);
  } else {
    el('attn-focus-word', '위 히트맵에서 단어를 클릭하세요');
  }
}

function setupAttention() {
  const sentSelect = document.getElementById('attn-sentence');
  if (!sentSelect) return;

  const redraw = () => {
    const idx = parseInt(sentSelect.value);
    selectedWord = -1;
    drawHeatmap(idx);
    drawAttnLines(idx);
  };

  sentSelect.addEventListener('change', redraw);

  // Click on heatmap to select word
  const heatCanvas = document.getElementById('attn-heatmap');
  if (heatCanvas) {
    heatCanvas.addEventListener('click', (e) => {
      const idx = parseInt(sentSelect.value);
      const sent = SENTENCES[idx];
      const n = sent.words.length;
      const rect = heatCanvas.getBoundingClientRect();
      const scaleY = heatCanvas.height / rect.height;
      const py = (e.clientY - rect.top) * scaleY;
      const pad = 60;
      const cellH = (heatCanvas.height - pad) / n;
      const row = Math.floor((py - pad) / cellH);
      if (row >= 0 && row < n) {
        selectedWord = row;
        drawHeatmap(idx);
        drawAttnLines(idx);
      }
    });
  }

  redraw();
}

// ==================== INTERACTIVE 2: NEXT TOKEN PREDICTOR ====================
// Simple Korean n-gram model
const NGRAMS = {
  '오늘': [['날씨', 0.30], ['점심', 0.20], ['아침', 0.15], ['하루', 0.15], ['밤', 0.10], ['저녁', 0.10]],
  '날씨': [['가', 0.35], ['좋다', 0.25], ['맑다', 0.15], ['흐리다', 0.10], ['춥다', 0.15]],
  '가': [['좋다', 0.30], ['나쁘다', 0.15], ['맑다', 0.15], ['흐리다', 0.10], ['덥다', 0.10], ['춥다', 0.10], ['변하다', 0.10]],
  '점심': [['먹다', 0.30], ['메뉴', 0.20], ['시간', 0.20], ['약속', 0.15], ['맛있다', 0.15]],
  '아침': [['일찍', 0.25], ['밥', 0.20], ['운동', 0.20], ['출근', 0.15], ['커피', 0.20]],
  '하루': [['종일', 0.25], ['빨리', 0.20], ['행복', 0.15], ['피곤', 0.20], ['보내다', 0.20]],
  '나는': [['오늘', 0.20], ['학생', 0.20], ['매일', 0.15], ['어제', 0.15], ['정말', 0.15], ['항상', 0.15]],
  '학생': [['이다', 0.30], ['시절', 0.20], ['생활', 0.15], ['들이', 0.20], ['때', 0.15]],
  '인공': [['지능', 0.50], ['위성', 0.15], ['호흡', 0.10], ['눈물', 0.05], ['관절', 0.10], ['수정', 0.10]],
  '지능': [['기술', 0.25], ['연구', 0.20], ['발전', 0.20], ['시대', 0.15], ['모델', 0.20]],
  '데이터': [['분석', 0.30], ['과학', 0.20], ['수집', 0.15], ['처리', 0.15], ['활용', 0.20]],
  '분석': [['결과', 0.25], ['방법', 0.20], ['도구', 0.15], ['기법', 0.20], ['보고서', 0.20]],
  '좋다': [['정말', 0.25], ['매우', 0.20], ['너무', 0.15], ['오늘', 0.20], ['항상', 0.20]],
  // default fallback
  '__default__': [['그리고', 0.15], ['하지만', 0.15], ['때문에', 0.12], ['그래서', 0.12], ['또한', 0.10], ['이것은', 0.10], ['그러나', 0.10], ['우리', 0.08], ['매우', 0.08]]
};

let genChart = null;
let generatedText = [];

function applyTemperature(probs, temp) {
  const logits = probs.map(([w, p]) => [w, Math.log(Math.max(p, 1e-8)) / temp]);
  const maxLogit = Math.max(...logits.map(l => l[1]));
  const exps = logits.map(([w, l]) => [w, Math.exp(l - maxLogit)]);
  const sumExp = exps.reduce((s, [, e]) => s + e, 0);
  return exps.map(([w, e]) => [w, e / sumExp]);
}

async function setupNextToken() {
  await loadChart();

  const runPredict = () => {
    const input = document.getElementById('gen-input')?.value?.trim() || '';
    if (!input) return;

    if (generatedText.length === 0) generatedText = [input];

    const lastWord = generatedText[generatedText.length - 1];
    const temp = parseFloat(document.getElementById('gen-temp')?.value || '1.0');

    let candidates = NGRAMS[lastWord] || NGRAMS['__default__'];
    candidates = applyTemperature(candidates, temp);

    // Sort by probability
    candidates.sort((a, b) => b[1] - a[1]);
    const top5 = candidates.slice(0, 5);

    // Render output text
    const outputDiv = document.getElementById('gen-output');
    if (outputDiv) {
      outputDiv.innerHTML = generatedText.map((w, i) =>
        `<span style="display:inline;${i === generatedText.length - 1 ? 'color:var(--tb-primary);font-weight:700;text-decoration:underline;' : ''}">${w}</span>`
      ).join(' ');
    }

    // Render candidates
    const candDiv = document.getElementById('gen-candidates');
    if (candDiv) {
      candDiv.innerHTML = top5.map(([w, p]) =>
        `<button class="tb-btn" style="padding:8px 16px;background:var(--tb-primary-light);color:var(--tb-primary);border:2px solid var(--tb-primary);font-family:Paperlogy,sans-serif;" data-word="${w}">${w} <span style="font-size:0.8rem;opacity:0.7;">(${(p * 100).toFixed(1)}%)</span></button>`
      ).join('');

      // Click handler for candidates
      candDiv.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          const word = btn.getAttribute('data-word');
          generatedText.push(word);
          document.getElementById('gen-input').value = word;
          runPredict();
        });
      });
    }

    // Update probability chart
    updateGenChart(top5);
  };

  document.getElementById('gen-temp')?.addEventListener('input', function () {
    el('gen-temp-val', parseFloat(this.value).toFixed(1));
  });

  document.getElementById('btn-gen-predict')?.addEventListener('click', () => {
    generatedText = [document.getElementById('gen-input')?.value?.trim() || ''];
    runPredict();
  });

  document.getElementById('btn-gen-clear')?.addEventListener('click', () => {
    generatedText = [];
    const outputDiv = document.getElementById('gen-output');
    if (outputDiv) outputDiv.innerHTML = '';
    const candDiv = document.getElementById('gen-candidates');
    if (candDiv) candDiv.innerHTML = '';
    if (genChart) { genChart.destroy(); genChart = null; }
  });
}

function updateGenChart(top5) {
  const canvas = document.getElementById('gen-prob-chart');
  if (!canvas || !ChartJS) return;

  const labels = top5.map(([w]) => w);
  const data = top5.map(([, p]) => (p * 100));
  const bgColors = ['#2563eb', '#3b82f6', '#60a5fa', '#93c5fd', '#bfdbfe'];

  if (genChart) {
    genChart.data.labels = labels;
    genChart.data.datasets[0].data = data;
    genChart.update('none');
  } else {
    genChart = new ChartJS(canvas, {
      type: 'bar',
      data: {
        labels,
        datasets: [{ label: '확률 (%)', data, backgroundColor: bgColors, borderRadius: 6 }]
      },
      options: {
        responsive: true, maintainAspectRatio: false, animation: false,
        indexAxis: 'y',
        plugins: { legend: { display: false } },
        scales: {
          x: { beginAtZero: true, max: 60, title: { display: true, text: '확률 (%)', font: { family: "'Paperlogy'" } }, ticks: { font: { size: 10 } } },
          y: { ticks: { font: { family: "'Paperlogy'", size: 12, weight: '700' } } }
        }
      }
    });
  }
}

// ==================== INTERACTIVE 3: TRANSFORMER vs RNN COMPARISON ====================
const COMP_WORDS = ['나는', '어제', '학교에서', '친구를', '만나서', '기뻤다'];
let compRunning = false;

function drawCompCanvas(canvasId, words, active, connections) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const n = words.length;
  const yCenter = H / 2;
  const xPad = 30;
  const gap = (W - 2 * xPad) / (n - 1 || 1);

  // Draw connections
  if (connections) {
    connections.forEach(([from, to]) => {
      const x1 = xPad + from * gap, x2 = xPad + to * gap;
      ctx.beginPath();
      ctx.moveTo(x1, yCenter - 10);
      ctx.quadraticCurveTo((x1 + x2) / 2, yCenter - 50 - Math.abs(to - from) * 10, x2, yCenter - 10);
      ctx.strokeStyle = 'rgba(37,99,235,0.3)';
      ctx.lineWidth = 2;
      ctx.stroke();
    });
  }

  // Draw word boxes
  words.forEach((w, i) => {
    const x = xPad + i * gap;
    const isActive = active.includes(i);

    ctx.fillStyle = isActive ? '#2563eb' : '#e2e8f0';
    const boxW = 60, boxH = 36;
    ctx.beginPath();
    ctx.roundRect(x - boxW / 2, yCenter - boxH / 2, boxW, boxH, 8);
    ctx.fill();

    ctx.font = isActive ? 'bold 11px Paperlogy, sans-serif' : '11px Paperlogy, sans-serif';
    ctx.fillStyle = isActive ? '#fff' : '#475569';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(w, x, yCenter);

    // Processing indicator
    if (isActive) {
      ctx.beginPath();
      ctx.arc(x, yCenter + boxH / 2 + 12, 4, 0, Math.PI * 2);
      ctx.fillStyle = '#22c55e';
      ctx.fill();
    }
  });
}

function setupComparison() {
  let compStep = 0;
  let compAnimFrame = null;

  document.getElementById('btn-compare-run')?.addEventListener('click', () => {
    if (compRunning) return;
    compRunning = true;
    compStep = 0;

    const n = COMP_WORDS.length;

    function tick() {
      if (!compRunning) return;

      // RNN: process one word at a time
      const rnnActive = compStep < n ? [compStep] : Array.from({ length: n }, (_, i) => i);
      const rnnDone = Math.min(compStep + 1, n);
      drawCompCanvas('compare-rnn', COMP_WORDS, rnnActive, null);
      el('comp-rnn-done', `${rnnDone}/${n}`);
      el('comp-rnn-steps', Math.min(compStep + 1, n).toString());

      // Transformer: all at once (show all active after step 0)
      if (compStep === 0) {
        // Step 0: show initial state
        drawCompCanvas('compare-tf', COMP_WORDS, [], null);
        el('comp-tf-done', `0/${n}`);
        el('comp-tf-steps', '0');
      } else {
        // All words processed simultaneously with connections
        const allActive = Array.from({ length: n }, (_, i) => i);
        const conns = [];
        for (let i = 0; i < n; i++) {
          for (let j = 0; j < n; j++) {
            if (i !== j && Math.random() > 0.5) conns.push([i, j]);
          }
        }
        drawCompCanvas('compare-tf', COMP_WORDS, allActive, conns);
        el('comp-tf-done', `${n}/${n}`);
        el('comp-tf-steps', '1');
      }

      compStep++;
      if (compStep <= n) {
        compAnimFrame = setTimeout(tick, 700);
      } else {
        compRunning = false;
      }
    }
    tick();
  });

  document.getElementById('btn-compare-reset')?.addEventListener('click', () => {
    compRunning = false;
    if (compAnimFrame) clearTimeout(compAnimFrame);
    drawCompCanvas('compare-rnn', COMP_WORDS, [], null);
    drawCompCanvas('compare-tf', COMP_WORDS, [], null);
    el('comp-rnn-done', '0/6'); el('comp-rnn-steps', '0');
    el('comp-tf-done', '0/6'); el('comp-tf-steps', '0');
  });

  // Initial draw
  drawCompCanvas('compare-rnn', COMP_WORDS, [], null);
  drawCompCanvas('compare-tf', COMP_WORDS, [], null);
}

