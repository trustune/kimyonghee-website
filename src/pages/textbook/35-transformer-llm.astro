function setupQuiz() {
  const container = document.getElementById('quiz-container');
  if (!container) return;

  container.innerHTML = QUIZ_DATA.map((q, i) => `
    <div class="tb-card" style="margin-bottom: 12px; padding: 16px;" id="quiz-q${i}">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
        <span class="tb-badge" style="background: var(--tb-primary-light); color: var(--tb-primary);">${q.type}</span>
        <span style="font-weight: 700; font-size: 0.95rem;">문제 ${i + 1}</span>
      </div>
      <p style="margin-bottom: 12px;">${q.question}</p>
      <div style="display: flex; gap: 8px;">
        <button class="tb-btn quiz-choice" data-q="${i}" data-v="possible" style="padding:6px 16px;background:#dcfce7;color:#16a34a;border:2px solid transparent;">LLM 가능</button>
        <button class="tb-btn quiz-choice" data-q="${i}" data-v="difficult" style="padding:6px 16px;background:#fee2e2;color:#dc2626;border:2px solid transparent;">LLM 어려움</button>
      </div>
      <div id="quiz-explain-${i}" style="display:none;margin-top:12px;"></div>
    </div>
  `).join('');

  // Choice handlers
  const userAnswers = {};
  container.querySelectorAll('.quiz-choice').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = parseInt(btn.getAttribute('data-q'));
      const v = btn.getAttribute('data-v');
      userAnswers[q] = v;

      // Highlight selected
      container.querySelectorAll(`[data-q="${q}"]`).forEach(b => {
        b.style.borderColor = 'transparent';
        b.style.fontWeight = '400';
      });
      btn.style.borderColor = v === 'possible' ? '#16a34a' : '#dc2626';
      btn.style.fontWeight = '700';
    });
  });

  // Reveal answers
  document.getElementById('btn-quiz-reveal')?.addEventListener('click', () => {
    let correct = 0;
    QUIZ_DATA.forEach((q, i) => {
      const explainDiv = document.getElementById(`quiz-explain-${i}`);
      if (!explainDiv) return;

      const isCorrect = userAnswers[i] === q.answer;
      if (isCorrect) correct++;

      const icon = isCorrect ? 'O' : 'X';
      const color = isCorrect ? '#16a34a' : '#dc2626';
      explainDiv.style.display = 'block';
      explainDiv.innerHTML = `
        <div style="padding:12px;background:${isCorrect ? '#f0fdf4' : '#fef2f2'};border-radius:8px;">
          <span style="font-weight:700;color:${color};font-size:1.1rem;">${icon}</span>
          <span style="font-weight:600;margin-left:8px;">정답: ${q.answer === 'possible' ? 'LLM 가능' : 'LLM 어려움'}</span>
          <p style="margin-top:8px;font-size:0.88rem;">${q.explanation}</p>
        </div>
      `;
    });

    const resultDiv = document.getElementById('quiz-result');
    if (resultDiv) resultDiv.style.display = 'block';
    el('quiz-correct', correct.toString());
  });

  document.getElementById('btn-quiz-reset')?.addEventListener('click', () => {
    Object.keys(userAnswers).forEach(k => delete userAnswers[k]);
    QUIZ_DATA.forEach((_, i) => {
      const explainDiv = document.getElementById(`quiz-explain-${i}`);
      if (explainDiv) explainDiv.style.display = 'none';
      container.querySelectorAll(`[data-q="${i}"]`).forEach(b => {
        b.style.borderColor = 'transparent';
        b.style.fontWeight = '400';
      });
    });
    const resultDiv = document.getElementById('quiz-result');
    if (resultDiv) resultDiv.style.display = 'none';
  });
}

