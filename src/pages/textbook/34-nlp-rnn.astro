// ==================== INTERACTIVE 1: TOKENIZER ====================
function simpleSubwordTokenize(text) {
  // Simplified BPE-like tokenization for Korean
  const commonPairs = ['자연어', '처리', '인공', '지능', '기술', '입니다', '니다', '습니다', '에서', '으로', '하다', '이다', '있다', '었다', '했다'];
  let remaining = text.replace(/\s+/g, ' ').trim();
  const tokens = [];
  let i = 0;

  while (i < remaining.length) {
    if (remaining[i] === ' ') { i++; continue; }

    let matched = false;
    // Try longest common subword first
    for (let len = Math.min(4, remaining.length - i); len >= 2; len--) {
      const sub = remaining.substring(i, i + len);
      if (commonPairs.includes(sub)) {
        tokens.push(sub);
        i += len;
        matched = true;
        break;
      }
    }

    if (!matched) {
      // Syllable block as token
      tokens.push(remaining[i]);
      i++;
    }
  }
  return tokens;
}

function renderTokens(containerId, tokens, bgColor) {
  const container = document.getElementById(containerId);
  if (!container) return;
  container.innerHTML = tokens.map(t =>
    `<span style="display:inline-block;padding:4px 10px;background:${bgColor};border-radius:6px;font-size:0.88rem;font-weight:600;font-family:Paperlogy,sans-serif;border:1px solid rgba(0,0,0,0.1);">${t}</span>`
  ).join('');
}

function setupTokenizer() {
  const runTokenize = () => {
    const text = document.getElementById('tok-input')?.value || '';
    if (!text.trim()) return;

    // Character-level
    const charTokens = text.replace(/\s/g, '').split('');
    renderTokens('tok-char-result', charTokens, '#dbeafe');
    el('tok-char-count', `(${charTokens.length}개)`);
    el('tok-stat-char', charTokens.length.toString());

    // Word-level (space-separated)
    const wordTokens = text.trim().split(/\s+/);
    renderTokens('tok-word-result', wordTokens, '#dcfce7');
    el('tok-word-count', `(${wordTokens.length}개)`);
    el('tok-stat-word', wordTokens.length.toString());

    // Subword-level
    const bpeTokens = simpleSubwordTokenize(text);
    renderTokens('tok-bpe-result', bpeTokens, '#fef3c7');
    el('tok-bpe-count', `(${bpeTokens.length}개)`);
    el('tok-stat-bpe', bpeTokens.length.toString());
  };

  document.getElementById('btn-tokenize')?.addEventListener('click', runTokenize);
  document.getElementById('tok-input')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') runTokenize(); });
  runTokenize();
}

// ==================== INTERACTIVE 2: BoW vs TF-IDF ====================
function setupTFIDF() {
  document.getElementById('btn-tfidf')?.addEventListener('click', () => {
    const doc1 = (document.getElementById('tfidf-doc1')?.value || '').trim().split(/\s+/);
    const doc2 = (document.getElementById('tfidf-doc2')?.value || '').trim().split(/\s+/);

    // Build vocabulary
    const vocab = [...new Set([...doc1, ...doc2])].sort();
    const n = 2; // total documents

    // BoW
    const bow1 = {}, bow2 = {};
    doc1.forEach(w => bow1[w] = (bow1[w] || 0) + 1);
    doc2.forEach(w => bow2[w] = (bow2[w] || 0) + 1);

    // TF-IDF
    const tfidf1 = {}, tfidf2 = {};
    vocab.forEach(w => {
      const df = (bow1[w] ? 1 : 0) + (bow2[w] ? 1 : 0);
      const idf = Math.log(n / df);
      tfidf1[w] = ((bow1[w] || 0) / doc1.length) * idf;
      tfidf2[w] = ((bow2[w] || 0) / doc2.length) * idf;
    });

    // Render BoW table
    const bowTbody = document.getElementById('bow-tbody');
    if (bowTbody) {
      bowTbody.innerHTML = vocab.map(w => {
        const v1 = bow1[w] || 0, v2 = bow2[w] || 0;
        const common = v1 > 0 && v2 > 0;
        return `<tr style="${common ? 'background:#fef3c7;' : ''}"><td style="font-weight:600;">${w}</td><td>${v1}</td><td>${v2}</td></tr>`;
      }).join('');
    }

    // Render TF-IDF table
    const tfidfTbody = document.getElementById('tfidf-tbody');
    if (tfidfTbody) {
      tfidfTbody.innerHTML = vocab.map(w => {
        const v1 = tfidf1[w] || 0, v2 = tfidf2[w] || 0;
        const isZero = v1 === 0 && v2 === 0;
        return `<tr style="${isZero ? 'color:var(--tb-g300);' : ''}"><td style="font-weight:600;">${w}</td><td>${v1.toFixed(3)}</td><td>${v2.toFixed(3)}</td></tr>`;
      }).join('');
    }
  });

  // Auto-run
  document.getElementById('btn-tfidf')?.click();
}

