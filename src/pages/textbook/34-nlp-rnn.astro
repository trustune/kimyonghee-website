const CAT_COLORS = { '음식': '#2563eb', '감정': '#16a34a', '직업': '#92400e', '가족': '#be185d', '장소': '#4338ca' };

function drawEmbeddingCanvas() {
  const canvas = document.getElementById('embed-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const pad = 40;

  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#fafafa';
  ctx.fillRect(0, 0, W, H);

  WORD_DATA.forEach(d => {
    const px = pad + d.x * (W - 2 * pad);
    const py = pad + (1 - d.y) * (H - 2 * pad);
    const color = CAT_COLORS[d.cat] || '#666';

    ctx.beginPath();
    ctx.arc(px, py, 5, 0, Math.PI * 2);
    ctx.fillStyle = color;
    ctx.fill();

    ctx.font = '12px Paperlogy, sans-serif';
    ctx.fillStyle = color;
    ctx.textAlign = 'center';
    ctx.fillText(d.word, px, py - 10);
  });
}

function setupEmbeddingExplorer() {
  drawEmbeddingCanvas();

  // Populate dropdowns
  const words = WORD_DATA.map(d => d.word);
  ['embed-a', 'embed-b', 'embed-c'].forEach((id, idx) => {
    const sel = document.getElementById(id);
    if (!sel) return;
    sel.innerHTML = words.map(w => `<option value="${w}" ${(idx === 0 && w === '왕') || (idx === 1 && w === '남자') || (idx === 2 && w === '여자') ? 'selected' : ''}>${w}</option>`).join('');
  });

  document.getElementById('btn-embed-calc')?.addEventListener('click', () => {
    const a = document.getElementById('embed-a')?.value;
    const b = document.getElementById('embed-b')?.value;
    const c = document.getElementById('embed-c')?.value;
    if (!a || !b || !c) return;

    const da = WORD_DATA.find(d => d.word === a);
    const db = WORD_DATA.find(d => d.word === b);
    const dc = WORD_DATA.find(d => d.word === c);
    if (!da || !db || !dc) return;

    const targetX = da.x - db.x + dc.x;
    const targetY = da.y - db.y + dc.y;

    // Find nearest word
    let minDist = Infinity, nearest = '';
    WORD_DATA.forEach(d => {
      if (d.word === a || d.word === b || d.word === c) return;
      const dist = Math.sqrt((d.x - targetX) ** 2 + (d.y - targetY) ** 2);
      if (dist < minDist) { minDist = dist; nearest = d.word; }
    });

    el('embed-result', nearest);

    // Highlight on canvas
    drawEmbeddingCanvas();
    const canvas = document.getElementById('embed-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    const pad = 40;

    // Draw result point
    const rpx = pad + targetX * (W - 2 * pad);
    const rpy = pad + (1 - targetY) * (H - 2 * pad);
    ctx.beginPath();
    ctx.arc(rpx, rpy, 8, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(239,68,68,0.3)';
    ctx.fill();
    ctx.strokeStyle = '#ef4444';
    ctx.lineWidth = 2;
    ctx.stroke();

    ctx.font = 'bold 14px Paperlogy, sans-serif';
    ctx.fillStyle = '#ef4444';
    ctx.textAlign = 'center';
    ctx.fillText('= ' + nearest + '?', rpx, rpy + 22);
  });
}

// ==================== INTERACTIVE 4: SENTIMENT CLASSIFIER ====================
const POS_WORDS = ['좋', '훌륭', '재미있', '재밌', '감동', '최고', '사랑', '행복', '만족', '추천', '대박', '멋지', '아름다', '완벽', '즐거', '신나', '편하', '따뜻', '기쁘', '유익'];
const NEG_WORDS = ['나쁘', '최악', '실망', '지루', '별로', '짜증', '불만', '후회', '싫', '화나', '끔찍', '형편없', '불편', '아프', '힘들', '어렵', '슬프', '우울', '무섭', '재미없'];

function setupSentiment() {
  const analyze = () => {
    const text = document.getElementById('sent-input')?.value || '';
    if (!text.trim()) return;

    let posScore = 0, negScore = 0;
    const highlights = [];

    // Split into chunks for analysis
    const chars = text.split('');
    let i = 0;
    while (i < chars.length) {
      let matched = false;
      // Try matching positive words
      for (const pw of POS_WORDS) {
        if (text.substring(i, i + pw.length) === pw) {
          highlights.push({ text: text.substring(i, i + pw.length + 1), type: 'pos', start: i });
          posScore++;
          matched = true;
          break;
        }
      }
      if (!matched) {
        for (const nw of NEG_WORDS) {
          if (text.substring(i, i + nw.length) === nw) {
            highlights.push({ text: text.substring(i, i + nw.length + 1), type: 'neg', start: i });
            negScore++;
            matched = true;
            break;
          }
        }
      }
      i++;
    }

    // Render highlighted text
    const resultDiv = document.getElementById('sent-result');
    const hlDiv = document.getElementById('sent-highlight');
    if (resultDiv) resultDiv.style.display = 'block';

    if (hlDiv) {
      let html = '';
      let lastEnd = 0;
      // Sort highlights by start position
      highlights.sort((a, b) => a.start - b.start);
      // Remove overlaps
      const filtered = [];
      let prev = -1;
      highlights.forEach(h => {
        if (h.start > prev) { filtered.push(h); prev = h.start + h.text.length; }
      });

      filtered.forEach(h => {
        if (h.start > lastEnd) html += text.substring(lastEnd, h.start);
        const color = h.type === 'pos' ? 'background:#dcfce7;color:#16a34a;' : 'background:#fee2e2;color:#dc2626;';
        html += `<span style="${color}padding:2px 6px;border-radius:4px;font-weight:700;">${h.text}</span>`;
        lastEnd = h.start + h.text.length;
      });
      if (lastEnd < text.length) html += text.substring(lastEnd);
      hlDiv.innerHTML = html || text;
    }

    el('sent-pos', posScore.toString());
    el('sent-neg', negScore.toString());
    const verdict = posScore > negScore ? '긍정' : posScore < negScore ? '부정' : '중립';
    const verdictEl = document.getElementById('sent-verdict');
    if (verdictEl) {
      verdictEl.textContent = verdict;
      verdictEl.style.color = verdict === '긍정' ? '#16a34a' : verdict === '부정' ? '#dc2626' : '#64748b';
    }
  };

  document.getElementById('btn-sentiment')?.addEventListener('click', analyze);
  document.getElementById('sent-input')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') analyze(); });
}

// ==================== INTERACTIVE 5: RNN SEQUENCE DEMO ====================
let rnnChart1 = null, rnnChart2 = null;
let rnnRunning = false;

function generateSequence(pattern, length) {
  const seq = [];
  for (let i = 0; i < length; i++) {
    switch (pattern) {
      case 'sine': seq.push(Math.sin(i * 0.6) * 0.5 + 0.5); break;
      case 'linear': seq.push(i / length); break;
      case 'step': seq.push(i < length / 2 ? 0.2 : 0.8); break;
      case 'random': seq.push(Math.random()); break;
      default: seq.push(Math.sin(i * 0.6) * 0.5 + 0.5);
    }
  }
  return seq;
}

async function setupRNNDemo() {
  

  const runRNN = () => {
    if (rnnRunning) return;
    rnnRunning = true;

    const pattern = document.getElementById('rnn-pattern')?.value || 'sine';
    const length = parseInt(document.getElementById('rnn-length')?.value || '12');
    const seq = generateSequence(pattern, length);

    // Simple RNN simulation
    const wx = 0.7, wh = 0.5, bh = -0.1, wo = 0.8, bo = 0.0;
    let h = 0;
    const hiddenStates = [h];
    const predictions = [];
    let step = 0;
    const infoDiv = document.getElementById('rnn-step-info');

    function tick() {
      if (step >= seq.length) {
        rnnRunning = false;
        if (infoDiv) infoDiv.textContent = `처리 완료. ${length}개 시점 모두 처리되었습니다.`;
        return;
      }

      const x = seq[step];
      const z = wx * x + wh * h + bh;
      h = Math.tanh(z);
      hiddenStates.push(h);
      const pred = Math.max(0, Math.min(1, wo * h + bo));
      predictions.push(pred);

      el('rnn-step', (step + 1).toString());
      el('rnn-input-val', x.toFixed(3));
      el('rnn-hidden-val', h.toFixed(3));
      el('rnn-pred-val', pred.toFixed(3));

      if (infoDiv) {
        infoDiv.textContent =
          `시점 ${step + 1}: 입력 x=${x.toFixed(3)}, ` +
          `h = tanh(${wx.toFixed(1)}*${x.toFixed(3)} + ${wh.toFixed(1)}*${hiddenStates[step].toFixed(3)} + ${bh.toFixed(1)}) = ${h.toFixed(3)}, ` +
          `예측 = ${wo.toFixed(1)}*${h.toFixed(3)} + ${bo.toFixed(1)} = ${pred.toFixed(3)}`;
      }

      // Update charts
      updateRNNCharts(seq, predictions, hiddenStates, step + 1);

      step++;
      setTimeout(tick, 400);
    }
    tick();
  };

  document.getElementById('btn-rnn-run')?.addEventListener('click', runRNN);
  document.getElementById('btn-rnn-reset')?.addEventListener('click', () => {
    rnnRunning = false;
    if (rnnChart1) { rnnChart1.destroy(); rnnChart1 = null; }
    if (rnnChart2) { rnnChart2.destroy(); rnnChart2 = null; }
    ['rnn-step', 'rnn-input-val', 'rnn-hidden-val', 'rnn-pred-val'].forEach(id => el(id, id === 'rnn-step' ? '0' : '-'));
    const infoDiv = document.getElementById('rnn-step-info');
    if (infoDiv) infoDiv.textContent = '"처리 시작"을 눌러 RNN의 단계별 처리 과정을 관찰하세요.';
  });
}

function updateRNNCharts(seq, preds, hidden, currentStep) {
  return;

  // Sequence chart
  const canvas1 = document.getElementById('rnn-seq-chart');
  if (canvas1) {
    const labels = seq.map((_, i) => `t${i + 1}`);
    const datasets = [
      { label: '입력', data: seq.map((v, i) => i < currentStep ? v : null), borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.1)', fill: false, pointRadius: 4, borderWidth: 2 },
      { label: '예측', data: [null, ...preds], borderColor: '#ef4444', backgroundColor: 'transparent', fill: false, pointRadius: 4, borderWidth: 2, borderDash: [5, 5] }
    ];

    if (rnnChart1) {
      rnnChart1.data.labels = labels;
      rnnChart1.data.datasets = datasets;
      rnnChart1.update('none');
    } else {
      rnnChart1 = new Chart(canvas1, {
        type: 'line', data: { labels, datasets },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          plugins: { legend: { labels: { font: { family: "'Paperlogy'", size: 11 } } } },
          scales: {
            x: { ticks: { font: { size: 10 } } },
            y: { min: -0.5, max: 1.5, ticks: { font: { size: 10 } } }
          }
        }
      });
    }
  }

  // Hidden state chart
  const canvas2 = document.getElementById('rnn-hidden-chart');
  if (canvas2) {
    const hLabels = hidden.map((_, i) => i === 0 ? 'h0' : `h${i}`);
    const hData = hidden.map((v, i) => i <= currentStep ? v : null);

    if (rnnChart2) {
      rnnChart2.data.labels = hLabels;
      rnnChart2.data.datasets[0].data = hData;
      rnnChart2.update('none');
    } else {
      rnnChart2 = new Chart(canvas2, {
        type: 'line',
        data: {
          labels: hLabels,
          datasets: [{ label: '숨겨진 상태 h', data: hData, borderColor: '#7c3aed', backgroundColor: 'rgba(124,58,237,0.1)', fill: true, pointRadius: 5, borderWidth: 2 }]
        },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          plugins: { legend: { labels: { font: { family: "'Paperlogy'", size: 11 } } } },
          scales: {
            x: { ticks: { font: { size: 10 } } },
            y: { min: -1, max: 1, ticks: { font: { size: 10 } } }
          }
        }
      });
    }
  }
}

// ==================== INIT ====================
function init() {

  setupTokenizer();
  setupTFIDF();
  setupEmbeddingExplorer();
  setupSentiment();
  setupRNNDemo();
}

document.addEventListener('DOMContentLoaded', init);
