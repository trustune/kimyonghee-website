function initQuiz() {
  const container = document.getElementById('interpret-quiz');
  container.innerHTML = '';

  QUIZ_QUESTIONS.forEach((q, qi) => {
    const div = document.createElement('div');
    div.style.cssText = 'margin-bottom: 16px; padding: 14px; background: var(--tb-g100); border-radius: var(--tb-radius);';
    div.innerHTML = `
      <div style="font-weight: 700; margin-bottom: 8px; font-size: 0.93rem;">Q${qi + 1}. ${q.q}</div>
      <div class="quiz-options" data-qi="${qi}">
        ${q.options.map((opt, oi) => `
          <label style="display: block; padding: 8px 12px; margin: 4px 0; cursor: pointer; border: 2px solid var(--tb-g200); border-radius: 8px; font-size: 0.88rem; transition: 0.15s;" class="quiz-opt" data-qi="${qi}" data-oi="${oi}" data-correct="${opt.correct}">
            <input type="radio" name="quiz-${qi}" value="${oi}" style="margin-right: 8px;">
            ${opt.text}
          </label>
        `).join('')}
      </div>
      <div class="quiz-fb" data-qi="${qi}" style="display: none; margin-top: 8px; font-size: 0.85rem; padding: 8px 12px; border-radius: 8px;"></div>
    `;
    container.appendChild(div);
  });

  container.querySelectorAll('input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      const qi = parseInt(e.target.closest('.quiz-options').dataset.qi);
      const oi = parseInt(e.target.value);
      const q = QUIZ_QUESTIONS[qi];
      const opt = q.options[oi];
      const fb = container.querySelector(`.quiz-fb[data-qi="${qi}"]`);
      fb.style.display = '';
      fb.textContent = opt.fb;

      // Highlight
      container.querySelectorAll(`.quiz-opt[data-qi="${qi}"]`).forEach(label => {
        label.style.borderColor = 'var(--tb-g200)';
        label.style.background = '';
      });

      const selectedLabel = container.querySelector(`.quiz-opt[data-qi="${qi}"][data-oi="${oi}"]`);
      if (opt.correct) {
        selectedLabel.style.borderColor = 'var(--tb-success)';
        selectedLabel.style.background = '#f0fdf4';
        fb.style.background = '#f0fdf4';
        fb.style.color = 'var(--tb-success)';
      } else {
        selectedLabel.style.borderColor = 'var(--tb-danger)';
        selectedLabel.style.background = '#fef2f2';
        fb.style.background = '#fef2f2';
        fb.style.color = 'var(--tb-danger)';
        // Also highlight the correct one
        container.querySelectorAll(`.quiz-opt[data-qi="${qi}"]`).forEach(l => {
          if (l.dataset.correct === 'true') {
            l.style.borderColor = 'var(--tb-success)';
            l.style.background = '#f0fdf4';
          }
        });
      }

      updateQuizScore();
    });
  });
}

function updateQuizScore() {
  let correct = 0, wrong = 0;
  QUIZ_QUESTIONS.forEach((q, qi) => {
    const checked = document.querySelector(`input[name="quiz-${qi}"]:checked`);
    if (!checked) return;
    const oi = parseInt(checked.value);
    if (q.options[oi].correct) correct++;
    else wrong++;
  });
  if (correct + wrong > 0) {
    document.getElementById('interpret-score-row').style.display = '';
    document.getElementById('interpret-correct').textContent = correct;
    document.getElementById('interpret-wrong').textContent = wrong;
  }
}

// ==================== 3D REGRESSION SURFACE (Exercise 4) ====================
let data3D = [];
let ols3D = { b0: 0, b1: 0, b2: 0 };
let rotX = -0.5, rotY = 0.5;
let isDragging3D = false, lastMX = 0, lastMY = 0;

function generate3DData() {
  const noise = parseInt(document.getElementById('noise-3d').value);
  const n = 40;
  data3D = [];
  for (let i = 0; i < n; i++) {
    const x1 = 30 + Math.random() * 100; // area
    const x2 = 1 + Math.floor(Math.random() * 25); // floor
    const y = -2000 + 80 * x1 + 50 * x2 + randNorm(0, noise * 15);
    data3D.push({ x1, x2, y });
  }

  // Fit OLS
  const result = multiOLS(
    data3D.map(d => ({ price: d.y, area: d.x1, floor: d.x2 })),
    'price',
    ['area', 'floor']
  );

  ols3D = {
    b0: result.coeffs.intercept || 0,
    b1: result.coeffs.area || 0,
    b2: result.coeffs.floor || 0,
  };

  document.getElementById('coef-3d-b0').textContent = ols3D.b0.toFixed(1);
  document.getElementById('coef-3d-b1').textContent = ols3D.b1.toFixed(2);
  document.getElementById('coef-3d-b2').textContent = ols3D.b2.toFixed(2);
  document.getElementById('r2-3d').textContent = result.r2.toFixed(4);

  draw3D();
}

function project3D(x, y, z, W, H) {
  // Normalize to [-1, 1]
  const cosX = Math.cos(rotX), sinX = Math.sin(rotX);
  const cosY = Math.cos(rotY), sinY = Math.sin(rotY);

  // Rotate around Y axis
  let x2 = x * cosY - z * sinY;
  let z2 = x * sinY + z * cosY;

  // Rotate around X axis
  let y2 = y * cosX - z2 * sinX;
  let z3 = y * sinX + z2 * cosX;

  // Simple perspective
  const scale = 200 / (3 + z3 * 0.5);
  return {
    px: W / 2 + x2 * scale,
    py: H / 2 - y2 * scale,
    depth: z3,
  };
}

function draw3D() {
  const canvas = document.getElementById('canvas-3d');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;

  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#f8fafc';
  ctx.fillRect(0, 0, W, H);

  if (data3D.length === 0) return;

  // Normalize data to [-1.5, 1.5]
  const x1s = data3D.map(d => d.x1);
  const x2s = data3D.map(d => d.x2);
  const ys = data3D.map(d => d.y);
  const x1Min = Math.min(...x1s), x1Max = Math.max(...x1s);
  const x2Min = Math.min(...x2s), x2Max = Math.max(...x2s);
  const yMin = Math.min(...ys), yMax = Math.max(...ys);

  const norm = (v, min, max) => ((v - min) / (max - min || 1) - 0.5) * 3;
  const normY = (v) => norm(v, yMin, yMax);
  const normX1 = (v) => norm(v, x1Min, x1Max);
  const normX2 = (v) => norm(v, x2Min, x2Max);

  const showResid = document.getElementById('show-3d-resid').checked;

  // Draw regression surface (grid)
  const gridN = 8;
  ctx.strokeStyle = 'rgba(37, 99, 235, 0.2)';
  ctx.lineWidth = 1;

  for (let i = 0; i <= gridN; i++) {
    const u = i / gridN;
    // Lines along x1
    ctx.beginPath();
    let first = true;
    for (let j = 0; j <= gridN; j++) {
      const v = j / gridN;
      const gx1 = x1Min + u * (x1Max - x1Min);
      const gx2 = x2Min + v * (x2Max - x2Min);
      const gy = ols3D.b0 + ols3D.b1 * gx1 + ols3D.b2 * gx2;
      const p = project3D(normX1(gx1), normY(gy), normX2(gx2), W, H);
      if (first) { ctx.moveTo(p.px, p.py); first = false; }
      else ctx.lineTo(p.px, p.py);
    }
    ctx.stroke();

    // Lines along x2
    ctx.beginPath();
    first = true;
    for (let j = 0; j <= gridN; j++) {
      const v = j / gridN;
      const gx1 = x1Min + v * (x1Max - x1Min);
      const gx2 = x2Min + u * (x2Max - x2Min);
      const gy = ols3D.b0 + ols3D.b1 * gx1 + ols3D.b2 * gx2;
      const p = project3D(normX1(gx1), normY(gy), normX2(gx2), W, H);
      if (first) { ctx.moveTo(p.px, p.py); first = false; }
      else ctx.lineTo(p.px, p.py);
    }
    ctx.stroke();
  }

  // Fill surface with transparent color
  ctx.fillStyle = 'rgba(37, 99, 235, 0.06)';
  ctx.beginPath();
  const corners = [
    [x1Min, x2Min], [x1Max, x2Min], [x1Max, x2Max], [x1Min, x2Max],
  ];
  corners.forEach(([gx1, gx2], ci) => {
    const gy = ols3D.b0 + ols3D.b1 * gx1 + ols3D.b2 * gx2;
    const p = project3D(normX1(gx1), normY(gy), normX2(gx2), W, H);
    if (ci === 0) ctx.moveTo(p.px, p.py); else ctx.lineTo(p.px, p.py);
  });
  ctx.closePath();
  ctx.fill();

  // Draw data points (sorted by depth for painter's algorithm)
  const projPoints = data3D.map((d, i) => {
    const p = project3D(normX1(d.x1), normY(d.y), normX2(d.x2), W, H);
    return { ...d, ...p, idx: i };
  }).sort((a, b) => b.depth - a.depth);

  projPoints.forEach(d => {
    const yhat = ols3D.b0 + ols3D.b1 * d.x1 + ols3D.b2 * d.x2;

    // Residual line
    if (showResid) {
      const pHat = project3D(normX1(d.x1), normY(yhat), normX2(d.x2), W, H);
      ctx.strokeStyle = d.y > yhat ? 'rgba(239,68,68,0.5)' : 'rgba(37,99,235,0.5)';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.moveTo(d.px, d.py);
      ctx.lineTo(pHat.px, pHat.py);
      ctx.stroke();
    }

    // Point
    const r = Math.max(3, 6 - d.depth * 0.8);
    ctx.fillStyle = d.y > yhat ? '#ef4444' : '#2563eb';
    ctx.globalAlpha = 0.85;
    ctx.beginPath();
    ctx.arc(d.px, d.py, r, 0, Math.PI * 2);
    ctx.fill();
    ctx.globalAlpha = 1;
  });

  // Axis labels
  ctx.font = '12px Paperlogy, sans-serif';
  ctx.fillStyle = '#475569';
  const axX = project3D(1.8, -1.7, 0, W, H);
  ctx.fillText('면적(m2)', axX.px, axX.py);
  const axZ = project3D(0, -1.7, 1.8, W, H);
  ctx.fillText('층수', axZ.px, axZ.py);
  const axY = project3D(-1.7, 1.5, 0, W, H);
  ctx.fillText('가격', axY.px, axY.py);
}

// ==================== INITIALIZATION ====================
function init() {
  try {
  } catch(e) {}

  // Generate data
  generateAptData(100);
  initVarPool();
  initQuiz();
  generate3DData();

  // Events
  document.getElementById('btn-reset-vars').addEventListener('click', () => {
    modelVars = [];
    r2History = [];
    initVarPool();
  });

  document.getElementById('btn-collin-run').addEventListener('click', runCollinearityDemo);

  // 3D canvas
  const noise3d = document.getElementById('noise-3d');
  noise3d.addEventListener('input', () => {
    document.getElementById('noise-3d-val').textContent = noise3d.value;
  });

  document.getElementById('btn-3d-gen').addEventListener('click', generate3DData);
  document.getElementById('show-3d-resid').addEventListener('change', draw3D);

  const canvas3d = document.getElementById('canvas-3d');
  canvas3d.addEventListener('mousedown', (e) => {
    isDragging3D = true;
    lastMX = e.clientX;
    lastMY = e.clientY;
    canvas3d.style.cursor = 'grabbing';
  });

  window.addEventListener('mousemove', (e) => {
    if (!isDragging3D) return;
    const dx = e.clientX - lastMX;
    const dy = e.clientY - lastMY;
    rotY += dx * 0.01;
    rotX += dy * 0.01;
    rotX = Math.max(-1.2, Math.min(1.2, rotX));
    lastMX = e.clientX;
    lastMY = e.clientY;
    draw3D();
  });

  window.addEventListener('mouseup', () => {
    isDragging3D = false;
    const c = document.getElementById('canvas-3d');
    if (c) c.style.cursor = 'grab';
  });
}

init();
