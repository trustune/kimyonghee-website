function init() {
  try {
    import('../../textbook/lib/progress').then(m => m.markVisited('15-simple-regression')).catch(() => {});
  } catch(e) {}

  // Generate initial data
  generateRegData();
  drawRegCanvas();
  drawResidCanvas();
  generateR2Data();
  updateOutputTable();

  // Slider events
  const b0Slider = document.getElementById('reg-b0');
  const b1Slider = document.getElementById('reg-b1');

  b0Slider.addEventListener('input', () => {
    document.getElementById('reg-b0-val').textContent = b0Slider.value;
    drawRegCanvas();
  });

  b1Slider.addEventListener('input', () => {
    document.getElementById('reg-b1-val').textContent = parseFloat(b1Slider.value).toFixed(1);
    drawRegCanvas();
  });

  document.getElementById('btn-show-ols').addEventListener('click', showOLS);

  document.getElementById('btn-new-reg-data').addEventListener('click', () => {
    generateRegData();
    drawRegCanvas();
    drawResidCanvas();
    selectedPoint = -1;
    showAllResiduals = false;
    updateOutputTable();
  });

  // Residual canvas click
  document.getElementById('resid-canvas').addEventListener('click', handleResidClick);

  document.getElementById('btn-show-all-resid').addEventListener('click', () => {
    showAllResiduals = true;
    drawResidCanvas();
  });

  document.getElementById('btn-hide-resid').addEventListener('click', () => {
    showAllResiduals = false;
    selectedPoint = -1;
    drawResidCanvas();
  });

  // R-squared
  const noiseSlider = document.getElementById('r2-noise');
  noiseSlider.addEventListener('input', () => {
    document.getElementById('r2-noise-val').textContent = noiseSlider.value;
  });

  document.getElementById('btn-r2-gen').addEventListener('click', generateR2Data);

  // Diagnostics
  document.getElementById('btn-diag-gen').addEventListener('click', generateDiagData);
}

document.addEventListener('astro:page-load', init);
