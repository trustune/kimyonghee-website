<script is:inline>
// ==================== UTILITIES ====================
const COLORS = ['#2563eb','#ef4444','#22c55e','#f59e0b','#7c3aed','#06b6d4','#ec4899','#84cc16','#f97316','#6366f1'];
function dist(a, b) { return Math.sqrt((a[0]-b[0])**2 + (a[1]-b[1])**2); }
function randGauss() { let u=0,v=0; while(!u) u=Math.random(); while(!v) v=Math.random(); return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v); }

// ==================== DATA GENERATORS ====================
function generateBlobs(n, canvasW, canvasH, numCenters) {
  const margin = 60;
  const centers = [];
  for (let c = 0; c < numCenters; c++) {
    centers.push([margin + Math.random()*(canvasW - 2*margin), margin + Math.random()*(canvasH - 2*margin)]);
  }
  const pts = [];
  for (let i = 0; i < n; i++) {
    const c = centers[i % numCenters];
    pts.push([c[0] + randGauss()*30, c[1] + randGauss()*30]);
  }
  return pts;
}

function generateMoons(n, canvasW, canvasH) {
  const pts = [];
  const cx = canvasW / 2, cy = canvasH / 2;
  const r = Math.min(canvasW, canvasH) * 0.28;
  const half = Math.floor(n / 2);
  for (let i = 0; i < half; i++) {
    const angle = Math.PI * i / half;
    pts.push([cx - r*0.4 + r*Math.cos(angle) + randGauss()*6, cy - r*0.15 + r*Math.sin(angle) + randGauss()*6]);
  }
  for (let i = 0; i < n - half; i++) {
    const angle = Math.PI * i / (n - half);
    pts.push([cx + r*0.4 + r*Math.cos(angle + Math.PI) + randGauss()*6, cy + r*0.15 + r*Math.sin(angle + Math.PI) + randGauss()*6]);
  }
  return pts;
}

function generateRings(n, canvasW, canvasH) {
  const pts = [];
  const cx = canvasW / 2, cy = canvasH / 2;
  const r1 = Math.min(canvasW, canvasH) * 0.15;
  const r2 = Math.min(canvasW, canvasH) * 0.35;
  const half = Math.floor(n / 2);
  for (let i = 0; i < half; i++) {
    const angle = 2 * Math.PI * Math.random();
    const rr = r1 + randGauss() * 6;
    pts.push([cx + rr*Math.cos(angle), cy + rr*Math.sin(angle)]);
  }
  for (let i = 0; i < n - half; i++) {
    const angle = 2 * Math.PI * Math.random();
    const rr = r2 + randGauss() * 6;
    pts.push([cx + rr*Math.cos(angle), cy + rr*Math.sin(angle)]);
  }
  return pts;
}

function generateVaried(n, canvasW, canvasH) {
  const pts = [];
  const third = Math.floor(n / 3);
  // Dense small cluster
  for (let i = 0; i < third; i++) {
    pts.push([canvasW*0.25 + randGauss()*15, canvasH*0.35 + randGauss()*15]);
  }
  // Medium cluster
  for (let i = 0; i < third; i++) {
    pts.push([canvasW*0.65 + randGauss()*40, canvasH*0.55 + randGauss()*40]);
  }
  // Sparse spread cluster
  for (let i = 0; i < n - 2*third; i++) {
    pts.push([canvasW*0.35 + randGauss()*25, canvasH*0.75 + randGauss()*25]);
  }
  // Some noise
  for (let i = 0; i < Math.floor(n*0.08); i++) {
    pts.push([Math.random()*canvasW*0.9 + canvasW*0.05, Math.random()*canvasH*0.9 + canvasH*0.05]);
  }
  return pts;
}

function getDataset(name, canvasW, canvasH) {
  const n = 120;
  switch(name) {
    case 'blobs': return generateBlobs(n, canvasW, canvasH, 3);
    case 'moons': return generateMoons(n, canvasW, canvasH);
    case 'rings': return generateRings(n, canvasW, canvasH);
    case 'varied': return generateVaried(n, canvasW, canvasH);
    default: return generateBlobs(n, canvasW, canvasH, 3);
  }
}

// ==================== DBSCAN ALGORITHM ====================
function dbscan(points, epsilon, minPts) {
  const n = points.length;
  const labels = new Array(n).fill(-2); // -2 = unvisited, -1 = noise
  const pointTypes = new Array(n).fill('noise'); // core, border, noise
  let clusterId = 0;

  function regionQuery(idx) {
    const neighbors = [];
    for (let i = 0; i < n; i++) {
      if (dist(points[idx], points[i]) <= epsilon) neighbors.push(i);
    }
    return neighbors;
  }

  for (let i = 0; i < n; i++) {
    if (labels[i] !== -2) continue;
    const neighbors = regionQuery(i);
    if (neighbors.length < minPts) {
      labels[i] = -1; // noise
      continue;
    }
    // Core point -- start new cluster
    labels[i] = clusterId;
    pointTypes[i] = 'core';
    const seed = [...neighbors];
    let j = 0;
    while (j < seed.length) {
      const q = seed[j];
      if (labels[q] === -1) {
        labels[q] = clusterId;
        pointTypes[q] = 'border';
      }
      if (labels[q] !== -2) { j++; continue; }
      labels[q] = clusterId;
      const qNeighbors = regionQuery(q);
      if (qNeighbors.length >= minPts) {
        pointTypes[q] = 'core';
        for (const nn of qNeighbors) {
          if (!seed.includes(nn)) seed.push(nn);
        }
      } else {
        pointTypes[q] = 'border';
      }
      j++;
    }
    clusterId++;
  }
  return { labels, pointTypes, numClusters: clusterId };
}

// ==================== K-MEANS ALGORITHM ====================
function kmeans(points, k, maxIter) {
  maxIter = maxIter || 50;
  const n = points.length;
  // Random initialization
  const indices = [];
  while (indices.length < k) {
    const idx = Math.floor(Math.random() * n);
    if (!indices.includes(idx)) indices.push(idx);
  }
  let centroids = indices.map(i => [...points[i]]);
  let labels = new Array(n).fill(0);

  for (let iter = 0; iter < maxIter; iter++) {
    // Assign
    let changed = false;
    for (let i = 0; i < n; i++) {
      let minD = Infinity, minC = 0;
      for (let c = 0; c < k; c++) {
        const d = dist(points[i], centroids[c]);
        if (d < minD) { minD = d; minC = c; }
      }
      if (labels[i] !== minC) changed = true;
      labels[i] = minC;
    }
    if (!changed) break;
    // Update centroids
    centroids = centroids.map((_, c) => {
      const members = points.filter((_, i) => labels[i] === c);
      if (members.length === 0) return centroids[c];
      return [
        members.reduce((s, p) => s + p[0], 0) / members.length,
        members.reduce((s, p) => s + p[1], 0) / members.length
      ];
    });
  }
  return labels;
}

// ==================== HIERARCHICAL CLUSTERING ====================
function computeLinkageDist(clusterA, clusterB, points, linkage) {
  let dists = [];
  for (const a of clusterA) {
    for (const b of clusterB) {
      dists.push(dist(points[a], points[b]));
    }
  }
  if (linkage === 'single') return Math.min(...dists);
  if (linkage === 'complete') return Math.max(...dists);
  return dists.reduce((s, d) => s + d, 0) / dists.length; // average
}

// ==================== 1. HC STEP-BY-STEP VISUALIZER ====================
let hcState = null;

function hcInit() {
  const canvas = document.getElementById('hc-canvas');
  const w = canvas.width, h = canvas.height;
  const pts = [];
  for (let i = 0; i < 30; i++) {
    pts.push([50 + Math.random() * (w - 100), 40 + Math.random() * (h - 80)]);
  }
  const clusters = pts.map((_, i) => [i]);
  const mergeHistory = [];
  hcState = { points: pts, clusters, mergeHistory, step: 0 };
  document.getElementById('hc-cluster-count').textContent = clusters.length;
  document.getElementById('hc-merge-dist').textContent = '-';
  document.getElementById('hc-step-count').textContent = '0';
  drawHC();
}

function hcStep() {
  if (!hcState || hcState.clusters.length <= 1) return;
  const { points, clusters } = hcState;
  const linkage = document.getElementById('hc-linkage').value;

  let minDist = Infinity, mergeI = 0, mergeJ = 1;
  for (let i = 0; i < clusters.length; i++) {
    for (let j = i + 1; j < clusters.length; j++) {
      const d = computeLinkageDist(clusters[i], clusters[j], points, linkage);
      if (d < minDist) { minDist = d; mergeI = i; mergeJ = j; }
    }
  }

  const merged = [...clusters[mergeI], ...clusters[mergeJ]];
  hcState.mergeHistory.push({
    a: [...clusters[mergeI]], b: [...clusters[mergeJ]],
    distance: minDist
  });
  hcState.clusters.splice(mergeJ, 1);
  hcState.clusters.splice(mergeI, 1, merged);
  hcState.step++;

  document.getElementById('hc-cluster-count').textContent = hcState.clusters.length;
  document.getElementById('hc-merge-dist').textContent = minDist.toFixed(1);
  document.getElementById('hc-step-count').textContent = hcState.step;
  drawHC();
}

function drawHC() {
  const canvas = document.getElementById('hc-canvas');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  canvas.width = canvas.clientWidth * dpr;
  canvas.height = canvas.clientHeight * dpr;
  ctx.scale(dpr, dpr);
  const w = canvas.clientWidth, h = canvas.clientHeight;
  ctx.clearRect(0, 0, w, h);

  if (!hcState) return;
  const { points, clusters } = hcState;
  const scaleX = w / 760, scaleY = h / 420;

  // Draw connection lines between merged points
  clusters.forEach((cluster, ci) => {
    if (cluster.length > 1) {
      ctx.strokeStyle = COLORS[ci % COLORS.length] + '40';
      ctx.lineWidth = 1;
      for (let i = 0; i < cluster.length; i++) {
        for (let j = i + 1; j < cluster.length; j++) {
          const a = points[cluster[i]], b = points[cluster[j]];
          ctx.beginPath();
          ctx.moveTo(a[0]*scaleX, a[1]*scaleY);
          ctx.lineTo(b[0]*scaleX, b[1]*scaleY);
          ctx.stroke();
        }
      }
    }
  });

  // Draw convex hull-like boundary for each cluster
  clusters.forEach((cluster, ci) => {
    if (cluster.length >= 3) {
      const cPts = cluster.map(i => [points[i][0]*scaleX, points[i][1]*scaleY]);
      const cx = cPts.reduce((s, p) => s + p[0], 0) / cPts.length;
      const cy = cPts.reduce((s, p) => s + p[1], 0) / cPts.length;
      cPts.sort((a, b) => Math.atan2(a[1]-cy, a[0]-cx) - Math.atan2(b[1]-cy, b[0]-cx));
      ctx.fillStyle = COLORS[ci % COLORS.length] + '15';
      ctx.beginPath();
      ctx.moveTo(cPts[0][0], cPts[0][1]);
      for (let i = 1; i < cPts.length; i++) ctx.lineTo(cPts[i][0], cPts[i][1]);
      ctx.closePath();
      ctx.fill();
    }
  });

  // Draw points
  clusters.forEach((cluster, ci) => {
    ctx.fillStyle = COLORS[ci % COLORS.length];
    cluster.forEach(idx => {
      const p = points[idx];
      ctx.beginPath();
      ctx.arc(p[0]*scaleX, p[1]*scaleY, 5, 0, Math.PI*2);
      ctx.fill();
    });
  });

  // Last merge highlight
  if (hcState.mergeHistory.length > 0) {
    const last = hcState.mergeHistory[hcState.mergeHistory.length - 1];
    ctx.strokeStyle = '#ef4444';
    ctx.lineWidth = 2;
    ctx.setLineDash([4, 4]);
    const centA = last.a.reduce((s, i) => [s[0]+points[i][0], s[1]+points[i][1]], [0,0]);
    centA[0] /= last.a.length; centA[1] /= last.a.length;
    const centB = last.b.reduce((s, i) => [s[0]+points[i][0], s[1]+points[i][1]], [0,0]);
    centB[0] /= last.b.length; centB[1] /= last.b.length;
    ctx.beginPath();
    ctx.moveTo(centA[0]*scaleX, centA[1]*scaleY);
    ctx.lineTo(centB[0]*scaleX, centB[1]*scaleY);
    ctx.stroke();
    ctx.setLineDash([]);
  }
}

let hcAutoTimer = null;
function hcAuto() {
  if (hcAutoTimer) { clearInterval(hcAutoTimer); hcAutoTimer = null; return; }
  hcAutoTimer = setInterval(() => {
    if (!hcState || hcState.clusters.length <= 1) { clearInterval(hcAutoTimer); hcAutoTimer = null; return; }
    hcStep();
  }, 400);
}

// ==================== 2. DENDROGRAM + CUT LINE ====================
let dendroState = null;

function dendroInit() {
  const canvas = document.getElementById('dendro-canvas');
  const w = 370, h = 380;
  const pts = generateBlobs(20, 400, 400, 3);
  // Run full agglomerative clustering
  let clusters = pts.map((_, i) => [i]);
  const merges = [];
  const linkage = 'average';

  while (clusters.length > 1) {
    let minDist = Infinity, mi = 0, mj = 1;
    for (let i = 0; i < clusters.length; i++) {
      for (let j = i + 1; j < clusters.length; j++) {
        const d = computeLinkageDist(clusters[i], clusters[j], pts, linkage);
        if (d < minDist) { minDist = d; mi = i; mj = j; }
      }
    }
    merges.push({ a: [...clusters[mi]], b: [...clusters[mj]], distance: minDist,
                  merged: [...clusters[mi], ...clusters[mj]] });
    const merged = [...clusters[mi], ...clusters[mj]];
    clusters.splice(mj, 1);
    clusters.splice(mi, 1, merged);
  }

  const maxDist = merges.length > 0 ? merges[merges.length - 1].distance : 1;
  dendroState = { points: pts, merges, maxDist };

  const slider = document.getElementById('dendro-cut');
  slider.max = 100;
  slider.value = 50;
  dendroUpdate();
}

function dendroUpdate() {
  if (!dendroState) return;
  const { points, merges, maxDist } = dendroState;
  const cutPct = parseInt(document.getElementById('dendro-cut').value);
  const cutHeight = (cutPct / 100) * maxDist * 1.1;

  document.getElementById('dendro-cut-val').textContent = cutHeight.toFixed(1);
  document.getElementById('dendro-height').textContent = cutHeight.toFixed(1);

  // Determine clusters at cut height
  let clusters = points.map((_, i) => [i]);
  for (const m of merges) {
    if (m.distance > cutHeight) break;
    // Find which clusters contain the members of a and b
    let ci = -1, cj = -1;
    for (let c = 0; c < clusters.length; c++) {
      if (clusters[c].includes(m.a[0])) ci = c;
      if (clusters[c].includes(m.b[0])) cj = c;
    }
    if (ci !== -1 && cj !== -1 && ci !== cj) {
      const j = Math.max(ci, cj), i = Math.min(ci, cj);
      clusters[i] = [...clusters[i], ...clusters[j]];
      clusters.splice(j, 1);
    }
  }

  document.getElementById('dendro-k').textContent = clusters.length;

  // Draw dendrogram
  drawDendrogram(merges, maxDist, cutHeight, points.length);
  // Draw scatter
  drawDendroScatter(points, clusters);
}

function drawDendrogram(merges, maxDist, cutHeight, n) {
  const canvas = document.getElementById('dendro-canvas');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  canvas.width = canvas.clientWidth * dpr;
  canvas.height = canvas.clientHeight * dpr;
  ctx.scale(dpr, dpr);
  const W = canvas.clientWidth, H = canvas.clientHeight;
  ctx.clearRect(0, 0, W, H);

  const padL = 40, padR = 10, padT = 20, padB = 30;
  const plotW = W - padL - padR;
  const plotH = H - padT - padB;
  const scaleH = maxDist * 1.1;

  // Build tree structure for positioning
  // Each leaf gets an x position, internal nodes get avg of children
  const nodePos = {}; // nodeId -> { x, y (height) }
  const leafOrder = [];

  // Simple ordering: follow merge order
  // Assign leaves their order
  function getLeaves(mergeIdx) {
    if (mergeIdx < 0) return [-(mergeIdx + 1)]; // leaf
    const m = merges[mergeIdx];
    return [...m.merged];
  }

  // Build a simpler dendrogram: for each merge, track which points
  // We'll use a flat approach: position leaves evenly, draw bars
  const leafX = {};
  // Order leaves by first appearance in merges
  const ordered = [];
  const seen = new Set();
  for (const m of merges) {
    for (const idx of m.a) { if (!seen.has(idx)) { ordered.push(idx); seen.add(idx); } }
    for (const idx of m.b) { if (!seen.has(idx)) { ordered.push(idx); seen.add(idx); } }
  }
  // Add any remaining
  for (let i = 0; i < n; i++) { if (!seen.has(i)) { ordered.push(i); seen.add(i); } }

  ordered.forEach((idx, i) => {
    leafX[idx] = padL + (i + 0.5) * (plotW / n);
  });

  // For each merge, compute position
  const clusterPos = {}; // key: sorted member string -> {x, y}
  for (let i = 0; i < n; i++) {
    clusterPos[JSON.stringify([i])] = { x: leafX[i], y: 0 };
  }

  ctx.strokeStyle = '#475569';
  ctx.lineWidth = 1.5;

  for (const m of merges) {
    const keyA = JSON.stringify([...m.a].sort((a,b) => a-b));
    const keyB = JSON.stringify([...m.b].sort((a,b) => a-b));
    const keyM = JSON.stringify([...m.merged].sort((a,b) => a-b));

    const posA = clusterPos[keyA] || { x: m.a.reduce((s, i) => s + leafX[i], 0) / m.a.length, y: 0 };
    const posB = clusterPos[keyB] || { x: m.b.reduce((s, i) => s + leafX[i], 0) / m.b.length, y: 0 };
    const mergeY = padT + plotH * (1 - m.distance / scaleH);
    const yA = padT + plotH * (1 - posA.y / scaleH);
    const yB = padT + plotH * (1 - posB.y / scaleH);

    // Draw the U-shape
    ctx.beginPath();
    ctx.moveTo(posA.x, yA);
    ctx.lineTo(posA.x, mergeY);
    ctx.lineTo(posB.x, mergeY);
    ctx.lineTo(posB.x, yB);
    ctx.stroke();

    clusterPos[keyM] = { x: (posA.x + posB.x) / 2, y: m.distance };
  }

  // Draw cut line
  const cutY = padT + plotH * (1 - cutHeight / scaleH);
  ctx.strokeStyle = '#ef4444';
  ctx.lineWidth = 2;
  ctx.setLineDash([6, 4]);
  ctx.beginPath();
  ctx.moveTo(padL, cutY);
  ctx.lineTo(W - padR, cutY);
  ctx.stroke();
  ctx.setLineDash([]);

  // Label
  ctx.fillStyle = '#ef4444';
  ctx.font = '11px Paperlogy, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText('cut = ' + cutHeight.toFixed(1), padL + 4, cutY - 4);

  // Y axis labels
  ctx.fillStyle = '#475569';
  ctx.font = '10px Paperlogy, sans-serif';
  ctx.textAlign = 'right';
  for (let i = 0; i <= 4; i++) {
    const val = (scaleH * i / 4);
    const y = padT + plotH * (1 - val / scaleH);
    ctx.fillText(val.toFixed(0), padL - 4, y + 3);
  }
}

function drawDendroScatter(points, clusters) {
  const canvas = document.getElementById('dendro-scatter');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  canvas.width = canvas.clientWidth * dpr;
  canvas.height = canvas.clientHeight * dpr;
  ctx.scale(dpr, dpr);
  const W = canvas.clientWidth, H = canvas.clientHeight;
  ctx.clearRect(0, 0, W, H);

  const pad = 30;
  // Find bounds of points
  let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
  for (const p of points) {
    if (p[0] < minX) minX = p[0]; if (p[0] > maxX) maxX = p[0];
    if (p[1] < minY) minY = p[1]; if (p[1] > maxY) maxY = p[1];
  }
  const rangeX = maxX - minX || 1, rangeY = maxY - minY || 1;
  const sx = (x) => pad + (x - minX) / rangeX * (W - 2*pad);
  const sy = (y) => pad + (y - minY) / rangeY * (H - 2*pad);

  clusters.forEach((cluster, ci) => {
    ctx.fillStyle = COLORS[ci % COLORS.length];
    cluster.forEach(idx => {
      ctx.beginPath();
      ctx.arc(sx(points[idx][0]), sy(points[idx][1]), 5, 0, Math.PI*2);
      ctx.fill();
    });
  });

  // Label cluster count
  ctx.fillStyle = '#1e293b';
  ctx.font = 'bold 13px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText(clusters.length + '개 군집', W/2, H - 6);
}

// ==================== 3. DBSCAN EXPLORER ====================
let dbscanPoints = [];

function dbscanInit() {
  const canvas = document.getElementById('dbscan-canvas');
  const dataset = document.getElementById('dbscan-dataset').value;
  dbscanPoints = getDataset(dataset, 760, 460);
  dbscanRun();
}

function dbscanRun() {
  const eps = parseInt(document.getElementById('dbscan-eps').value);
  const minPts = parseInt(document.getElementById('dbscan-minpts').value);
  document.getElementById('dbscan-eps-val').textContent = eps;
  document.getElementById('dbscan-minpts-val').textContent = minPts;

  if (dbscanPoints.length === 0) return;
  const result = dbscan(dbscanPoints, eps, minPts);
  drawDBSCAN(dbscanPoints, result, eps);

  const nClusters = result.numClusters;
  const nCore = result.pointTypes.filter(t => t === 'core').length;
  const nBorder = result.pointTypes.filter(t => t === 'border').length;
  const nNoise = result.labels.filter(l => l === -1).length;
  document.getElementById('dbscan-clusters').textContent = nClusters;
  document.getElementById('dbscan-core').textContent = nCore;
  document.getElementById('dbscan-border').textContent = nBorder;
  document.getElementById('dbscan-noise').textContent = nNoise;
}

function drawDBSCAN(points, result, eps) {
  const canvas = document.getElementById('dbscan-canvas');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  canvas.width = canvas.clientWidth * dpr;
  canvas.height = canvas.clientHeight * dpr;
  ctx.scale(dpr, dpr);
  const W = canvas.clientWidth, H = canvas.clientHeight;
  ctx.clearRect(0, 0, W, H);
  const scaleX = W / 760, scaleY = H / 460;

  // Draw epsilon circles for core points (faint)
  for (let i = 0; i < points.length; i++) {
    if (result.pointTypes[i] === 'core') {
      ctx.strokeStyle = COLORS[result.labels[i] % COLORS.length] + '20';
      ctx.fillStyle = COLORS[result.labels[i] % COLORS.length] + '08';
      ctx.lineWidth = 0.5;
      ctx.beginPath();
      ctx.arc(points[i][0]*scaleX, points[i][1]*scaleY, eps*scaleX, 0, Math.PI*2);
      ctx.fill();
      ctx.stroke();
    }
  }

  // Draw points
  for (let i = 0; i < points.length; i++) {
    const x = points[i][0]*scaleX, y = points[i][1]*scaleY;
    if (result.labels[i] === -1) {
      // Noise: gray X
      ctx.strokeStyle = '#94a3b8';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(x-4, y-4); ctx.lineTo(x+4, y+4);
      ctx.moveTo(x+4, y-4); ctx.lineTo(x-4, y+4);
      ctx.stroke();
    } else {
      const color = COLORS[result.labels[i] % COLORS.length];
      ctx.fillStyle = color;
      ctx.beginPath();
      if (result.pointTypes[i] === 'core') {
        ctx.arc(x, y, 5, 0, Math.PI*2);
        ctx.fill();
      } else {
        // Border: smaller, ring
        ctx.arc(x, y, 4, 0, Math.PI*2);
        ctx.fill();
        ctx.strokeStyle = '#fff';
        ctx.lineWidth = 1;
        ctx.stroke();
      }
    }
  }

  // Legend
  ctx.font = '11px Paperlogy, sans-serif';
  ctx.textAlign = 'left';
  const legendY = H - 16;
  ctx.fillStyle = '#2563eb';
  ctx.beginPath(); ctx.arc(12, legendY, 5, 0, Math.PI*2); ctx.fill();
  ctx.fillStyle = '#1e293b'; ctx.fillText('핵심점', 22, legendY + 4);

  ctx.fillStyle = '#f59e0b';
  ctx.beginPath(); ctx.arc(82, legendY, 4, 0, Math.PI*2); ctx.fill();
  ctx.fillStyle = '#1e293b'; ctx.fillText('경계점', 92, legendY + 4);

  ctx.strokeStyle = '#94a3b8'; ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(148, legendY-4); ctx.lineTo(156, legendY+4);
  ctx.moveTo(156, legendY-4); ctx.lineTo(148, legendY+4); ctx.stroke();
  ctx.fillStyle = '#1e293b'; ctx.fillText('노이즈', 162, legendY + 4);
}

// ==================== 4. K-MEANS vs DBSCAN COMPARISON ====================
function runComparison() {
  const dataset = document.getElementById('compare-dataset').value;
  const k = parseInt(document.getElementById('compare-k').value);
  const points = getDataset(dataset, 370, 370);

  // K-Means
  const kmLabels = kmeans(points, k);
  drawCompareCanvas('compare-kmeans', points, kmLabels, false);

  // DBSCAN with reasonable defaults based on dataset
  let eps = 28, minPts = 4;
  if (dataset === 'rings') { eps = 22; minPts = 4; }
  if (dataset === 'blobs') { eps = 35; minPts = 4; }
  const dbResult = dbscan(points, eps, minPts);
  drawCompareCanvas('compare-dbscan', points, dbResult.labels, true);
}

function drawCompareCanvas(canvasId, points, labels, showNoise) {
  const canvas = document.getElementById(canvasId);
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  canvas.width = canvas.clientWidth * dpr;
  canvas.height = canvas.clientHeight * dpr;
  ctx.scale(dpr, dpr);
  const W = canvas.clientWidth, H = canvas.clientHeight;
  ctx.clearRect(0, 0, W, H);
  const scaleX = W / 370, scaleY = H / 370;

  for (let i = 0; i < points.length; i++) {
    const x = points[i][0]*scaleX, y = points[i][1]*scaleY;
    if (showNoise && labels[i] === -1) {
      ctx.strokeStyle = '#94a3b8';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(x-3, y-3); ctx.lineTo(x+3, y+3);
      ctx.moveTo(x+3, y-3); ctx.lineTo(x-3, y+3);
      ctx.stroke();
    } else {
      const ci = labels[i] < 0 ? 0 : labels[i];
      ctx.fillStyle = COLORS[ci % COLORS.length];
      ctx.beginPath();
      ctx.arc(x, y, 4, 0, Math.PI*2);
      ctx.fill();
    }
  }

  // Count clusters
  const unique = [...new Set(labels.filter(l => l >= 0))];
  const noiseCount = labels.filter(l => l === -1).length;
  ctx.fillStyle = '#1e293b';
  ctx.font = 'bold 12px Paperlogy, sans-serif';
  ctx.textAlign = 'center';
  let info = unique.length + '개 군집';
  if (showNoise && noiseCount > 0) info += ', 노이즈 ' + noiseCount;
  ctx.fillText(info, W/2, H - 8);
}

// ==================== 5. STORE LOCATION CLUSTERING ====================
let storePoints = [];

function generateStores() {
  storePoints = [];
  // Seoul-like area: simulate clusters around major commercial districts
  const districts = [
    { name: '강남', cx: 500, cy: 300, n: 12, spread: 35 },
    { name: '홍대/마포', cx: 250, cy: 180, n: 10, spread: 30 },
    { name: '종로/광화문', cx: 380, cy: 140, n: 8, spread: 25 },
    { name: '영등포/여의도', cx: 220, cy: 310, n: 7, spread: 28 },
    { name: '잠실/송파', cx: 620, cy: 340, n: 6, spread: 25 },
  ];
  for (const d of districts) {
    for (let i = 0; i < d.n; i++) {
      storePoints.push({
        x: d.cx + randGauss() * d.spread,
        y: d.cy + randGauss() * d.spread,
        district: d.name
      });
    }
  }
  // Add isolated stores
  for (let i = 0; i < 7; i++) {
    storePoints.push({
      x: 80 + Math.random() * 600,
      y: 60 + Math.random() * 380,
      district: '기타'
    });
  }
  document.getElementById('store-total').textContent = storePoints.length;
}

function runStoreAnalysis() {
  const eps = parseInt(document.getElementById('store-eps').value);
  const minPts = parseInt(document.getElementById('store-minpts').value);
  document.getElementById('store-eps-val').textContent = eps;

  const pts = storePoints.map(s => [s.x, s.y]);
  const result = dbscan(pts, eps, minPts);
  drawStoreMap(result, eps);

  const nZones = result.numClusters;
  const isolated = result.labels.filter(l => l === -1).length;
  const clusterSizes = [];
  for (let c = 0; c < nZones; c++) {
    clusterSizes.push(result.labels.filter(l => l === c).length);
  }
  const avgSize = clusterSizes.length > 0 ? (clusterSizes.reduce((a,b) => a+b, 0) / clusterSizes.length).toFixed(1) : '-';

  document.getElementById('store-zones').textContent = nZones;
  document.getElementById('store-avg').textContent = avgSize;
  document.getElementById('store-isolated').textContent = isolated;
}

function drawStoreMap(result, eps) {
  const canvas = document.getElementById('store-canvas');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  canvas.width = canvas.clientWidth * dpr;
  canvas.height = canvas.clientHeight * dpr;
  ctx.scale(dpr, dpr);
  const W = canvas.clientWidth, H = canvas.clientHeight;
  ctx.clearRect(0, 0, W, H);
  const scaleX = W / 760, scaleY = H / 480;

  // Background grid
  ctx.strokeStyle = '#e2e8f066';
  ctx.lineWidth = 0.5;
  for (let x = 0; x < W; x += 40) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke(); }
  for (let y = 0; y < H; y += 40) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke(); }

  // Draw cluster zones (convex hull-like shading)
  for (let c = 0; c < result.numClusters; c++) {
    const members = [];
    for (let i = 0; i < storePoints.length; i++) {
      if (result.labels[i] === c) members.push(i);
    }
    if (members.length >= 3) {
      const cPts = members.map(i => [storePoints[i].x*scaleX, storePoints[i].y*scaleY]);
      const cx = cPts.reduce((s, p) => s + p[0], 0) / cPts.length;
      const cy = cPts.reduce((s, p) => s + p[1], 0) / cPts.length;
      cPts.sort((a, b) => Math.atan2(a[1]-cy, a[0]-cx) - Math.atan2(b[1]-cy, b[0]-cx));

      ctx.fillStyle = COLORS[c % COLORS.length] + '18';
      ctx.strokeStyle = COLORS[c % COLORS.length] + '50';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.moveTo(cPts[0][0], cPts[0][1]);
      for (let i = 1; i < cPts.length; i++) ctx.lineTo(cPts[i][0], cPts[i][1]);
      ctx.closePath();
      ctx.fill();
      ctx.stroke();

      // Zone label
      ctx.fillStyle = COLORS[c % COLORS.length];
      ctx.font = 'bold 12px Paperlogy, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('권역 ' + (c+1), cx, cy - 18);
    }
  }

  // Draw stores
  for (let i = 0; i < storePoints.length; i++) {
    const x = storePoints[i].x * scaleX, y = storePoints[i].y * scaleY;
    if (result.labels[i] === -1) {
      // Isolated store
      ctx.fillStyle = '#ef4444';
      ctx.strokeStyle = '#ef4444';
      ctx.lineWidth = 2;
      // Draw diamond shape for isolated
      ctx.beginPath();
      ctx.moveTo(x, y-6); ctx.lineTo(x+5, y); ctx.lineTo(x, y+6); ctx.lineTo(x-5, y);
      ctx.closePath();
      ctx.fill();
    } else {
      ctx.fillStyle = COLORS[result.labels[i] % COLORS.length];
      ctx.beginPath();
      ctx.arc(x, y, 5, 0, Math.PI*2);
      ctx.fill();
      ctx.strokeStyle = '#fff';
      ctx.lineWidth = 1;
      ctx.stroke();
    }
  }

  // Legend
  ctx.font = '11px Paperlogy, sans-serif';
  ctx.textAlign = 'left';
  const ly = H - 14;
  ctx.fillStyle = '#2563eb';
  ctx.beginPath(); ctx.arc(14, ly, 5, 0, Math.PI*2); ctx.fill();
  ctx.fillStyle = '#1e293b'; ctx.fillText('군집 매장', 24, ly + 4);

  ctx.fillStyle = '#ef4444';
  ctx.beginPath();
  ctx.moveTo(100, ly-5); ctx.lineTo(105, ly); ctx.lineTo(100, ly+5); ctx.lineTo(95, ly); ctx.closePath();
  ctx.fill();
  ctx.fillStyle = '#1e293b'; ctx.fillText('고립 매장', 112, ly + 4);
}

// ==================== INIT & EVENT BINDING ====================
function init() {

  // 1. HC Visualizer
  hcInit();
  document.getElementById('btn-hc-step').addEventListener('click', hcStep);
  document.getElementById('btn-hc-auto').addEventListener('click', hcAuto);
  document.getElementById('btn-hc-reset').addEventListener('click', () => {
    if (hcAutoTimer) { clearInterval(hcAutoTimer); hcAutoTimer = null; }
    hcInit();
  });
  document.getElementById('hc-linkage').addEventListener('change', () => {
    if (hcAutoTimer) { clearInterval(hcAutoTimer); hcAutoTimer = null; }
    hcInit();
  });

  // 2. Dendrogram
  dendroInit();
  document.getElementById('dendro-cut').addEventListener('input', dendroUpdate);
  document.getElementById('btn-dendro-reset').addEventListener('click', dendroInit);

  // 3. DBSCAN Explorer
  dbscanInit();
  document.getElementById('dbscan-dataset').addEventListener('change', dbscanInit);
  document.getElementById('dbscan-eps').addEventListener('input', dbscanRun);
  document.getElementById('dbscan-minpts').addEventListener('input', dbscanRun);

  // 4. Comparison
  runComparison();
  document.getElementById('btn-compare-run').addEventListener('click', runComparison);
  document.getElementById('compare-dataset').addEventListener('change', runComparison);
  document.getElementById('compare-k').addEventListener('change', runComparison);

  // 5. Store analysis
  generateStores();
  runStoreAnalysis();
  document.getElementById('btn-store-run').addEventListener('click', runStoreAnalysis);
  document.getElementById('store-eps').addEventListener('input', runStoreAnalysis);
  document.getElementById('store-minpts').addEventListener('change', runStoreAnalysis);
  document.getElementById('btn-store-new').addEventListener('click', () => {
    generateStores();
    runStoreAnalysis();
  });

  // Handle canvas resize
  window.addEventListener('resize', () => {
    drawHC();
    dendroUpdate();
    dbscanRun();
  });
}

init();
</script>

