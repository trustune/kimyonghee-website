<script is:inline>
// ==================== CHART.JS LOADER ====================

// ==================== MATH UTILITIES ====================
function randNormal(mu = 0, sigma = 1) {
  let u = 0, v = 0;
  while (u === 0) u = Math.random();
  while (v === 0) v = Math.random();
  return mu + sigma * Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
}

function randExponential(lambda) {
  return -Math.log(1 - Math.random()) / lambda;
}

function randBinomial(n, p) {
  let s = 0;
  for (let i = 0; i < n; i++) if (Math.random() < p) s++;
  return s;
}

function randPoisson(lambda) {
  let L = Math.exp(-lambda), k = 0, p = 1;
  do { k++; p *= Math.random(); } while (p > L);
  return k - 1;
}

function randBimodal() {
  return Math.random() < 0.5 ? randNormal(-3, 1) : randNormal(3, 1);
}

function randT(df) {
  // Using ratio of normals method for t-distribution
  const u = randNormal(0, 1);
  let s = 0;
  for (let i = 0; i < df; i++) { const z = randNormal(0, 1); s += z * z; }
  return u / Math.sqrt(s / df);
}

function computeStats(arr) {
  const n = arr.length;
  const mean = arr.reduce((a, b) => a + b, 0) / n;
  const variance = arr.reduce((a, v) => a + (v - mean) ** 2, 0) / n;
  const sd = Math.sqrt(variance);
  const m3 = arr.reduce((a, v) => a + ((v - mean) / sd) ** 3, 0) / n;
  const m4 = arr.reduce((a, v) => a + ((v - mean) / sd) ** 4, 0) / n;
  return { mean, sd, skewness: m3, kurtosis: m4 - 3 };
}

function makeHistogram(data, bins = 30) {
  const min = Math.min(...data), max = Math.max(...data);
  const bw = (max - min) / bins || 1;
  const hist = new Array(bins).fill(0);
  data.forEach(v => { hist[Math.min(bins - 1, Math.floor((v - min) / bw))]++; });
  const labels = hist.map((_, i) => (min + (i + 0.5) * bw).toFixed(1));
  return { hist, labels, min, max, bw };
}

function normalPDF(x, mu, sigma) {
  return (1 / (sigma * Math.sqrt(2 * Math.PI))) * Math.exp(-0.5 * ((x - mu) / sigma) ** 2);
}

// Standard normal CDF approximation (Abramowitz and Stegun)
function normalCDF(z) {
  if (z < -8) return 0;
  if (z > 8) return 1;
  const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741, a4 = -1.453152027, a5 = 1.061405429;
  const p = 0.3275911;
  const sign = z < 0 ? -1 : 1;
  z = Math.abs(z);
  const t = 1 / (1 + p * z);
  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-z * z / 2);
  return 0.5 * (1 + sign * y);
}

// Inverse normal CDF (rational approximation)
function normalQuantile(p) {
  if (p <= 0) return -Infinity;
  if (p >= 1) return Infinity;
  if (p === 0.5) return 0;
  const a = [-3.969683028665376e+01, 2.209460984245205e+02, -2.759285104469687e+02,
             1.383577518672690e+02, -3.066479806614716e+01, 2.506628277459239e+00];
  const b = [-5.447609879822406e+01, 1.615858368580409e+02, -1.556989798598866e+02,
             6.680131188771972e+01, -1.328068155288572e+01];
  const c = [-7.784894002430293e-03, -3.223964580411365e-01, -2.400758277161838e+00,
             -2.549732539343734e+00, 4.374664141464968e+00, 2.938163982698783e+00];
  const d = [7.784695709041462e-03, 3.224671290700398e-01, 2.445134137142996e+00, 3.754408661907416e+00];
  const pLow = 0.02425, pHigh = 1 - pLow;
  let q, r;
  if (p < pLow) {
    q = Math.sqrt(-2 * Math.log(p));
    return (((((c[0]*q+c[1])*q+c[2])*q+c[3])*q+c[4])*q+c[5]) / ((((d[0]*q+d[1])*q+d[2])*q+d[3])*q+1);
  } else if (p <= pHigh) {
    q = p - 0.5; r = q * q;
    return (((((a[0]*r+a[1])*r+a[2])*r+a[3])*r+a[4])*r+a[5])*q / (((((b[0]*r+b[1])*r+b[2])*r+b[3])*r+b[4])*r+1);
  } else {
    q = Math.sqrt(-2 * Math.log(1 - p));
    return -(((((c[0]*q+c[1])*q+c[2])*q+c[3])*q+c[4])*q+c[5]) / ((((d[0]*q+d[1])*q+d[2])*q+d[3])*q+1);
  }
}

// ==================== INTERACTIVE 1: DISTRIBUTION GALLERY ====================
let distChart = null;

function updateDistParams() {
  const sel = document.getElementById('dist-select').value;
  const container = document.getElementById('dist-params');
  const configs = {
    uniform: '<label>최소값 (a):</label><input type="number" id="dp-a" value="0" style="width:70px" /> <label>최대값 (b):</label><input type="number" id="dp-b" value="10" style="width:70px" />',
    exponential: '<label>Lambda:</label><input type="range" id="dp-lambda" min="0.5" max="10" step="0.5" value="2" /><span class="tb-speed-label" id="dp-lambda-label">2</span>',
    binomial: '<label>시행 횟수 (n):</label><input type="number" id="dp-bn" value="20" min="1" max="100" style="width:70px" /> <label>성공 확률 (p):</label><input type="range" id="dp-bp" min="0.01" max="0.99" step="0.01" value="0.5" /><span class="tb-speed-label" id="dp-bp-label">0.5</span>',
    poisson: '<label>Lambda:</label><input type="range" id="dp-plambda" min="0.5" max="30" step="0.5" value="5" /><span class="tb-speed-label" id="dp-plambda-label">5</span>',
    normal: '<label>평균 (mu):</label><input type="number" id="dp-mu" value="0" style="width:70px" /> <label>표준편차 (sigma):</label><input type="range" id="dp-sigma" min="0.5" max="20" step="0.5" value="5" /><span class="tb-speed-label" id="dp-sigma-label">5</span>',
  };
  container.innerHTML = configs[sel] || '';

  // Bind sliders
  const sliders = container.querySelectorAll('input[type="range"]');
  sliders.forEach(s => {
    const label = container.querySelector(`#${s.id}-label`);
    if (label) {
      s.addEventListener('input', () => { label.textContent = s.value; });
    }
  });
}

async function generateDistribution() {
  
  const sel = document.getElementById('dist-select').value;
  const N = 1000;
  let data = [];
  let theoryCurve = null;

  if (sel === 'uniform') {
    const a = parseFloat(document.getElementById('dp-a').value) || 0;
    const b = parseFloat(document.getElementById('dp-b').value) || 10;
    for (let i = 0; i < N; i++) data.push(a + Math.random() * (b - a));
  } else if (sel === 'exponential') {
    const lam = parseFloat(document.getElementById('dp-lambda').value) || 2;
    for (let i = 0; i < N; i++) data.push(randExponential(lam));
  } else if (sel === 'binomial') {
    const n = parseInt(document.getElementById('dp-bn').value) || 20;
    const p = parseFloat(document.getElementById('dp-bp').value) || 0.5;
    for (let i = 0; i < N; i++) data.push(randBinomial(n, p));
  } else if (sel === 'poisson') {
    const lam = parseFloat(document.getElementById('dp-plambda').value) || 5;
    for (let i = 0; i < N; i++) data.push(randPoisson(lam));
  } else {
    const mu = parseFloat(document.getElementById('dp-mu').value) || 0;
    const sig = parseFloat(document.getElementById('dp-sigma').value) || 5;
    for (let i = 0; i < N; i++) data.push(randNormal(mu, sig));
  }

  const stats = computeStats(data);
  document.getElementById('dist-mean').textContent = stats.mean.toFixed(2);
  document.getElementById('dist-sd').textContent = stats.sd.toFixed(2);
  document.getElementById('dist-skew').textContent = stats.skewness.toFixed(3);
  document.getElementById('dist-kurt').textContent = stats.kurtosis.toFixed(3);

  // Histogram
  const bins = 30;
  const { hist, labels, min, max, bw } = makeHistogram(data, bins);
  // Normalize histogram to density
  const totalArea = data.length * bw;
  const density = hist.map(h => h / totalArea);

  // Theory curve
  const theoryLabels = [];
  const theoryData = [];
  const step = (max - min) / 100;
  for (let x = min; x <= max; x += step) {
    theoryLabels.push(x.toFixed(1));
    if (sel === 'normal') {
      const mu = parseFloat(document.getElementById('dp-mu').value) || 0;
      const sig = parseFloat(document.getElementById('dp-sigma').value) || 5;
      theoryData.push(normalPDF(x, mu, sig));
    } else if (sel === 'exponential') {
      const lam = parseFloat(document.getElementById('dp-lambda').value) || 2;
      theoryData.push(x >= 0 ? lam * Math.exp(-lam * x) : 0);
    } else if (sel === 'uniform') {
      const a = parseFloat(document.getElementById('dp-a').value) || 0;
      const b = parseFloat(document.getElementById('dp-b').value) || 10;
      theoryData.push(x >= a && x <= b ? 1 / (b - a) : 0);
    } else {
      theoryData.push(normalPDF(x, stats.mean, stats.sd));
    }
  }

  const canvas = document.getElementById('dist-gallery-chart');
  if (distChart) { distChart.destroy(); distChart = null; }

  distChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels,
      datasets: [
        {
          label: '히스토그램 (밀도)',
          data: density,
          backgroundColor: '#2563eb55',
          borderColor: '#2563eb',
          borderWidth: 1,
          borderRadius: 2,
          order: 2,
        },
        {
          label: '이론 곡선',
          type: 'line',
          data: labels.map(l => {
            const x = parseFloat(l);
            if (sel === 'normal') {
              const mu = parseFloat(document.getElementById('dp-mu').value) || 0;
              const sig = parseFloat(document.getElementById('dp-sigma').value) || 5;
              return normalPDF(x, mu, sig);
            } else if (sel === 'exponential') {
              const lam = parseFloat(document.getElementById('dp-lambda').value) || 2;
              return x >= 0 ? lam * Math.exp(-lam * x) : 0;
            } else if (sel === 'uniform') {
              const a = parseFloat(document.getElementById('dp-a').value) || 0;
              const b = parseFloat(document.getElementById('dp-b').value) || 10;
              return x >= a && x <= b ? 1 / (b - a) : 0;
            } else {
              return normalPDF(x, stats.mean, stats.sd);
            }
          }),
          borderColor: '#ef4444',
          borderWidth: 2,
          pointRadius: 0,
          fill: false,
          order: 1,
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: { legend: { position: 'top' } },
      scales: {
        y: { beginAtZero: true, title: { display: true, text: '밀도' } },
        x: { title: { display: true, text: '값' }, ticks: { maxTicksLimit: 15 } },
      }
    }
  });
}

// ==================== INTERACTIVE 2: CLT MACHINE ====================
let cltPopChart = null, cltSampChart = null;
let cltMeans = [];
let cltAutoInterval = null;
let cltPopulation = [];
let cltPopType = 'uniform';
let cltPopStats = { mean: 0, sd: 1 };

function generatePopulation(type) {
  const N = 10000;
  const pop = [];
  if (type === 'uniform') {
    for (let i = 0; i < N; i++) pop.push(Math.random() * 10);
  } else if (type === 'exponential') {
    for (let i = 0; i < N; i++) pop.push(randExponential(1));
  } else {
    for (let i = 0; i < N; i++) pop.push(randBimodal());
  }
  return pop;
}

async function drawPopulation() {
  
  const canvas = document.getElementById('clt-population-chart');
  if (cltPopChart) { cltPopChart.destroy(); cltPopChart = null; }

  const { hist, labels } = makeHistogram(cltPopulation, 25);

  cltPopChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: '모집단',
        data: hist,
        backgroundColor: '#f59e0b66',
        borderColor: '#f59e0b',
        borderWidth: 1,
        borderRadius: 2,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, title: { display: true, text: '빈도' } },
        x: { ticks: { maxTicksLimit: 8 } },
      }
    }
  });

  const stats = computeStats(cltPopulation);
  cltPopStats = stats;
  document.getElementById('clt-pop-mean').textContent = stats.mean.toFixed(2);
  document.getElementById('clt-pop-sd').textContent = stats.sd.toFixed(2);
}

async function drawSamplingDist() {
  
  const canvas = document.getElementById('clt-sampling-chart');
  if (cltSampChart) { cltSampChart.destroy(); cltSampChart = null; }

  if (cltMeans.length < 2) {
    cltSampChart = new Chart(canvas, {
      type: 'bar',
      data: { labels: [], datasets: [{ data: [], backgroundColor: '#2563eb55' }] },
      options: { responsive: true, maintainAspectRatio: false, animation: false,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true } }
      }
    });
    return;
  }

  const { hist, labels } = makeHistogram(cltMeans, Math.min(30, Math.ceil(Math.sqrt(cltMeans.length))));

  // Normal overlay
  const stats = computeStats(cltMeans);
  const overlayData = labels.map(l => {
    const x = parseFloat(l);
    const bw = (Math.max(...cltMeans) - Math.min(...cltMeans)) / hist.length || 1;
    return normalPDF(x, stats.mean, stats.sd) * cltMeans.length * bw;
  });

  cltSampChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels,
      datasets: [
        {
          label: '표본평균 분포',
          data: hist,
          backgroundColor: '#2563eb55',
          borderColor: '#2563eb',
          borderWidth: 1,
          borderRadius: 2,
          order: 2,
        },
        {
          label: '정규곡선 (이론)',
          type: 'line',
          data: overlayData,
          borderColor: '#ef4444',
          borderWidth: 2,
          pointRadius: 0,
          fill: false,
          order: 1,
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: { legend: { position: 'top' } },
      scales: {
        y: { beginAtZero: true, title: { display: true, text: '빈도' } },
        x: { ticks: { maxTicksLimit: 8 } },
      }
    }
  });

  document.getElementById('clt-sample-mean').textContent = stats.mean.toFixed(3);
  document.getElementById('clt-sample-sd').textContent = stats.sd.toFixed(3);

  const n = parseInt(document.getElementById('clt-n').value);
  const theorySE = cltPopStats.sd / Math.sqrt(n);
  const seLabel = document.getElementById('clt-sample-sd').parentElement.querySelector('.sub');
  if (seLabel) seLabel.textContent = 'sigma/sqrt(n) = ' + theorySE.toFixed(3);
}

function drawOneSample() {
  const n = parseInt(document.getElementById('clt-n').value);
  const sample = [];
  for (let i = 0; i < n; i++) {
    sample.push(cltPopulation[Math.floor(Math.random() * cltPopulation.length)]);
  }
  const mean = sample.reduce((a, b) => a + b, 0) / n;
  cltMeans.push(mean);

  document.getElementById('clt-count').textContent = '추출 횟수: ' + cltMeans.length;
  const progress = Math.min(100, (cltMeans.length / 500) * 100);
  document.getElementById('clt-progress').style.width = progress + '%';

  if (cltMeans.length % 10 === 0 || cltMeans.length <= 20) {
    drawSamplingDist();
  }
}

function toggleAutoSample() {
  const btn = document.getElementById('btn-clt-auto');
  if (cltAutoInterval) {
    clearInterval(cltAutoInterval);
    cltAutoInterval = null;
    btn.textContent = '자동 추출 시작';
    btn.className = 'tb-btn tb-btn-success';
    drawSamplingDist();
  } else {
    const speed = 101 - parseInt(document.getElementById('clt-speed').value);
    cltAutoInterval = setInterval(() => {
      drawOneSample();
      if (cltMeans.length >= 2000) {
        clearInterval(cltAutoInterval);
        cltAutoInterval = null;
        btn.textContent = '자동 추출 시작';
        btn.className = 'tb-btn tb-btn-success';
        drawSamplingDist();
      }
    }, speed * 2);
    btn.textContent = '자동 추출 중지';
    btn.className = 'tb-btn tb-btn-danger';
  }
}

function resetCLT() {
  if (cltAutoInterval) { clearInterval(cltAutoInterval); cltAutoInterval = null; }
  cltMeans = [];
  document.getElementById('clt-count').textContent = '추출 횟수: 0';
  document.getElementById('clt-progress').style.width = '0%';
  document.getElementById('clt-sample-mean').textContent = '-';
  document.getElementById('clt-sample-sd').textContent = '-';
  document.getElementById('btn-clt-auto').textContent = '자동 추출 시작';
  document.getElementById('btn-clt-auto').className = 'tb-btn tb-btn-success';
  cltPopulation = generatePopulation(cltPopType);
  drawPopulation();
  drawSamplingDist();
}

// ==================== INTERACTIVE 3: NORMAL EXPLORER ====================
let normChart = null;

async function drawNormalExplorer() {
  
  const mu = parseFloat(document.getElementById('norm-mu').value);
  const sigma = parseFloat(document.getElementById('norm-sigma').value);
  const a = parseFloat(document.getElementById('norm-a').value);
  const b = parseFloat(document.getElementById('norm-b').value);

  const xMin = mu - 4 * sigma, xMax = mu + 4 * sigma;
  const step = (xMax - xMin) / 200;
  const xs = [], ys = [], fills = [];
  for (let x = xMin; x <= xMax; x += step) {
    xs.push(x.toFixed(1));
    const y = normalPDF(x, mu, sigma);
    ys.push(y);
    fills.push(x >= a && x <= b ? y : 0);
  }

  const canvas = document.getElementById('norm-explorer-chart');
  if (normChart) { normChart.destroy(); normChart = null; }

  normChart = new Chart(canvas, {
    type: 'line',
    data: {
      labels: xs,
      datasets: [
        {
          label: '정규분포 곡선',
          data: ys,
          borderColor: '#2563eb',
          borderWidth: 2,
          pointRadius: 0,
          fill: false,
          order: 1,
        },
        {
          label: `P(${a} < X < ${b})`,
          data: fills,
          backgroundColor: '#2563eb33',
          borderColor: 'transparent',
          pointRadius: 0,
          fill: 'origin',
          order: 2,
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: { legend: { position: 'top' } },
      scales: {
        y: { beginAtZero: true, title: { display: true, text: 'f(x)' } },
        x: { title: { display: true, text: 'X' }, ticks: { maxTicksLimit: 12 } },
      }
    }
  });

  // Calculate probability
  const za = (a - mu) / sigma;
  const zb = (b - mu) / sigma;
  const prob = normalCDF(zb) - normalCDF(za);

  document.getElementById('norm-prob').textContent = (prob * 100).toFixed(2) + '%';
  document.getElementById('norm-za').textContent = za.toFixed(3);
  document.getElementById('norm-zb').textContent = zb.toFixed(3);
}

function calcZScore() {
  const mu = parseFloat(document.getElementById('norm-mu').value);
  const sigma = parseFloat(document.getElementById('norm-sigma').value);
  const x = parseFloat(document.getElementById('zscore-x').value);
  const z = (x - mu) / sigma;
  const pct = normalCDF(z);

  document.getElementById('zscore-z').textContent = z.toFixed(3);
  document.getElementById('zscore-pct').textContent = (pct * 100).toFixed(1) + '%';

  let interp = '';
  const absZ = Math.abs(z);
  if (absZ < 1) interp = '평균 근처 (보통)';
  else if (absZ < 2) interp = '약간 벗어남';
  else if (absZ < 3) interp = '상당히 극단적';
  else interp = '매우 극단적 (이상치?)';
  document.getElementById('zscore-interp').textContent = interp;
}

// ==================== INTERACTIVE 4: QQ-PLOT ====================
let qqHistChart = null, qqPlotChart = null;

async function generateQQData() {
  
  const dist = document.getElementById('qq-dist').value;
  const n = parseInt(document.getElementById('qq-n').value);
  let data = [];

  if (dist === 'normal') {
    for (let i = 0; i < n; i++) data.push(randNormal(0, 1));
  } else if (dist === 'exponential') {
    for (let i = 0; i < n; i++) data.push(randExponential(1));
  } else if (dist === 'uniform') {
    for (let i = 0; i < n; i++) data.push(Math.random() * 10);
  } else if (dist === 't3') {
    for (let i = 0; i < n; i++) data.push(randT(3));
  } else {
    for (let i = 0; i < n; i++) data.push(randBimodal());
  }

  const stats = computeStats(data);
  document.getElementById('qq-skew').textContent = stats.skewness.toFixed(3);
  document.getElementById('qq-kurt').textContent = stats.kurtosis.toFixed(3);

  // Verdict
  const isNormal = Math.abs(stats.skewness) < 0.5 && Math.abs(stats.kurtosis) < 1;
  document.getElementById('qq-verdict').textContent = isNormal ? '정규 의심' : '비정규 의심';
  document.getElementById('qq-verdict').style.color = isNormal ? 'var(--tb-success)' : 'var(--tb-danger)';

  // Histogram
  const canvasHist = document.getElementById('qq-hist-chart');
  if (qqHistChart) { qqHistChart.destroy(); qqHistChart = null; }
  const { hist, labels } = makeHistogram(data, 20);

  qqHistChart = new Chart(canvasHist, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: '빈도',
        data: hist,
        backgroundColor: '#7c3aed55',
        borderColor: '#7c3aed',
        borderWidth: 1,
        borderRadius: 2,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true },
        x: { ticks: { maxTicksLimit: 8 } },
      }
    }
  });

  // QQ-Plot
  const sorted = [...data].sort((a, b) => a - b);
  const theoretical = sorted.map((_, i) => {
    const p = (i + 0.5) / n;
    return normalQuantile(p);
  });

  // Standardize data for comparison
  const dataMean = stats.mean;
  const dataSd = stats.sd;
  const standardized = sorted.map(v => (v - dataMean) / dataSd);

  const canvasQQ = document.getElementById('qq-plot-chart');
  if (qqPlotChart) { qqPlotChart.destroy(); qqPlotChart = null; }

  const minVal = Math.min(Math.min(...theoretical), Math.min(...standardized));
  const maxVal = Math.max(Math.max(...theoretical), Math.max(...standardized));

  qqPlotChart = new Chart(canvasQQ, {
    type: 'scatter',
    data: {
      datasets: [
        {
          label: 'QQ점',
          data: theoretical.map((t, i) => ({ x: t, y: standardized[i] })),
          backgroundColor: '#2563eb88',
          pointRadius: 3,
          order: 2,
        },
        {
          label: '대각선 (정규)',
          type: 'line',
          data: [{ x: minVal, y: minVal }, { x: maxVal, y: maxVal }],
          borderColor: '#ef4444',
          borderWidth: 2,
          borderDash: [5, 5],
          pointRadius: 0,
          fill: false,
          order: 1,
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: { legend: { position: 'top' } },
      scales: {
        x: { title: { display: true, text: '이론적 분위수 (정규)' } },
        y: { title: { display: true, text: '표본 분위수 (표준화)' } },
      }
    }
  });
}

// ==================== INIT & EVENT BINDING ====================
function init() {

  // Interactive 1
  updateDistParams();
  document.getElementById('dist-select').addEventListener('change', updateDistParams);
  document.getElementById('btn-gen-dist').addEventListener('click', generateDistribution);
  document.getElementById('btn-reset-dist').addEventListener('click', () => {
    if (distChart) { distChart.destroy(); distChart = null; }
    document.getElementById('dist-mean').textContent = '-';
    document.getElementById('dist-sd').textContent = '-';
    document.getElementById('dist-skew').textContent = '-';
    document.getElementById('dist-kurt').textContent = '-';
  });

  // Interactive 2 - CLT
  document.querySelectorAll('.pop-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.pop-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      cltPopType = btn.dataset.pop;
      resetCLT();
    });
  });

  document.getElementById('clt-n').addEventListener('input', (e) => {
    document.getElementById('clt-n-label').textContent = 'n=' + e.target.value;
  });
  document.getElementById('clt-speed').addEventListener('input', (e) => {
    document.getElementById('clt-speed-label').textContent = (101 - parseInt(e.target.value)) * 2 + 'ms';
  });

  document.getElementById('btn-clt-draw').addEventListener('click', drawOneSample);
  document.getElementById('btn-clt-auto').addEventListener('click', toggleAutoSample);
  document.getElementById('btn-clt-reset').addEventListener('click', resetCLT);

  cltPopulation = generatePopulation('uniform');
  drawPopulation();
  drawSamplingDist();

  // Interactive 3 - Normal Explorer
  const updateNormLabels = () => {
    document.getElementById('norm-mu-label').textContent = 'mu=' + document.getElementById('norm-mu').value;
    document.getElementById('norm-sigma-label').textContent = 'sigma=' + document.getElementById('norm-sigma').value;
  };
  document.getElementById('norm-mu').addEventListener('input', updateNormLabels);
  document.getElementById('norm-sigma').addEventListener('input', updateNormLabels);
  document.getElementById('btn-norm-update').addEventListener('click', drawNormalExplorer);
  document.getElementById('btn-zscore').addEventListener('click', calcZScore);

  // Interactive 4 - QQ-Plot
  document.getElementById('btn-qq-gen').addEventListener('click', generateQQData);

  // Auto-generate initial views
  generateDistribution();
  drawNormalExplorer();
  generateQQData();
}

document.addEventListener('DOMContentLoaded', init);
</script>

