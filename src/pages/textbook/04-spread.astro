// ==================== INTERACTIVE 2: STOCK VOLATILITY ====================
let stockChart = null;
let stockRunCount = 0;

async function runStockSim() {
  const Chart = await loadChart();
  const canvas = document.getElementById('stock-chart');
  if (stockChart) stockChart.destroy();
  stockRunCount++;

  const dailyReturn = 0.0003; // 0.03% per day -> ~8% annual
  const volStable = parseFloat(document.getElementById('stock-vol-stable').value);
  const volStartup = parseFloat(document.getElementById('stock-vol-startup').value);
  const days = 252;

  const priceStable = [100], priceStartup = [100];
  let maxStable = 100, maxStartup = 100;
  let ddStable = 0, ddStartup = 0;

  for (let i = 0; i < days; i++) {
    const u1 = Math.random(), u2 = Math.random();
    const z1 = Math.sqrt(-2 * Math.log(u1)) * Math.cos(2 * Math.PI * u2);
    const z2 = Math.sqrt(-2 * Math.log(u1)) * Math.sin(2 * Math.PI * u2);

    const retS = dailyReturn + volStable * z1;
    const retU = dailyReturn + volStartup * z2;

    const newS = priceStable[priceStable.length - 1] * (1 + retS);
    const newU = priceStartup[priceStartup.length - 1] * (1 + retU);

    priceStable.push(newS);
    priceStartup.push(newU);

    maxStable = Math.max(maxStable, newS);
    maxStartup = Math.max(maxStartup, newU);
    ddStable = Math.max(ddStable, (maxStable - newS) / maxStable);
    ddStartup = Math.max(ddStartup, (maxStartup - newU) / maxStartup);
  }

  const labels = Array.from({length: days + 1}, (_, i) => i);

  stockChart = new Chart(canvas, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: '삼성전자 (안정)',
          data: priceStable,
          borderColor: '#2563eb',
          backgroundColor: '#2563eb22',
          fill: false,
          pointRadius: 0,
          borderWidth: 2,
        },
        {
          label: '가상 스타트업 (고변동)',
          data: priceStartup,
          borderColor: '#ef4444',
          backgroundColor: '#ef444422',
          fill: false,
          pointRadius: 0,
          borderWidth: 2,
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: {
        legend: { position: 'top' },
        title: { display: true, text: '1년 주가 시뮬레이션 (시작가 100)', font: { size: 13, family: "'Paperlogy'" } }
      },
      scales: {
        y: { title: { display: true, text: '가격' } },
        x: { title: { display: true, text: '거래일' }, ticks: { maxTicksLimit: 10 } }
      }
    }
  });

  const retStable = ((priceStable[days] - 100) / 100 * 100).toFixed(1);
  const retStartup = ((priceStartup[days] - 100) / 100 * 100).toFixed(1);

  document.getElementById('stock-ret-stable').textContent = retStable + '%';
  document.getElementById('stock-ret-startup').textContent = retStartup + '%';
  document.getElementById('stock-dd-stable').textContent = '-' + (ddStable * 100).toFixed(1) + '%';
  document.getElementById('stock-dd-startup').textContent = '-' + (ddStartup * 100).toFixed(1) + '%';

  document.getElementById('stock-run-count').textContent =
    `${stockRunCount}회 시뮬레이션 완료. 여러 번 실행하여 결과의 변동성을 비교해 보세요.`;
}

// ==================== INTERACTIVE 3: CHEBYSHEV ====================
let chebChart = null;

async function runChebyshev() {
  const Chart = await loadChart();
  const dist = document.getElementById('cheb-dist').value;
  const n = parseInt(document.getElementById('cheb-n').value);

  let data;
  if (dist === 'normal') data = genNormal(n, 50, 15);
  else if (dist === 'skewed') data = genSkewed(n, 40);
  else if (dist === 'uniform') data = genUniform(n, 50, 60);
  else data = genBimodal(n);

  const mean = calcMean(data);
  const sd = calcSD(data);

  // Histogram with sigma bands
  const canvas = document.getElementById('cheb-chart');
  if (chebChart) chebChart.destroy();
  const h = makeHistogram(data, 25);

  // Color bins by sigma
  const bgColors = h.labels.map(label => {
    const dist = Math.abs(label - mean);
    if (dist <= sd) return '#22c55e66';
    if (dist <= 2 * sd) return '#f59e0b66';
    if (dist <= 3 * sd) return '#ef444466';
    return '#94a3b844';
  });

  chebChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: h.labels,
      datasets: [{
        data: h.hist,
        backgroundColor: bgColors,
        borderColor: bgColors.map(c => c.replace('66', 'cc')),
        borderWidth: 1,
        borderRadius: 2,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, animation: false,
      plugins: {
        legend: { display: false },
        title: { display: true, text: '녹색=1SD, 노랑=2SD, 빨강=3SD, 회색=3SD 밖', font: { size: 11, family: "'Paperlogy'" } }
      },
      scales: {
        y: { beginAtZero: true },
        x: { ticks: { maxTicksLimit: 12 } }
      }
    }
  });

  // Calculate percentages
  const within1 = data.filter(v => Math.abs(v - mean) <= sd).length / n * 100;
  const within2 = data.filter(v => Math.abs(v - mean) <= 2 * sd).length / n * 100;
  const within3 = data.filter(v => Math.abs(v - mean) <= 3 * sd).length / n * 100;

  const tbody = document.getElementById('cheb-tbody');
  tbody.innerHTML = '';

  const rows = [
    { range: 'x-bar +/- 1 SD', actual: within1, empirical: 68, cheb: 0 },
    { range: 'x-bar +/- 2 SD', actual: within2, empirical: 95, cheb: 75 },
    { range: 'x-bar +/- 3 SD', actual: within3, empirical: 99.7, cheb: 88.9 },
  ];

  rows.forEach(r => {
    const matchEmpirical = Math.abs(r.actual - r.empirical) < 5;
    const passCheb = r.actual >= r.cheb;
    tbody.insertAdjacentHTML('beforeend', `<tr>
      <td><strong>${r.range}</strong></td>
      <td style="font-weight: 700;">${r.actual.toFixed(1)}%</td>
      <td>${r.empirical}%</td>
      <td>${r.cheb > 0 ? r.cheb.toFixed(1) + '%' : '-'}</td>
      <td>
        ${dist === 'normal' && matchEmpirical
          ? '<span style="color:var(--tb-success);font-weight:700;">경험적 규칙 적합</span>'
          : passCheb
            ? '<span style="color:var(--tb-primary);font-weight:700;">체비셰프 충족</span>'
            : '<span style="color:var(--tb-danger);">확인 필요</span>'
        }
      </td>
    </tr>`);
  });
}

// ==================== INTERACTIVE 4: BOX PLOT ====================
function drawBoxPlot(canvasId, data, color, prefix) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const w = canvas.width, h = canvas.height;
  ctx.clearRect(0, 0, w, h);

  if (data.length < 5) {
    ctx.fillStyle = '#94a3b8';
    ctx.font = '14px Paperlogy, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('데이터가 부족합니다 (최소 5개)', w/2, h/2);
    return;
  }

  const sorted = [...data].sort((a, b) => a - b);
  const q1 = calcQ(sorted, 0.25);
  const q2 = calcQ(sorted, 0.5);
  const q3 = calcQ(sorted, 0.75);
  const iqr = q3 - q1;
  const lowerFence = q1 - 1.5 * iqr;
  const upperFence = q3 + 1.5 * iqr;

  const minWhisker = Math.max(sorted[0], lowerFence);
  const maxWhisker = Math.min(sorted[sorted.length - 1], upperFence);
  const outliers = sorted.filter(v => v < lowerFence || v > upperFence);

  const dataMin = Math.min(sorted[0], lowerFence) - iqr * 0.3;
  const dataMax = Math.max(sorted[sorted.length - 1], upperFence) + iqr * 0.3;
  const range = dataMax - dataMin || 1;

  const pad = 60;
  const plotW = w - 2 * pad;
  const plotH = h - 80;
  const cx = w / 2;
  const boxW = 80;

  function scaleY(v) {
    return pad + plotH - ((v - dataMin) / range) * plotH;
  }

  // Background
  ctx.fillStyle = '#f8fafc';
  ctx.fillRect(0, 0, w, h);

  // Y axis labels
  ctx.fillStyle = '#475569';
  ctx.font = '11px Paperlogy, sans-serif';
  ctx.textAlign = 'right';
  const ticks = 6;
  for (let i = 0; i <= ticks; i++) {
    const val = dataMin + (range * i / ticks);
    const y = scaleY(val);
    ctx.fillText(Math.round(val).toString(), pad - 8, y + 4);
    ctx.strokeStyle = '#e2e8f0';
    ctx.lineWidth = 0.5;
    ctx.beginPath();
    ctx.moveTo(pad, y);
    ctx.lineTo(w - pad, y);
    ctx.stroke();
  }

  // Whisker (lower)
  ctx.strokeStyle = color;
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(cx, scaleY(minWhisker));
  ctx.lineTo(cx, scaleY(q1));
  ctx.stroke();
  // Whisker cap (lower)
  ctx.beginPath();
  ctx.moveTo(cx - 20, scaleY(minWhisker));
  ctx.lineTo(cx + 20, scaleY(minWhisker));
  ctx.stroke();

  // Whisker (upper)
  ctx.beginPath();
  ctx.moveTo(cx, scaleY(q3));
  ctx.lineTo(cx, scaleY(maxWhisker));
  ctx.stroke();
  // Whisker cap (upper)
  ctx.beginPath();
  ctx.moveTo(cx - 20, scaleY(maxWhisker));
  ctx.lineTo(cx + 20, scaleY(maxWhisker));
  ctx.stroke();

  // Box
  const boxTop = scaleY(q3);
  const boxBottom = scaleY(q1);
  ctx.fillStyle = color + '33';
  ctx.fillRect(cx - boxW/2, boxTop, boxW, boxBottom - boxTop);
  ctx.strokeStyle = color;
  ctx.lineWidth = 2;
  ctx.strokeRect(cx - boxW/2, boxTop, boxW, boxBottom - boxTop);

  // Median line
  ctx.strokeStyle = color;
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.moveTo(cx - boxW/2, scaleY(q2));
  ctx.lineTo(cx + boxW/2, scaleY(q2));
  ctx.stroke();

  // Outliers
  outliers.forEach(v => {
    ctx.beginPath();
    ctx.arc(cx, scaleY(v), 4, 0, Math.PI * 2);
    ctx.fillStyle = color;
    ctx.fill();
  });

  // Labels
  ctx.fillStyle = '#475569';
  ctx.font = '11px Paperlogy, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText('Q3: ' + Math.round(q3), cx + boxW/2 + 8, boxTop + 4);
  ctx.fillText('Q2: ' + Math.round(q2), cx + boxW/2 + 8, scaleY(q2) + 4);
  ctx.fillText('Q1: ' + Math.round(q1), cx + boxW/2 + 8, boxBottom + 4);
  ctx.fillText('IQR: ' + Math.round(iqr), cx + boxW/2 + 8, (boxTop + boxBottom)/2 + 4);

  if (outliers.length > 0) {
    ctx.fillStyle = '#ef4444';
    ctx.fillText('이상치: ' + outliers.length + '개', cx + boxW/2 + 8, scaleY(outliers[outliers.length - 1]) + 4);
  }

  // Update stat boxes
  const el = (id) => document.getElementById(id);
  if (el(prefix + '-q1')) el(prefix + '-q1').textContent = Math.round(q1);
  if (el(prefix + '-q2')) el(prefix + '-q2').textContent = Math.round(q2);
  if (el(prefix + '-q3')) el(prefix + '-q3').textContent = Math.round(q3);
  if (el(prefix + '-iqr')) el(prefix + '-iqr').textContent = Math.round(iqr);
}

function genBoxData(dist) {
  if (dist === 'normal') return genNormal(80, 50, 15);
  if (dist === 'skewed') return genSkewed(80, 40);
  return genUniform(80, 50, 60);
}

function updateBoxPlots() {
  const distA = document.getElementById('box-dist-a').value;
  const distB = document.getElementById('box-dist-b').value;
  drawBoxPlot('box-canvas-a', genBoxData(distA), '#2563eb', 'box-q1-a,box-q2-a,box-q3-a,box-iqr-a'.split(',')[0] ? 'box' : 'box');
  const dataA = genBoxData(distA);
  const dataB = genBoxData(distB);
  drawBoxPlot('box-canvas-a', dataA, '#2563eb', 'box');

  // Prefix adjustment for B
  drawBoxPlotB(dataB);
}

function drawBoxPlotB(data) {
  drawBoxPlot('box-canvas-b', data, '#ef4444', 'box');
  // Override B stats manually
  if (data.length >= 5) {
    const q1 = calcQ(data, 0.25);
    const q2 = calcQ(data, 0.5);
    const q3 = calcQ(data, 0.75);
    document.getElementById('box-q1-b').textContent = Math.round(q1);
    document.getElementById('box-q2-b').textContent = Math.round(q2);
    document.getElementById('box-q3-b').textContent = Math.round(q3);
    document.getElementById('box-iqr-b').textContent = Math.round(q3 - q1);
  }
}

function generateBoxPlots() {
  const distA = document.getElementById('box-dist-a').value;
  const distB = document.getElementById('box-dist-b').value;
  const dataA = genBoxData(distA);
  const dataB = genBoxData(distB);

  drawBoxPlot('box-canvas-a', dataA, '#2563eb', 'box');
  // For A stats
  if (dataA.length >= 5) {
    const q1 = calcQ(dataA, 0.25);
    const q2 = calcQ(dataA, 0.5);
    const q3 = calcQ(dataA, 0.75);
    document.getElementById('box-q1-a').textContent = Math.round(q1);
    document.getElementById('box-q2-a').textContent = Math.round(q2);
    document.getElementById('box-q3-a').textContent = Math.round(q3);
    document.getElementById('box-iqr-a').textContent = Math.round(q3 - q1);
  }

  drawBoxPlot('box-canvas-b', dataB, '#ef4444', 'box');
  if (dataB.length >= 5) {
    const q1 = calcQ(dataB, 0.25);
    const q2 = calcQ(dataB, 0.5);
    const q3 = calcQ(dataB, 0.75);
    document.getElementById('box-q1-b').textContent = Math.round(q1);
    document.getElementById('box-q2-b').textContent = Math.round(q2);
    document.getElementById('box-q3-b').textContent = Math.round(q3);
    document.getElementById('box-iqr-b').textContent = Math.round(q3 - q1);
  }
}

function applyManualData() {
  const input = document.getElementById('box-manual-input').value;
  const vals = input.split(',').map(s => parseFloat(s.trim())).filter(v => !isNaN(v));
  if (vals.length < 5) {
    alert('최소 5개의 숫자를 쉼표로 구분하여 입력하세요.');
    return;
  }
  drawBoxPlot('box-canvas-a', vals, '#2563eb', 'box');
  const q1 = calcQ(vals, 0.25);
  const q2 = calcQ(vals, 0.5);
  const q3 = calcQ(vals, 0.75);
  document.getElementById('box-q1-a').textContent = Math.round(q1);
  document.getElementById('box-q2-a').textContent = Math.round(q2);
  document.getElementById('box-q3-a').textContent = Math.round(q3);
  document.getElementById('box-iqr-a').textContent = Math.round(q3 - q1);
}

// ==================== INIT ====================
function init() {
  try {
  } catch(e) {}

  // Interactive 1: Dual distribution
  updateDual();

  // Interactive 2: Stock sim
  runStockSim();

  // Interactive 3: Chebyshev
  runChebyshev();

  // Interactive 4: Box plot
  generateBoxPlots();

  // Event listeners
  document.getElementById('dual-sd-a').addEventListener('input', updateDual);
  document.getElementById('dual-sd-b').addEventListener('input', updateDual);

  document.getElementById('btn-stock-run').addEventListener('click', runStockSim);

  document.getElementById('btn-cheb-gen').addEventListener('click', runChebyshev);

  document.getElementById('btn-box-gen').addEventListener('click', generateBoxPlots);
  document.getElementById('btn-box-manual').addEventListener('click', applyManualData);
}

document.addEventListener('DOMContentLoaded', init);
