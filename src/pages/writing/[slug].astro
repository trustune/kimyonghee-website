---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialShare from '../../components/SocialShare.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, title_en, excerpt, excerpt_en, date, category, tags, image, author, enableShare } = entry.data;
const readingTime = (entry.data as any).readingTime as number | undefined;

const titleKo = title;
const titleEn = title_en || title;

const formattedDateKo = new Date(date).toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedDateEn = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const currentUrl = `https://kimyonghee.com/writing/${entry.slug}`;
const fullImageUrl = image ? `https://kimyonghee.com${image}` : '';
---

<BaseLayout title={`${titleEn} | Yonghee Kim`} description={excerpt_en || excerpt} image={fullImageUrl} url={currentUrl}>
  <article class="post container">
    <header class="post-header">
      <a href="/writing" class="back-link reveal" aria-label="글 목록으로 / Back to writing">
        <span class="back-arrow" aria-hidden="true">&larr;</span>
        <span data-lang="ko">글 목록</span><span data-lang="en">Back to writing</span>
      </a>

      <div class="post-cat reveal">
        <span class="cat-tag">{category}</span>
      </div>

      <h1 class="post-title reveal">
        <span data-lang="ko">{titleKo}</span><span data-lang="en">{titleEn}</span>
      </h1>

      {(excerpt || excerpt_en) && (
        <p class="post-lede reveal">
          <span data-lang="ko">{excerpt}</span>
          <span data-lang="en">{excerpt_en || excerpt}</span>
        </p>
      )}

      <dl class="post-meta reveal">
        <div class="meta-item">
          <dt class="meta-label"><span data-lang="ko">작성일</span><span data-lang="en">Published</span></dt>
          <dd class="meta-value">
            <span data-lang="ko">{formattedDateKo}</span>
            <span data-lang="en">{formattedDateEn}</span>
          </dd>
        </div>
        <div class="meta-item">
          <dt class="meta-label"><span data-lang="ko">분류</span><span data-lang="en">Category</span></dt>
          <dd class="meta-value">{category}</dd>
        </div>
        {readingTime && readingTime > 0 && (
          <div class="meta-item">
            <dt class="meta-label"><span data-lang="ko">읽는 시간</span><span data-lang="en">Reading time</span></dt>
            <dd class="meta-value">
              <span data-lang="ko">{readingTime}분</span>
              <span data-lang="en">{readingTime} min</span>
            </dd>
          </div>
        )}
        <div class="meta-item">
          <dt class="meta-label"><span data-lang="ko">글쓴이</span><span data-lang="en">Author</span></dt>
          <dd class="meta-value">{author}</dd>
        </div>
      </dl>
    </header>

    {image && (
      <figure class="post-hero reveal">
        <img src={image} alt={titleEn} class="post-hero-image" loading="lazy" />
      </figure>
    )}

    <div class="prose post-body reveal">
      <Content />
    </div>

    {tags && tags.length > 0 && (
      <div class="post-tags reveal">
        <span class="tags-label"><span data-lang="ko">키워드</span><span data-lang="en">Keywords</span></span>
        <ul class="tags-list">
          {tags.map((tag) => (
            <li class="post-tag">#{tag}</li>
          ))}
        </ul>
      </div>
    )}

    {enableShare && (
      <div class="share-section reveal">
        <SocialShare
          title={titleEn}
          url={currentUrl}
          excerpt={excerpt_en || excerpt}
          image={fullImageUrl}
        />
      </div>
    )}

    <footer class="post-footer reveal">
      <a href="/writing" class="text-link">
        <span class="arrow" aria-hidden="true">&larr;</span>
        <span data-lang="ko">전체 글 보기</span><span data-lang="en">View all writing</span>
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 760px;
    padding-block: var(--section-gap);
  }

  /* ── Header ── */
  .post-header {
    margin-bottom: var(--space-10);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
    font-size: 0.9rem;
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
  }
  .back-link .back-arrow {
    transition: transform var(--transition-base);
  }
  .back-link:hover { color: var(--color-accent-hover); }
  .back-link:hover .back-arrow { transform: translateX(-3px); }

  .post-cat {
    margin-bottom: var(--space-5);
  }
  .cat-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .post-title {
    font-size: var(--step-4);
    font-weight: var(--weight-black);
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0 0 var(--space-6) 0;
  }

  .post-lede {
    font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem);
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-8) 0;
    max-width: 56ch;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    margin: 0;
  }
  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .meta-label {
    font-size: 0.72rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }
  .meta-value {
    font-size: 0.92rem;
    font-weight: var(--weight-medium);
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }

  /* ── Hero image ── */
  .post-hero {
    margin: 0 0 var(--space-12) 0;
  }
  .post-hero-image {
    width: 100%;
    height: auto;
    max-height: 440px;
    object-fit: cover;
    border-radius: var(--radius-soft);
    border: 1px solid var(--color-border-light);
  }

  /* ── Body ── */
  .post-body {
    font-size: var(--step-0);
    color: var(--color-text);
  }

  /* ── Tags ── */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-light);
  }
  .tags-label {
    font-size: 0.72rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }
  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-tag {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ── Share ── */
  .share-section {
    margin-top: var(--space-10);
  }

  /* ── Footer ── */
  .post-footer {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-light);
  }
  .post-footer .text-link .arrow {
    transition: transform var(--transition-base);
  }
  .post-footer .text-link:hover .arrow { transform: translateX(-4px); }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .post {
      padding-block: var(--space-12);
    }
    .post-title {
      font-size: var(--step-3);
    }
    .post-meta {
      gap: var(--space-6);
    }
  }
</style>
