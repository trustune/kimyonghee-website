---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import media from '../../data/media.json';

const allPosts = await getCollection('blog');

const blogItems = allPosts.map(post => ({
  title: post.data.title,
  title_ko: (post.data as any).title_ko as string | undefined,
  title_en: (post.data as any).title_en as string | undefined,
  slug: post.slug,
  date: post.data.date,
  excerpt: post.data.excerpt,
  excerpt_ko: (post.data as any).excerpt_ko as string | undefined,
  excerpt_en: (post.data as any).excerpt_en as string | undefined,
  category: post.data.category || 'Blog',
  tags: post.data.tags || [],
  source: 'blog' as const,
}));

const mediaItems = media.articles.map(article => ({
  title: article.title,
  title_ko: (article as any).title_ko as string | undefined,
  title_en: (article as any).title_en as string | undefined,
  slug: article.url,
  date: article.date,
  excerpt: article.description,
  excerpt_ko: (article as any).description_ko as string | undefined,
  excerpt_en: (article as any).description_en as string | undefined,
  category: article.category || 'Opinion',
  tags: [] as string[],
  source: 'media' as const,
  url: article.url,
}));

const allItems = [...blogItems, ...mediaItems]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const tagStats: Record<string, number> = {};
allItems.forEach(item => {
  item.tags?.forEach(tag => {
    tagStats[tag] = (tagStats[tag] || 0) + 1;
  });
});
const sortedTags = Object.entries(tagStats)
  .sort((a, b) => b[1] - a[1]);

// 날짜 로캘 분기: ko-KR / en-US
const fmtDate = (d: any, lang: 'ko' | 'en') =>
  new Date(d).toLocaleDateString(lang === 'ko' ? 'ko-KR' : 'en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });

// 카테고리 라벨 한국어 매핑(미지정 카테고리는 원문 유지)
const CAT_KO: Record<string, string> = {
  'Blog': '블로그',
  'Announcement': '공지',
  'Analysis': '분석',
  'Opinion': '오피니언',
  'Expert Column': '전문가 칼럼',
  'Content Column': '콘텐츠 칼럼',
  'ET Opinion': '전자신문 오피니언',
  'editorial': '사설',
  'Review': '리뷰',
  'Essay': '에세이',
};
const catKo = (c: string) => CAT_KO[c] || c;
---

<BaseLayout
  title="글"
  description="미디어 정책, 디지털 플랫폼, 기술 규제, 학술 연구에 관한 글과 칼럼, 분석. Articles, columns, and analysis on media policy, digital platforms, technology regulation, and research.">
  <div class="writing-page container">
    <!-- ═══════════════ HEADER ═══════════════ -->
    <header class="page-head reveal">
      <h1 class="page-title">
        <span data-lang="ko">글</span><span data-lang="en">Writing</span>
      </h1>
      <p class="page-lede">
        <span data-lang="ko">미디어 정책과 디지털 플랫폼, 기술 규제, 그리고 학술 연구에 관한 글과 칼럼, 분석을 모았습니다.</span>
        <span data-lang="en">Posts, columns, and analysis on media policy, digital platforms, technology regulation, and academic research.</span>
      </p>
      <span class="page-rule" aria-hidden="true"></span>
    </header>

    {allItems.length === 0 ? (
      <div class="empty-state reveal">
        <p><span data-lang="ko">아직 등록된 글이 없습니다.</span><span data-lang="en">No posts yet.</span></p>
      </div>
    ) : (
      <div class="writing-content">
        <!-- ═══════════════ SIDEBAR ═══════════════ -->
        <aside class="sidebar reveal">
          <div class="filter-group">
            <h2 class="sidebar-heading"><span data-lang="ko">검색</span><span data-lang="en">Search</span></h2>
            <div class="search-box">
              <input
                type="text"
                id="searchInput"
                autocomplete="off"
                data-ph-ko="글 검색…"
                data-ph-en="Search posts…"
                aria-label="글 검색 / Search posts"
              />
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>
            </div>
          </div>

          {sortedTags.length > 0 && (
            <div class="filter-group">
              <h2 class="sidebar-heading"><span data-lang="ko">태그</span><span data-lang="en">Tags</span></h2>
              <div class="tag-cloud">
                <button class="tag-filter active" data-tag="all">
                  <span data-lang="ko">전체</span><span data-lang="en">All</span>
                  <span class="tag-count">{allItems.length}</span>
                </button>
                {sortedTags.map(([tag, count]) => (
                  <button class="tag-filter" data-tag={tag}>
                    {tag}<span class="tag-count">{count}</span>
                  </button>
                ))}
              </div>
            </div>
          )}
        </aside>

        <!-- ═══════════════ POSTS ═══════════════ -->
        <section class="posts-section">
          <ul id="postsContainer" class="rows">
            {allItems.map((item, i) => {
              const href = item.source === 'media' ? (item.url || item.slug) : `/writing/${item.slug}`;
              const isExternal = item.source === 'media';
              const tagList = item.tags?.join(',') || '';
              const titleKo = item.title_ko || item.title;
              const titleEn = item.title_en || item.title;
              const excerptKo = item.excerpt_ko || item.excerpt;
              const excerptEn = item.excerpt_en || item.excerpt;
              return (
                <li
                  class="row reveal"
                  style={`--i:${i}`}
                  data-title={`${titleKo} ${titleEn}`}
                  data-tags={tagList}
                  data-tag-list={tagList}>
                  <a
                    href={href}
                    class="row-link"
                    target={isExternal ? '_blank' : undefined}
                    rel={isExternal ? 'noopener noreferrer' : undefined}>
                    <span class="row-main">
                      <span class="row-eyebrow">
                        <span class={`row-source row-source--${item.source}`}>
                          {isExternal
                            ? (<><span data-lang="ko">외부 기고</span><span data-lang="en">External</span></>)
                            : (<><span data-lang="ko">블로그</span><span data-lang="en">Blog</span></>)}
                        </span>
                        <span class="row-cat"><span data-lang="ko">{catKo(item.category)}</span><span data-lang="en">{item.category}</span></span>
                        <span class="row-dot" aria-hidden="true"></span>
                        <time class="row-date" datetime={new Date(item.date).toISOString()}>
                          <span data-lang="ko">{fmtDate(item.date, 'ko')}</span>
                          <span data-lang="en">{fmtDate(item.date, 'en')}</span>
                        </time>
                      </span>
                      <span class="row-title">
                        <span data-lang="ko">{titleKo}</span>
                        <span data-lang="en">{titleEn}</span>
                      </span>
                      {(excerptKo || excerptEn) && (
                        <span class="row-excerpt">
                          <span data-lang="ko">{excerptKo}</span>
                          <span data-lang="en">{excerptEn}</span>
                        </span>
                      )}
                      {item.tags && item.tags.length > 0 && (
                        <span class="row-tags">
                          {item.tags.map((tag) => (<span class="row-tag">{tag}</span>))}
                        </span>
                      )}
                    </span>
                    <span class="row-arrow" aria-hidden="true">
                      {isExternal ? '↗' : '→'}
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
          <div id="noResults" class="no-results" style="display: none;">
            <p><span data-lang="ko">검색 결과가 없습니다.</span><span data-lang="en">No posts found matching your search.</span></p>
          </div>
        </section>
      </div>
    )}
  </div>
</BaseLayout>

<script is:inline>
  function initWritingSearch() {
    var searchInput = document.getElementById('searchInput');
    var postsContainer = document.getElementById('postsContainer');
    if (!searchInput || !postsContainer) return;

    var postCards = postsContainer.querySelectorAll('.row');
    var noResults = document.getElementById('noResults');
    var tagFilters = document.querySelectorAll('.tag-filter');

    // 검색창 placeholder를 현재 언어에 맞춰 적용
    function syncPlaceholder() {
      var lang = document.documentElement.getAttribute('data-language') === 'ko' ? 'ko' : 'en';
      var ph = searchInput.getAttribute('data-ph-' + lang);
      if (ph) searchInput.setAttribute('placeholder', ph);
    }
    syncPlaceholder();

    var currentTag = 'all';
    var currentSearch = '';

    function filterPosts() {
      var visibleCount = 0;
      postCards.forEach(function (card) {
        var title = (card.getAttribute('data-title') || '').toLowerCase();
        var tags = (card.getAttribute('data-tags') || '').toLowerCase();
        var tagList = card.getAttribute('data-tag-list') || '';

        var searchMatch = currentSearch === '' ||
          title.indexOf(currentSearch) !== -1 ||
          tags.indexOf(currentSearch) !== -1;

        var tagMatch = currentTag === 'all' ||
          tagList.split(',').indexOf(currentTag) !== -1;

        if (searchMatch && tagMatch) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (visibleCount === 0) {
        postsContainer.style.display = 'none';
        if (noResults) noResults.style.display = 'block';
      } else {
        postsContainer.style.display = '';
        if (noResults) noResults.style.display = 'none';
      }
    }

    searchInput.addEventListener('input', function (e) {
      currentSearch = (e.target.value || '').toLowerCase();
      filterPosts();
    });

    tagFilters.forEach(function (button) {
      button.addEventListener('click', function () {
        tagFilters.forEach(function (btn) { btn.classList.remove('active'); });
        button.classList.add('active');
        currentTag = button.getAttribute('data-tag') || 'all';
        filterPosts();
      });
    });

    // 언어 토글 시 placeholder 갱신
    var langObserver = new MutationObserver(syncPlaceholder);
    langObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-language'] });
  }

  document.addEventListener('astro:page-load', initWritingSearch);
</script>

<style>
  .writing-page {
    padding-block: var(--space-16) var(--section-gap);
  }

  /* ═══════════════ HEADER ═══════════════ */
  .page-head {
    margin-bottom: var(--space-12);
  }
  .page-title {
    font-size: var(--step-5);
    font-weight: var(--weight-black);
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--color-text);
    margin: 0 0 var(--space-5);
  }
  .page-lede {
    max-width: 54ch;
    font-size: clamp(1.05rem, 1rem + 0.45vw, 1.3rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .page-rule {
    display: block;
    width: 56px;
    height: 2px;
    margin-top: var(--space-8);
    background: var(--color-accent);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-20) var(--space-8);
    color: var(--color-text-muted);
    font-size: var(--step-0);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-soft);
  }

  /* ═══════════════ LAYOUT ═══════════════ */
  .writing-content {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: clamp(2rem, 1rem + 4vw, 4rem);
    align-items: start;
  }

  /* ═══════════════ SIDEBAR ═══════════════ */
  .sidebar {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .sidebar-heading {
    font-size: 0.72rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  .search-box { position: relative; }
  .search-box input {
    width: 100%;
    padding: var(--space-3) var(--space-8) var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    font-size: 0.9rem;
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color var(--transition-fast);
  }
  .search-box input::placeholder { color: var(--color-text-muted); }
  .search-box input:focus { outline: none; border-color: var(--color-accent); }
  .search-box svg {
    position: absolute;
    right: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .tag-cloud {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .tag-filter {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    background: transparent;
    border: 1px solid transparent;
    color: var(--color-text-secondary);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--border-radius);
    font-size: 0.83rem;
    font-family: var(--font-sans);
    cursor: pointer;
    text-align: left;
    transition: color var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast);
  }
  .tag-filter:hover { color: var(--color-text); background: var(--color-surface); }
  .tag-filter.active {
    color: var(--color-accent);
    background: var(--color-accent-light);
    border-color: var(--color-accent);
    font-weight: var(--weight-semibold);
  }
  .tag-count {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .tag-filter.active .tag-count { color: var(--color-accent); }

  /* ═══════════════ POSTS ═══════════════ */
  .posts-section { min-width: 0; }
  .rows { list-style: none; padding: 0; margin: 0; }
  .row { border-bottom: 1px solid var(--color-border-light); }
  .row:first-child { border-top: 1px solid var(--color-border-light); }

  .row-link {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: var(--space-5);
    padding: var(--space-6) var(--space-2);
    color: var(--color-text);
    transition: background var(--transition-base), padding var(--transition-base);
  }
  .row-link:hover {
    background: var(--color-accent-light);
    padding-inline: var(--space-4);
    color: var(--color-text);
  }
  .row-main { display: flex; flex-direction: column; gap: var(--space-2); min-width: 0; }

  .row-eyebrow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .row-source {
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.68rem;
    color: var(--color-accent);
  }
  .row-source--media { color: var(--color-index-amber); }
  .row-cat { font-weight: var(--weight-medium); color: var(--color-text-secondary); }
  .row-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--color-border-strong);
  }
  .row-date { font-variant-numeric: tabular-nums; }

  .row-title {
    font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem);
    font-weight: var(--weight-bold);
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .row-link:hover .row-title { color: var(--color-accent); }

  .row-excerpt {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .row-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }
  .row-tag {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.1rem 0.55rem;
    line-height: 1.5;
  }

  .row-arrow {
    align-self: center;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity var(--transition-base), transform var(--transition-base), color var(--transition-base);
  }
  .row-link:hover .row-arrow { opacity: 1; transform: none; color: var(--color-accent); }

  .no-results {
    text-align: center;
    padding: var(--space-16) var(--space-8);
    color: var(--color-text-muted);
    font-size: var(--step-0);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-soft);
  }

  /* ═══════════════ Responsive ═══════════════ */
  @media (max-width: 968px) {
    .writing-content {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-6);
      padding: var(--space-6);
      background: var(--color-bg-sunken);
      border: 1px solid var(--color-border-light);
      border-radius: var(--radius-soft);
    }
    .filter-group { flex: 1 1 14rem; min-width: 0; }
    .tag-cloud { flex-direction: row; flex-wrap: wrap; gap: var(--space-2); }
    .tag-filter { flex: 0 0 auto; }
  }

  @media (max-width: 768px) {
    .writing-page { padding-block: var(--space-10) var(--space-16); }
    .page-title { font-size: var(--step-4); }
    .row-arrow { display: none; }
    .row-link:hover { padding-inline: var(--space-2); }
  }

  @media (max-width: 480px) {
    .writing-page { padding-inline: var(--space-5); }
  }
</style>
