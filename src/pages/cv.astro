  /* ═══════════════ Print ═══════════════ */
  @media print {
    .no-print { display: none !important; }
    /* 인쇄 시 비활성 언어를 숨기는 i18n 규칙은 그대로 유지된다. */
    .cv { color: #000; }
    .cv-head { border-bottom: 2px solid #000; padding-top: 0; }
