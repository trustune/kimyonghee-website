    color: var(--color-text-secondary);
    white-space: nowrap;
  }
  .cv-badge--ssci { color: var(--color-accent); border-color: color-mix(in srgb, var(--color-accent) 45%, transparent); }
  .cv-badge--scie { color: var(--color-index-amber); border-color: color-mix(in srgb, var(--color-index-amber) 45%, transparent); }

  /* ═══════════════ SERVICE (grants / activities) ═══════════════ */
  .block-count {
    font-size: 0.82rem;
