  .row-line--link {
    grid-template-columns: 6rem 1fr auto;
    transition: background var(--transition-base), padding var(--transition-base);
  }
  .row-line--link:hover {
    background: var(--color-accent-light);
    color: var(--color-text);
  }
  .row-index {
    font-size: 0.85rem;
