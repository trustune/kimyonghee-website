    .block { padding-block: 12pt 0; break-inside: avoid; }
    .block-head { border-bottom: 1px solid #333; }
    .row { break-inside: avoid; }
    .row-meta, .row-note, .cv-role, .cv-lede { color: #222; }
    .row-doi, .cv-updated, .cv-source { color: #444; }
    .cv-badge { border-color: #999; color: #333; }
    a { color: #000; }
    .cv-stats { border-top: 1px solid #999; }
    .cv-foot { border-top: 1px solid #999; }
  }
</style>

<script>
  // 인쇄 버튼 — 라벨은 마크업에서 이중언어 처리, 동작만 바인딩.
  function bindPrint() {
    document.querySelectorAll('.js-print').forEach((btn) => {
      btn.addEventListener('click', () => window.print());
    });
  }
  bindPrint();
  document.addEventListener('astro:page-load', bindPrint);
</script>
