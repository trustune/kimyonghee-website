---
// CV page — 이력 / Curriculum Vitae (bilingual ko/en)
import BaseLayout from '../layouts/BaseLayout.astro';
import publicationsData from '../data/publications.json';
import booksData from '../data/books.json';
import mediaData from '../data/media.json';
import awardsData from '../data/awards.json';
import activitiesData from '../data/activities.json';
import grantsData from '../data/grants.json';

const publications = (publicationsData as any).publications || [];
const domesticPubs = (publicationsData as any).domestic_publications || [];
const scholar = (publicationsData as any).scholarStats || { citations: 0, hIndex: 0, i10Index: 0 };
const books = (booksData as any).books || [];
// 데이터 키는 `articles`. 기존 코드의 `media` 별칭이 비어 있던 점을 바로잡는다.
const media = (mediaData as any).articles || (mediaData as any).media || [];
const awards = (awardsData as any).awards || [];
const activities = (activitiesData as any).activities || [];
const grants = (grantsData as any).grants || [];

const intlPubs = publications
  .filter((p: any) => ['ssci', 'scie', 'scopus'].includes(p.type))
  .sort((a: any, b: any) => (b.year || 0) - (a.year || 0));
const workingPapers = publications
  .filter((p: any) => ['working-paper', 'work-in-progress'].includes(p.type))
  .sort((a: any, b: any) => (b.year || 0) - (a.year || 0));

const sortedBooks = [...books].sort((a: any, b: any) => (b.year || 0) - (a.year || 0));
const sortedMedia = [...media].sort(
  (a: any, b: any) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime()
);
const sortedAwards = [...awards].sort(
  (a: any, b: any) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime()
);

const yearOf = (d: any) => (d ? new Date(d).getFullYear() : '');
const badgeLabel: Record<string, string> = { ssci: 'SSCI', scie: 'SCIE', scopus: 'Scopus' };

const updated = new Date();
const updatedKo = updated.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedEn = updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="이력 / CV"
  description="선문대학교 경영학과 교수 김용희의 이력(CV). 학력, 현직, 논문, 저서, 수상, 언론 기고를 정리합니다.">
  <article class="cv">
    <!-- ═══════════════ HEADER ═══════════════ -->
    <header class="cv-head container reveal">
      <p class="cv-kicker">
        <span data-lang="ko">이력</span><span data-lang="en">Curriculum Vitae</span>
      </p>
      <h1 class="cv-name">
        <span data-lang="ko">김용희</span><span data-lang="en">Yonghee Kim</span><span class="cv-degree">, Ph.D.</span>
      </h1>
      <p class="cv-role">
        <span data-lang="ko">선문대학교 경영학과 교수 · 대연산업정책연구원 원장</span>
        <span data-lang="en">Assistant Professor, Department of Business Administration, Sunmoon University · Director, Daeyeon Industrial Policy Institute</span>
      </p>
      <ul class="cv-contact">
        <li><a href="mailto:yhkim1981@sunmoon.ac.kr">yhkim1981@sunmoon.ac.kr</a></li>
        <li><a href="https://scholar.google.com/citations?user=semkeskAAAAJ" target="_blank" rel="noopener noreferrer">Google Scholar</a></li>
        <li><a href="https://orcid.org/0000-0002-5643-2748" target="_blank" rel="noopener noreferrer">ORCID</a></li>
        <li><a href="https://kimyonghee.com">kimyonghee.com</a></li>
      </ul>

      <div class="cv-actions no-print">
        <button type="button" class="btn btn-accent js-print">
          <span data-lang="ko">PDF로 인쇄</span><span data-lang="en">Print / Save as PDF</span>
        </button>
        <span class="cv-hint">
          <span data-lang="ko">Ctrl/Cmd + P 로도 저장할 수 있습니다.</span>
          <span data-lang="en">You can also use Ctrl/Cmd + P.</span>
        </span>
      </div>

      <dl class="cv-stats">
        <div class="cv-stat">
          <dt class="cv-stat-num">{scholar.citations.toLocaleString()}</dt>
          <dd class="cv-stat-lbl"><span data-lang="ko">누적 인용</span><span data-lang="en">Citations</span></dd>
        </div>
        <div class="cv-stat">
          <dt class="cv-stat-num">{scholar.hIndex}</dt>
          <dd class="cv-stat-lbl"><span data-lang="ko">h-지수</span><span data-lang="en">h-index</span></dd>
        </div>
        <div class="cv-stat">
          <dt class="cv-stat-num">{intlPubs.length + domesticPubs.length}</dt>
          <dd class="cv-stat-lbl"><span data-lang="ko">발표 논문</span><span data-lang="en">Publications</span></dd>
        </div>
      </dl>
    </header>

    <!-- ═══════════════ RESEARCH INTERESTS ═══════════════ -->
    <section class="block container reveal">
      <div class="block-head">
        <h2 class="block-title"><span data-lang="ko">연구 관심분야</span><span data-lang="en">Research Interests</span></h2>
      </div>
      <p class="cv-lede">
        <span data-lang="ko">미디어 정책과 경제, 디지털 플랫폼 규제, 인공지능 거버넌스, 온라인 동영상 서비스 시장 경쟁. 계량경제 방법과 산업연관분석으로 방송·통신 산업의 구조와 효율성을 살핍니다.</span>
        <span data-lang="en">Media policy and economics, digital platform regulation, AI governance, and competition in online video markets. I examine the structure and efficiency of the broadcasting and telecommunications industries using econometric methods and input-output analysis.</span>
      </p>
    </section>

    <!-- ═══════════════ EDUCATION ═══════════════ -->
    <section class="block container">
      <div class="block-head reveal">
        <h2 class="block-title"><span data-lang="ko">학력</span><span data-lang="en">Education</span></h2>
      </div>
      <ul class="rows">
        <li class="row reveal" style="--i:0">
          <div class="row-line">
            <span class="row-index" aria-hidden="true">2013–2016</span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">경영학 박사 (생산관리·경영정보)</span>
                <span data-lang="en">Ph.D. in Business Administration (Operations Management & MIS)</span>
              </span>
              <span class="row-meta">
                <span data-lang="ko">숭실대학교, 서울</span>
                <span data-lang="en">Soongsil University, Seoul, Korea</span>
              </span>
              <span class="row-note">
                <span data-lang="ko">학위논문: "사물인터넷 기반 스마트홈 서비스 수용에 관한 연구 — 조건부가치측정법과 가치기반 수용모형을 중심으로"</span>
                <span data-lang="en">Dissertation: "A Study on the Acceptance of IoT-based Smart Home Services: Focusing on Contingent Valuation Method and Value-based Acceptance Model"</span>
              </span>
            </span>
          </div>
        </li>
        <li class="row reveal" style="--i:1">
          <div class="row-line">
            <span class="row-index" aria-hidden="true">2010–2012</span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">경영학 석사 (생산관리·경영정보)</span>
                <span data-lang="en">M.S. in Business Administration (Operations Management & MIS)</span>
              </span>
              <span class="row-meta">
                <span data-lang="ko">숭실대학교, 서울</span>
                <span data-lang="en">Soongsil University, Seoul, Korea</span>
              </span>
              <span class="row-note">
                <span data-lang="ko">학위논문: "유료방송 사업자의 생산성과 효율성에 관한 국제 비교"</span>
                <span data-lang="en">Thesis: "International Comparison of Productivity and Efficiency of Pay-TV Operators"</span>
              </span>
            </span>
          </div>
        </li>
        <li class="row reveal" style="--i:2">
          <div class="row-line">
            <span class="row-index" aria-hidden="true">2000–2010</span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">경제학 학사</span>
                <span data-lang="en">B.A. in Economics</span>
              </span>
              <span class="row-meta">
                <span data-lang="ko">숭실대학교, 서울</span>
                <span data-lang="en">Soongsil University, Seoul, Korea</span>
              </span>
            </span>
          </div>
        </li>
      </ul>
    </section>

    <!-- ═══════════════ CURRENT POSITION ═══════════════ -->
    <section class="block container">
      <div class="block-head reveal">
        <h2 class="block-title"><span data-lang="ko">현직</span><span data-lang="en">Current Position</span></h2>
      </div>
      <ul class="rows">
        <li class="row reveal" style="--i:0">
          <div class="row-line">
            <span class="row-index" aria-hidden="true">2024–</span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">교수, 경영학과</span>
                <span data-lang="en">Assistant Professor, Department of Business Administration</span>
              </span>
              <span class="row-meta">
                <span data-lang="ko">선문대학교</span>
                <span data-lang="en">Sunmoon University</span>
              </span>
            </span>
          </div>
        </li>
        <li class="row reveal" style="--i:1">
          <div class="row-line">
            <span class="row-index" aria-hidden="true">2019–</span>
            <span class="row-main">
              <span class="row-title">
                <span data-lang="ko">원장</span>
                <span data-lang="en">Director</span>
              </span>
              <span class="row-meta">
                <span data-lang="ko">대연산업정책연구원</span>
                <span data-lang="en">Daeyeon Industrial Policy Institute</span>
              </span>
            </span>
          </div>
        </li>
      </ul>
    </section>

    <!-- ═══════════════ PUBLICATIONS (international) ═══════════════ -->
    {intlPubs.length > 0 && (
      <section class="block container">
        <div class="block-head reveal">
          <h2 class="block-title"><span data-lang="ko">논문 (국제)</span><span data-lang="en">Publications (International)</span></h2>
        </div>
        <ul class="rows">
          {intlPubs.map((pub: any, i: number) => (
            <li class="row reveal" style={`--i:${i}`}>
              <div class="row-line">
                <span class="row-index" aria-hidden="true">{pub.year}</span>
                <span class="row-main">
                  <span class="row-title">
                    {pub.title}
                    {badgeLabel[pub.type] && <span class={`cv-badge cv-badge--${pub.type}`}>{badgeLabel[pub.type]}</span>}
                  </span>
                  <span class="row-meta">
                    <em>{pub.journal}</em>{pub.year ? `, ${pub.year}` : ''}{pub.impact_factor ? ` (IF ${pub.impact_factor})` : ''}
                  </span>
                  {pub.doi && <span class="row-doi">DOI: {pub.doi}</span>}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ═══════════════ PUBLICATIONS (domestic) ═══════════════ -->
    {domesticPubs.length > 0 && (
      <section class="block container">
        <div class="block-head reveal">
          <h2 class="block-title"><span data-lang="ko">논문 (국내)</span><span data-lang="en">Publications (Domestic)</span></h2>
        </div>
        <ul class="rows">
          {domesticPubs.map((pub: any, i: number) => (
            <li class="row reveal" style={`--i:${i}`}>
              <div class="row-line">
                <span class="row-index" aria-hidden="true">{pub.year || ''}</span>
                <span class="row-main">
                  <span class="row-title">{(pub as any).title}</span>
                  <span class="row-meta">
                    <em>{(pub as any).journal}</em>{(pub as any).year ? `, ${(pub as any).year}` : ''}
                  </span>
                </span>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ═══════════════ WORKING PAPERS ═══════════════ -->
    {workingPapers.length > 0 && (
      <section class="block container">
        <div class="block-head reveal">
          <h2 class="block-title"><span data-lang="ko">작업 중인 논문</span><span data-lang="en">Working Papers</span></h2>
        </div>
        <ul class="rows">
          {workingPapers.map((pub: any, i: number) => (
            <li class="row reveal" style={`--i:${i}`}>
              <div class="row-line">
                <span class="row-index" aria-hidden="true">{pub.year}</span>
                <span class="row-main">
                  <span class="row-title">{pub.title}</span>
                  <span class="row-meta"><em>{pub.journal}</em></span>
                </span>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ═══════════════ BOOKS ═══════════════ -->
    {sortedBooks.length > 0 && (
      <section class="block container">
        <div class="block-head reveal">
          <h2 class="block-title"><span data-lang="ko">저서 · 보고서</span><span data-lang="en">Books & Reports</span></h2>
        </div>
        <ul class="rows">
          {sortedBooks.map((book: any, i: number) => (
            <li class="row reveal" style={`--i:${i}`}>
              <div class="row-line">
                <span class="row-index" aria-hidden="true">{book.year}</span>
                <span class="row-main">
                  <span class="row-title">{book.title}</span>
                  <span class="row-meta">
                    {Array.isArray(book.authors) ? book.authors.join(', ') : book.authors}
                    {book.book_title ? <>, <em>{book.book_title}</em></> : ''}
                    {book.pages ? `, pp. ${book.pages}` : ''}
                  </span>
                  {book.isbn && <span class="row-doi">ISBN: {book.isbn}</span>}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ═══════════════ MEDIA ═══════════════ -->
    {sortedMedia.length > 0 && (
      <section class="block container">
        <div class="block-head reveal">
          <h2 class="block-title"><span data-lang="ko">언론 기고 · 칼럼</span><span data-lang="en">Media & Op-eds</span></h2>
        </div>
        <ul class="rows">
          {sortedMedia.map((item: any, i: number) => (
            <li class="row reveal" style={`--i:${i}`}>
              {item.url ? (
                <a href={item.url} class="row-line row-line--link" target="_blank" rel="noopener noreferrer">
                  <span class="row-index" aria-hidden="true">{yearOf(item.date)}</span>
                  <span class="row-main">
                    <span class="row-title"><span data-lang="ko">{item.title_ko || item.title}</span><span data-lang="en">{item.title_en || item.title}</span></span>
                    <span class="row-meta"><em>{item.outlet}</em>, {item.date}</span>
                  </span>
                  <span class="row-arrow" aria-hidden="true">&rarr;</span>
                </a>
              ) : (
                <div class="row-line">
                  <span class="row-index" aria-hidden="true">{yearOf(item.date)}</span>
                  <span class="row-main">
                    <span class="row-title"><span data-lang="ko">{item.title_ko || item.title}</span><span data-lang="en">{item.title_en || item.title}</span></span>
                    <span class="row-meta"><em>{item.outlet}</em>, {item.date}</span>
                  </span>
                </div>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ═══════════════ RESEARCH GRANTS ═══════════════ -->
    {grants.length > 0 && (
      <section class="block container">
        <div class="block-head reveal">
          <h2 class="block-title"><span data-lang="ko">연구 과제</span><span data-lang="en">Research Grants</span></h2>
          <span class="block-count">{grants.length}</span>
        </div>
        <p class="svc-note reveal">
          <span data-lang="ko">총괄책임자로 수행한 정부·기관·기업 수탁 연구</span>
          <span data-lang="en">Commissioned research projects led as principal investigator</span>
        </p>
        <div class="svc-grid reveal">
          {grants.map((g: any, i: number) => (
            <div class="svc-item" style={`--i:${Math.min(i, 10)}`}>
              <div class="svc-main">
                <span class="svc-role">{g.title}</span>
                <span class="svc-org">{g.client}</span>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ═══════════════ PROFESSIONAL ACTIVITIES ═══════════════ -->
    {activities.length > 0 && (
      <section class="block container">
        <div class="block-head reveal">
          <h2 class="block-title"><span data-lang="ko">대외 활동</span><span data-lang="en">Professional Activities</span></h2>
        </div>
        <ul class="svc-list reveal">
          {activities.map((a: any, i: number) => (
            <li class="svc-item" style={`--i:${Math.min(i, 10)}`}>
              <div class="svc-main">
                <span class="svc-role">{a.role}</span>
                <span class="svc-org">{a.org}</span>
              </div>
              <span class="svc-period">
                {a.start}&ndash;{a.end === '현재'
                  ? (<><span data-lang="ko">현재</span><span data-lang="en">Present</span></>)
                  : a.end}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ═══════════════ AWARDS ═══════════════ -->
    {sortedAwards.length > 0 && (
      <section class="block container">
        <div class="block-head reveal">
          <h2 class="block-title"><span data-lang="ko">수상</span><span data-lang="en">Awards & Honors</span></h2>
        </div>
        <ul class="rows">
          {sortedAwards.map((award: any, i: number) => (
            <li class="row reveal" style={`--i:${i}`}>
              <div class="row-line">
                <span class="row-index" aria-hidden="true">{yearOf(award.date)}</span>
                <span class="row-main">
                  <span class="row-title">
                    <span data-lang="ko">{award.title_ko || award.title}</span>
                    <span data-lang="en">{award.title}</span>
                  </span>
                  {award.organization && (
                    <span class="row-meta">
                      <span data-lang="ko">{award.organization_ko || award.organization}</span>
                      <span data-lang="en">{award.organization}</span>
                    </span>
                  )}
                  {(award.description || award.subtitle) && (
                    <span class="row-note">
                      <span data-lang="ko">{award.subtitle_ko || award.description_ko || award.subtitle || award.description}</span>
                      <span data-lang="en">{award.subtitle || award.description}</span>
                    </span>
                  )}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ═══════════════ FOOTER ═══════════════ -->
    <footer class="cv-foot container reveal">
      <p class="cv-updated">
        <span data-lang="ko">마지막 업데이트: {updatedKo}</span>
        <span data-lang="en">Last updated: {updatedEn}</span>
      </p>
      <p class="cv-source">
        <span data-lang="ko">이 이력은 <a href="https://kimyonghee.com">kimyonghee.com</a>에서 자동으로 생성됩니다.</span>
        <span data-lang="en">This CV is generated automatically from <a href="https://kimyonghee.com">kimyonghee.com</a>.</span>
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .cv { width: 100%; }

  /* ═══════════════ HEADER ═══════════════ */
  .cv-head {
    padding-block: var(--space-16) var(--space-10);
    border-bottom: 2px solid var(--color-text);
  }
  .cv-kicker {
    font-size: 0.8rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }
  .cv-name {
    font-size: var(--step-5);
    font-weight: var(--weight-black);
    letter-spacing: -0.03em;
    line-height: 1.02;
  }
  .cv-degree { font-weight: var(--weight-medium); color: var(--color-text-secondary); }
  .cv-role {
    margin-top: var(--space-4);
    max-width: 60ch;
    font-size: clamp(1.02rem, 0.95rem + 0.4vw, 1.2rem);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .cv-contact {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
    margin-top: var(--space-5);
    padding: 0;
  }
  .cv-contact li {
    position: relative;
    font-size: 0.92rem;
    color: var(--color-text-secondary);
  }
  .cv-contact li + li::before {
    content: "";
    position: absolute;
    left: calc(var(--space-5) / -2);
    top: 50%;
    width: 1px;
    height: 12px;
    background: var(--color-border-strong);
    transform: translateY(-50%);
  }
  .cv-contact a { color: var(--color-accent); font-weight: var(--weight-medium); }
  .cv-contact a:hover { color: var(--color-accent-hover); }

  .cv-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
  .cv-hint { font-size: 0.85rem; color: var(--color-text-muted); }

  .cv-stats {
    display: flex;
    gap: clamp(1.5rem, 1rem + 3vw, 3.5rem);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    max-width: 34rem;
  }
  .cv-stat { display: flex; flex-direction: column; gap: 2px; }
  .cv-stat-num {
    font-size: clamp(1.5rem, 1.2rem + 1.1vw, 2rem);
    font-weight: var(--weight-heavy);
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
