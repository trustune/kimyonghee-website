---
import BaseLayout from '../layouts/BaseLayout.astro';
import media from '../data/media.json';

// 외부 칼럼·기고·언론 활동 목록. 원문은 모두 외부 매체에 게재되어 있으며,
// media.json 은 영어 메타데이터만 담고 있어 한국어 번역을 이 페이지에서 덧붙인다.
// (데이터 파일은 수정하지 않는다.)

type Article = {
  id: string;
  title: string;
  outlet: string;
  date: string;
  url: string;
  type: string;
  category: string;
  description: string;
};

const articles: Article[] = [...(media.articles as Article[])].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

// 매체명 한국어 표기 (고유명: 영어 원문은 그대로 두고 한국어 페이지에서만 풀어 씀)
const outletKo: Record<string, string> = {
  'The Electronic Times': '전자신문',
  'Economist Korea': '이코노미스트 코리아',
};

// 글 유형 라벨 (ko / en)
const typeLabel: Record<string, { ko: string; en: string }> = {
  opinion: { ko: '칼럼', en: 'Column' },
  editorial: { ko: '사설', en: 'Editorial' },
};

// 분류(카테고리) 한국어 표기
const categoryKo: Record<string, string> = {
  'Expert Column': '전문가 칼럼',
  'ET Opinion': '전자신문 사설',
  'Content Column': '콘텐츠 칼럼',
};

// 기사별 한국어 번역 (id 기준). 제목·요약을 자연스러운 한국어로.
const ko: Record<string, { title: string; description: string }> = {
  'economist-20260420': {
    title: 'AI가 불붙인 전력 전쟁, 한국은 어디에 서 있나',
    description:
      'AI 경쟁력이 이제 안정적이고 저렴한 전력 확보에 달려 있다고 보고, 에너지 전환 계획과 AI 데이터센터 관련 법제를 잇는 다섯 갈래 정책 과제를 제안한다. "AI 공동화(空洞化)"를 막기 위한 처방이다.',
  },
  'etnews-20251109': {
    title: '방송통신발전기금의 역설: ‘발전’이 투자를 억누르는가',
    description:
      '방송통신발전기금이 오히려 산업 투자를 위축시키는 구조를 비판한다. 종합유선방송사업자는 이익의 168.4%를 부담하는 반면 IPTV는 4.7%만 낸다는 점을 짚는다.',
  },
  'etnews-20251103': {
    title: '규제 입법은 혁신만 막지 않는다, 소상공인의 생계도 벼랑 끝에 선다',
    description:
      '공유 킥보드 규제안이 공유경제에 생계를 기대는 수천 명의 소상공인을 위협한다고 주장한다.',
  },
  'etnews-20250922': {
    title: 'K-콘텐츠의 지속 성장을 위한 AI 투명성 규제의 방향',
    description:
      '혁신과 신뢰 구축의 균형을 맞추는 AI 투명성 규제 다섯 가지 원칙을 제안한다. 빠르게 성장하는 한국 엔터테인먼트 산업을 염두에 둔 설계다.',
  },
  'etnews-20250825': {
    title: '미디어 산업의 공존: 송출수수료 가이드라인 개편을 출발점으로',
    description:
      '미디어 산업 생태계의 지속가능한 공존을 위해 송출수수료 가이드라인 개편이 필요한 이유를 짚는다.',
  },
  'etnews-20250721': {
    title: '디지털 전환 시대, 미디어 거버넌스를 다시 설계하다',
    description:
      '디지털 전환 시대에 맞는 미디어 거버넌스 구조의 새 틀을 제안한다.',
  },
  'etnews-20250711': {
    title: '글로벌 온라인 동영상 시장의 새 공식: K-콘텐츠가 증명한 것',
    description:
      '한국 콘텐츠가 글로벌 온라인 동영상 플랫폼 시장에서 어떻게 새로운 성공 공식을 만들어냈는지 분석한다.',
  },
  'etnews-20250314': {
    title: 'AI 시대, 규제의 틀을 넘어 진흥에 속도를 내야 한다',
    description:
      'AI 정책에서 규제 중심 접근을 넘어 진흥 전략으로 무게중심을 옮겨야 한다고 주장한다.',
  },
};

const fmtDate = (d: string, lang: 'ko' | 'en') =>
  new Date(d).toLocaleDateString(lang === 'ko' ? 'ko-KR' : 'en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });

const yearOf = (d: string) => new Date(d).getFullYear();

// 매체별 집계 (담백한 요약 지표)
const outletCount = new Set(articles.map((a) => a.outlet)).size;
const total = articles.length;
---

<BaseLayout
  title="미디어 활동"
  description="김용희가 전자신문 등 언론에 기고한 정책 칼럼과 사설 모음. 미디어 정책, 플랫폼 규제, AI 거버넌스에 관한 글.">
  <div class="media-page">
    <!-- ═══════════════ HEADER ═══════════════ -->
    <header class="page-head container reveal">
      <p class="page-eyebrow">
        <span data-lang="ko">미디어 활동</span><span data-lang="en">Media</span>
      </p>
      <h1 class="page-title">
        <span data-lang="ko">언론 기고와 칼럼</span>
        <span data-lang="en">Columns &amp; Commentary</span>
      </h1>
      <p class="page-lede">
        <span data-lang="ko">전자신문을 비롯한 언론에 미디어 정책, 플랫폼 규제, AI 거버넌스에 관한 칼럼과 사설을 씁니다. 연구가 논문에 머물지 않고 정책과 시장으로 이어지도록 하는 자리입니다.</span>
        <span data-lang="en">I write columns and editorials on media policy, platform regulation, and AI governance for The Electronic Times and other outlets. This is where research reaches policy and markets, not just journals.</span>
      </p>
      <dl class="page-stats">
        <div class="stat">
          <dt class="stat-num">{total}</dt>
          <dd class="stat-lbl"><span data-lang="ko">기고 글</span><span data-lang="en">pieces</span></dd>
        </div>
        <div class="stat">
          <dt class="stat-num">{outletCount}</dt>
          <dd class="stat-lbl"><span data-lang="ko">매체</span><span data-lang="en">outlets</span></dd>
        </div>
      </dl>
    </header>

    <!-- ═══════════════ LIST ═══════════════ -->
    <section class="block container">
      <div class="block-head reveal">
        <h2 class="block-title">
          <span data-lang="ko">전체 목록</span><span data-lang="en">All Pieces</span>
        </h2>
        <a class="text-link" href="/writing">
          <span data-lang="ko">전체 글 보기</span><span data-lang="en">All writing</span>
          <span class="arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>

      {articles.length === 0 ? (
        <p class="empty">
          <span data-lang="ko">아직 등록된 글이 없습니다.</span>
          <span data-lang="en">No pieces yet.</span>
        </p>
      ) : (
        <ul class="rows">
          {articles.map((a, i) => {
            const tr = ko[a.id];
            const tLabel = typeLabel[a.type];
            const oKo = outletKo[a.outlet] || a.outlet;
            const cKo = categoryKo[a.category] || a.category;
            return (
              <li class="row reveal" style={`--i:${i}`}>
                <a
                  href={a.url}
                  class="row-link"
                  target="_blank"
                  rel="noopener noreferrer">
                  <span class="row-index" aria-hidden="true">{yearOf(a.date)}</span>
                  <span class="row-main">
                    <span class="row-kicker">
                      {tLabel && (
                        <span class="tag tag-type">
                          <span data-lang="ko">{tLabel.ko}</span><span data-lang="en">{tLabel.en}</span>
                        </span>
                      )}
                      <span class="row-outlet">
                        <span data-lang="ko">{oKo}</span><span data-lang="en">{a.outlet}</span>
                      </span>
                    </span>
                    <span class="row-title">
                      <span data-lang="ko">{tr ? tr.title : a.title}</span>
                      <span data-lang="en">{a.title}</span>
                    </span>
                    <span class="row-desc">
                      <span data-lang="ko">{tr ? tr.description : a.description}</span>
                      <span data-lang="en">{a.description}</span>
                    </span>
                    <span class="row-meta">
                      <span class="row-cat">
                        <span data-lang="ko">{cKo}</span><span data-lang="en">{a.category}</span>
                      </span>
                      <span class="row-dot" aria-hidden="true">&middot;</span>
                      <span data-lang="ko">{fmtDate(a.date, 'ko')}</span>
                      <span data-lang="en">{fmtDate(a.date, 'en')}</span>
                    </span>
                  </span>
                  <span class="row-ext" aria-hidden="true">&#8599;</span>
                </a>
              </li>
            );
          })}
        </ul>
      )}

      <p class="ext-note reveal">
        <span data-lang="ko">모든 글은 게재 매체의 외부 페이지에서 새 창으로 열립니다.</span>
        <span data-lang="en">Every piece opens in a new tab on the publishing outlet's site.</span>
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .media-page { width: 100%; }

  /* ═══════════════ HEADER ═══════════════ */
  .page-head {
    padding-block: var(--section-gap) var(--space-12);
  }
  .page-eyebrow {
    font-size: 0.8rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: var(--space-5);
  }
  .page-title {
    font-size: var(--step-5);
    font-weight: var(--weight-black);
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }
  .page-lede {
    max-width: 54ch;
    margin-top: var(--space-6);
    font-size: clamp(1.05rem, 1rem + 0.5vw, 1.3rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .page-stats {
    display: flex;
    gap: clamp(2rem, 1rem + 4vw, 4rem);
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    max-width: 24rem;
  }
  .page-stats .stat { display: flex; flex-direction: column; gap: 4px; }
  .stat-num {
    font-size: clamp(1.6rem, 1.3rem + 1.2vw, 2.2rem);
    font-weight: var(--weight-heavy);
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1;
  }
  .stat-lbl {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
  }

  /* ═══════════════ BLOCK ═══════════════ */
  .block { padding-bottom: var(--section-gap); }
  .block-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 2px solid var(--color-text);
  }
  .block-title {
    font-size: var(--step-3);
    font-weight: var(--weight-heavy);
    letter-spacing: -0.025em;
  }

  /* ═══════════════ ROWS ═══════════════ */
  .rows { list-style: none; padding: 0; margin: 0; }
  .row { border-bottom: 1px solid var(--color-border-light); }
  .row-link {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    align-items: start;
    gap: var(--space-5);
    padding: var(--space-6) var(--space-2);
    color: var(--color-text);
    transition: background var(--transition-base), padding var(--transition-base);
  }
  .row-link:hover {
    background: var(--color-accent-light);
    padding-inline: var(--space-4);
    color: var(--color-text);
  }
  .row-index {
    font-size: 0.85rem;
    font-weight: var(--weight-bold);
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    padding-top: 0.15rem;
  }
  .row-main { display: flex; flex-direction: column; gap: var(--space-2); min-width: 0; }

  .row-kicker {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .tag {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-pill);
  }
  .tag-type {
    color: var(--color-accent);
    background: var(--color-accent-surface);
  }
  .row-outlet {
    font-size: 0.82rem;
    font-weight: var(--weight-semibold);
    color: var(--color-text-secondary);
  }

  .row-title {
    font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem);
    font-weight: var(--weight-bold);
    line-height: 1.4;
    color: var(--color-text);
  }
  .row-desc {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: 64ch;
  }
  .row-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-top: var(--space-1);
  }
  .row-cat { font-weight: var(--weight-medium); }
  .row-dot { color: var(--color-border-strong); }

  .row-ext {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: opacity var(--transition-base), transform var(--transition-base), color var(--transition-base);
    padding-top: 0.1rem;
  }
  .row-link:hover .row-ext {
    opacity: 1;
    transform: none;
    color: var(--color-accent);
  }

  .empty {
    padding: var(--space-12) 0;
    color: var(--color-text-muted);
    font-size: var(--step-0);
  }
  .ext-note {
    margin-top: var(--space-6);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* ═══════════════ Responsive ═══════════════ */
  @media (max-width: 760px) {
    .row-link {
      grid-template-columns: 3rem 1fr;
      gap: var(--space-3);
      padding-inline: 0;
    }
    .row-link:hover { padding-inline: var(--space-2); }
    .row-ext { display: none; }
    .block-head { flex-direction: column; align-items: flex-start; gap: var(--space-2); }
  }
</style>
