---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LineChart from '../../components/LineChart.astro';
import PieChart from '../../components/PieChart.astro';
import SocialShare from '../../components/SocialShare.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { data } = project;
const showCharts = project.slug === 'broadcasting-revenue-2015-2024';

// Chart data
const revenueLabels = ['2015', '2016', '2017', '2018', '2019', '2020', '2021', '2022', '2023', '2024'];
const revenueDatasets = [
  {
    label: 'Pay-TV Subscriptions',
    data: [27.5, 28.3, 29.4, 31.2, 32.4, 33.5, 36.5, 37.1, 37.3, 37.6],
    borderColor: 'rgba(102, 126, 234, 1)',
    backgroundColor: 'rgba(102, 126, 234, 0.1)',
    borderWidth: 3,
    fill: true,
    tension: 0.4
  },
  {
    label: 'Broadcasting Advertising',
    data: [35.0, 34.6, 31.8, 32.4, 33.0, 31.4, 31.0, 28.8, 25.0, 22.9],
    borderColor: 'rgba(239, 68, 68, 1)',
    backgroundColor: 'rgba(239, 68, 68, 0.1)',
    borderWidth: 3,
    fill: true,
    tension: 0.4
  },
  {
    label: 'Home Shopping Fees',
    data: [0, 0, 24.4, 24.0, 23.7, 23.5, 22.0, 21.5, 20.5, 20.2],
    borderColor: 'rgba(245, 158, 11, 1)',
    backgroundColor: 'rgba(245, 158, 11, 0.1)',
    borderWidth: 3,
    fill: true,
    tension: 0.4
  }
];

const pieLabels = ['Pay-TV Subscriptions', 'Broadcasting Advertising', 'Home Shopping Fees', 'Program Sales', 'Government Subsidy', 'Other'];
const pieValues = [37.6, 22.9, 20.2, 9.5, 2.8, 7.0];
const pieColors = [
  'rgba(102, 126, 234, 0.8)',
  'rgba(239, 68, 68, 0.8)',
  'rgba(245, 158, 11, 0.8)',
  'rgba(16, 185, 129, 0.8)',
  'rgba(139, 92, 246, 0.8)',
  'rgba(107, 114, 128, 0.8)'
];

const d = data as any;

// 이중언어 우선 폴백 — 한국어 변형이 있으면 쓰고, 없으면 원문(주로 영어)으로 폴백.
// 논문 제목·고유명은 원문 유지가 원칙이므로 폴백이 안전하다.
const titleKo = d.title_ko || d.title;
const titleEn = d.title_en || d.title;
const subtitleKo = d.subtitle_ko || d.subtitle || '';
const subtitleEn = d.subtitle_en || d.subtitle || '';
const conferenceKo = d.conference_ko || d.conference || '';
const conferenceEn = d.conference_en || d.conference || '';
const summaryKo = d.summary_ko || d.summary || '';
const summaryEn = d.summary_en || d.summary || '';

const keyFindingsKo: string[] = (d.key_findings_ko && d.key_findings_ko.length > 0) ? d.key_findings_ko : (d.key_findings || []);
const keyFindingsEn: string[] = d.key_findings || [];
const hasFindings = keyFindingsEn.length > 0;

const policyProposalsEn: string[] = d.policy_proposals || [];
const policyProposalsKo: string[] = (d.policy_proposals_ko && d.policy_proposals_ko.length > 0) ? d.policy_proposals_ko : policyProposalsEn;
const policyConcernsEn: string[] = d.policy_concerns || [];
const policyConcernsKo: string[] = (d.policy_concerns_ko && d.policy_concerns_ko.length > 0) ? d.policy_concerns_ko : policyConcernsEn;

const methodology: string[] = d.methodology || [];
const dataSources: { name: string; type: string }[] = d.data_sources || [];

// SocialShare 는 단일 문자열만 받으므로 영어 제목/발췌 우선
const titleText = titleEn;
const currentUrl = `https://kimyonghee.com/projects/${project.slug}`;
const shareExcerpt = summaryEn || d.description_en || d.description || '';

const dateKo = new Date(data.date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
const dateEn = new Date(data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={data.title}>
  <article class="project-detail container">
    <!-- ═══════════════ HEADER ═══════════════ -->
    <header class="project-header reveal">
      <a class="back-link" href="/projects">
        <span class="arrow" aria-hidden="true">&larr;</span>
        <span data-lang="ko">프로젝트</span><span data-lang="en">Projects</span>
      </a>

      <span class="category-badge">{data.category}</span>

      <h1>
        <span data-lang="ko">{titleKo}</span><span data-lang="en">{titleEn}</span>
      </h1>

      {(subtitleKo || subtitleEn) && (
        <p class="subtitle">
          <span data-lang="ko">{subtitleKo}</span><span data-lang="en">{subtitleEn}</span>
        </p>
      )}

      <div class="meta-info">
        <time datetime={typeof data.date === 'string' ? data.date : new Date(data.date).toISOString()}>
          <span data-lang="ko">{dateKo}</span><span data-lang="en">{dateEn}</span>
        </time>
        {(conferenceKo || conferenceEn) && (
          <span class="conference">
            <span data-lang="ko">{conferenceKo}</span><span data-lang="en">{conferenceEn}</span>
          </span>
        )}
      </div>

      {data.tags && data.tags.length > 0 && (
        <div class="tags">
          {data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    {/* ═══════════════ SUMMARY ═══════════════ */}
    {(summaryKo || summaryEn) && (
      <section class="callout callout--summary reveal">
        <h2 class="callout-title">
          <span data-lang="ko">초록</span><span data-lang="en">Abstract</span>
        </h2>
        <p class="callout-body">
          <span data-lang="ko">{summaryKo}</span><span data-lang="en">{summaryEn}</span>
        </p>
      </section>
    )}

    {/* ═══════════════ KEY FINDINGS ═══════════════ */}
    {hasFindings && (
      <section class="callout callout--findings reveal">
        <h2 class="callout-title">
          <span data-lang="ko">주요 결과</span><span data-lang="en">Key Findings</span>
        </h2>
        <ul class="finding-list" data-lang="ko">
          {keyFindingsKo.map((finding: string, i: number) => (
            <li style={`--i:${i}`}>{finding}</li>
          ))}
        </ul>
        <ul class="finding-list" data-lang="en">
          {keyFindingsEn.map((finding: string, i: number) => (
            <li style={`--i:${i}`}>{finding}</li>
          ))}
        </ul>
      </section>
    )}

    {/* ═══════════════ POLICY PROPOSALS ═══════════════ */}
    {policyProposalsEn.length > 0 && (
      <section class="callout callout--policy reveal">
        <h2 class="callout-title">
          <span data-lang="ko">정책 제언</span><span data-lang="en">Policy Proposals</span>
        </h2>
        <ul class="finding-list" data-lang="ko">
          {policyProposalsKo.map((item: string, i: number) => (
            <li style={`--i:${i}`}>{item}</li>
          ))}
        </ul>
        <ul class="finding-list" data-lang="en">
          {policyProposalsEn.map((item: string, i: number) => (
            <li style={`--i:${i}`}>{item}</li>
          ))}
        </ul>
      </section>
    )}

    {/* ═══════════════ POLICY CONCERNS ═══════════════ */}
    {policyConcernsEn.length > 0 && (
      <section class="callout callout--policy reveal">
        <h2 class="callout-title">
          <span data-lang="ko">정책 쟁점</span><span data-lang="en">Policy Concerns</span>
        </h2>
        <ul class="finding-list" data-lang="ko">
          {policyConcernsKo.map((item: string, i: number) => (
            <li style={`--i:${i}`}>{item}</li>
          ))}
        </ul>
        <ul class="finding-list" data-lang="en">
          {policyConcernsEn.map((item: string, i: number) => (
            <li style={`--i:${i}`}>{item}</li>
          ))}
        </ul>
      </section>
    )}

    {/* ═══════════════ BODY + CHARTS ═══════════════ */}
    <div class:list={['content-wrapper', { 'with-charts': showCharts }]}>
      <div class="project-content prose reveal">
        <Content />
      </div>

      {showCharts && (
        <aside class="charts-sidebar reveal">
          <div class="chart-card">
            <h3>
              <span data-lang="ko">매출 추이 (2015–2024)</span>
              <span data-lang="en">Revenue Trends (2015–2024)</span>
            </h3>
            <LineChart
              chartId="revenueChart"
              title="Revenue Trends (2015-2024)"
              labels={revenueLabels}
              datasets={revenueDatasets}
              yAxisLabel="Trillion KRW"
            />
          </div>

          <div class="chart-card">
            <h3>
              <span data-lang="ko">매출 구성 2024</span>
              <span data-lang="en">Revenue Composition 2024</span>
            </h3>
            <PieChart
              chartId="compositionChart"
              title="Revenue Composition 2024"
              labels={pieLabels}
              data={pieValues}
              backgroundColors={pieColors}
            />
          </div>
        </aside>
      )}
    </div>

    {/* ═══════════════ METHODOLOGY ═══════════════ */}
    {methodology.length > 0 && (
      <section class="meta-block reveal">
        <h2 class="block-title">
          <span data-lang="ko">방법론</span><span data-lang="en">Methodology</span>
        </h2>
        <div class="method-tags">
          {methodology.map((method: string) => (
            <span class="method-tag">{method}</span>
          ))}
        </div>
      </section>
    )}

    {/* ═══════════════ DATA SOURCES ═══════════════ */}
    {dataSources.length > 0 && (
      <section class="meta-block reveal">
        <h2 class="block-title">
          <span data-lang="ko">데이터 출처</span><span data-lang="en">Data Sources</span>
        </h2>
        <ul class="sources-list">
          {dataSources.map((source: { name: string; type: string }, i: number) => (
            <li style={`--i:${i}`}>
              <span class="source-name">{source.name}</span>
              <span class={`source-type ${source.type}`}>
                {source.type === 'primary' ? (
                  <>
                    <span data-lang="ko">1차</span><span data-lang="en">Primary</span>
                  </>
                ) : (
                  <>
                    <span data-lang="ko">2차</span><span data-lang="en">Secondary</span>
                  </>
                )}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="share-wrap reveal">
      <SocialShare title={titleText} url={currentUrl} excerpt={shareExcerpt} />
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail {
    padding-block: var(--section-gap);
  }

  /* ═══════════════ HEADER ═══════════════ */
  .project-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 2px solid var(--color-text);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.9rem;
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }
  .back-link .arrow { transition: transform var(--transition-base); }
  .back-link:hover { color: var(--color-accent); }
  .back-link:hover .arrow { transform: translateX(-3px); }

  .category-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-pill);
    font-size: 0.78rem;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.01em;
    margin-bottom: var(--space-5);
  }

  h1 {
    font-size: var(--step-4);
    line-height: 1.12;
    letter-spacing: -0.025em;
    margin-bottom: var(--space-4);
    color: var(--color-text);
    font-weight: var(--weight-heavy);
  }

  .subtitle {
    font-size: var(--step-1);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    line-height: 1.55;
    max-width: var(--measure-wide);
    font-weight: var(--weight-regular);
  }

  .meta-info {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-variant-numeric: tabular-nums;
  }
  .conference {
    padding-left: var(--space-4);
    border-left: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-weight: var(--weight-medium);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .tag {
    padding: var(--space-1) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-pill);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  /* ═══════════════ CALLOUTS (summary / findings / policy) ═══════════════ */
  .callout {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-soft);
    background: var(--color-bg-sunken);
    padding: var(--space-8);
    margin-bottom: var(--space-8);
  }
  .callout--summary {
    background: var(--color-accent-surface);
    border-color: color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
  }

  .callout-title {
    font-size: var(--step-1);
    font-weight: var(--weight-bold);
    letter-spacing: -0.015em;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }
  .callout-body {
    color: var(--color-text);
    line-height: var(--leading-body);
    margin: 0;
    max-width: var(--measure-wide);
  }
  html[data-language="en"] .callout-body { color: var(--color-text-secondary); }

  .finding-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .finding-list li {
    position: relative;
    padding-left: var(--space-6);
    color: var(--color-text);
    line-height: 1.65;
  }
  .finding-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent);
  }
  .callout--policy .finding-list li::before {
    border-radius: 2px;
    background: var(--color-text);
  }

  /* ═══════════════ BODY + CHARTS ═══════════════ */
  .content-wrapper {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    margin-top: var(--space-12);
  }
  @media (min-width: 1024px) {
    .content-wrapper.with-charts {
      grid-template-columns: minmax(0, 1fr) 400px;
    }
  }

  .project-content {
    line-height: var(--leading-body);
    color: var(--color-text);
    min-width: 0;
  }

  /* prose 공유 클래스가 대부분 처리. 테이블은 페이지 고유 스크롤 래핑 보강. */
  .project-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-8) 0;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    font-size: 0.92rem;
  }
  .project-content :global(thead),
  .project-content :global(tbody),
  .project-content :global(tr) {
    display: table;
    width: 100%;
    table-layout: fixed;
  }
  .project-content :global(th),
  .project-content :global(td) {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    text-align: left;
    min-width: 120px;
  }
  .project-content :global(th) {
    background: var(--color-surface);
    font-weight: var(--weight-semibold);
  }

  .charts-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .chart-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-soft);
    padding: var(--space-6);
  }
  .chart-card h3 {
    font-size: var(--step-0);
    margin-bottom: var(--space-4);
    color: var(--color-text);
    font-weight: var(--weight-semibold);
  }

  /* ═══════════════ META BLOCKS (methodology / sources) ═══════════════ */
  .meta-block {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }
  .block-title {
    font-size: var(--step-2);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
  }

  .method-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .method-tag {
    padding: var(--space-2) var(--space-4);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
  }

  .sources-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .sources-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border-light);
  }
  .sources-list li:last-child { border-bottom: none; }
  .source-name {
    color: var(--color-text);
    min-width: 0;
  }
  .source-type {
    flex-shrink: 0;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    font-size: 0.72rem;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: var(--color-surface);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }
  .source-type.primary {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
    background: var(--color-accent-light);
  }

  .share-wrap {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  /* ═══════════════ Responsive ═══════════════ */
  @media (max-width: 1024px) {
    .content-wrapper.with-charts { grid-template-columns: 1fr; }
    .charts-sidebar {
      flex-direction: row;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .chart-card { min-width: 300px; flex: 1; }
  }

  @media (max-width: 760px) {
    .callout { padding: var(--space-6); }
    .meta-info { gap: var(--space-2); }
    .conference { padding-left: 0; border-left: none; }
    .charts-sidebar { flex-direction: column; }
    .chart-card { min-width: auto; }
    .sources-list li { flex-wrap: wrap; gap: var(--space-2); }
  }

  /* reveal 스태거: 콜아웃 리스트 항목에 미세 지연 */
  .js .finding-list li,
  .js .sources-list li {
    transition-delay: calc(var(--i, 0) * 40ms);
  }
</style>
